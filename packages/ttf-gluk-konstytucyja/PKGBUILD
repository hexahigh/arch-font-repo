pkgname=ttf-gluk-konstytucyja
pkgver=0.91
pkgrel=1
pkgdesc="Konstytucyja font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Konstytucyja'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/konstytucyja/konstytucyja_091.zip")
sha256sums=('d73bdb2a8278459a4e1a5a665f90b50aa576510911ac45820b243ea672c5aef1')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Konstytucyja
License info from upstream page: Public Domain
EOF
}
