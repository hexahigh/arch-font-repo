pkgname=ttf-google-notosanssinhalaui
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssinhalaui
pkgdesc="Google Fonts family: Noto Sans Sinhala UI"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Sinhala+UI"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssinhalaui/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssinhalaui/NotoSansSinhalaUI[wdth,wght].ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "3daf1ec98108a0705b4d197424492d0955386a9bc76a7838ec9f31db47c1fc32"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
