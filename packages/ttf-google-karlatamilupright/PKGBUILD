pkgname=ttf-google-karlatamilupright
pkgver=1.001
pkgrel=1
_commit="494381ebbd37fddd4f0277a104f71a2e429630a9"  # Latest commit touching ofl/karlatamilupright
pkgdesc="Google Fonts family: Karla Tamil Upright"
arch=('any')
url="https://fonts.google.com/specimen/Karla+Tamil+Upright"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/karlatamilupright/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/karlatamilupright/KarlaTamilUpright-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/karlatamilupright/KarlaTamilUpright-Regular.ttf"
)
sha256sums=(
  "cc31fe974951d56d542f33782d07b2d5577a4afdddba89744e6bd69bcbf3a853"
  "0121d30ef4d7b3b8f8bdd62f3ed2108d37135da8021a737d5fc4976c33f11396"
  "7d79ee26d351ecf03cbeb129ef0a1c29779b58dec45a153291f1a3c6c926e50f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
