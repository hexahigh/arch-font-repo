pkgname=ttf-google-jomolhari
pkgver=1.000
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/jomolhari
pkgdesc="Google Fonts family: Jomolhari"
arch=('any')
url="https://fonts.google.com/specimen/Jomolhari"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/jomolhari/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/jomolhari/Jomolhari-Regular.ttf"
)
sha256sums=(
  "49b9214f7b40024abec2fc89a32bdda380f2174ba7005d7636e6ea340157c5a6"
  "4507597ac6d8faad3908c06a4698167f8204a1101d38bf32b04582cc2d22e86c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
