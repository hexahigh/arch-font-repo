pkgname=ttf-google-mervalescript
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mervalescript
pkgdesc="Google Fonts family: Mervale Script"
arch=('any')
url="https://fonts.google.com/specimen/Mervale+Script"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mervalescript/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mervalescript/MervaleScript-Regular.ttf"
)
sha256sums=(
  "2f871c2e81de6d0c72c981615002c30bc9f1637003d6d3d4c3f0149886b70569"
  "52522c4965b84bf5e56015bf919b165b7eedbaedb08d7d0d7477c38141c953d6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
