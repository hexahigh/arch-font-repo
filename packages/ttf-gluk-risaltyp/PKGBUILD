pkgname=ttf-gluk-risaltyp
pkgver=0.24
pkgrel=1
pkgdesc="Risaltyp font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Risaltyp'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Risaltyp/Risaltyp_024.zip")
sha256sums=('b69aa0e8620f766e61e73298a2d7ad8770cd8d956f5de196867eafeb480db51d')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Risaltyp
License info from upstream page: OpenFontLicense
EOF
}
