pkgname=ttf-google-bhavuka
pkgver=2.94.0
pkgrel=1
_commit="20bbf0707a336a84a533db6d823d6b944ee76121"  # Latest commit touching ofl/bhavuka
pkgdesc="Google Fonts family: Bhavuka"
arch=('any')
url="https://fonts.google.com/specimen/Bhavuka"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bhavuka/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bhavuka/Bhavuka-Regular.ttf"
)
sha256sums=(
  "012b1870f81b0d97ca756edd9eea315c7fc22657ac2f1cbdfcb6772fed3e20f3"
  "153806257782e9bb99f4504659175a4ba27a5933291702963416c98870b37aa9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
