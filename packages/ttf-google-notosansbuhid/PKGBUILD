pkgname=ttf-google-notosansbuhid
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansbuhid
pkgdesc="Google Fonts family: Noto Sans Buhid"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Buhid"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbuhid/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbuhid/NotoSansBuhid-Regular.ttf"
)
sha256sums=(
  "6c127a87daaa23faca73b3607879fe6f86799e3948d07275800b54b805610294"
  "70408dbcf0da33d12d3b582305057a63a3ea132b4bf313027834e5b9b6a7d886"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
