pkgname=ttf-fontshare-familjen-grotesk
pkgver=2.0
pkgrel=1
_slug="familjen-grotesk"
pkgdesc="Fontshare family: Familjen Grotesk"
arch=('any')
url="https://www.fontshare.com/fonts/familjen-grotesk/"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://api.fontshare.com/v2/fonts/download/familjen-grotesk")
sha256sums=('2158d1ac95e6a01ea1a1b190cd44b5f9bd10aaca88a89a5c88b78ecf102ff56f')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install every shipped TTF/OTF/TTC font from the Fontshare bundle.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  license_file="$(find "${srcdir}" -type f \( -iname 'OFL.txt' -o -iname 'FFL.txt' -o -iname 'LICENSE*' \) | head -n 1)"
  if [[ -n "${license_file}" ]]; then
    install -Dm644 "${license_file}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  fi
}
