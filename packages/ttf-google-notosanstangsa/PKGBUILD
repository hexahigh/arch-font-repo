pkgname=ttf-google-notosanstangsa
pkgver=1.506
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanstangsa
pkgdesc="Google Fonts family: Noto Sans Tangsa"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Tangsa"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstangsa/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstangsa/NotoSansTangsa%5Bwght%5D.ttf"
)
sha256sums=(
  "b4c6eab864c1283a5c1846d7b5467e70cdc58fac872123aeac0b966a9ab3169b"
  "2ed50f0ba084742ce2dfe4909bc529131272d9468b1aa341d5866fbc1a1be48f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
