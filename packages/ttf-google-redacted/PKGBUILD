pkgname=ttf-google-redacted
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/redacted
pkgdesc="Google Fonts family: Redacted"
arch=('any')
url="https://fonts.google.com/specimen/Redacted"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/redacted/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/redacted/Redacted-Regular.ttf"
)
sha256sums=(
  "ed836da2ff14b9b2d04001057e03c0531afdd2626bf66a612b17124589f58efa"
  "38d8c529c8a995426c8ec75d0b9d465296e541587632da038e4a5d030b4d1069"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
