pkgname=ttf-google-mooli
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mooli
pkgdesc="Google Fonts family: Mooli"
arch=('any')
url="https://fonts.google.com/specimen/Mooli"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mooli/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mooli/Mooli-Regular.ttf"
)
sha256sums=(
  "12c5c11cf37c77a574ef3964fd27f117aa1e1dc4c1569b723cfe45c3d474306e"
  "1ab6e242c359f16f2a30741c21634c9f4a4183426730928f9545a2aeeb14078a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
