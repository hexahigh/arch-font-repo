pkgname=ttf-google-texturina
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/texturina
pkgdesc="Google Fonts family: Texturina"
arch=('any')
url="https://fonts.google.com/specimen/Texturina"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/texturina/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/texturina/Texturina-Italic%5Bopsz%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/texturina/Texturina%5Bopsz%2Cwght%5D.ttf"
)
sha256sums=(
  "631ba6504ec2454e472196173aea91c423295787d2128f3732e73fb07a9ea1e0"
  "d5827e6531510e9b5e2a95f3042ee7463b0b1f320f9a4146159a553482f6e339"
  "478a15d7145cf94565cfc1aeb33596aeb0118c7d86a84d061ddf46de3d7dfda3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
