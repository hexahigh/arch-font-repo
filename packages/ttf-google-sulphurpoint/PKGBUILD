pkgname=ttf-google-sulphurpoint
pkgver=1.000
pkgrel=1
_commit="5ef4ccb8f5fee7750467e0fd1844c50434cc081d"  # Latest commit touching ofl/sulphurpoint
pkgdesc="Google Fonts family: Sulphur Point"
arch=('any')
url="https://fonts.google.com/specimen/Sulphur+Point"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sulphurpoint/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sulphurpoint/SulphurPoint-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sulphurpoint/SulphurPoint-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sulphurpoint/SulphurPoint-Regular.ttf"
)
sha256sums=(
  "aa8a8196a3e22c3bd985e33cd3245ae9a38accba5e79fc0e3b292612a8d6b337"
  "6c486637421b3b7507ade75795ca51abd5063fb74f2811618f393fae6d9ce8cb"
  "5d3aa827b5fd1544712081f4509df1451c36b1d10191291862902a51c7f78801"
  "46d6d54960c777007434e2a992b0ecf63c9f554c2b27f059321f4204662dcb6a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
