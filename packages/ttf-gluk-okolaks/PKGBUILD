pkgname=ttf-gluk-okolaks
pkgver=0.60
pkgrel=1
pkgdesc="Okolaks font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Okolaks'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/okolaks/okolaks-0.6.0.zip")
sha256sums=('3ef1920d54aa22983be6509ca6e30cb7ef9a3e164e4bf6f08db62b88a13ff09d')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Okolaks
License info from upstream page: OpenFontLicense
EOF
}
