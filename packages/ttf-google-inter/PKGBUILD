pkgname=ttf-google-inter
pkgver=4.001
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/inter
pkgdesc="Google Fonts family: Inter"
arch=('any')
url="https://fonts.google.com/specimen/Inter"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/inter/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/inter/Inter-Italic[opsz,wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/inter/Inter[opsz,wght].ttf"
)
sha256sums=(
  "5b9321a4298cfeb6b34354164a1c3afc3db114569984c502b9b35d988fd58c57"
  "acd98e64795781b2058f07b18475e0ecee2a0fe2b42a49e2f9e37d0d6bf66ce6"
  "29160a80ff49ddcab2c97711247e08b1fab27a484a329ce8b813d820dc559031"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
