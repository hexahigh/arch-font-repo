pkgname=ttf-google-notosanscypriot
pkgver=2.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanscypriot
pkgdesc="Google Fonts family: Noto Sans Cypriot"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Cypriot"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscypriot/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscypriot/NotoSansCypriot-Regular.ttf"
)
sha256sums=(
  "18f3c4770aae15b8f60a8d4e5a7d7e7065fbcca195d6fa8ca23fd10374647b0a"
  "80590aed2c4223ee0ca53fda21281236529dcc637451d016248559c83880d14d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
