pkgname=ttf-google-notosanslimbu
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanslimbu
pkgdesc="Google Fonts family: Noto Sans Limbu"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Limbu"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslimbu/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslimbu/NotoSansLimbu-Regular.ttf"
)
sha256sums=(
  "9745259e135d9de74a122c6498a830a1e45c59b75677821f42e11691e769deec"
  "5a8b4fd72c5a64051332f66fcf46fda1a32a37d130631362378c6b465d852dd5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
