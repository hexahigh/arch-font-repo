pkgname=ttf-google-specialgothic
pkgver=1.011
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/specialgothic
pkgdesc="Google Fonts family: Special Gothic"
arch=('any')
url="https://fonts.google.com/specimen/Special+Gothic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/specialgothic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/specialgothic/SpecialGothic%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "0bac2fe19bcf60beddb3c9301da3c7889e6d5b996af22462853ff391b933f978"
  "2bbf8bcb6c02cacbdcdc4b6db7ae450b85447bfe5a0ba4ae46c9f69182b5c414"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
