pkgname=ttf-google-lovedbytheking
pkgver=1.002
pkgrel=1
_commit="4e5f06dbb274a27ebe71ed54ea706b3ee40eabd9"  # Latest commit touching ofl/lovedbytheking
pkgdesc="Google Fonts family: Loved by the King"
arch=('any')
url="https://fonts.google.com/specimen/Loved+by+the+King"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/lovedbytheking/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/lovedbytheking/LovedbytheKing.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "1d2fce705c902a0c47264992e698ce76336013458f0612cc68917025ca6fcfb3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
