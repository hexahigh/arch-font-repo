pkgname=ttf-google-vendsans
pkgver=1.611
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/vendsans
pkgdesc="Google Fonts family: Vend Sans"
arch=('any')
url="https://fonts.google.com/specimen/Vend+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/vendsans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/vendsans/VendSans-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/vendsans/VendSans[wght].ttf"
)
sha256sums=(
  "b9511bc8cb3b35d82086718739f368efa50c520e084cc28192bd275b39fe5cc8"
  "1042315d8a89fed420d90f77986d9dd3ca128eb7119a9b7b87f7a71a5a24513a"
  "2cb848ca14258afcffc47b1e63ab7d562de915f0de5fe7a68079633880565d36"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
