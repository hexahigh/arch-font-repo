pkgname=ttf-google-anekgujarati
pkgver=1.003
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/anekgujarati
pkgdesc="Google Fonts family: Anek Gujarati"
arch=('any')
url="https://fonts.google.com/specimen/Anek+Gujarati"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/anekgujarati/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/anekgujarati/AnekGujarati[wdth,wght].ttf"
)
sha256sums=(
  "de62be758bba267e653a5f457dfebb4680957e2c343eb3e7de15aff4746bed05"
  "7d68cf90804e69cd23717f9f5485f4ac10b660096ab0b406e86f32e09d96029b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
