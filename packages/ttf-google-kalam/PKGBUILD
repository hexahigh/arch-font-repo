pkgname=ttf-google-kalam
pkgver=2.001
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/kalam
pkgdesc="Google Fonts family: Kalam"
arch=('any')
url="https://fonts.google.com/specimen/Kalam"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/kalam/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/kalam/Kalam-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/kalam/Kalam-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/kalam/Kalam-Regular.ttf"
)
sha256sums=(
  "f62ef357d3a1c3d27edd35a6e1ba350e8a8d13499797964eeadefbf0b3b15d1f"
  "2f6576601db015d4f6c08678120277fc8510b98c06e932ce7a6a9cbff4cbdded"
  "2b8f2c0208d397a1823688783da3317d6af18ea007a9a1b56ddb17e27820507e"
  "57cecb63d4608019371954274ae1d8c397764debd5b19d4a33c1efa4dc923c0b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
