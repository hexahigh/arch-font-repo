pkgname=ttf-google-marcellussc
pkgver=1.001
pkgrel=1
_commit="4e5f06dbb274a27ebe71ed54ea706b3ee40eabd9"  # Latest commit touching ofl/marcellussc
pkgdesc="Google Fonts family: Marcellus SC"
arch=('any')
url="https://fonts.google.com/specimen/Marcellus+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/marcellussc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/marcellussc/MarcellusSC-Regular.ttf"
)
sha256sums=(
  "715ba72697e14daa9b29a333545f69bde7c497b9f77d0a2a4c4a5a752d961801"
  "03044ab65228b0554c9a5c1e63df29d4e58a71857e212801aaf768dfd106bdf0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
