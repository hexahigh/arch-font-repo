pkgname=ttf-google-juliussansone
pkgver=1.002
pkgrel=1
_commit="a8d88dca820b6bade5b39faf75b17241bcbb5904"  # Latest commit touching ofl/juliussansone
pkgdesc="Google Fonts family: Julius Sans One"
arch=('any')
url="https://fonts.google.com/specimen/Julius+Sans+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/juliussansone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/juliussansone/JuliusSansOne-Regular.ttf"
)
sha256sums=(
  "955655cafa13f187f45a79dcf451942fd1118a8426abc5a25ffc5dbb00709da6"
  "b540bcad9283f58955a8db82d8103b1fd356378f55ec764cdb20d9f5ae749f23"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
