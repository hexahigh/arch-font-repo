pkgname=ttf-gluk-sudegnakno3
pkgver=0.12
pkgrel=1
pkgdesc="SudegnakNo3 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=SudegnakNo3'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/SudegnakNo3/SudegnakNo3_012.zip")
sha256sums=('45356bba631c859f95e914e9a79311b3de08abcca7a8e19f6abfc5608aaa18ee')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=SudegnakNo3
License info from upstream page: OpenFontLicense
EOF
}
