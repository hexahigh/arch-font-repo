pkgname=ttf-google-robotomono
pkgver=3.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/robotomono
pkgdesc="Google Fonts family: Roboto Mono"
arch=('any')
url="https://fonts.google.com/specimen/Roboto+Mono"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/robotomono/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/robotomono/RobotoMono-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/robotomono/RobotoMono[wght].ttf"
)
sha256sums=(
  "50ab8dd54680d3473f649c9db86fece88434d097c7834475c1c72d2f8c429215"
  "49ac343bb7b070071e53f0a8a501d68d140ed98ebd0a43b6b8fb96cf22f09ff7"
  "66a80e79d17e4c7cabd162e2916578a4cc08fd19eef6e2a643305eae9c567b2b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
