pkgname=ttf-google-flamenco
pkgver=1.003
pkgrel=1
_commit="d116c0e1f47697deb2d099b055158b7e84eb7e9d"  # Latest commit touching ofl/flamenco
pkgdesc="Google Fonts family: Flamenco"
arch=('any')
url="https://fonts.google.com/specimen/Flamenco"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/flamenco/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/flamenco/Flamenco-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/flamenco/Flamenco-Regular.ttf"
)
sha256sums=(
  "e3ea566dbf689a9110b2094f9f2e5d16d7ec31720147651efc1005ca20420dd4"
  "6e755ea4c20b869dd7463c0f2a5b37aae0be6b158d0ef8281b0374af3c515210"
  "4de67f9c6b2444ae2073c236f0829c95d380c5ef44aff4539754888fc2e3cf23"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
