pkgname=ttf-google-jsmathcmti10
pkgver=001.001
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching apache/jsmathcmti10
pkgdesc="Google Fonts family: jsMath cmti10"
arch=('any')
url="https://fonts.google.com/specimen/jsMath+cmti10"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/aclonica/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/jsmathcmti10/jsMath-cmti10.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "199f93e76ad4abfc4582a3559de776be595835b04e0327fcd79b4cabaa1ebfc3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
