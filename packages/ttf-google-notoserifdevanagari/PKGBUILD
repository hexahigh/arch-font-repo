pkgname=ttf-google-notoserifdevanagari
pkgver=2.006
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifdevanagari
pkgdesc="Google Fonts family: Noto Serif Devanagari"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Devanagari"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifdevanagari/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifdevanagari/NotoSerifDevanagari[wdth,wght].ttf"
)
sha256sums=(
  "a216f6f8d85c7228093e0ee5e258d9d377e6671f68acb4db1930b29583d0f331"
  "1191e07bfeb062d80e252eb85b0eafdfbda1e350707a2a60628668e8f677dbbb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
