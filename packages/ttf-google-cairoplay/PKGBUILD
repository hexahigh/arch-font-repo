pkgname=ttf-google-cairoplay
pkgver=3.130
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/cairoplay
pkgdesc="Google Fonts family: Cairo Play"
arch=('any')
url="https://fonts.google.com/specimen/Cairo+Play"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cairoplay/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cairoplay/CairoPlay%5Bslnt%2Cwght%5D.ttf"
)
sha256sums=(
  "a4554e1799d42e1405924b61eb0e0722ae1623b1f1f07f995348f96c496362a9"
  "2c275b43ace54233a0960c3aa1d05b4e9e0e396a501cd3f8d446b16cc3362745"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
