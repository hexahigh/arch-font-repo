pkgname=ttf-google-labrada
pkgver=1.000
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/labrada
pkgdesc="Google Fonts family: Labrada"
arch=('any')
url="https://fonts.google.com/specimen/Labrada"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/labrada/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/labrada/Labrada-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/labrada/Labrada[wght].ttf"
)
sha256sums=(
  "b1a62ca897c597c0a0f01be8cb50c0d8370579acd1eadc3f2cc43093d6bbd142"
  "d5d491f4d6c530707e2cc689a4be4a9b28c45e98012ecf6e040b0ac38ee9b428"
  "0374729c732da52ad8681bc0a84a7e992cef34dbfc5f681dfdbdf7c5de25617b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
