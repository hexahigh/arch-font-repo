pkgname=ttf-google-eduauvicwantguides
pkgver=1.001
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/eduauvicwantguides
pkgdesc="Google Fonts family: Edu AU VIC WA NT Guides"
arch=('any')
url="https://fonts.google.com/specimen/Edu+AU+VIC+WA+NT+Guides"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/eduauvicwantguides/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/eduauvicwantguides/EduAUVICWANTGuides%5Bwght%5D.ttf"
)
sha256sums=(
  "11a98fa66908aa244c7608443d945dd50e2821d879bb25b5897ffc8f94712688"
  "7c47fc85f944c729e9df8af4be787a3c222604916b8700045451a0743cd29d4a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
