pkgname=ttf-google-brunoacesc
pkgver=1.100
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/brunoacesc
pkgdesc="Google Fonts family: Bruno Ace SC"
arch=('any')
url="https://fonts.google.com/specimen/Bruno+Ace+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/brunoacesc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/brunoacesc/BrunoAceSC-Regular.ttf"
)
sha256sums=(
  "0818bff7217e2a147826e6f18f6b4c5094f7415fcc61298883dde2fded9b4411"
  "97fc6885b4c0345793ddf13bedd7864bc0f45ed47ad05628e42cafc5d8e795d5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
