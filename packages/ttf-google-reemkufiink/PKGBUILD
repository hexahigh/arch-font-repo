pkgname=ttf-google-reemkufiink
pkgver=1.899
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/reemkufiink
pkgdesc="Google Fonts family: Reem Kufi Ink"
arch=('any')
url="https://fonts.google.com/specimen/Reem+Kufi+Ink"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/reemkufiink/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/reemkufiink/ReemKufiInk-Regular.ttf"
)
sha256sums=(
  "fedb204ccadda62524c5467136cef4968b6b67efdc6ca3e8752c1248d81e7f4e"
  "45fecf59cff786a23357b61d282e5ad383438be9507f3aa9ea00eb0534d0a87e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
