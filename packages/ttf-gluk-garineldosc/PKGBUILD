pkgname=ttf-gluk-garineldosc
pkgver=0.24
pkgrel=1
pkgdesc="GarineldoSC font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=GarineldoSC'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/GarineldoSC/GarineldoSC-024.zip")
sha256sums=('05bd080919e67aac478697fa7ae90c7f2e8816803a08761f84ee2585e38f0b62')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=GarineldoSC
License info from upstream page: OpenFontLicense
EOF
}
