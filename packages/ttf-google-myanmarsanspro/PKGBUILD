pkgname=ttf-google-myanmarsanspro
pkgver=1.10
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/myanmarsanspro
pkgdesc="Google Fonts family: Myanmarsanspro"
arch=('any')
url="https://fonts.google.com/specimen/Myanmarsanspro"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/myanmarsanspro/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/myanmarsanspro/MyanmarSansPro-Regular.ttf"
)
sha256sums=(
  "b9d592c3bf421197d9b7e353416b8e2ec81584988824b43d38c86d997a08b868"
  "bd22052d31852907f35a5690c19ad20bedc505c47cd091201625089ffc29bb97"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
