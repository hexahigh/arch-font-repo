pkgname=ttf-google-goldman
pkgver=1.000
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/goldman
pkgdesc="Google Fonts family: Goldman"
arch=('any')
url="https://fonts.google.com/specimen/Goldman"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/goldman/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/goldman/Goldman-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/goldman/Goldman-Regular.ttf"
)
sha256sums=(
  "bb7828b16438c97ca84b53e2fbd2c3bd9dcf2a86ccda6806ec9ae955a1814d29"
  "3d875bc02d79dff86369ada5b4c4d8c1b7b184bc70a322b651aa5c39693631e3"
  "747d4eb547ffca1b1c4ceb49d38f04a2cd8767d5d86425b71290456ab8eb280a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
