pkgname=ttf-google-autourone
pkgver=1.007
pkgrel=1
_commit="42e01ed7f4cf1405dda363146d96f79cbc8f9044"  # Latest commit touching ofl/autourone
pkgdesc="Google Fonts family: Autour One"
arch=('any')
url="https://fonts.google.com/specimen/Autour+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/autourone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/autourone/AutourOne-Regular.ttf"
)
sha256sums=(
  "793891edf1f4f4f35b52fcc9706b03f779c7ea18ab8e9e441242d63ef0279488"
  "6a3f5bf27e9398c25bd8c4edaee8bd503d8074553537a2bf3b1d724353aab252"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
