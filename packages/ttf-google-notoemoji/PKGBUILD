pkgname=ttf-google-notoemoji
pkgver=3.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoemoji
pkgdesc="Google Fonts family: Noto Emoji"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Emoji"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoemoji/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoemoji/NotoEmoji%5Bwght%5D.ttf"
)
sha256sums=(
  "500bb1ccf43df7bbb522112f9133a52b16e1c35e809632f5d8609b179152de5b"
  "de6c18832938afc99caf132b39d6a30a19bac7f2e812e28db2535b4608d27551"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
