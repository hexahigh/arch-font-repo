pkgname=ttf-google-cascadiamono
pkgver=2407.024
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/cascadiamono
pkgdesc="Google Fonts family: Cascadia Mono"
arch=('any')
url="https://fonts.google.com/specimen/Cascadia+Mono"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cascadiamono/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cascadiamono/CascadiaMono-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/cascadiamono/CascadiaMono%5Bwght%5D.ttf"
)
sha256sums=(
  "82c05d6c53dfa0c9025985c19e371810020b74ed2c61d51d370f2a8ab2506d52"
  "53f999d8032b8e16332507d0e18ad638e59cbe72cae52c3ee62ec99337942e51"
  "78864a1b4d03767a44731454a6f24c6b7d6e93fb5f62932860eb02e409cd50cb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
