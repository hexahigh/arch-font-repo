pkgname=ttf-google-bizudgothic
pkgver=1.05
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bizudgothic
pkgdesc="Google Fonts family: BIZ UDGothic"
arch=('any')
url="https://fonts.google.com/specimen/BIZ+UDGothic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudgothic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudgothic/BIZUDGothic-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudgothic/BIZUDGothic-Regular.ttf"
)
sha256sums=(
  "e753d7155d53c747d037a445e584c8ecfca6dd79846db610417e282a736b28bc"
  "98a528b6b638463041968783cc0f63adaf4cdc26f5398afed68bab712d1113f3"
  "709fcd41e3209fb765da750472f55ccdf925653e9fa7e1eb007cb65c8f749c75"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
