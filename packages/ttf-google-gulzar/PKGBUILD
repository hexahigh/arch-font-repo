pkgname=ttf-google-gulzar
pkgver=1.000
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/gulzar
pkgdesc="Google Fonts family: Gulzar"
arch=('any')
url="https://fonts.google.com/specimen/Gulzar"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gulzar/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gulzar/Gulzar-Regular.ttf"
)
sha256sums=(
  "42d665be2bd66ea6445e0a37cb6f80eb4ac10d56cd0503efa0c6d6d6ebe86de2"
  "246337973ac64e8b70fe611405dcf32a395a8885c4497dc45dbc4975d3ac0831"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
