pkgname=ttf-google-notosansosage
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansosage
pkgdesc="Google Fonts family: Noto Sans Osage"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Osage"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansosage/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansosage/NotoSansOsage-Regular.ttf"
)
sha256sums=(
  "46683544b3fae35c1716ad6deead57b7363edfc369aabcd8d159250e3fce57ae"
  "fb7f7fed310568cceddf3d08cfbb13ccde7b84b1ddd93f9430cb91c2bdd4172d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
