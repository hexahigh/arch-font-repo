pkgname=ttf-google-bigshouldersinlinetext
pkgver=2.002
pkgrel=1
_commit="10cef14fe1360f00510d03d5380c7be6143e63b9"  # Latest commit touching ofl/bigshouldersinlinetext
pkgdesc="Google Fonts family: Big Shoulders Inline Text"
arch=('any')
url="https://fonts.google.com/specimen/Big+Shoulders+Inline+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersinlinetext/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersinlinetext/BigShouldersInlineText[wght].ttf"
)
sha256sums=(
  "338f9c050f19daeda1d597243faf79f3a3d437c338af58cb7047617d0ce08771"
  "e1da2aa867fb756db228ba6d0e9954e1076706a4eaa9471fee8f255a4c30a13f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
