pkgname=ttf-google-playwriteittradguides
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwriteittradguides
pkgdesc="Google Fonts family: Playwrite IT Trad Guides"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+IT+Trad+Guides"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwriteittradguides/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwriteittradguides/PlaywriteITTradGuides-Regular.ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "ccbf16933be4d643802b4125dce67d64eb1cde0dcde9a44becf7f5c82c49522e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
