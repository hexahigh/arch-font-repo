pkgname=ttf-google-solway
pkgver=1.000
pkgrel=1
_commit="b7343b2753a27bb04060a7d7b86c65ed17dacba4"  # Latest commit touching ofl/solway
pkgdesc="Google Fonts family: Solway"
arch=('any')
url="https://fonts.google.com/specimen/Solway"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/solway/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/solway/Solway-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/solway/Solway-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/solway/Solway-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/solway/Solway-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/solway/Solway-Regular.ttf"
)
sha256sums=(
  "00730ae6eab82c336c89e1b9ad751540b032a54c822cc26a0268161fd200b16f"
  "1929aeae0836799a08472026aff797a768f1c051db629a853d35589ba5e5ae1e"
  "4d2a7458d613ba3316cd9c1cb7a1ac89daecc34c73aed100d72c5170db1a86d8"
  "7d5819ffda578c61363779789aa23ad26285a44472743a8ab30e17df15c88033"
  "3c47643b4b48c825e65e44af9356bb7392ee63c7c4e7211e6f8d1e1b96b633f0"
  "a7a5103509a64884149b94b500003d3deecc289cb94f2556c81945ca28b0da55"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
