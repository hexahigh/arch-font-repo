pkgname=ttf-google-notosanskr
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanskr
pkgdesc="Google Fonts family: Noto Sans KR"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+KR"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanskr/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanskr/NotoSansKR%5Bwght%5D.ttf"
)
sha256sums=(
  "1c05c68c34f9708415aada51f17e1b0092d2cea709bf4a94cd38114f9e73d7d9"
  "194018e6b2b293a7964f037b25c0249ce1418bc9ab3c971060a03aa57861e252"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
