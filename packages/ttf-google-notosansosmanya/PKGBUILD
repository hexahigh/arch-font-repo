pkgname=ttf-google-notosansosmanya
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansosmanya
pkgdesc="Google Fonts family: Noto Sans Osmanya"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Osmanya"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansosmanya/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansosmanya/NotoSansOsmanya-Regular.ttf"
)
sha256sums=(
  "a912228f344a47ecb6e7f00c96f70a62033e18c028304bd0b23ce77c929621f4"
  "8832125f106a0be9d4b7e6442493a96f2d6626b8edb2cc20f53c48e9b73fd5a7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
