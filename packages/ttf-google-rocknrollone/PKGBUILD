pkgname=ttf-google-rocknrollone
pkgver=1.100
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rocknrollone
pkgdesc="Google Fonts family: RocknRoll One"
arch=('any')
url="https://fonts.google.com/specimen/RocknRoll+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rocknrollone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rocknrollone/RocknRollOne-Regular.ttf"
)
sha256sums=(
  "b2f42a005a6a48ead81e369021e300184f0cbecb48aee6f831e46c7897f6055b"
  "dc0f5ff975851827f63f2c6bfed128ffbca14b6399a10fb5e1711215c0108526"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
