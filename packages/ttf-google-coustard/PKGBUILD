pkgname=ttf-google-coustard
pkgver=1.100
pkgrel=1
_commit="a0db7446456b7e40495dd8679206daa7c9197d3f"  # Latest commit touching ofl/coustard
pkgdesc="Google Fonts family: Coustard"
arch=('any')
url="https://fonts.google.com/specimen/Coustard"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/coustard/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/coustard/Coustard-Black.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/coustard/Coustard-Regular.ttf"
)
sha256sums=(
  "9db9983bb803b5a12d635f24f9a07aab91beaa53499c1036d6aeb79599b03f7b"
  "6a7c7019eaf2a96ac6ef242f537a583800687a1e95786e02601f498538c5a24b"
  "71f251444fc70fc98adb011cdf8d8c64ecc7ae5d57fc04f59d8ebb1cfc16460c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
