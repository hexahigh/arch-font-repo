pkgname=ttf-google-squarepeg
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/squarepeg
pkgdesc="Google Fonts family: Square Peg"
arch=('any')
url="https://fonts.google.com/specimen/Square+Peg"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/squarepeg/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/squarepeg/SquarePeg-Regular.ttf"
)
sha256sums=(
  "0dbdce2f23073469bc0047c323e259399a76cfec756aa5f0bd1a58f34f438220"
  "eec103268e16f1f348482687964e5c1545c9c5888052cb48d1aa8dc9f27a37fc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
