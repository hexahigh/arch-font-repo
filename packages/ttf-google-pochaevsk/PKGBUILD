pkgname=ttf-google-pochaevsk
pkgver=1.210
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/pochaevsk
pkgdesc="Google Fonts family: Pochaevsk"
arch=('any')
url="https://fonts.google.com/specimen/Pochaevsk"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pochaevsk/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pochaevsk/Pochaevsk-Regular.ttf"
)
sha256sums=(
  "45133ae0ae8aa0ab93f056e452bc4e7c491f2cc00a8bd17879cf4951749614b6"
  "1c424dbaad55832f4067c631c89ecae1c917f23f8c33323987ea4a99f97012a8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
