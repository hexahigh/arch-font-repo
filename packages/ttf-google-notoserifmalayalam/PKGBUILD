pkgname=ttf-google-notoserifmalayalam
pkgver=2.104
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifmalayalam
pkgdesc="Google Fonts family: Noto Serif Malayalam"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Malayalam"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifmalayalam/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifmalayalam/NotoSerifMalayalam%5Bwght%5D.ttf"
)
sha256sums=(
  "1df18163a0bf60f02131401ba1609df90051f40c4047684dda1c8a2e9586f7f2"
  "eed354cadb35992df6e8b32fdb7edb399989b165f0f25e7a921009683db26e8e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
