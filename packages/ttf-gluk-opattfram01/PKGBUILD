pkgname=ttf-gluk-opattfram01
pkgver=0.9
pkgrel=1
pkgdesc="Opattfram01 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Opattfram01'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212//font/opattfram01/Opattfram01.zip")
sha256sums=('dbb643a3ac89317b2d53f1858da8be019c54a058527f854a107742fd1eb3ca98')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Opattfram01
License info from upstream page: OpenFontLicense
EOF
}
