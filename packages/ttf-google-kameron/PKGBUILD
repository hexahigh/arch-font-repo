pkgname=ttf-google-kameron
pkgver=1.100
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/kameron
pkgdesc="Google Fonts family: Kameron"
arch=('any')
url="https://fonts.google.com/specimen/Kameron"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/kameron/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/kameron/Kameron[wght].ttf"
)
sha256sums=(
  "3105b49207b8deaef9efa249489df8eff9d76b331d46a433e15cc4685932dff7"
  "b7e9bf8756c3403c1acb1d93d225dcd14dbafc9864ee891268c89459e99db410"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
