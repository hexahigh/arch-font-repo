pkgname=ttf-google-sedansc
pkgver=1.100
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sedansc
pkgdesc="Google Fonts family: Sedan SC"
arch=('any')
url="https://fonts.google.com/specimen/Sedan+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sedansc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sedansc/SedanSC-Regular.ttf"
)
sha256sums=(
  "ab9b88d7e03c04feede45c8ee1b569ab3f26874d86b474a3b219ed3e3b59e5a4"
  "b015b262e6138cd0e8279ba75695f07748af01f8a9eed5d4d536e283baa57314"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
