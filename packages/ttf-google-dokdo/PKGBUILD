pkgname=ttf-google-dokdo
pkgver=2.00
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/dokdo
pkgdesc="Google Fonts family: Dokdo"
arch=('any')
url="https://fonts.google.com/specimen/Dokdo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/dokdo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/dokdo/Dokdo-Regular.ttf"
)
sha256sums=(
  "dcc832bd71ea62cbf97f06327a1b5442905b49ea446801421d71f7d1362db215"
  "5b3a3d8d28af31fa9adec3fc5da81a88b52e1ff39ed3930c1db787aa4e79c36d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
