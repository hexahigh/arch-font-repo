pkgname=ttf-google-permanentmarker
pkgver=1.001
pkgrel=1
_commit="3b093c4be99bbc9cc5384441270a05eaac52cd39"  # Latest commit touching apache/permanentmarker
pkgdesc="Google Fonts family: Permanent Marker"
arch=('any')
url="https://fonts.google.com/specimen/Permanent+Marker"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/permanentmarker/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/permanentmarker/PermanentMarker-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "28f82c8a7943cb8e9d599f8554da1d4fc75dbcf69b9885ad6c0611d20c6946c5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
