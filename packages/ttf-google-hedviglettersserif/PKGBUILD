pkgname=ttf-google-hedviglettersserif
pkgver=1.000
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/hedviglettersserif
pkgdesc="Google Fonts family: Hedvig Letters Serif"
arch=('any')
url="https://fonts.google.com/specimen/Hedvig+Letters+Serif"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hedviglettersserif/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hedviglettersserif/HedvigLettersSerif%5Bopsz%5D.ttf"
)
sha256sums=(
  "2a603f9fb5d68c3a67b3ab5d79e685fbc0c0585a9a478e5b89b2edab135cc1f6"
  "4892f22754178b5d18360b24b16bfac38b4a2344395316d66ebd1f3d11ca28c6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
