pkgname=ttf-google-notosanssyriaceastern
pkgver=3.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssyriaceastern
pkgdesc="Google Fonts family: Noto Sans Syriac Eastern"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Syriac+Eastern"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssyriaceastern/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssyriaceastern/NotoSansSyriacEastern%5Bwght%5D.ttf"
)
sha256sums=(
  "6442860dad2700aabece2ac7252680b1a5bfc0987cec1ca0c3d605ab8f0b7975"
  "5f562f4ed8a00bcdf57a46726d15111e6b97bd06bb554a5e368a084c2116f5e4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
