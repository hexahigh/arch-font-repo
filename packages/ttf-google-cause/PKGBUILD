pkgname=ttf-google-cause
pkgver=1.000
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/cause
pkgdesc="Google Fonts family: Cause"
arch=('any')
url="https://fonts.google.com/specimen/Cause"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cause/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cause/Cause%5Bwght%5D.ttf"
)
sha256sums=(
  "011ee2115104c54c2211d2bd39e1dc16ec29dcbb6e3eb797f4c2a615579e0c7d"
  "3f6b01fa9cfe6d84948ae903f954effa5cdf37a3ec0e3a67e15276d9ccbf95f2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
