pkgname=ttf-google-engagement
pkgver=1.000
pkgrel=1
_commit="c0da1d694f81baec07de8b94d6b781cfad64af8f"  # Latest commit touching ofl/engagement
pkgdesc="Google Fonts family: Engagement"
arch=('any')
url="https://fonts.google.com/specimen/Engagement"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/engagement/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/engagement/Engagement-Regular.ttf"
)
sha256sums=(
  "ef0bdccd20de76d517fb3939161d05ecd5808382fb8fa82cde5fcdb3adcb8029"
  "0bfb666005c0f37e9c51265ca5dff812b2fc4929ed324f359caa92f80c25e01a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
