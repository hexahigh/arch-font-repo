pkgname=ttf-gluk-znikomit
pkgver=0.56
pkgrel=1
pkgdesc="Znikomit font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Znikomit'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/znikomit/Znikomit_056.zip")
sha256sums=('c504fe7a42657a28ca330a530a319d8d6f078c7bb5cc4b5225b4595c9dea629b')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Znikomit
License info from upstream page: OpenFontLicense
EOF
}
