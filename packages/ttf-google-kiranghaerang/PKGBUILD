pkgname=ttf-google-kiranghaerang
pkgver=1.001
pkgrel=1
_commit="130fcfb0ff422fec96b335616b2ca99f91914792"  # Latest commit touching ofl/kiranghaerang
pkgdesc="Google Fonts family: Kirang Haerang"
arch=('any')
url="https://fonts.google.com/specimen/Kirang+Haerang"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/kiranghaerang/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/kiranghaerang/KirangHaerang-Regular.ttf"
)
sha256sums=(
  "7e896665d0863d2a17a671001dbe2528a5f9302f1dff9222af8b0834e9088d0c"
  "d677d28d466989017c520f00a2a7794ea581ea3d9fa9a830fbb44f1015eac72d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
