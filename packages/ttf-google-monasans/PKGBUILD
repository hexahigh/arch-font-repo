pkgname=ttf-google-monasans
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/monasans
pkgdesc="Google Fonts family: Mona Sans"
arch=('any')
url="https://fonts.google.com/specimen/Mona+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/monasans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/monasans/MonaSans-Italic[wdth,wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/monasans/MonaSans[wdth,wght].ttf"
)
sha256sums=(
  "9261dcb61fb5e3c587d50d7a9fdae12bc7422d8822d7ac06b8f34550479575de"
  "31e7df54477a3cd46677356ada1d2806bcb4c0dbe3b32987783a74a139d8d064"
  "fd6e79634b5ae804a45aac7e2e3c2a325b41291fba59034f4732b0135b8475b3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
