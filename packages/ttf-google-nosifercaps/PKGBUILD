pkgname=ttf-google-nosifercaps
pkgver=001.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/nosifercaps
pkgdesc="Google Fonts family: Nosifer Caps"
arch=('any')
url="https://fonts.google.com/specimen/Nosifer+Caps"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/nosifercaps/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/nosifercaps/NosiferCaps-Regular.ttf"
)
sha256sums=(
  "4f8b437578b20bff261adfe6c02f63bcf7dbb6a45ab37804b3547e5d5f44927b"
  "1a1d4fe8f93c32408dc6d068f43e59aaaa3fae4e2cff74dccfbb64de5005d9c1"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
