pkgname=ttf-google-reggaeone
pkgver=1.100
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/reggaeone
pkgdesc="Google Fonts family: Reggae One"
arch=('any')
url="https://fonts.google.com/specimen/Reggae+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/reggaeone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/reggaeone/ReggaeOne-Regular.ttf"
)
sha256sums=(
  "2756c3dcd85ad997b742330f91332fb478afad302708d4149f7bcd4600543ce2"
  "aebe62598732d76036f30ec11bb0ec5f68938e373a06d1b4ceb6b9cf1abf3db2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
