pkgname=ttf-google-ponomar
pkgver=1.302
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/ponomar
pkgdesc="Google Fonts family: Ponomar"
arch=('any')
url="https://fonts.google.com/specimen/Ponomar"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ponomar/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ponomar/Ponomar-Regular.ttf"
)
sha256sums=(
  "37307a13a67f427671ecccf513453525348a165c9973baba7678076884043d88"
  "c3f7aa32d64fa80e3b53357f057ca31ced4249fae3ba5fcab8cddb39b64c68a0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
