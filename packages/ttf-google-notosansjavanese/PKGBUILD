pkgname=ttf-google-notosansjavanese
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansjavanese
pkgdesc="Google Fonts family: Noto Sans Javanese"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Javanese"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansjavanese/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansjavanese/NotoSansJavanese%5Bwght%5D.ttf"
)
sha256sums=(
  "8a5665bd3b16a64f953b24a71f12e298f5233be8a4ed17424129c5524a397892"
  "0bcb88de05a855aec38471d6317e860fa2a40d1c3ca93f2736b7c34ad9288d90"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
