pkgname=ttf-google-notosanslycian
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanslycian
pkgdesc="Google Fonts family: Noto Sans Lycian"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Lycian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslycian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslycian/NotoSansLycian-Regular.ttf"
)
sha256sums=(
  "43ade220daeb7c8f610c4ca136304710e4eb910f64627d6010ddf9fe2fe18cf8"
  "81ad6994c822aba066219b06e6e097dcedba449b33c6fe6ceb79c2cdeb88664f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
