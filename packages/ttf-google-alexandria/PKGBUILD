pkgname=ttf-google-alexandria
pkgver=5.100
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/alexandria
pkgdesc="Google Fonts family: Alexandria"
arch=('any')
url="https://fonts.google.com/specimen/Alexandria"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alexandria/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alexandria/Alexandria%5Bwght%5D.ttf"
)
sha256sums=(
  "56372aed19c2701f50e6e784110af55bf8796ed51648805324ad1adb0a3860bb"
  "db8ae03b62d55a65aa4e04307878df8c00d6e5388e4800635cbe0e22b6411b64"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
