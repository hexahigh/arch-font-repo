pkgname=ttf-google-ptserifcaption
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/ptserifcaption
pkgdesc="Google Fonts family: PT Serif Caption"
arch=('any')
url="https://fonts.google.com/specimen/PT+Serif+Caption"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ptserifcaption/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ptserifcaption/PT_Serif-Caption-Web-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ptserifcaption/PT_Serif-Caption-Web-Regular.ttf"
)
sha256sums=(
  "ddf311c28ddf5a5ad9747649837346b67bed9d356789c3072bb27dbce49e514d"
  "afe69233498676c418383b9defda8aace407eca0e86f4499d9ba4e9f494f9da5"
  "d17d47f44e840eee017f839b27dff3c94c7afe7743eff308d4bd11f7018b69af"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
