pkgname=ttf-google-notosansdisplay
pkgver=2.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansdisplay
pkgdesc="Google Fonts family: Noto Sans Display"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Display"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansdisplay/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansdisplay/NotoSansDisplay-Italic%5Bwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansdisplay/NotoSansDisplay%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "81374b375e9476e2fa5b31a9ee4bcab524a307270dd5bf033346c7ba932f226b"
  "deaa68141fa5ad21bd17d7c11fa79183ceda19b32e40ff5c33874d42f3636dde"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
