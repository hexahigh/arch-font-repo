pkgname=ttf-google-notosanszanabazarsquare
pkgver=2.006
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanszanabazarsquare
pkgdesc="Google Fonts family: Noto Sans Zanabazar Square"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Zanabazar+Square"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanszanabazarsquare/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanszanabazarsquare/NotoSansZanabazarSquare-Regular.ttf"
)
sha256sums=(
  "bb3dc754adff0b5baa523c96e6ecc424df94b406b1f32ac19630905230ff0739"
  "73419252f55ba853edeb9f635533da240ed612b4dff59cdb48d83948864126c7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
