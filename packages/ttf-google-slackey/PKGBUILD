pkgname=ttf-google-slackey
pkgver=1.001
pkgrel=1
_commit="22ba627a88604d40de5fa943401b83c3e8da1269"  # Latest commit touching apache/slackey
pkgdesc="Google Fonts family: Slackey"
arch=('any')
url="https://fonts.google.com/specimen/Slackey"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/slackey/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/slackey/Slackey-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "0be253cdeadcd1ea90ff5954e86641b3ccbef27152608e266af91619cd308eb2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
