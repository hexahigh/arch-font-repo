pkgname=ttf-gluk-mikodacs
pkgver=0.28
pkgrel=1
pkgdesc="Mikodacs font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Mikodacs'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Mikodacs/Mikodacs_028.zip")
sha256sums=('5ae3fbf5d8d4f93b8246863225044dce6a4758b9f45fdb5094f8478635d4825a')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Mikodacs
License info from upstream page: OpenFontLicense
EOF
}
