pkgname=ttf-google-convergence
pkgver=1.002
pkgrel=1
_commit="83c062a2f5abbb5cb6208a0d3ac7f983df83a6cd"  # Latest commit touching ofl/convergence
pkgdesc="Google Fonts family: Convergence"
arch=('any')
url="https://fonts.google.com/specimen/Convergence"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/convergence/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/convergence/Convergence-Regular.ttf"
)
sha256sums=(
  "354b4be0340cd58e381fdf58793a108897bf944a7f8faf9e877c476ed6c730d1"
  "4e17355228610042e6922db7f19d9d87eb99b4f09ba3a12be8a2800bad0e9904"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
