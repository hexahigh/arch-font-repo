pkgname=ttf-google-moul
pkgver=8.002
pkgrel=1
_commit="adde58aa7f4ef91d3464a7d2a168ff07cc3d9e07"  # Latest commit touching ofl/moul
pkgdesc="Google Fonts family: Moul"
arch=('any')
url="https://fonts.google.com/specimen/Moul"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/moul/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/moul/Moul-Regular.ttf"
)
sha256sums=(
  "993860a6b21dbb0eb98c7e07490f07d24c919d4ad4fed04a1b34f1663d9d53e3"
  "c0445e86767edf1bfb08a6fe65bd38f350b588c641af7e2e88a59d72ccecd9c3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
