pkgname=ttf-google-nunito
pkgver=3.602
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/nunito
pkgdesc="Google Fonts family: Nunito"
arch=('any')
url="https://fonts.google.com/specimen/Nunito"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/nunito/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/nunito/Nunito-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/nunito/Nunito[wght].ttf"
)
sha256sums=(
  "580df76c95a1ec5ab878ceb25bb3d85c6a076804e9c970c8c6972aea775fdf65"
  "b520cc871868b0acfca1beda875df7f4a44ebce914f8a89f83977fc9c09529c8"
  "bb55a5ca5c2042335b3991af27c4d0705d0ef41cac6164ac737fd8f2a1e85207"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
