pkgname=ttf-google-cactusclassicalserif
pkgver=1.005
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/cactusclassicalserif
pkgdesc="Google Fonts family: Cactus Classical Serif"
arch=('any')
url="https://fonts.google.com/specimen/Cactus+Classical+Serif"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cactusclassicalserif/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cactusclassicalserif/CactusClassicalSerif-Regular.ttf"
)
sha256sums=(
  "358cbc7066747b8ed6581a771dbccf6397c21db559fdf671e560d7a8a084c5d4"
  "ecbd58961db922392d7fecfafa3681fefaeec0c399b860ab6940ba700f7da055"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
