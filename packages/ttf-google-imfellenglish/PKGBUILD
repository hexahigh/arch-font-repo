pkgname=ttf-google-imfellenglish
pkgver=3.00
pkgrel=1
_commit="54c498a094a60f39492311d0afeb81fc3b2ddc5d"  # Latest commit touching ofl/imfellenglish
pkgdesc="Google Fonts family: IM Fell English"
arch=('any')
url="https://fonts.google.com/specimen/IM+Fell+English"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/imfellenglish/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/imfellenglish/IMFeENit28P.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/imfellenglish/IMFeENrm28P.ttf"
)
sha256sums=(
  "2a3ca501fc4d5efcad9798531e3e06962b1e20c60e464f6cbd6c17630112c773"
  "47cd75dce54b1f2e0831359d22d5e688f519d68ae45706b664fd310fd0e3ccf7"
  "fe9705bbde51af802719246d4608d08d37bde956ab99d9a590da996a5221a24c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
