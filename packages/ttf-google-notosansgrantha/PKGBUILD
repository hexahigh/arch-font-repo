pkgname=ttf-google-notosansgrantha
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansgrantha
pkgdesc="Google Fonts family: Noto Sans Grantha"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Grantha"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansgrantha/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansgrantha/NotoSansGrantha-Regular.ttf"
)
sha256sums=(
  "57ddd5a347bbe5f83d47a5a63679af4a3eb7f609f5a3d5c059ad12fd1fa29e21"
  "a3e57ddeeb9763111d0e4bd6440af2c7b2fa6763fe02ca56570d33e2afbf7ffb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
