pkgname=ttf-google-novaoval
pkgver=2.000
pkgrel=1
_commit="92dc81a50f5978795f532f2023e050b0e9889433"  # Latest commit touching ofl/novaoval
pkgdesc="Google Fonts family: Nova Oval"
arch=('any')
url="https://fonts.google.com/specimen/Nova+Oval"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/novaoval/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/novaoval/NovaOval.ttf"
)
sha256sums=(
  "bb655534b6c7bf3e547c1368a68a5b1032d0e96fd08b5cc75f3d7a78528784ef"
  "2ae90689c17afdcb69fd45325fc65cd98ca8d537a63ed2c33eed9827ac6a16f6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
