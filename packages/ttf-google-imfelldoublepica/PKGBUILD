pkgname=ttf-google-imfelldoublepica
pkgver=3.00
pkgrel=1
_commit="62d695ba95c009c1d5053680d713472566bc1a77"  # Latest commit touching ofl/imfelldoublepica
pkgdesc="Google Fonts family: IM Fell Double Pica"
arch=('any')
url="https://fonts.google.com/specimen/IM+Fell+Double+Pica"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/imfelldoublepica/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/imfelldoublepica/IMFELLDoublePica-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/imfelldoublepica/IMFELLDoublePica-Regular.ttf"
)
sha256sums=(
  "2a3ca501fc4d5efcad9798531e3e06962b1e20c60e464f6cbd6c17630112c773"
  "00ac0e73855f16e7192a76bc284fb86f69b2f2c21b405e29991f99ece83d6391"
  "481afa82a0060b3649668fa629455caeea407864d4c1f6d815380866c504df07"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
