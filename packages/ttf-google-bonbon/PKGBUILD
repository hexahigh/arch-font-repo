pkgname=ttf-google-bonbon
pkgver=1.001
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bonbon
pkgdesc="Google Fonts family: Bonbon"
arch=('any')
url="https://fonts.google.com/specimen/Bonbon"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bonbon/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bonbon/Bonbon-Regular.ttf"
)
sha256sums=(
  "d13a278247ce39695f5ea6b721103faa668083022c5280b78c6392263e473929"
  "718753f714468e878b2af1c82ec65b68c60ce81732308957c3e90d59bce7ce98"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
