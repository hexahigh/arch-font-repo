  "https://github.com/google/fonts/raw/$_commit/ofl/zillaslab/ZillaSlab-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/zillaslab/ZillaSlab-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/zillaslab/ZillaSlab-SemiBoldItalic.ttf"
