pkgname=ttf-google-gurajada
pkgver=1.0.3
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/gurajada
pkgdesc="Google Fonts family: Gurajada"
arch=('any')
url="https://fonts.google.com/specimen/Gurajada"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gurajada/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gurajada/Gurajada-Regular.ttf"
)
sha256sums=(
  "2bd35914efa381c80f9fb62d6ea7d736d3c0739196a3783c3122593c3408392c"
  "353c1289a6f4ba743154c870418272cf68e0f63c0c38598ed33cba814d3178e8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
