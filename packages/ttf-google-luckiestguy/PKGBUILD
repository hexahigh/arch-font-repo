pkgname=ttf-google-luckiestguy
pkgver=1.001
pkgrel=1
_commit="ac011ec057856b010986a55104323d63cada00f8"  # Latest commit touching apache/luckiestguy
pkgdesc="Google Fonts family: Luckiest Guy"
arch=('any')
url="https://fonts.google.com/specimen/Luckiest+Guy"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/luckiestguy/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/luckiestguy/LuckiestGuy-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "cfbdd68a039f92df51cf3721506af6242e64594c6325fe0bedbeff3fe385d980"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
