pkgname=ttf-google-notoseriforiya
pkgver=1.051
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoseriforiya
pkgdesc="Google Fonts family: Noto Serif Oriya"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Oriya"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriforiya/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriforiya/NotoSerifOriya%5Bwght%5D.ttf"
)
sha256sums=(
  "c90ff15ade263a49148e35af34e9c177c6d56881e81260b29f10123e9e227eca"
  "9fa2a08cb6a677d155a823bc58b4c587613780bd43013fd362369c251001502a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
