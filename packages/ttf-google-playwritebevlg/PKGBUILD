pkgname=ttf-google-playwritebevlg
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwritebevlg
pkgdesc="Google Fonts family: Playwrite BE VLG"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+BE+VLG"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritebevlg/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritebevlg/PlaywriteBEVLG[wght].ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "f98fd3cb89c1a04521586cbc16fd1b5d9913b3ad83a9f6202a5bb0ddc92d0067"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
