pkgname=ttf-google-notosanssoyombo
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssoyombo
pkgdesc="Google Fonts family: Noto Sans Soyombo"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Soyombo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssoyombo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssoyombo/NotoSansSoyombo-Regular.ttf"
)
sha256sums=(
  "a5f1c842c6b33865210dda255cbbc8257ce6f05e861129af3d45b887147cdcc3"
  "a1ed643ffe8f84fd7c397a6eb0030f58e2722e7acd8b6a2305f33bf569d1bb2f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
