pkgname=ttf-google-pixelifysans
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/pixelifysans
pkgdesc="Google Fonts family: Pixelify Sans"
arch=('any')
url="https://fonts.google.com/specimen/Pixelify+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pixelifysans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pixelifysans/PixelifySans%5Bwght%5D.ttf"
)
sha256sums=(
  "b66ba46f511a851ab09998b5a5a9fdbb102545a3864cb993095e1745996873a7"
  "9ba86cd010a4de309d263ceff8e8044092c9db7efda869620cb9ff1c4389e8a5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
