pkgname=ttf-gluk-itsadzoke
pkgver=0.46
pkgrel=1
pkgdesc="Itsadzoke font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Itsadzoke'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/itsadzoke/itsadzoke046.zip")
sha256sums=('825020345a10697bd395c5d151ff2a0b64ae6f8789430fbb1f6da831f358ab36')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Itsadzoke
License info from upstream page: OpenFontLicense
EOF
}
