pkgname=ttf-google-lexenddeca
pkgver=1.007
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/lexenddeca
pkgdesc="Google Fonts family: Lexend Deca"
arch=('any')
url="https://fonts.google.com/specimen/Lexend+Deca"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/lexenddeca/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/lexenddeca/LexendDeca%5Bwght%5D.ttf"
)
sha256sums=(
  "5da8505887d0fa7fe963445fd58852707fda34adfeb65af25c99d152bab285bd"
  "d11c12298f431d7e416a1e615d33f2c2b98bda2318a0c186c8c94f08c2d90ce8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
