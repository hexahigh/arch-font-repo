pkgname=ttf-gluk-spinwerad
pkgver=0.30
pkgrel=1
pkgdesc="Spinwerad font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Spinwerad'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/spinwerad/spinwerad-030.zip")
sha256sums=('eb7c80100718e9855b7af7ab643838ee15916a91832bb9ff88ad6b2e18c9157a')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Spinwerad
License info from upstream page: OpenFontLicense
EOF
}
