pkgname=ttf-google-notonastaliqurdu
pkgver=3.009
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notonastaliqurdu
pkgdesc="Google Fonts family: Noto Nastaliq Urdu"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Nastaliq+Urdu"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notonastaliqurdu/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notonastaliqurdu/NotoNastaliqUrdu%5Bwght%5D.ttf"
)
sha256sums=(
  "e90279e3fb2003c4d54f8685e25274bd7838b1b21c891520d71dbdb1d4a98907"
  "98a4787f34eb6fde57fb9a1121a8f216301196ab0da98ea110cad581be8abbcd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
