pkgname=ttf-google-notosanshatran
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanshatran
pkgdesc="Google Fonts family: Noto Sans Hatran"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Hatran"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanshatran/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanshatran/NotoSansHatran-Regular.ttf"
)
sha256sums=(
  "910456012f8244afa9af0d21863a0d637e62b20af4d935350b8635c9664860c0"
  "8d26a25e634783f3fe285868bc71ca396c11d0f760129ce9f85a24f3f943116d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
