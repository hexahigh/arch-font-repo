  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthai/IBMPlexSansThai-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthai/IBMPlexSansThai-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthai/IBMPlexSansThai-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthai/IBMPlexSansThai-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthai/IBMPlexSansThai-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthai/IBMPlexSansThai-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthai/IBMPlexSansThai-Thin.ttf"
)
sha256sums=(
  "7e6b2818edbd8f6a01ae80641cc8f16a51080d08fb4e532be3a0b6f74adb07da"
  "f88fbe0a3717c93deddf4b13e50a05c9adcd38f58d675d9d5d0b869961851667"
  "b1ba0c97d959657832c1a0929c274e4d4d8128ca2c52d24c6835cf87fb4a5a04"
  "b8e2da56ec11f1965af59a7119ee0b9b78773a9c9a89ae049b4975c9197b5c8d"
