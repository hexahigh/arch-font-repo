pkgname=ttf-google-ibmplexsansthai
pkgver=1.1
pkgrel=1
_commit="d935ac9235ee2071604dd67866959dc7528585d9"  # Latest commit touching ofl/ibmplexsansthai
pkgdesc="Google Fonts family: IBM Plex Sans Thai"
arch=('any')
url="https://fonts.google.com/specimen/IBM+Plex+Sans+Thai"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
