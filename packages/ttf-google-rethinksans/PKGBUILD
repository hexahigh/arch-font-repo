pkgname=ttf-google-rethinksans
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rethinksans
pkgdesc="Google Fonts family: Rethink Sans"
arch=('any')
url="https://fonts.google.com/specimen/Rethink+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rethinksans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rethinksans/RethinkSans-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/rethinksans/RethinkSans%5Bwght%5D.ttf"
)
sha256sums=(
  "453da5aa5ad479f38cfec84f83ea03fa89106e728e286272db8a4198d681a9db"
  "c5f1f9a01cd7b1b5d665aea41332d3cb315d5bb520bc882256238dca9bbcde38"
  "c700224149f9248587ccb1e1482bb01c1c779076c8c593720838877ad9643347"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
