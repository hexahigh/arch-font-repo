pkgname=ttf-google-notosansimperialaramaic
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansimperialaramaic
pkgdesc="Google Fonts family: Noto Sans Imperial Aramaic"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Imperial+Aramaic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansimperialaramaic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansimperialaramaic/NotoSansImperialAramaic-Regular.ttf"
)
sha256sums=(
  "965a8053ceb55292d06262810224e7e283015545a73bcb0e0c5931bdcc982aa7"
  "51433e25557eac79df4e447e0b6be4a23bcf3680a60432ebb388a13ea82d227d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
