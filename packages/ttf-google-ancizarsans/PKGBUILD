pkgname=ttf-google-ancizarsans
pkgver=8.100
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/ancizarsans
pkgdesc="Google Fonts family: Ancizar Sans"
arch=('any')
url="https://fonts.google.com/specimen/Ancizar+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ancizarsans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ancizarsans/AncizarSans-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ancizarsans/AncizarSans%5Bwght%5D.ttf"
)
sha256sums=(
  "aeb148248b2b404e2192a9b07c971cd3a7fd348fc334781354fe774fa5889a28"
  "834be8cfccb25c8fdec55908fdbfb3fe682de616688e10e502e22c29ecd5933d"
  "c99ce8a9cd997f264e6c34c2799faecd94c39acf7d06928124f9e7c12d72c743"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
