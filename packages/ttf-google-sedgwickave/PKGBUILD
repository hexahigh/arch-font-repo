pkgname=ttf-google-sedgwickave
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sedgwickave
pkgdesc="Google Fonts family: Sedgwick Ave"
arch=('any')
url="https://fonts.google.com/specimen/Sedgwick+Ave"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sedgwickave/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sedgwickave/SedgwickAve-Regular.ttf"
)
sha256sums=(
  "f323edc1e5a6d8fa16120aa15367cdfb15468474cc621f9bda1a2f73c5d08d73"
  "9c3633e56a8a104e0d10debb70907b66bb3cf32b03137fae7d5392712b253efa"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
