pkgname=ttf-google-balooda2
pkgver=1.700
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/balooda2
pkgdesc="Google Fonts family: Baloo Da 2"
arch=('any')
url="https://fonts.google.com/specimen/Baloo+Da+2"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/balooda2/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/balooda2/BalooDa2[wght].ttf"
)
sha256sums=(
  "ad09b05dc8bc678c9daf7c4c5f7ef1f55e5726127f4330b2e98e40b9dffcb860"
  "8b62a8c4dbe659be5e4d40c19b7b3012120335b333205c5aa101b45cdb449cff"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
