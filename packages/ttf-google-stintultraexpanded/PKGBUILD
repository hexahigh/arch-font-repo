pkgname=ttf-google-stintultraexpanded
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/stintultraexpanded
pkgdesc="Google Fonts family: Stint Ultra Expanded"
arch=('any')
url="https://fonts.google.com/specimen/Stint+Ultra+Expanded"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/stintultraexpanded/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/stintultraexpanded/StintUltraExpanded-Regular.ttf"
)
sha256sums=(
  "fbc351e1b5428e4f45834647dc23a5f8aaa3e744e2f4117ca03c44f640b9a3a2"
  "82b0ec50644e8824100a32085c7136aeb79b2dc9a81804aefc82c3c9337f8a6f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
