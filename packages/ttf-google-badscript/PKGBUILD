pkgname=ttf-google-badscript
pkgver=2.000
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/badscript
pkgdesc="Google Fonts family: Bad Script"
arch=('any')
url="https://fonts.google.com/specimen/Bad+Script"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/badscript/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/badscript/BadScript-Regular.ttf"
)
sha256sums=(
  "0b742ad45c246502b6d56c62146011e37098978b8feb5970d7da313553dedd91"
  "40ec737eee65ec4efbc24ae636fa31d7d84d1ccca83ab54cd555edb72cb3eaf0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
