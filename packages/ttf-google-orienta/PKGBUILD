pkgname=ttf-google-orienta
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/orienta
pkgdesc="Google Fonts family: Orienta"
arch=('any')
url="https://fonts.google.com/specimen/Orienta"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/orienta/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/orienta/Orienta-Regular.ttf"
)
sha256sums=(
  "781433e63668e8f766a755b3df5e1a7100850d3a2fecaf5bc6d01d87888fb354"
  "c7ca99f5789c097565d12313a23449eeb7b46a9d60342419ab696870793ca291"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
