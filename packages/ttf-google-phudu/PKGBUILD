pkgname=ttf-google-phudu
pkgver=1.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/phudu
pkgdesc="Google Fonts family: Phudu"
arch=('any')
url="https://fonts.google.com/specimen/Phudu"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/phudu/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/phudu/Phudu[wght].ttf"
)
sha256sums=(
  "907fa104d1ab720c2d698e51035593f5e6ea5283bd34a6c7cbdad5d6715e68de"
  "56dfb12f5f7b6a851f3638cf975d7733fbcaba0a8f81865513f025730e3536a0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
