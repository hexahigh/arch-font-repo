pkgname=ttf-google-doto
pkgver=1.000
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/doto
pkgdesc="Google Fonts family: Doto"
arch=('any')
url="https://fonts.google.com/specimen/Doto"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/doto/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/doto/Doto[ROND,wght].ttf"
)
sha256sums=(
  "26a7b58bdba6cda8a78ca6e8b3791d8013b8abc6d5e6519f84193893aee02020"
  "6f4fe7d37853b91df3698daa84cde2dbe1c9695d88c986e6510134910337d426"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
