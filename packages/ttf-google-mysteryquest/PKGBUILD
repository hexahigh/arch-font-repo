pkgname=ttf-google-mysteryquest
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mysteryquest
pkgdesc="Google Fonts family: Mystery Quest"
arch=('any')
url="https://fonts.google.com/specimen/Mystery+Quest"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mysteryquest/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mysteryquest/MysteryQuest-Regular.ttf"
)
sha256sums=(
  "965bd2c907f7bb6f36da4f85e83f29aea8b2f720783deebd7ed7b40678e67672"
  "fc3fba61be98d7de03964b41175ee5629bcc6958b251f8037ef13eabb5431eb2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
