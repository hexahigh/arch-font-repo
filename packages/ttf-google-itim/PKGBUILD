pkgname=ttf-google-itim
pkgver=1.002
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/itim
pkgdesc="Google Fonts family: Itim"
arch=('any')
url="https://fonts.google.com/specimen/Itim"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/itim/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/itim/Itim-Regular.ttf"
)
sha256sums=(
  "1f00d1f970b4ea469b6936e599b599bb217edaab792e586658ef2e71cf438685"
  "9164d7eb92ca717b53b07193e3445c96782222d24215151b8d2851b576b17645"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
