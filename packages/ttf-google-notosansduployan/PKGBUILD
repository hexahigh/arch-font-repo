pkgname=ttf-google-notosansduployan
pkgver=3.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansduployan
pkgdesc="Google Fonts family: Noto Sans Duployan"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Duployan"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansduployan/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansduployan/NotoSansDuployan-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansduployan/NotoSansDuployan-Regular.ttf"
)
sha256sums=(
  "b1b12c372165b0a2cf7533c7fa8b6568b8981d2e207a15d7bf631bd1910c4fe0"
  "f7766eabbec7c00e50b0e64bf130805f03da77474c203809ceedf1ae96a521db"
  "2510875cbe4b602f90446e185b25eff1dc600acbc37e8a7a46bbf352603373be"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
