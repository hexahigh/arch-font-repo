pkgname=ttf-google-notosansmultani
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansmultani
pkgdesc="Google Fonts family: Noto Sans Multani"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Multani"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmultani/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmultani/NotoSansMultani-Regular.ttf"
)
sha256sums=(
  "a1b3ca46173087cac8b37010a23bd72edab3fd104ea8ef6cc0ff282078df52e4"
  "fe39d78a4f0acae8e5033ac59aa7af3f8664410c048a3b58b5d76ea44548c090"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
