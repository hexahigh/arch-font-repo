pkgname=ttf-google-opensans
pkgver=3.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/opensans
pkgdesc="Google Fonts family: Open Sans"
arch=('any')
url="https://fonts.google.com/specimen/Open+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/opensans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/opensans/OpenSans-Italic%5Bwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/opensans/OpenSans%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "fbbbcfef55318de350562559b671360de6d597112ecc5c73881b05092db89602"
  "fe269381e992f32e135801740998544d6235061e37c93ec067ad2be3edd5b17b"
  "36643644f318a812aab2d2ed3bb98f8cf0872527f835fe9398d95fe6b9adb878"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
