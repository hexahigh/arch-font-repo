pkgname=ttf-google-pollerone
pkgver=1.002
pkgrel=1
_commit="8cbb608f60730c6f439b7034d0c78b2fbed87ae1"  # Latest commit touching ofl/pollerone
pkgdesc="Google Fonts family: Poller One"
arch=('any')
url="https://fonts.google.com/specimen/Poller+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pollerone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pollerone/PollerOne.ttf"
)
sha256sums=(
  "de318dcb99e332a746edb9f83180ee206fc3bce74ff96ad7d1cb219967ec74af"
  "49c5128cb550156e9384453906b869b830aafacfc3a9332ccf989c8ed146d773"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
