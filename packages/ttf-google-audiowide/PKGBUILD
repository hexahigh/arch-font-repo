pkgname=ttf-google-audiowide
pkgver=1.003
pkgrel=1
_commit="531939b3ed365d0ee9d985c842062d25830c0ceb"  # Latest commit touching ofl/audiowide
pkgdesc="Google Fonts family: Audiowide"
arch=('any')
url="https://fonts.google.com/specimen/Audiowide"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/audiowide/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/audiowide/Audiowide-Regular.ttf"
)
sha256sums=(
  "4fe01b13ffb41faa8f030d84843a95dab32792dfeeca7c072abbfd3f4d6896ad"
  "c7c0f2b0f6fad8c623e31772ce79f94a4edb9321ffce9fce978ea892d20ae730"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
