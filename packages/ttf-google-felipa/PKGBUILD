pkgname=ttf-google-felipa
pkgver=1.001
pkgrel=1
_commit="ce74c68c93ee690652013c1ec4550c85b48fcee2"  # Latest commit touching ofl/felipa
pkgdesc="Google Fonts family: Felipa"
arch=('any')
url="https://fonts.google.com/specimen/Felipa"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/felipa/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/felipa/Felipa-Regular.ttf"
)
sha256sums=(
  "75c7ccf4f537a7a3ebbedd299c1d2542e13d3b27aaf76a0a2d9fa91a2a8fcd3a"
  "d3f07e2669e046acc1030139a4b08046d7eca87c0b477a8cc99ac1c46af84edc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
