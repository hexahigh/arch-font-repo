pkgname=ttf-google-arimo
pkgver=1.33
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching apache/arimo
pkgdesc="Google Fonts family: Arimo"
arch=('any')
url="https://fonts.google.com/specimen/Arimo"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/arimo/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/arimo/Arimo-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/apache/arimo/Arimo%5Bwght%5D.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "bd248f69d254987da54bdfe18d229c668a6734f5f098c5dbfd5873553935b89b"
  "c75270dfa8b5747c666d9e1915b8c9a6cb6e2de74d103cd0f6ee0104675a3604"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
