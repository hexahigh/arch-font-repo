pkgname=ttf-google-bayon
pkgver=8.001
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/bayon
pkgdesc="Google Fonts family: Bayon"
arch=('any')
url="https://fonts.google.com/specimen/Bayon"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bayon/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bayon/Bayon-Regular.ttf"
)
sha256sums=(
  "1fb43cb6d1df2ba95e6757c4abe9037c9736f87127aded80d41e7ba82119f488"
  "ffdeb7ad5ca1abd37631b0a637aaa1b2cd695f85e582f5c75ccce26bdaaf51b6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
