pkgname=ttf-google-herrvonmuellerhoff
pkgver=1.000
pkgrel=1
_commit="282027948c8010cc0edcb5d1b3481754e3cb9cc6"  # Latest commit touching ofl/herrvonmuellerhoff
pkgdesc="Google Fonts family: Herr Von Muellerhoff"
arch=('any')
url="https://fonts.google.com/specimen/Herr+Von+Muellerhoff"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/herrvonmuellerhoff/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/herrvonmuellerhoff/HerrVonMuellerhoff-Regular.ttf"
)
sha256sums=(
  "50265d2b41f8ad2dd350532d2286509aa694021b4aa0490b06f0068e4ed78c27"
  "ba8ac10807a79462b7c8265b2eebb8419e5017fdc1a5828b1a071d9e8478772e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
