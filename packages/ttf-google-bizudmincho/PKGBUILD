pkgname=ttf-google-bizudmincho
pkgver=1.06
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bizudmincho
pkgdesc="Google Fonts family: BIZ UDMincho"
arch=('any')
url="https://fonts.google.com/specimen/BIZ+UDMincho"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudmincho/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudmincho/BIZUDMincho-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudmincho/BIZUDMincho-Regular.ttf"
)
sha256sums=(
  "ef0ed524b3bd012f37015e986809eed6f67905456ebfc1ebd7fcc2765282ee01"
  "1f077f8f84c1e09d5c4acdd6828048180c2f733ae5ae13271f48cf01bee4ae83"
  "468ee6d9b149ca144809e03841bf18740ecf014e055a00da6ecaf1aaf4165af2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
