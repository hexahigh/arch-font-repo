pkgname=ttf-google-playwritegbjguides
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwritegbjguides
pkgdesc="Google Fonts family: Playwrite GB J Guides"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+GB+J+Guides"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbjguides/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbjguides/PlaywriteGBJGuides-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbjguides/PlaywriteGBJGuides-Regular.ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "f6741238e70ee582a1a28d97e271f1dc69fce769d12c8e4a126c4500c1e0b7b4"
  "b7be1f39971fd700acf9ef4e5c51d9412a3fc70af9e0efbfd5286ea88ea7b351"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
