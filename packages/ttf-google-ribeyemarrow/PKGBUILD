pkgname=ttf-google-ribeyemarrow
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/ribeyemarrow
pkgdesc="Google Fonts family: Ribeye Marrow"
arch=('any')
url="https://fonts.google.com/specimen/Ribeye+Marrow"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ribeyemarrow/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ribeyemarrow/RibeyeMarrow-Regular.ttf"
)
sha256sums=(
  "9acc45e5ba18b5b38868fad1f51c03df4f5d7a43061d46314843de45c4444233"
  "4b19d54b86a068bb5b8a060938d87d1e6028d566c8efb68fa9c7debaa19987d0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
