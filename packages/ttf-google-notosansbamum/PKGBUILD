pkgname=ttf-google-notosansbamum
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansbamum
pkgdesc="Google Fonts family: Noto Sans Bamum"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Bamum"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbamum/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbamum/NotoSansBamum%5Bwght%5D.ttf"
)
sha256sums=(
  "3dd4cce0a3d3405f7b690bc10bc2c78f2d2feb448c8f88b604bed2f33892d892"
  "ac9c498f2030192040e2c5541302ed428a81184ff4635faacd32417a58d83e53"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
