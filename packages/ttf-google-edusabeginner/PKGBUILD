pkgname=ttf-google-edusabeginner
pkgver=1.003
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/edusabeginner
pkgdesc="Google Fonts family: Edu SA Beginner"
arch=('any')
url="https://fonts.google.com/specimen/Edu+SA+Beginner"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/edusabeginner/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/edusabeginner/EduSABeginner[wght].ttf"
)
sha256sums=(
  "9c50bb9d2dbfd864553688da113bf817a294f3721b7a35ac6569c63bb939a998"
  "1ec0d8b4f3a6fda018079fa284570d2c4a3a514e3687d139b25b05dbb86c7ff4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
