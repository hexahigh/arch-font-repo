pkgname=ttf-google-notosanscaucasianalbanian
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanscaucasianalbanian
pkgdesc="Google Fonts family: Noto Sans Caucasian Albanian"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Caucasian+Albanian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscaucasianalbanian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscaucasianalbanian/NotoSansCaucasianAlbanian-Regular.ttf"
)
sha256sums=(
  "9fcb74e139ee491def8fd25fb9a651310594a0dd232616030fc8d304a7c9d0c0"
  "7d5a81e7f9f90eb1aaef9935b2c4d68b6300939a2df9dbb9472b38a4fbec50bc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
