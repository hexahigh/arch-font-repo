pkgname=ttf-google-geologica
pkgver=1.010
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/geologica
pkgdesc="Google Fonts family: Geologica"
arch=('any')
url="https://fonts.google.com/specimen/Geologica"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/geologica/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/geologica/Geologica%5BCRSV%2CSHRP%2Cslnt%2Cwght%5D.ttf"
)
sha256sums=(
  "778186245840aea0e60bec6a46e7fb1442e0cd78e41afeadffcd3e8824b379e0"
  "9124d9e88ac6c11d761f35241713a51d68e2c4ebedce0edaca834717a00959ec"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
