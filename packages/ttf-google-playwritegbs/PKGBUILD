pkgname=ttf-google-playwritegbs
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwritegbs
pkgdesc="Google Fonts family: Playwrite GB S"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+GB+S"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbs/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbs/PlaywriteGBS-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbs/PlaywriteGBS%5Bwght%5D.ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "9529eb87819fdf803a5d7e3e9c9d1d49ce85cf4f33a7ce1072acc3b4d55886b6"
  "563b1d961356f9116b550935f27b0cb55466ffba3b9176066a5d9d9ceda6753b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
