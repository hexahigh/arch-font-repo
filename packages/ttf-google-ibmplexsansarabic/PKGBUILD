pkgname=ttf-google-ibmplexsansarabic
pkgver=1.101
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/ibmplexsansarabic
pkgdesc="Google Fonts family: IBM Plex Sans Arabic"
arch=('any')
url="https://fonts.google.com/specimen/IBM+Plex+Sans+Arabic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
