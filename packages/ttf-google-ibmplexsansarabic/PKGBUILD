  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansarabic/IBMPlexSansArabic-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansarabic/IBMPlexSansArabic-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansarabic/IBMPlexSansArabic-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansarabic/IBMPlexSansArabic-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansarabic/IBMPlexSansArabic-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansarabic/IBMPlexSansArabic-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansarabic/IBMPlexSansArabic-Thin.ttf"
)
sha256sums=(
  "7e6b2818edbd8f6a01ae80641cc8f16a51080d08fb4e532be3a0b6f74adb07da"
  "691e0c891a38637ae6bbdb69700f8042cb0724a137bee615068ffdb92244f61f"
  "4d4137f37a1acd61f1b7eba47c08d0996789596b1e535f9220914ad5daf0a198"
  "0af9d1effbb36ff74d13c64f752c771ecb9162a451cf151c5425f4d00d4daa7c"
