pkgname=ttf-google-babylonica
pkgver=1.010
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/babylonica
pkgdesc="Google Fonts family: Babylonica"
arch=('any')
url="https://fonts.google.com/specimen/Babylonica"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/babylonica/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/babylonica/Babylonica-Regular.ttf"
)
sha256sums=(
  "213ab761dccc1d47421dd9b88c38b317f8cb35452655db4cf023886b78b76418"
  "d033b18ba66881e0f066ebc66b457944e0dc51e981f9be61c8365d4bcfdb165c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
