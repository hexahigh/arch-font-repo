pkgname=ttf-google-instrumentserif
pkgver=1.000
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/instrumentserif
pkgdesc="Google Fonts family: Instrument Serif"
arch=('any')
url="https://fonts.google.com/specimen/Instrument+Serif"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/instrumentserif/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/instrumentserif/InstrumentSerif-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/instrumentserif/InstrumentSerif-Regular.ttf"
)
sha256sums=(
  "129ed7618959716959f2941fdd5b49e0ad6e6c1d78726761786a00253d865521"
  "08939b8bdf534afec24ae0ef5e03f948940cd9a8fe08e7fecbad040e62327385"
  "498efd461f6ddfcb7a111bf9a565709d2085d48201d501ead960d93e84ffbb88"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
