pkgname=ttf-google-notosanshanunoo
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanshanunoo
pkgdesc="Google Fonts family: Noto Sans Hanunoo"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Hanunoo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanshanunoo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanshanunoo/NotoSansHanunoo-Regular.ttf"
)
sha256sums=(
  "1d243377ac4633a4b10bb66cc07695c8432e93a611433fb5e91a2009cbd2616f"
  "bdf8e293a79d753fcff1c3fdfc5e09fdfd8141cd08dbf2ac1268a24f4549a005"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
