pkgname=ttf-google-coralpixels
pkgver=1.000
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/coralpixels
pkgdesc="Google Fonts family: Coral Pixels"
arch=('any')
url="https://fonts.google.com/specimen/Coral+Pixels"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/coralpixels/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/coralpixels/CoralPixels-Regular.ttf"
)
sha256sums=(
  "448cab2c843116d91aaed166b50d8e05821ada22b94a7220b8422873390b9650"
  "c42dc4b002d50e1948beb761103631bf90a61878fa3e560699734091ad561540"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
