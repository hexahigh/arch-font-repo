pkgname=ttf-google-ysabeauinfant
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/ysabeauinfant
pkgdesc="Google Fonts family: Ysabeau Infant"
arch=('any')
url="https://fonts.google.com/specimen/Ysabeau+Infant"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ysabeauinfant/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ysabeauinfant/YsabeauInfant-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ysabeauinfant/YsabeauInfant%5Bwght%5D.ttf"
)
sha256sums=(
  "1343b9162a2d24f685767766ea23a75a80b88ba13ba421244e65b72210578b78"
  "1babfd11906d06d2ff9c4e1a26afd857e526f6059a7d4126eb4f5f8fbb04aa50"
  "3c0cfd9022bc445d9234a6dd697134476a86dfdd00e6ad58078c17b65587f984"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
