pkgname=ttf-google-portersansblock
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/portersansblock
pkgdesc="Google Fonts family: Porter Sans Block"
arch=('any')
url="https://fonts.google.com/specimen/Porter+Sans+Block"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/portersansblock/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/portersansblock/PorterSansBlock-Regular.ttf"
)
sha256sums=(
  "ac55580be2df22a06d29a47501e2ae11e1d399620f5a779e17a66f016ba6d5ff"
  "760943d1b089f37c8d079f3e0347e2b0858c8598894f2c04b7dc52cbd2ab4dfd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
