pkgname=ttf-google-headlandone
pkgver=1.002
pkgrel=1
_commit="42ea3a47d6548c2a6966a45ded23cfd01cd43293"  # Latest commit touching ofl/headlandone
pkgdesc="Google Fonts family: Headland One"
arch=('any')
url="https://fonts.google.com/specimen/Headland+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/headlandone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/headlandone/HeadlandOne-Regular.ttf"
)
sha256sums=(
  "7527e73a61f742a0dd050ab2fc7333de71ac7886023c100bca66a0a93b37498e"
  "b09ae2dd08b296e1e0d9af93f5c34899d6a04d6c57aff766409f8a96d085f3a4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
