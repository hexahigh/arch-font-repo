pkgname=ttf-google-qahiri
pkgver=3.00
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/qahiri
pkgdesc="Google Fonts family: Qahiri"
arch=('any')
url="https://fonts.google.com/specimen/Qahiri"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/qahiri/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/qahiri/Qahiri-Regular.ttf"
)
sha256sums=(
  "0f1071ef57cf3ed05972b47cc979ed6bb9ce323342f4a07dfd188e49efae3190"
  "68e31a245a8613d8b49d55f7ceffdd88b26f2abace2a9dd094a076d78f53a203"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
