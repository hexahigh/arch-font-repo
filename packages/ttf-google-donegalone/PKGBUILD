pkgname=ttf-google-donegalone
pkgver=1.004
pkgrel=1
_commit="d8c6d7dca2cc6cee6e7025cff5f016460f4c17e8"  # Latest commit touching ofl/donegalone
pkgdesc="Google Fonts family: Donegal One"
arch=('any')
url="https://fonts.google.com/specimen/Donegal+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/donegalone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/donegalone/DonegalOne-Regular.ttf"
)
sha256sums=(
  "8aa063e3a1299c5e1821f386f5ca8bc157ac561bd12c739ffa81c6f0821450c0"
  "1f9b07bbaf3813103281848f782fae74499f5dfc3b3b9f4e90ebea4aa42fbc75"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
