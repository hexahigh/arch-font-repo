pkgname=ttf-google-portlligatsans
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/portlligatsans
pkgdesc="Google Fonts family: Port Lligat Sans"
arch=('any')
url="https://fonts.google.com/specimen/Port+Lligat+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/portlligatsans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/portlligatsans/PortLligatSans-Regular.ttf"
)
sha256sums=(
  "021d5f1df697848da51620394659187be77cbe382ff2f896bc84ffb89c0c2d52"
  "89374c75b8b86c3634abb037997483708611cdd25faa3da9564bb68a9e162757"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
