pkgname=ttf-gluk-rawengulksans
pkgver=0.96
pkgrel=1
pkgdesc="RawengulkSans font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=RawengulkSans'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/rawengulksans/RawengulkSans_096.zip")
sha256sums=('a45b5bd46fabbe1b31c7241f9e6e2490a46ffa2e1242ab65dbb62270ab271253')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=RawengulkSans
License info from upstream page: OpenFontLicense
EOF
}
