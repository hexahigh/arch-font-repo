pkgname=ttf-google-sansation
pkgver=1.301
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sansation
pkgdesc="Google Fonts family: Sansation"
arch=('any')
url="https://fonts.google.com/specimen/Sansation"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sansation/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sansation/Sansation-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sansation/Sansation-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sansation/Sansation-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sansation/Sansation-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sansation/Sansation-LightItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sansation/Sansation-Regular.ttf"
)
sha256sums=(
  "156ea6985861158c7dea63ecaac4c78ab0ed737d168ddffc3e34c687985a033b"
  "8ec74c9628179ed95d075440ba4d01091f800ca9be045ddc25982bd8bc21afff"
  "428eb2f11e1b12c55505bc5aaf0579e7354391207df474d88f44517df7d48709"
  "df79f59618325d890aa611ff8742e313b1bcf0a5afc612b4be2f9d870742dc57"
  "ef7798f2d0a3435797793ac8b703bd3131e5a5b1ec5ccbd15f397f11a6ce1811"
  "96eef3afab26a9a018415da577c71dbceaae48f9f4b2ab26f0f7d412c1dd08d1"
  "6d47039ee6665d78b143a1b264abc02017a33ffa52a4e9f6645ce357f92d4f09"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
