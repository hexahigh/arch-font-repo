pkgname=ttf-google-belleza
pkgver=1.003
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/belleza
pkgdesc="Google Fonts family: Belleza"
arch=('any')
url="https://fonts.google.com/specimen/Belleza"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/belleza/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/belleza/Belleza-Regular.ttf"
)
sha256sums=(
  "355326d5707ff94ffe27711c7ae26217b63e93de6d5b3413292174fda5f5f9d8"
  "a88eb0fdf4e78687a40d3478e1c90d4d3079e8c0d7d3a2452488a3ba805bff1d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
