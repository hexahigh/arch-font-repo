pkgname=ttf-google-epilogue
pkgver=2.112
pkgrel=1
_commit="5e3449fddeb8ff7f383e64b384f330f94d3443c8"  # Latest commit touching ofl/epilogue
pkgdesc="Google Fonts family: Epilogue"
arch=('any')
url="https://fonts.google.com/specimen/Epilogue"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/epilogue/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/epilogue/Epilogue-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/epilogue/Epilogue[wght].ttf"
)
sha256sums=(
  "95ebd6a2e4035b8398c83928fb85297b48441f27f405398c29b59aae899fc747"
  "7e5263bfe5b8ea9d46201fc3e3d59c354628de2220c3f3fe831fad946a1f7db2"
  "012f651b45f47c10c7714cb7e3f2f7d9ccb7f235a2cc72c6b273ddc735705c67"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
