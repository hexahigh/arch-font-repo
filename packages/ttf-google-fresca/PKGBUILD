pkgname=ttf-google-fresca
pkgver=1.001
pkgrel=1
_commit="acd9f0f3fe988d4ef7b041cc2c0ee53573673a8d"  # Latest commit touching ofl/fresca
pkgdesc="Google Fonts family: Fresca"
arch=('any')
url="https://fonts.google.com/specimen/Fresca"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/fresca/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/fresca/Fresca-Regular.ttf"
)
sha256sums=(
  "a40c3a6d0c968d3a10b17a2614606de6f20178deccc2447305f31fb106a57fb0"
  "f64340016a820093202ca6af533f232ee7fe4c3d8448601ac42b4091236b5777"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
