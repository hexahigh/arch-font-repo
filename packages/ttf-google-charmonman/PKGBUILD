pkgname=ttf-google-charmonman
pkgver=1.000
pkgrel=1
_commit="e16ddbbf770f7b7a3e7ef03d361b7e1c66a144f8"  # Latest commit touching ofl/charmonman
pkgdesc="Google Fonts family: Charmonman"
arch=('any')
url="https://fonts.google.com/specimen/Charmonman"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/charmonman/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/charmonman/Charmonman-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/charmonman/Charmonman-Regular.ttf"
)
sha256sums=(
  "23b896f4937eac954a383340c92dfcac1c6e05ec21cc08ec6de47d30ad8496a3"
  "8bf4f82298997010662de35cec504c0504456e51d3d9a9a6b4f3788e4b04abee"
  "7ec5575c6c87a6be69de7839b3ecd1027b7ba6510ad3e49bc30b73cc9ee1bce0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
