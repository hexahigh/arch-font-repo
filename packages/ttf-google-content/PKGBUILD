pkgname=ttf-google-content
pkgver=6.00
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/content
pkgdesc="Google Fonts family: Content"
arch=('any')
url="https://fonts.google.com/specimen/Content"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/content/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/content/Content-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/content/Content-Regular.ttf"
)
sha256sums=(
  "08a12877eda24767239f26b527bfce0c515efaf623c66da6baad92a6d5315e9a"
  "3242d6b22201e6919c784a6d95d0284bc36ef6b38785fe002a8cfab18a3f841f"
  "b470db9d4ce6147203ff917c3ebadf3d31ebc78801a35aac4f7c090bf9b67802"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
