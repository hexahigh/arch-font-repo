pkgname=ttf-google-bokor
pkgver=8.002
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bokor
pkgdesc="Google Fonts family: Bokor"
arch=('any')
url="https://fonts.google.com/specimen/Bokor"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bokor/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bokor/Bokor-Regular.ttf"
)
sha256sums=(
  "3793a376255d457c0571e009846e92b4fca702756e6f28d43b54e71bff40e380"
  "640d475abdd109bfd80d2eef892fe1c63d3ec0faddcd15f819c5f1729712c370"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
