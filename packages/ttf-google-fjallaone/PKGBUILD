pkgname=ttf-google-fjallaone
pkgver=1.002
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/fjallaone
pkgdesc="Google Fonts family: Fjalla One"
arch=('any')
url="https://fonts.google.com/specimen/Fjalla+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/fjallaone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/fjallaone/FjallaOne-Regular.ttf"
)
sha256sums=(
  "047c204476dacfeddbf93d33ab3d43ba82fb7e66e398fdacfce8e815e9a5c270"
  "ce3b299625abe3c76f8acd235b57b3e07ac6ee2d550e106a4b4e4d60095ae2ba"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
