pkgname=ttf-google-cormorantgaramond
pkgver=4.001
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/cormorantgaramond
pkgdesc="Google Fonts family: Cormorant Garamond"
arch=('any')
url="https://fonts.google.com/specimen/Cormorant+Garamond"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cormorantgaramond/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cormorantgaramond/CormorantGaramond-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/cormorantgaramond/CormorantGaramond%5Bwght%5D.ttf"
)
sha256sums=(
  "60700d351cac4650c51f3f9db318d2a420f8b45052dba2715eb5fec41f0f6956"
  "0f48ea6abb2084537854f7174c470991a463b13036309e3b50a81511611c530d"
  "b20b7d9626dd956b2c5e558692ad328b1f19e3275e2782db4fa07670d83f35e0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
