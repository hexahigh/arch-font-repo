pkgname=ttf-google-ephesis
pkgver=1.010
pkgrel=1
_commit="1796e34455b893092713d206e7f23e3e07699f00"  # Latest commit touching ofl/ephesis
pkgdesc="Google Fonts family: Ephesis"
arch=('any')
url="https://fonts.google.com/specimen/Ephesis"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ephesis/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ephesis/Ephesis-Regular.ttf"
)
sha256sums=(
  "6160853a95e0826f3d9dd21d26b7518b86e50a3469f19a62c3f4ce1ab1ed5573"
  "8fb4729a918f992a37ab45f1466783c78ea8caa77a7b0e69545322e1dbe9c5f9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
