pkgname=ttf-google-licorice
pkgver=1.010
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/licorice
pkgdesc="Google Fonts family: Licorice"
arch=('any')
url="https://fonts.google.com/specimen/Licorice"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/licorice/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/licorice/Licorice-Regular.ttf"
)
sha256sums=(
  "5ee90951ba3cf079b5c79ec17029e073a72bea1ca08f03ee4b289773a5744ddd"
  "c72d8cb2f56e6995b3682d8620e2d602bacf78b67121cdfbface9acc422750d8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
