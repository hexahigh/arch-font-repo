pkgname=ttf-google-ewert
pkgver=1.001
pkgrel=1
_commit="1ccd9945047e4f526e2da47089438d73a35f0c2a"  # Latest commit touching ofl/ewert
pkgdesc="Google Fonts family: Ewert"
arch=('any')
url="https://fonts.google.com/specimen/Ewert"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ewert/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ewert/Ewert-Regular.ttf"
)
sha256sums=(
  "9bc1eb1c679510b32d2e3f5f4f3b47726b1657aa121494aa68ba0b124a3c3a53"
  "8a7eb23adce5193b61bc1843d752f37c208c163dd6db2fc1b64791791969f4ab"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
