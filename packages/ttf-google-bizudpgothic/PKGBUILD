pkgname=ttf-google-bizudpgothic
pkgver=1.051
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bizudpgothic
pkgdesc="Google Fonts family: BIZ UDPGothic"
arch=('any')
url="https://fonts.google.com/specimen/BIZ+UDPGothic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudpgothic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudpgothic/BIZUDPGothic-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudpgothic/BIZUDPGothic-Regular.ttf"
)
sha256sums=(
  "e753d7155d53c747d037a445e584c8ecfca6dd79846db610417e282a736b28bc"
  "30eba52fc837e8b62c97d4b82e6706583149fb7294e3712dd71a655eaea80a90"
  "258d7156c165f2ff774b6efee637c22c3b950de0d8a10e501137061bc8085d01"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
