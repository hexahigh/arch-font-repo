pkgname=ttf-gluk-odstemplik
pkgver=0.70
pkgrel=1
pkgdesc="Odstemplik font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Odstemplik'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/odstemplik/odstemplik-070-otf.zip")
sha256sums=('a2bf0a2e7ec194d686c9c80c865f235b9ccdd13f9f86085ccec10f07f3932ddc')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Odstemplik
License info from upstream page: OpenFontLicense
EOF
}
