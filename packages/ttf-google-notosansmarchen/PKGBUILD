pkgname=ttf-google-notosansmarchen
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansmarchen
pkgdesc="Google Fonts family: Noto Sans Marchen"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Marchen"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmarchen/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmarchen/NotoSansMarchen-Regular.ttf"
)
sha256sums=(
  "ff6916cdb42ea52dd0aeb275043ed78367e1aab5a82d2c426446ee1557f7fd7a"
  "6c8ecfbf4e0b5926ebee810be293c1018f921577b2f6dff22e19ec0a596c7ce3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
