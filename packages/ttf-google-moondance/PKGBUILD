pkgname=ttf-google-moondance
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/moondance
pkgdesc="Google Fonts family: Moon Dance"
arch=('any')
url="https://fonts.google.com/specimen/Moon+Dance"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/moondance/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/moondance/MoonDance-Regular.ttf"
)
sha256sums=(
  "8e032df9af3acefbcf2c02d5a868ecaf2233005014bdb00caba05c14dd279be5"
  "f25e6830b0c1b95df85446fc064cc0bc8db1588600a260a441b03011189e8335"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
