pkgname=ttf-google-bilbo
pkgver=1.100
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/bilbo
pkgdesc="Google Fonts family: Bilbo"
arch=('any')
url="https://fonts.google.com/specimen/Bilbo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bilbo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bilbo/Bilbo-Regular.ttf"
)
sha256sums=(
  "89ccbb54444cd2fa0ee25cceb2e67d3453d56250a561bd176983b169cdaf47bf"
  "f479505c839db0c7a8be7108d046acca3d409a034b777514241cc6a2f9d818fc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
