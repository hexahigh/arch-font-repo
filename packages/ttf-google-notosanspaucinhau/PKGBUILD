pkgname=ttf-google-notosanspaucinhau
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanspaucinhau
pkgdesc="Google Fonts family: Noto Sans Pau Cin Hau"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Pau+Cin+Hau"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanspaucinhau/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanspaucinhau/NotoSansPauCinHau-Regular.ttf"
)
sha256sums=(
  "ab62d184e7353d161ddea97e3aa400f9251a653b055dd5b030b07fede3bb546e"
  "148f6ad11e71c58a4c557af7f492a6478b3e96700202a62e7013dd7031057a83"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
