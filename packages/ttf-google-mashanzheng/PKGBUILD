pkgname=ttf-google-mashanzheng
pkgver=2.002
pkgrel=1
_commit="4e5f06dbb274a27ebe71ed54ea706b3ee40eabd9"  # Latest commit touching ofl/mashanzheng
pkgdesc="Google Fonts family: Ma Shan Zheng"
arch=('any')
url="https://fonts.google.com/specimen/Ma+Shan+Zheng"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mashanzheng/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mashanzheng/MaShanZheng-Regular.ttf"
)
sha256sums=(
  "d7bdb1cee215b689e23c2f95672a6084c790542170648267a55114103d756a08"
  "b844c59bf20bf530e41c20d6ff12b383b23a2e553b9b68cc89f070869213155d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
