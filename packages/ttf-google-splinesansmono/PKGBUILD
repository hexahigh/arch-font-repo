pkgname=ttf-google-splinesansmono
pkgver=1.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/splinesansmono
pkgdesc="Google Fonts family: Spline Sans Mono"
arch=('any')
url="https://fonts.google.com/specimen/Spline+Sans+Mono"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/splinesansmono/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/splinesansmono/SplineSansMono-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/splinesansmono/SplineSansMono[wght].ttf"
)
sha256sums=(
  "4abb88162e4c0c5f9fc6c2f15d7085f7b7e27fd89f541a13488e1bcb829bde3f"
  "073f111f37a86cc6d952b7870b3c1aebbfc78f4056dd3996db28bbc7166667a6"
  "e20c1df32aa2f886e828cfcc81ca5c405d3f3b160990f6b892923e2e449bf525"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
