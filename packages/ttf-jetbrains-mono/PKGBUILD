pkgname=ttf-jetbrains-mono
pkgver=2.304
pkgrel=1
pkgdesc="JetBrains Mono font family (all upstream TTF/OTF variants)"
arch=('any')
url='https://github.com/JetBrains/JetBrainsMono'
license=('custom:OFL')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://github.com/JetBrains/JetBrainsMono/releases/download/v${pkgver}/JetBrainsMono-${pkgver}.zip")
sha256sums=('6f6376c6ed2960ea8a963cd7387ec9d76e3f629125bc33d1fdcd7eb7012f7bbf')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Include all shipped OpenType and TrueType families from upstream.
  find "${srcdir}" -type f \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  while IFS= read -r -d '' license_file; do
    install -Dm644 "${license_file}" "${pkgdir}/usr/share/licenses/${pkgname}/$(basename "${license_file}")"
  done < <(find "${srcdir}" -type f \( -iname 'OFL*' -o -iname 'LICENSE*' \) -print0)
}
