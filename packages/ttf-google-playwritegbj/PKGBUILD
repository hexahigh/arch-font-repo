pkgname=ttf-google-playwritegbj
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwritegbj
pkgdesc="Google Fonts family: Playwrite GB J"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+GB+J"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbj/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbj/PlaywriteGBJ-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritegbj/PlaywriteGBJ%5Bwght%5D.ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "704b51bfa0fdb0a4d4c1514d377c70a986a81577e8df7ce907dc0b4d80457f65"
  "75263adf472a717edc4d7d10ea28016591928c98f2cd5da93b0269ef4a919fc9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
