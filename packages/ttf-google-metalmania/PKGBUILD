pkgname=ttf-google-metalmania
pkgver=1.002
pkgrel=1
_commit="b392a58e335dbda983fd21ccc491ea1919633374"  # Latest commit touching ofl/metalmania
pkgdesc="Google Fonts family: Metal Mania"
arch=('any')
url="https://fonts.google.com/specimen/Metal+Mania"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/metalmania/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/metalmania/MetalMania-Regular.ttf"
)
sha256sums=(
  "4e66943af352059c059dd658774f25fbc831f1ad478f9f0890c06ecc2dd324c7"
  "4b95f0e55b291990c26a7b68818b20c1b728a8be05a34982b7bb4736c46c19ea"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
