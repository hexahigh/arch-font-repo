pkgname=ttf-google-jomhuria
pkgver=1.0010
pkgrel=1
_commit="140ceb885c1753316b534fc1ffbffb53baf2310c"  # Latest commit touching ofl/jomhuria
pkgdesc="Google Fonts family: Jomhuria"
arch=('any')
url="https://fonts.google.com/specimen/Jomhuria"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/jomhuria/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/jomhuria/Jomhuria-Regular.ttf"
)
sha256sums=(
  "ca64dee162bf239c7b92d854d388bcd30552edc3ae1ef5e31714acda34c988db"
  "17b4b0453acdaafb940a8be8acccc968713e223e5d03942347f6562ca3b1dec3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
