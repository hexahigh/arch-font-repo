pkgname=ttf-google-notosanscarian
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanscarian
pkgdesc="Google Fonts family: Noto Sans Carian"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Carian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscarian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscarian/NotoSansCarian-Regular.ttf"
)
sha256sums=(
  "8d161a6467a3b032c852f311d23a8df336d2152ca9e4b236c8b6e2ed49199068"
  "73f83bf71bac6046bd409f42706cd5e3706bce4521150302be3010ef6a161ecd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
