pkgname=ttf-google-geostarfill
pkgver=1.002
pkgrel=1
_commit="662da72d1e17bab7c4624af47d1026d19848e6e6"  # Latest commit touching ofl/geostarfill
pkgdesc="Google Fonts family: Geostar Fill"
arch=('any')
url="https://fonts.google.com/specimen/Geostar+Fill"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/geostarfill/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/geostarfill/GeostarFill-Regular.ttf"
)
sha256sums=(
  "013e33b6b2919fd0ffbdde6080a1c0f4521689fdce0f4876a59cf49ff8ae31c0"
  "f09acdc20fa02f320e97046f618cb5e424d12d97a19d4746f05ea15371de12a8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
