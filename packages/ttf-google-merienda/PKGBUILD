pkgname=ttf-google-merienda
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/merienda
pkgdesc="Google Fonts family: Merienda"
arch=('any')
url="https://fonts.google.com/specimen/Merienda"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/merienda/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/merienda/Merienda[wght].ttf"
)
sha256sums=(
  "61470db03bfdf0616932a086346acf8eddaddbdffbac9c468f0d88ac72ccb151"
  "a91e4d88a50b4f80c7b1f31fe46e376eb87b72247d2a216f5e5be1881340deea"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
