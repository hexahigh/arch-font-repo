pkgname=ttf-google-voltaire
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/voltaire
pkgdesc="Google Fonts family: Voltaire"
arch=('any')
url="https://fonts.google.com/specimen/Voltaire"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/voltaire/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/voltaire/Voltaire-Regular.ttf"
)
sha256sums=(
  "ca6e7179764b1dd8880ee0ee838ed9aed2b3f9da7c1c4d1b619961a9c45462cb"
  "f46e955318c841722e8b7c9dfff1c9bccfe4c94ab69c00d7ea68c6f81d2e615e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
