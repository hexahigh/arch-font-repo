pkgname=ttf-google-kantumruypro
pkgver=1.002
pkgrel=1
_commit="130fcfb0ff422fec96b335616b2ca99f91914792"  # Latest commit touching ofl/kantumruypro
pkgdesc="Google Fonts family: Kantumruy Pro"
arch=('any')
url="https://fonts.google.com/specimen/Kantumruy+Pro"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/kantumruypro/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/kantumruypro/KantumruyPro-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/kantumruypro/KantumruyPro[wght].ttf"
)
sha256sums=(
  "7b300b8a1e2e9d7cddb68859551f1ad54a05019eff28da02e3be811c1257f0a7"
  "79912e0f9a6c77680bf320633ada1d8a4b01f2e70ed9f26a799223293914d4b0"
  "613bc1b1ca4e26f5f8ac98d223b76f5ed0cb79e7c3fa6558c2bd6929efe043ae"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
