pkgname=ttf-gluk-qumpellkano12
pkgver=0.49
pkgrel=1
pkgdesc="QumpellkaNo12 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=QumpellkaNo12'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/qumpellkaNo12/QumpellkaNo12-049.zip")
sha256sums=('9dd8cc0c3ecf5e72842377999a3bd3e41a6ad04132ab85f31803f37130e66be5')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=QumpellkaNo12
License info from upstream page: OpenFontLicense
EOF
}
