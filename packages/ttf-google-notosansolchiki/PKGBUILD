pkgname=ttf-google-notosansolchiki
pkgver=2.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansolchiki
pkgdesc="Google Fonts family: Noto Sans Ol Chiki"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Ol+Chiki"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansolchiki/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansolchiki/NotoSansOlChiki[wght].ttf"
)
sha256sums=(
  "b30754bbe6bea30b666a60d513ae80435a197979c9500e8380f83acd99dc763b"
  "c9c31988656f49eccec9588825ab3b5045099c2f850ef98f356f976e8a596b4d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
