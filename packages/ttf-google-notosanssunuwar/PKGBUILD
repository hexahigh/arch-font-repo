pkgname=ttf-google-notosanssunuwar
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssunuwar
pkgdesc="Google Fonts family: Noto Sans Sunuwar"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Sunuwar"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssunuwar/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssunuwar/NotoSansSunuwar-Regular.ttf"
)
sha256sums=(
  "985d2180d93a7ae74cf81296d22bf2ddb1851d8ef35a200e0fd406ac188b1501"
  "332bbbcbb64c42ccc0a1b79dfd557b47aa3bd88a8ffab1417dd2f6989ad67f4d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
