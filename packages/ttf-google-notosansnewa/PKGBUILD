pkgname=ttf-google-notosansnewa
pkgver=2.007
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansnewa
pkgdesc="Google Fonts family: Noto Sans Newa"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Newa"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnewa/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnewa/NotoSansNewa-Regular.ttf"
)
sha256sums=(
  "39b6d4531cfac5e6004bf5f34668bf1ce50ef3b1f2cbe0b2ecc432949a45c6dd"
  "5a67f2e2a94eb493076dbb708a91ee4d48cd204c608f531077ad7c624b524e9e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
