pkgname=ttf-gluk-agreloy
pkgver=0.27
pkgrel=1
pkgdesc="Agreloy font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Agreloy'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Agreloy/Agreloy_027.zip")
sha256sums=('8054f419025e83dc21b5ea6ee685993ae6a8997b054f3e2f351750c7abe3db38')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Agreloy
License info from upstream page: OpenFontLicense
EOF
}
