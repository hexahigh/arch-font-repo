pkgname=ttf-google-bitcountpropsingle
pkgver=1.0
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bitcountpropsingle
pkgdesc="Google Fonts family: Bitcount Prop Single"
arch=('any')
url="https://fonts.google.com/specimen/Bitcount+Prop+Single"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bitcountpropsingle/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bitcountpropsingle/BitcountPropSingle[CRSV,ELSH,ELXP,slnt,wght].ttf"
)
sha256sums=(
  "061dfb7681d7fff942e04f5217c40e05d2fe5a3cea6001222039fea4b0432254"
  "e6f39bb11077484a1becaf94b712331b5c2d169a27b4a4591f6ab70c901a8405"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
