pkgname=ttf-google-notosanscham
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanscham
pkgdesc="Google Fonts family: Noto Sans Cham"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Cham"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscham/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscham/NotoSansCham%5Bwght%5D.ttf"
)
sha256sums=(
  "dcbc971844d8db052a5fe3adfb8bce4e56788986fee96f9c7bfbf56ef519b9c9"
  "0b4db93cffadd22de4668cdf8238725f0eedf5c2fcbf89a36bb24ccc82a1d889"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
