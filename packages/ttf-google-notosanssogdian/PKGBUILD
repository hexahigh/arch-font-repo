pkgname=ttf-google-notosanssogdian
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssogdian
pkgdesc="Google Fonts family: Noto Sans Sogdian"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Sogdian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssogdian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssogdian/NotoSansSogdian-Regular.ttf"
)
sha256sums=(
  "ade8e858dd1b48cae4781855440ae9ba83358a7f4f1ac8eadfb0ad90644b1775"
  "e1575de303408101b8c8a6f1a812936b2b2e2eab5d9cab6b1926883f3fd73642"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
