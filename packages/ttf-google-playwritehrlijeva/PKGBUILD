pkgname=ttf-google-playwritehrlijeva
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwritehrlijeva
pkgdesc="Google Fonts family: Playwrite HR Lijeva"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+HR+Lijeva"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritehrlijeva/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritehrlijeva/PlaywriteHRLijeva%5Bwght%5D.ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "bc2bca64bcbbf7630d27ae3f5641a86ee8bb8432dd8f3023e87ce4857d2c3a81"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
