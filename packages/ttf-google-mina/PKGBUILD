pkgname=ttf-google-mina
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mina
pkgdesc="Google Fonts family: Mina"
arch=('any')
url="https://fonts.google.com/specimen/Mina"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mina/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mina/Mina-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mina/Mina-Regular.ttf"
)
sha256sums=(
  "d2875ded3e44e9ae53ea2b35e825dafffa19e82c5d14addb9f1150fcd7a3463d"
  "eb125869e00d5e2fa33baa03344923141f31a5f10e1ae3fa65143cb2739fc318"
  "1ca8f5fb637e21fd6ce7cd4cc230b7284a90524ce93a696b838bbe3edd25ab7c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
