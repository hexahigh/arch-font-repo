pkgname=ttf-google-averiagruesalibre
pkgver=1.002
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/averiagruesalibre
pkgdesc="Google Fonts family: Averia Gruesa Libre"
arch=('any')
url="https://fonts.google.com/specimen/Averia+Gruesa+Libre"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/averiagruesalibre/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/averiagruesalibre/AveriaGruesaLibre-Regular.ttf"
)
sha256sums=(
  "46239ba6485d28553fd944da4ad32a00d9c403aa1c3e111676b0b96fe458d1d4"
  "df080c6c99c694b3d741835957e4ebc37d640a9c54f4079ceb8c7211e3f2e209"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
