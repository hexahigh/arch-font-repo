pkgname=ttf-google-notosansoldnortharabian
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansoldnortharabian
pkgdesc="Google Fonts family: Noto Sans Old North Arabian"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Old+North+Arabian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoldnortharabian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoldnortharabian/NotoSansOldNorthArabian-Regular.ttf"
)
sha256sums=(
  "5f57555b16c41ca7ff067efefdb3eadfcb601d3d96263f5ba13ac017c770dc1b"
  "27e42ee27587eda9c2521650cca938d4b247e00d55603b0abab0789c2eb2cccb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
