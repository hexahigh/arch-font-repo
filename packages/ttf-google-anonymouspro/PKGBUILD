pkgname=ttf-google-anonymouspro
pkgver=1.003
pkgrel=1
_commit="b77cf8eb320760982c6486bb65ef1031e3d7aeba"  # Latest commit touching ofl/anonymouspro
pkgdesc="Google Fonts family: Anonymous Pro"
arch=('any')
url="https://fonts.google.com/specimen/Anonymous+Pro"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/anonymouspro/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/anonymouspro/AnonymousPro-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/anonymouspro/AnonymousPro-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/anonymouspro/AnonymousPro-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/anonymouspro/AnonymousPro-Regular.ttf"
)
sha256sums=(
  "8594350034ab1cb85a1946ef8852e69290255816c311450a66fed6eeda9d6292"
  "52895657e7d48860089ebfac63a27244f37a2218ec9c5019a0b37fe885c0fc0c"
  "4e811e1e3b60fc763fb24acd27781e72241a8380beb0ffa5e07af2b87133496d"
  "bc13ac34e9994128c61b54bf4e78a8adb439b543ea0b19761d159342599f441a"
  "46d8b9a5f4b38fc9d30f3cdd676d4c6f78a9bef949bb1a8304216cc731eb87f8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
