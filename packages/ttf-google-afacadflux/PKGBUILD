pkgname=ttf-google-afacadflux
pkgver=1.100
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/afacadflux
pkgdesc="Google Fonts family: Afacad Flux"
arch=('any')
url="https://fonts.google.com/specimen/Afacad+Flux"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/afacadflux/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/afacadflux/AfacadFlux[slnt,wght].ttf"
)
sha256sums=(
  "992be51252f484e260e4f84356dc0e87c3e458619b16d098c76b26ef5c5ab0fb"
  "28aa3569ad95f7f7b363890085ad231aad280b3f7f73d37bf6d80285189ea636"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
