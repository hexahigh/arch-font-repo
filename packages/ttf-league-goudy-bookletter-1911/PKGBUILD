pkgname=ttf-league-goudy-bookletter-1911
pkgver=20240219
pkgrel=1
pkgdesc="The League of Moveable Type family: goudy-bookletter-1911"
arch=('any')
url='https://github.com/theleagueof/goudy-bookletter-1911'
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=("https://github.com/theleagueof/goudy-bookletter-1911/archive/85ff5b834b4f63feb36fd2053949c19660580e48.tar.gz")
sha256sums=("cdbaaad32bb6597dd1b3c216c7f25d15ca89979e806c4925f6a27d81d7845b7c")

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped OpenType/TrueType font binaries from the repository archive.
  find "${srcdir}" -type f \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  license_file="$(find "${srcdir}" -type f \( -iname 'OFL*' -o -iname 'LICENSE*' \) | head -n 1)"
  if [[ -n "${license_file}" ]]; then
    install -Dm644 "${license_file}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  fi
}
