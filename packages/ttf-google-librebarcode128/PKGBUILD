pkgname=ttf-google-librebarcode128
pkgver=1.005
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/librebarcode128
pkgdesc="Google Fonts family: Libre Barcode 128"
arch=('any')
url="https://fonts.google.com/specimen/Libre+Barcode+128"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/librebarcode128/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/librebarcode128/LibreBarcode128-Regular.ttf"
)
sha256sums=(
  "a4b7ccd1bda3269afba7d6d9293a7161e699d2f4f1f280dd8a8535c569388de9"
  "bece6b8695cf29f04ce1c706f0f508a65545f3b6240a03cef302b70f846630a7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
