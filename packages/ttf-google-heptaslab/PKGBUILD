pkgname=ttf-google-heptaslab
pkgver=1.102
pkgrel=1
_commit="0283aa90b099ad0cbd7b57b1afc08077a114fe62"  # Latest commit touching ofl/heptaslab
pkgdesc="Google Fonts family: Hepta Slab"
arch=('any')
url="https://fonts.google.com/specimen/Hepta+Slab"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/heptaslab/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/heptaslab/HeptaSlab[wght].ttf"
)
sha256sums=(
  "66f19a3655694659983eab355b8833b54e17d34f653d5ae5b86cb90c0550a4de"
  "737badc7944d5b6f92c05919995240d6ea70e86bebe45d196e61677e7a901f29"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
