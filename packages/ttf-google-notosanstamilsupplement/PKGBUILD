pkgname=ttf-google-notosanstamilsupplement
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanstamilsupplement
pkgdesc="Google Fonts family: Noto Sans Tamil Supplement"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Tamil+Supplement"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstamilsupplement/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstamilsupplement/NotoSansTamilSupplement-Regular.ttf"
)
sha256sums=(
  "f8ff8ce7d0a81bf8d5e121c635ef027250c531f2fd37d5988b8dd6e45f19d7f1"
  "321ef3c69cd8b3859420164820f316f245772ab24a587ac35f484a7e18760071"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
