pkgname=ttf-google-gulim
pkgver=2.21
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/gulim
pkgdesc="Google Fonts family: Gulim"
arch=('any')
url="https://fonts.google.com/specimen/Gulim"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gulim/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gulim/Gulim-Regular.ttf"
)
sha256sums=(
  "59fc225e9c23417ad83070289cd77814937c72fe7c65e72aaff13e5114957988"
  "a435857b8ffe2102f8faa7cf098d0d48b1d01d951c1c8326770848203bb7b5c2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
