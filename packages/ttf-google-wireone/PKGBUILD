pkgname=ttf-google-wireone
pkgver=1.102
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/wireone
pkgdesc="Google Fonts family: Wire One"
arch=('any')
url="https://fonts.google.com/specimen/Wire+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/wireone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/wireone/WireOne-Regular.ttf"
)
sha256sums=(
  "87b05b85d41a2de76f04dd8efd0f5781db8a498556a6c5d320478903e2329b32"
  "d505059c3c094b921358db3e41be899789edf4c4aec1ec777be1643efcd9fc05"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
