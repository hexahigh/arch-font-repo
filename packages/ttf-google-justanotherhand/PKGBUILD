pkgname=ttf-google-justanotherhand
pkgver=1.001
pkgrel=1
_commit="9bd941c4194f760ad356a38cade454f4e9423c6d"  # Latest commit touching apache/justanotherhand
pkgdesc="Google Fonts family: Just Another Hand"
arch=('any')
url="https://fonts.google.com/specimen/Just+Another+Hand"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/justanotherhand/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/justanotherhand/JustAnotherHand-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "f1cd102ebacdb6388c879c9d481d63908ee0d5939a301415a78cdfdc752f79ea"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
