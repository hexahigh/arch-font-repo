pkgname=ttf-google-b612
pkgver=1.008
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/b612
pkgdesc="Google Fonts family: B612"
arch=('any')
url="https://fonts.google.com/specimen/B612"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/b612/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/b612/B612-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/b612/B612-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/b612/B612-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/b612/B612-Regular.ttf"
)
sha256sums=(
  "a815f65bc72d90494b01842d3171f7cb0f9f935e023d9cc260904d221ef1064a"
  "91749541ac7b2c328b58832b7e2c4df809d7e2ba38d62a3a5aa3f8e38b271814"
  "5911fe0ae69264fb74b2956fc66c616580cd392b47f29335fa68ce5db47a4d2f"
  "57fd8a0d3c8baf066f21c0a3034af277887a0b17b8c18cbbcc1c642640dd149f"
  "139dce659100a83bf95b48474696e448bee95631ef84fd3d0437ced2bf33cf73"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
