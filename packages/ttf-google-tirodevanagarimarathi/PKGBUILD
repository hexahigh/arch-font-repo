pkgname=ttf-google-tirodevanagarimarathi
pkgver=1.52
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/tirodevanagarimarathi
pkgdesc="Google Fonts family: Tiro Devanagari Marathi"
arch=('any')
url="https://fonts.google.com/specimen/Tiro+Devanagari+Marathi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/tirodevanagarimarathi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/tirodevanagarimarathi/TiroDevanagariMarathi-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/tirodevanagarimarathi/TiroDevanagariMarathi-Regular.ttf"
)
sha256sums=(
  "2ed6051706542c5d6d96480318152b17900bb6d4dbadb11d7d5d6464d8b3e0dd"
  "ffa2383d457e468db75775cf19910a4817c3e250da6cfa28a3c6994954ab7d4c"
  "8e1d4edf924c0685f1383d0d37aa7c4662103d2e485e53b535b4528af5acd966"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
