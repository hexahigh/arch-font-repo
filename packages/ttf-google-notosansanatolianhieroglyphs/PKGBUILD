pkgname=ttf-google-notosansanatolianhieroglyphs
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansanatolianhieroglyphs
pkgdesc="Google Fonts family: Noto Sans Anatolian Hieroglyphs"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Anatolian+Hieroglyphs"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansanatolianhieroglyphs/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansanatolianhieroglyphs/NotoSansAnatolianHieroglyphs-Regular.ttf"
)
sha256sums=(
  "38a991a0d87537daefe1a2332edcffdb599bf9670533badbbfc98f881b8f817c"
  "be46e1111764b0c65e448634f7fb410a14242ccbffd66002681d8f16a98bf26d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
