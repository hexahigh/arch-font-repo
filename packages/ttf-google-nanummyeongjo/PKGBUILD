pkgname=ttf-google-nanummyeongjo
pkgver=2.032
pkgrel=1
_commit="f12cf9db03e887b61a34ead809ec1b632bd013b5"  # Latest commit touching ofl/nanummyeongjo
pkgdesc="Google Fonts family: Nanum Myeongjo"
arch=('any')
url="https://fonts.google.com/specimen/Nanum+Myeongjo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/nanummyeongjo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/nanummyeongjo/NanumMyeongjo-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/nanummyeongjo/NanumMyeongjo-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/nanummyeongjo/NanumMyeongjo-Regular.ttf"
)
sha256sums=(
  "8eb1c1019fe7fe6d0b6e7d7bbbba1d9cbdd969d8c5f26455708f6cfb8a77284c"
  "bc9ed8e60d93fe6db054b8fb988481b625f2eef8cb2317ad0e9834681b8fe3f3"
  "60c0077fce069ba90ae97c0a3679f6eb3712e0ca637bdd0c15b72d335ec46db7"
  "7ed9e8653a8ed04285d51dc343ffea6eb3d9c73afc27383ea8929ee4ffd03205"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
