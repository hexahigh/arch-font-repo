pkgname=ttf-gluk-foglihtenfr02
pkgver=0.58
pkgrel=1
pkgdesc="FoglihtenFr02 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=FoglihtenFr02'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/foglihtenFr02/foglihtenFr02-068.zip")
sha256sums=('3d2c7579b0c1ff3c7eb984084c879cbc91df8bf706ea34b626513530f8aa2037')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=FoglihtenFr02
License info from upstream page: OpenFontLicense
EOF
}
