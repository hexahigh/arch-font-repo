pkgname=ttf-google-notosanscanadianaboriginal
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanscanadianaboriginal
pkgdesc="Google Fonts family: Noto Sans Canadian Aboriginal"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Canadian+Aboriginal"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscanadianaboriginal/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscanadianaboriginal/NotoSansCanadianAboriginal[wght].ttf"
)
sha256sums=(
  "507cc466e43d021662b9e9320a55a81798d293ed6a4a80c8d519f917bd90fdeb"
  "81b0f7e7ca48b28e343bb6a523a066743acedfbb29f374cbe4501e6d5f08f7af"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
