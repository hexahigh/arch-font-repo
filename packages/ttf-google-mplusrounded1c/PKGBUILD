  "https://github.com/google/fonts/raw/$_commit/ofl/mplusrounded1c/MPLUSRounded1c-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplusrounded1c/MPLUSRounded1c-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplusrounded1c/MPLUSRounded1c-Thin.ttf"
)
sha256sums=(
