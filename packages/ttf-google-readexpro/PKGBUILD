pkgname=ttf-google-readexpro
pkgver=1.205
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/readexpro
pkgdesc="Google Fonts family: Readex Pro"
arch=('any')
url="https://fonts.google.com/specimen/Readex+Pro"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/readexpro/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/readexpro/ReadexPro[HEXP,wght].ttf"
)
sha256sums=(
  "b41267a3903a45955f77b44596e080480c577fb7221df59672d0bc8cd8cd4b6f"
  "268bba7e1e8f3b14d798b3fb0e40ebaa3fc39308c9ac0020e2faf6df181cc30e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
