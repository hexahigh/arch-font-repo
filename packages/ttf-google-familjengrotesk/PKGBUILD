pkgname=ttf-google-familjengrotesk
pkgver=2.002
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/familjengrotesk
pkgdesc="Google Fonts family: Familjen Grotesk"
arch=('any')
url="https://fonts.google.com/specimen/Familjen+Grotesk"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/familjengrotesk/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/familjengrotesk/FamiljenGrotesk-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/familjengrotesk/FamiljenGrotesk[wght].ttf"
)
sha256sums=(
  "9708dd560d1f8aa1f006461aa447a31fda7b9aff662d152837654a388e0eb2ee"
  "278047492643756c75533d2acb90e0644abfe5df7bc6b99f21cf72a750580634"
  "2d25fc41321a04561fab20a90fc8bc9ed4d1c0743fe8ba76cc51cd3632138b80"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
