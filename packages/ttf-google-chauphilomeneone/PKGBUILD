pkgname=ttf-google-chauphilomeneone
pkgver=1.002
pkgrel=1
_commit="bd53c40b9ba0e97d0b66c31cba8963868f8dd30f"  # Latest commit touching ofl/chauphilomeneone
pkgdesc="Google Fonts family: Chau Philomene One"
arch=('any')
url="https://fonts.google.com/specimen/Chau+Philomene+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/chauphilomeneone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/chauphilomeneone/ChauPhilomeneOne-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/chauphilomeneone/ChauPhilomeneOne-Regular.ttf"
)
sha256sums=(
  "8c495ddd455def58a45310376a747bb61bf86e4b071cc527b3618bccd3ef00fa"
  "4a010ccb1f317377ed9f4b47604102a5db3e50533d37d805d3322e56797218e0"
  "2b9fffaa99f228498ee104bab524d7932eb1c49dd635e6be2a060c8ec999c9cc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
