pkgname=ttf-google-lineseedjp
pkgver=1.015
pkgrel=1
_commit="ca50ef7e44e4d5bc811b512708ff43c21acbac3e"  # Latest commit touching ofl/lineseedjp
pkgdesc="Google Fonts family: LINE Seed JP"
arch=('any')
url="https://fonts.google.com/specimen/LINE+Seed+JP"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/lineseedjp/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/lineseedjp/LINESeedJP-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/lineseedjp/LINESeedJP-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/lineseedjp/LINESeedJP-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/lineseedjp/LINESeedJP-Thin.ttf"
)
sha256sums=(
  "1cfc3752ddd076bc7d461b6680e42a345f2579f91319fa04192b754b3b993f65"
  "67aec2dc10b3ad210d6f7d53b33bbfea42ea28e32fa3834624eee699a638d5ff"
  "e310cf97ddae9e9deb15f769fd2f68a2ff24bd0a19953c5191df941cc7952c95"
  "04a6c0077ddb8ba5af3638bd76b4600708dde7b38df047b40fbe6f3af358d3c3"
  "e59cfc7cde710b0968e850b5fae4714d719e39d9bb731f7aa8c957f661c6bbec"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
