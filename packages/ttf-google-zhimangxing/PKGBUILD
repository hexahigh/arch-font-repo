pkgname=ttf-google-zhimangxing
pkgver=2.001
pkgrel=1
_commit="d24e34e9c5f1be84d904a1427149aab94ab03fb1"  # Latest commit touching ofl/zhimangxing
pkgdesc="Google Fonts family: Zhi Mang Xing"
arch=('any')
url="https://fonts.google.com/specimen/Zhi+Mang+Xing"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/zhimangxing/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/zhimangxing/ZhiMangXing-Regular.ttf"
)
sha256sums=(
  "10947328199e369a3e6b4a67e8e5507ed99d5bbb264a1f156415aa9b665e4d15"
  "644e0cae9b40f0b10ab729a01bd32032e3973bac22be3dccae01bf6ae7fde969"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
