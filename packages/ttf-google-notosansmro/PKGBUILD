pkgname=ttf-google-notosansmro
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansmro
pkgdesc="Google Fonts family: Noto Sans Mro"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Mro"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmro/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmro/NotoSansMro-Regular.ttf"
)
sha256sums=(
  "4db1c3aa73647bb9ad9b0137917e3e335ed1e7286c1764db707e3f5836a766d1"
  "fe05fbcf65aa3a42f446437a6e2db4e9ccf2a1d2fd85fddfd93af3df1d729cf9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
