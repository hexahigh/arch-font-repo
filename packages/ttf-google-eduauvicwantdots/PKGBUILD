pkgname=ttf-google-eduauvicwantdots
pkgver=1.001
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/eduauvicwantdots
pkgdesc="Google Fonts family: Edu AU VIC WA NT Dots"
arch=('any')
url="https://fonts.google.com/specimen/Edu+AU+VIC+WA+NT+Dots"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/eduauvicwantdots/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/eduauvicwantdots/EduAUVICWANTDots%5Bwght%5D.ttf"
)
sha256sums=(
  "11a98fa66908aa244c7608443d945dd50e2821d879bb25b5897ffc8f94712688"
  "4be8bf2aa8f4635ceb0d978a2588706e4d12e5c695fa0b8fe1df49b7274317af"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
