pkgname=ttf-google-comforter
pkgver=1.013
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/comforter
pkgdesc="Google Fonts family: Comforter"
arch=('any')
url="https://fonts.google.com/specimen/Comforter"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/comforter/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/comforter/Comforter-Regular.ttf"
)
sha256sums=(
  "abc9cc1c5d7dc6005ebffb703055380ad7b39a159f690e16233d80f78262f82b"
  "2852da85b2fbfd37ccd87387f3578a251cb9a8814fbab22c4487f792936a2267"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
