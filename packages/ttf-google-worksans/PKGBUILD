pkgname=ttf-google-worksans
pkgver=2.012
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/worksans
pkgdesc="Google Fonts family: Work Sans"
arch=('any')
url="https://fonts.google.com/specimen/Work+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/worksans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/worksans/WorkSans-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/worksans/WorkSans%5Bwght%5D.ttf"
)
sha256sums=(
  "749aca05078664ce682dce1b1b10096ac397cb088c1a6df4e1bb56f0092a9272"
  "0a9f935ea490d3477fc97e40248f356c29bce11a1973939056c4316b122341ec"
  "f50f61f2ba738e239442d40bf1069adb195c224b6a5a73a581fc2f3ed62a9f63"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
