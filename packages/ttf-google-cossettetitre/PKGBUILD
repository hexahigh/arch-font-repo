pkgname=ttf-google-cossettetitre
pkgver=1.002
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/cossettetitre
pkgdesc="Google Fonts family: Cossette Titre"
arch=('any')
url="https://fonts.google.com/specimen/Cossette+Titre"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cossettetitre/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cossettetitre/CossetteTitre-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/cossettetitre/CossetteTitre-Regular.ttf"
)
sha256sums=(
  "ab398cb1f55e73f298510c76bae3d2a6a87c71b8c711bf4ba146145f14fe503b"
  "05635008898dd896df9da3daf04312e22ba59db5774bc091dc2680a20ca571bb"
  "552ee5848f2afd5abdf52f6ec7896a4aa443aaadd68fa5d5048e5788f0850f00"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
