pkgname=ttf-google-notosanssymbols
pkgver=2.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssymbols
pkgdesc="Google Fonts family: Noto Sans Symbols"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Symbols"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssymbols/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssymbols/NotoSansSymbols[wght].ttf"
)
sha256sums=(
  "b118dd41337806a5d4797052c77caf3bd096aed783e5eb21b4d11154351e1ac0"
  "f7e7e04b4a24b6c78893d50cbfd2b2f6cae49617ab047bfef668d252adb128f7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
