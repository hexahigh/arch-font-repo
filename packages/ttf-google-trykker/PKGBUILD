pkgname=ttf-google-trykker
pkgver=1.001
pkgrel=1
_commit="02e49a693905bb4058921b986b894c62031e14f6"  # Latest commit touching ofl/trykker
pkgdesc="Google Fonts family: Trykker"
arch=('any')
url="https://fonts.google.com/specimen/Trykker"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/trykker/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/trykker/Trykker-Regular.ttf"
)
sha256sums=(
  "4bed7eaae70cab1bdf2bcf9b1cb562fcd9cc26d1c3533c4ade0ec70516dfb3a4"
  "bb5601709cfa4c0b28725afd45025afc79310738886d89ced9caa36164bd217a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
