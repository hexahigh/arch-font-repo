pkgname=ttf-google-songmyung
pkgver=1.00
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/songmyung
pkgdesc="Google Fonts family: Song Myung"
arch=('any')
url="https://fonts.google.com/specimen/Song+Myung"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/songmyung/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/songmyung/SongMyung-Regular.ttf"
)
sha256sums=(
  "40bd3f35477284c021978816e9d3b8723ff2283fd7065fafaa5bb3004e41b237"
  "7f90ab20250911560212cc5819c7b205f9c6644bb96b65095d89fcae096bbf58"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
