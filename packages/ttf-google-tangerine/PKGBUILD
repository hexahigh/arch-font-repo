pkgname=ttf-google-tangerine
pkgver=1.3
pkgrel=1
_commit="3b035861e76c9dd58f792340b13a9abf2111dafc"  # Latest commit touching ofl/tangerine
pkgdesc="Google Fonts family: Tangerine"
arch=('any')
url="https://fonts.google.com/specimen/Tangerine"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/tangerine/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/tangerine/Tangerine-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/tangerine/Tangerine-Regular.ttf"
)
sha256sums=(
  "adadb8d5d34fe2218dca0f4a4919a9b6f81dfaebb289e5446ac7b3063d6965e9"
  "a35368c814c71c15928ffc60cbac32bc81461f03b895a4a607df9c64b3d1548b"
  "3f5db6010de48f7173939f16621c0e0e794b589eec04e3b04e0a81be848dfab9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
