pkgname=ttf-google-ultra
pkgver=1.001
pkgrel=1
_commit="3c4ceb25cab01e4d2f1b4a717a3abe89cfe8c793"  # Latest commit touching apache/ultra
pkgdesc="Google Fonts family: Ultra"
arch=('any')
url="https://fonts.google.com/specimen/Ultra"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/ultra/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/ultra/Ultra-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "9ee63cffbc379e5d4eb5fed6a0b94b770da919497e5cba4a227a6393dae0939e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
