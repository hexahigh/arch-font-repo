pkgname=ttf-google-notosansrunic
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansrunic
pkgdesc="Google Fonts family: Noto Sans Runic"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Runic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansrunic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansrunic/NotoSansRunic-Regular.ttf"
)
sha256sums=(
  "b0fbcb9eaf0f5f415358bfefa5999ee75e18cde4a275b78285b2140a9e381865"
  "615b6c1166a8c51816dc1536784acbf486547e3bed03dbfdd70910e10066793b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
