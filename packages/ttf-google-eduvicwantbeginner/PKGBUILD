pkgname=ttf-google-eduvicwantbeginner
pkgver=1.003
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/eduvicwantbeginner
pkgdesc="Google Fonts family: Edu VIC WA NT Beginner"
arch=('any')
url="https://fonts.google.com/specimen/Edu+VIC+WA+NT+Beginner"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/eduvicwantbeginner/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/eduvicwantbeginner/EduVICWANTBeginner[wght].ttf"
)
sha256sums=(
  "9c50bb9d2dbfd864553688da113bf817a294f3721b7a35ac6569c63bb939a998"
  "b5cbf509d245c56f0a42caa7fed8a8661ad5927d76d88bb2008c9037209154b3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
