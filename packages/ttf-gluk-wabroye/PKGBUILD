pkgname=ttf-gluk-wabroye
pkgver=0.14
pkgrel=1
pkgdesc="Wabroye font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Wabroye'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Wabroye/Wabroye_014.zip")
sha256sums=('b8f62b652508f1ba9db107c2d870dd1acd82ceb71127275890d758f9e30b8231')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Wabroye
License info from upstream page: OpenFontLicense
EOF
}
