pkgname=ttf-google-mpluscodelatin
pkgver=1.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mpluscodelatin
pkgdesc="Google Fonts family: M PLUS Code Latin"
arch=('any')
url="https://fonts.google.com/specimen/M+PLUS+Code+Latin"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mpluscodelatin/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mpluscodelatin/MPLUSCodeLatin%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "04971e3fcee60b247395150d93b3616f6a0b092572332c96187b472976553abc"
  "c755d11b372d7e2ed1f7a10640c6ff3a473c666b4a8e0b4f809e40e7d4b4c5f5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
