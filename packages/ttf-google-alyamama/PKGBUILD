pkgname=ttf-google-alyamama
pkgver=1.213
pkgrel=1
_commit="3ae0a1cfe88d71c664c593ece479cd7ed570674f"  # Latest commit touching ofl/alyamama
pkgdesc="Google Fonts family: Alyamama"
arch=('any')
url="https://fonts.google.com/specimen/Alyamama"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alyamama/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alyamama/Alyamama[wght].ttf"
)
sha256sums=(
  "9034b97c728d88af36129932cc8d6a544f225941a2640e860686fa2f44239294"
  "f09eb4ad2eaf1b0a7c990cb9b3b7658414405804d74775269fdddc25efdb1883"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
