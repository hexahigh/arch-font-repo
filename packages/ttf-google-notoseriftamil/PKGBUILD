pkgname=ttf-google-notoseriftamil
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoseriftamil
pkgdesc="Google Fonts family: Noto Serif Tamil"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Tamil"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriftamil/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriftamil/NotoSerifTamil-Italic%5Bwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriftamil/NotoSerifTamil%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "f8ff8ce7d0a81bf8d5e121c635ef027250c531f2fd37d5988b8dd6e45f19d7f1"
  "fd83887a38aa103aade5e6f73437386bf010bec2afac5b5973e4996c1a98193b"
  "4b10fe56ee22907a80136c16dbe386ee20f3bf116332b35128bb35eeb775d91e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
