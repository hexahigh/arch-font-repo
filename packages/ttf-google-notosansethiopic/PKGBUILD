pkgname=ttf-google-notosansethiopic
pkgver=2.102
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansethiopic
pkgdesc="Google Fonts family: Noto Sans Ethiopic"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Ethiopic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansethiopic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansethiopic/NotoSansEthiopic[wdth,wght].ttf"
)
sha256sums=(
  "72606b23f312cb25973958f2892d4d2c2012deabadbf0f763232624a9649fc69"
  "0dbccc00b22d180ebd6a4bd8a733918a29e709fa6798023adc3e6cd40da65077"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
