pkgname=ttf-google-pathwayextreme
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/pathwayextreme
pkgdesc="Google Fonts family: Pathway Extreme"
arch=('any')
url="https://fonts.google.com/specimen/Pathway+Extreme"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pathwayextreme/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pathwayextreme/PathwayExtreme-Italic%5Bopsz%2Cwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/pathwayextreme/PathwayExtreme%5Bopsz%2Cwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "66a018bdb4174781a473d6b26c9873a8b8ed5f5c8086bc18f1532f850f61cacd"
  "ad71db067a33c101fb1ec792e94c405f22274f68a6842dc4521f623c17805fa1"
  "a7640e7731dbd5556123aa8b56948c23542ce8696f0bc882ce56f2dd9a9ee9fa"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
