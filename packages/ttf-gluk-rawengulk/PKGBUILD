pkgname=ttf-gluk-rawengulk
pkgver=0.92..0.93
pkgrel=1
pkgdesc="Rawengulk font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Rawengulk'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/rawengulk/RawengulkOtf-093.zip")
sha256sums=('7d5f82967d1a1f55e0bfc63db6cd0e10b34c44dc9ab7b4e2c69bae0d2315e956')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Rawengulk
License info from upstream page: OpenFontLicense
EOF
}
