pkgname=ttf-google-notoserifyezidi
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifyezidi
pkgdesc="Google Fonts family: Noto Serif Yezidi"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Yezidi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifyezidi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifyezidi/NotoSerifYezidi[wght].ttf"
)
sha256sums=(
  "e54b92f7047e9de3276849387c4109fe77718bf608408ac2f9826188af442dfb"
  "807b3ec568b2333601e297484565e1ff48adb014aa4d8aaa7eba23dc04e44e05"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
