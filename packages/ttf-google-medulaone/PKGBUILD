pkgname=ttf-google-medulaone
pkgver=1.002
pkgrel=1
_commit="a71769759ec1c6ab7431f365dd573f8a2ce36723"  # Latest commit touching ofl/medulaone
pkgdesc="Google Fonts family: Medula One"
arch=('any')
url="https://fonts.google.com/specimen/Medula+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/medulaone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/medulaone/MedulaOne-Regular.ttf"
)
sha256sums=(
  "88ac81fcd30e64f6e6b91b61b159c9b700bb3dd59012b72ec61629abcfc7fba1"
  "ec96fcb6468878d6ce17334214421f4c01bb97ebe0a89bee6e22352929f60f2a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
