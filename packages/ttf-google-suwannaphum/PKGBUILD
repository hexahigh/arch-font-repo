pkgname=ttf-google-suwannaphum
pkgver=8.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/suwannaphum
pkgdesc="Google Fonts family: Suwannaphum"
arch=('any')
url="https://fonts.google.com/specimen/Suwannaphum"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/suwannaphum/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/suwannaphum/Suwannaphum-Black.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/suwannaphum/Suwannaphum-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/suwannaphum/Suwannaphum-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/suwannaphum/Suwannaphum-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/suwannaphum/Suwannaphum-Thin.ttf"
)
sha256sums=(
  "f0e7cf380f1f4665979058b18a2f3d7bd4155dffc52dcecf2a6e82f5bd1f46f9"
  "c68112a98a143165dcf231b04a335497f6c028214006b0e1ad5905d65d0a2906"
  "8afa1154b77de9be28248395160cf5f94cda7847aca123971af212e074d6f83d"
  "4c63d8be65e55a9b755385c6114d9e40dd3d00542cb7581d321e41b029826be9"
  "f10e67bb256c78c126ac9def562a933ac44a51e5fa0cebea2a6234faa55de4a5"
  "a7622a399293c36352a182d829d71b90bf8e711416c9ed551434a15451933766"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
