pkgname=ttf-google-notosanshk
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanshk
pkgdesc="Google Fonts family: Noto Sans HK"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+HK"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanshk/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanshk/NotoSansHK%5Bwght%5D.ttf"
)
sha256sums=(
  "1c05c68c34f9708415aada51f17e1b0092d2cea709bf4a94cd38114f9e73d7d9"
  "76098ee78ec234cd4f8c950742b3f766fea2f8b43d5180d901048f4fc86c6849"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
