pkgname=ttf-google-andika
pkgver=6.101
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/andika
pkgdesc="Google Fonts family: Andika"
arch=('any')
url="https://fonts.google.com/specimen/Andika"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/andika/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/andika/Andika-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/andika/Andika-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/andika/Andika-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/andika/Andika-Regular.ttf"
)
sha256sums=(
  "43ee152fcd7be0c6eb3468f3012e776cb75bf88f5dec548be0aa4619bf438f9e"
  "4361126189a2d0e0da66999352db58aaf1b4ca940faf8a8239d725f8303d890d"
  "2d000f8791a1827c0c4d411e9f4593c4fc2db0fdbb868bb1f863593b3d3968e6"
  "6a4a0dd26d28f577b51dd6afb5acf6fd91ab21694e25649c270a32179bb52a62"
  "202b96b1f174a4a43baefe885b40dacacb81786755efd08ed4b7704e79c45515"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
