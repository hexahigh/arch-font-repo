pkgname=ttf-google-cormorant
pkgver=4.000
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/cormorant
pkgdesc="Google Fonts family: Cormorant"
arch=('any')
url="https://fonts.google.com/specimen/Cormorant"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cormorant/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cormorant/Cormorant-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/cormorant/Cormorant[wght].ttf"
)
sha256sums=(
  "60700d351cac4650c51f3f9db318d2a420f8b45052dba2715eb5fec41f0f6956"
  "2c4e1c43fa126b51a84160815b9264af442c6c531d13bfd3c1723703cd489dd2"
  "8f12cb21f05b61649192eaff13eeeb1b5619bc524feeae672fb916974259a076"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
