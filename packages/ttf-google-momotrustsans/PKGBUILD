pkgname=ttf-google-momotrustsans
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/momotrustsans
pkgdesc="Google Fonts family: Momo Trust Sans"
arch=('any')
url="https://fonts.google.com/specimen/Momo+Trust+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/momotrustsans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/momotrustsans/MomoTrustSans[wght].ttf"
)
sha256sums=(
  "476bf91ae130fe9bb42ab62a0ca5ba4667ab340bf5b9fe9d9a1cca4cadbe72f9"
  "c29f50ffe3aa991ec7d02d8b37d2bc8b0cca1bf296e7b04023a819e6c1e91611"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
