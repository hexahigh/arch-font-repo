pkgname=ttf-google-ropasans
pkgver=1.100
pkgrel=1
_commit="5844d2dcb9c2e2fd8a0b77c8e09a3af3b586a812"  # Latest commit touching ofl/ropasans
pkgdesc="Google Fonts family: Ropa Sans"
arch=('any')
url="https://fonts.google.com/specimen/Ropa+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ropasans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ropasans/RopaSans-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ropasans/RopaSans-Regular.ttf"
)
sha256sums=(
  "16741ac498178f645283cfb45b7a487b6d361b5de5730c5ea729f056f414f6b0"
  "c7a8d38df247c21fb55ee452619b1ae5c452771c501972dbd317a0f07ca1706d"
  "4a0bc3429f672cab4f9ad5e58047d9e7ccb6ad16db155ab92c56d1aefcdda8f1"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
