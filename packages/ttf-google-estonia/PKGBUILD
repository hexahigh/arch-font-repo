pkgname=ttf-google-estonia
pkgver=1.014
pkgrel=1
_commit="1796e34455b893092713d206e7f23e3e07699f00"  # Latest commit touching ofl/estonia
pkgdesc="Google Fonts family: Estonia"
arch=('any')
url="https://fonts.google.com/specimen/Estonia"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/estonia/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/estonia/Estonia-Regular.ttf"
)
sha256sums=(
  "b3a14dd814e7e5158a1869fd89094e213f1ab9abc62e1e1730b751cc93fef3a3"
  "03087597ea24879c19d51ca4622f8c4e9cd867d081e7ad0ad3e7dccfdb1933b2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
