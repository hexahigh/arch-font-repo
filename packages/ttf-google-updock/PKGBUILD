pkgname=ttf-google-updock
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/updock
pkgdesc="Google Fonts family: Updock"
arch=('any')
url="https://fonts.google.com/specimen/Updock"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/updock/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/updock/Updock-Regular.ttf"
)
sha256sums=(
  "b658a65a9462d5204aaebb6804efacbb0fced61b2d03f7a321f7173aa114b7ab"
  "2b9138ac107e6b5831828474c5f9e773c2da3a762afb76841deb6ecf5fd99ef6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
