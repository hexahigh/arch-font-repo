pkgname=ttf-gluk-resagokr
pkgver=0.95
pkgrel=1
pkgdesc="Resagokr font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Resagokr'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Resagokr/Resagokr_095.zip")
sha256sums=('e685ceb65cc8899212762a9116de5ec9bdcdec91f6961468002e084eef45876d')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Resagokr
License info from upstream page: OpenFontLicense
EOF
}
