pkgname=ttf-google-murecho
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/murecho
pkgdesc="Google Fonts family: Murecho"
arch=('any')
url="https://fonts.google.com/specimen/Murecho"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/murecho/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/murecho/Murecho[wght].ttf"
)
sha256sums=(
  "7d9f69e9be971aaa0caf64555545b3d34d23204d53ee88085790866ee21c75f9"
  "3a273c2f11e0164f829bc15c0689e587fe34d1493ff167d5afff8fe71a29e667"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
