pkgname=ttf-google-momosignature
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/momosignature
pkgdesc="Google Fonts family: Momo Signature"
arch=('any')
url="https://fonts.google.com/specimen/Momo+Signature"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/momosignature/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/momosignature/MomoSignature-Regular.ttf"
)
sha256sums=(
  "eaf1b004665b9567b5acba1881067d81f763fc969f45b5ce237ef2256bc82e92"
  "2f64c80e245b171c0931ae222d569261134212f0c0f54784c570f2e6cc6d2347"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
