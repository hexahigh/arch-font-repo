pkgname=ttf-google-rem
pkgver=1.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rem
pkgdesc="Google Fonts family: REM"
arch=('any')
url="https://fonts.google.com/specimen/REM"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rem/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rem/REM-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/rem/REM[wght].ttf"
)
sha256sums=(
  "2366789d24196c55c9a79058d3a56a3e659f0629cad97f47df83ace26396d7d6"
  "4ed7f32cb4c5ec11c5c8138c27dc26d83704a38027da0bf673a16f6135ee72bc"
  "ea889cb78c4a724a865859c29d5d9fbf26932eb56442865b37303e1277428d3d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
