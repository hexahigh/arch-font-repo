pkgname=ttf-google-elmssans
pkgver=1.061
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/elmssans
pkgdesc="Google Fonts family: Elms Sans"
arch=('any')
url="https://fonts.google.com/specimen/Elms+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/elmssans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/elmssans/ElmsSans-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/elmssans/ElmsSans[wght].ttf"
)
sha256sums=(
  "864c1942a1eab3864b1c674e3358e360e530c17286ee27ea1a762cd3a2cb5101"
  "bc485f45f3090748e540223fe29f44bed69b67c7311a3f984dffa5295713a017"
  "5a5c6aca186c65ad8323212c4e336507e68f4ee09d75ae0366607b5eb1a4498f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
