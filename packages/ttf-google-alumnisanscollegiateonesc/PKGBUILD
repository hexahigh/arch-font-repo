pkgname=ttf-google-alumnisanscollegiateonesc
pkgver=1.100
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/alumnisanscollegiateonesc
pkgdesc="Google Fonts family: Alumni Sans Collegiate One SC"
arch=('any')
url="https://fonts.google.com/specimen/Alumni+Sans+Collegiate+One+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanscollegiateonesc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanscollegiateonesc/AlumniSansCollegiateOneSC-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanscollegiateonesc/AlumniSansCollegiateOneSC-Regular.ttf"
)
sha256sums=(
  "2b0ed87071361caf613d6362b46d7289037f1001af3b11ab747905692f87025e"
  "e6a3630296c51921596647bd834f7fbfa5b04fe9335e4b33ad9ee702ac8654d7"
  "dae9c9d91919a15c3bf226538a5dc2bab1bc108d685bdaea3232979cc100de53"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
