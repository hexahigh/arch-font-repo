pkgname=ttf-google-wendyone
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/wendyone
pkgdesc="Google Fonts family: Wendy One"
arch=('any')
url="https://fonts.google.com/specimen/Wendy+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/wendyone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/wendyone/WendyOne-Regular.ttf"
)
sha256sums=(
  "aff3cea99bf300b4b29f4dc04867cf9b49d83de8c5ecaf991c446d506b56173e"
  "2e2da0e8bb0a593656d38fc8e265c5b09b2c45b294bd23f39f135c2e36c89daf"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
