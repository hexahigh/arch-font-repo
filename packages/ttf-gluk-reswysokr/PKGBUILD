pkgname=ttf-gluk-reswysokr
pkgver=0.984
pkgrel=1
pkgdesc="Reswysokr font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Reswysokr'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/reswysokr/Reswysokr.zip")
sha256sums=('9272c7897afd5b2bbbdb849759b39da3dc8908324e0cc465186178ad729c00ed')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Reswysokr
License info from upstream page: OpenFontLicense
EOF
}
