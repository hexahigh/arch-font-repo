pkgname=ttf-google-akayatelivigala
pkgver=1.002
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/akayatelivigala
pkgdesc="Google Fonts family: Akaya Telivigala"
arch=('any')
url="https://fonts.google.com/specimen/Akaya+Telivigala"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/akayatelivigala/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/akayatelivigala/AkayaTelivigala-Regular.ttf"
)
sha256sums=(
  "c9fe51b84ce71b4e8bd90eee48812942694c46f8b8c89207c0fc5579727d595e"
  "e57498133912f5abab1651ac44654fd67ebefebb489052748587b4ba33e182c2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
