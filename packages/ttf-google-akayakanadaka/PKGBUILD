pkgname=ttf-google-akayakanadaka
pkgver=1.002
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/akayakanadaka
pkgdesc="Google Fonts family: Akaya Kanadaka"
arch=('any')
url="https://fonts.google.com/specimen/Akaya+Kanadaka"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/akayakanadaka/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/akayakanadaka/AkayaKanadaka-Regular.ttf"
)
sha256sums=(
  "ca8b6e93436590a2e4efe58431345c0d5c00a43f1f4412c7cbac650215933ad9"
  "7891840f8c14326220aafd73f599f592bf44c60e4f8882bcf7c57426d62e9427"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
