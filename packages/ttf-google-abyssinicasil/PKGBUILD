pkgname=ttf-google-abyssinicasil
pkgver=2.300
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/abyssinicasil
pkgdesc="Google Fonts family: Abyssinica SIL"
arch=('any')
url="https://fonts.google.com/specimen/Abyssinica+SIL"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/abyssinicasil/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/abyssinicasil/AbyssinicaSIL-Regular.ttf"
)
sha256sums=(
  "a3668b2617181157065f100ec626a4ab8e350bf375df756b28406a575dbaf5cb"
  "f0e4fb92ee26967a3e6462342494956a3798b952345f917e1388913bb191cf2b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
