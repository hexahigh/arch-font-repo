pkgname=ttf-google-hanalei
pkgver=1.000
pkgrel=1
_commit="0325655f1752c800577dab063e341372657c560b"  # Latest commit touching ofl/hanalei
pkgdesc="Google Fonts family: Hanalei"
arch=('any')
url="https://fonts.google.com/specimen/Hanalei"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hanalei/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hanalei/Hanalei-Regular.ttf"
)
sha256sums=(
  "1f581506286e960436548dba0701aab278f7e67f2adc6bdae2958923867d1e64"
  "000ddd2a6be57f52aa41876c2ba71310e2a711f0343c1bdd71e43c9f137000f6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
