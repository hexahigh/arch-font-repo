pkgname=ttf-google-rancho
pkgver=1.001
pkgrel=1
_commit="7e8a8ece304c0294fd7b863226dc1ed524ae495b"  # Latest commit touching apache/rancho
pkgdesc="Google Fonts family: Rancho"
arch=('any')
url="https://fonts.google.com/specimen/Rancho"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/rancho/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/rancho/Rancho-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "1add7ee1a98ace8d687935b2a1735e1c53efc8a2108b73c8828db2df8a231306"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
