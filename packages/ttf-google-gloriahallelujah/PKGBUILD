pkgname=ttf-google-gloriahallelujah
pkgver=1.004
pkgrel=1
_commit="e5aa6436901dd75c3b029b8a80a2aca7242935f9"  # Latest commit touching ofl/gloriahallelujah
pkgdesc="Google Fonts family: Gloria Hallelujah"
arch=('any')
url="https://fonts.google.com/specimen/Gloria+Hallelujah"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gloriahallelujah/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gloriahallelujah/GloriaHallelujah.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "eb59f2762ce8785a292bebb2af3b3e6aa21454913d791f5f25441d1d57ead9fc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
