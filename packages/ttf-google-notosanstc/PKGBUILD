pkgname=ttf-google-notosanstc
pkgver=2.004
pkgrel=1
_commit="3be1884c48c3e45b52ecc725676a08f87776373e"  # Latest commit touching ofl/notosanstc
pkgdesc="Google Fonts family: Noto Sans TC"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+TC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstc/NotoSansTC%5Bwght%5D.ttf"
)
sha256sums=(
  "1c05c68c34f9708415aada51f17e1b0092d2cea709bf4a94cd38114f9e73d7d9"
  "864727d210d54f2537bbe23b3a839436c3992af72de9322af5270897246bd44f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
