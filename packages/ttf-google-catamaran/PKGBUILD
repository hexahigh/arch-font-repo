pkgname=ttf-google-catamaran
pkgver=2.000
pkgrel=1
_commit="bf751db669e232ec535924ea1dba8673d236e718"  # Latest commit touching ofl/catamaran
pkgdesc="Google Fonts family: Catamaran"
arch=('any')
url="https://fonts.google.com/specimen/Catamaran"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/catamaran/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/catamaran/Catamaran%5Bwght%5D.ttf"
)
sha256sums=(
  "c88333734ad7cd30540ec6614d12aa829a0395715de30e336d22ddfa3005db42"
  "f6ee331c381f441454225196d7930d4d0a31554d7f1f9c8c58149ca9e122b294"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
