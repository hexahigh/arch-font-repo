pkgname=ttf-google-margarine
pkgver=1.000
pkgrel=1
_commit="4e5f06dbb274a27ebe71ed54ea706b3ee40eabd9"  # Latest commit touching ofl/margarine
pkgdesc="Google Fonts family: Margarine"
arch=('any')
url="https://fonts.google.com/specimen/Margarine"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/margarine/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/margarine/Margarine-Regular.ttf"
)
sha256sums=(
  "50f7b09af5ff677f611a96cdf5eb916307c59b29f2e8144942718cb432a9bf6f"
  "54043d3d857af45cfe40d243dfcf138bd45f7fb452364a70925989384198d7f3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
