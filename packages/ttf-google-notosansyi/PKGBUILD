pkgname=ttf-google-notosansyi
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansyi
pkgdesc="Google Fonts family: Noto Sans Yi"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Yi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansyi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansyi/NotoSansYi-Regular.ttf"
)
sha256sums=(
  "e231e5bdb5cea3b5a3a9055d3ddc8ea9225dd9eb46db6404a8cd8b0cb5b0c4dc"
  "ee4de376a1e4f3c4bc7e116f4f46538348716b8408b86a0fc18c1c6128d2e56d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
