pkgname=ttf-google-notosansnewtailue
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansnewtailue
pkgdesc="Google Fonts family: Noto Sans New Tai Lue"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+New+Tai+Lue"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnewtailue/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnewtailue/NotoSansNewTaiLue%5Bwght%5D.ttf"
)
sha256sums=(
  "c689158356ee339a27b56c95a802dc5980b7d654586fa44b5ccdd3d5c7230c2f"
  "5362f7ab42089804beb05c936bef575f08ab27cf26109c71df99bfa28bda1cb4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
