pkgname=ttf-google-neonderthaw
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/neonderthaw
pkgdesc="Google Fonts family: Neonderthaw"
arch=('any')
url="https://fonts.google.com/specimen/Neonderthaw"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/neonderthaw/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/neonderthaw/Neonderthaw-Regular.ttf"
)
sha256sums=(
  "1b6b1362683d5bb1f864615e723b4323a3c05de5dd020e0e448546135bab75de"
  "15a72ab630eb73ee922ad653783b81053cf381ef53bcc17a536f3c7fa8097184"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
