pkgname=ttf-google-yujimai
pkgver=3.002
pkgrel=1
_commit="f6a4e8a8247cd8382551b8c2926fae6b650df6f0"  # Latest commit touching ofl/yujimai
pkgdesc="Google Fonts family: Yuji Mai"
arch=('any')
url="https://fonts.google.com/specimen/Yuji+Mai"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/yujimai/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/yujimai/YujiMai-Regular.ttf"
)
sha256sums=(
  "ef7c85c72ae94381c8bc4832ae4e6fbabdeafa2bb8a31313cd75dce95a690256"
  "05d83b65204a5de6fc34c222057fc082f8c6e2e44c05a0d28f4189b3e54c54c2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
