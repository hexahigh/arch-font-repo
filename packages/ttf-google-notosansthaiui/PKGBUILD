pkgname=ttf-google-notosansthaiui
pkgver=2.000
pkgrel=1
_commit="54584294ef89979740aa9687fdc3c04d11c4b539"  # Latest commit touching ofl/notosansthaiui
pkgdesc="Google Fonts family: Noto Sans Thai UI"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Thai+UI"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansthaiui/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansthaiui/NotoSansThaiUI%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "3eddf0ec5225225b9cfd9e649314b883d209cedbc593ff96e485557296353389"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
