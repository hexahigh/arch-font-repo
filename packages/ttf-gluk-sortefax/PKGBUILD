pkgname=ttf-gluk-sortefax
pkgver=0.261
pkgrel=1
pkgdesc="Sortefax font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Sortefax'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Sortefax/Sortefax_0261.zip")
sha256sums=('d90a8fa49b4bd0bfb198055dfda37b7566c20ab287ffc3f1eaff20d5977a696e')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Sortefax
License info from upstream page: OpenFontLicense
EOF
}
