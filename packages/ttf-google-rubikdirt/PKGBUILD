pkgname=ttf-google-rubikdirt
pkgver=2.200
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rubikdirt
pkgdesc="Google Fonts family: Rubik Dirt"
arch=('any')
url="https://fonts.google.com/specimen/Rubik+Dirt"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rubikdirt/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rubikdirt/RubikDirt-Regular.ttf"
)
sha256sums=(
  "f9e2d4498ea80d38bac7b8841d68af68c132fa67e1552e7c05717e6987de1d74"
  "9de3d928e434a47ec85d759012c8a0ebfeab0860076eea4e3989a47c5e213123"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
