pkgname=ttf-google-blakahollow
pkgver=1.003
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/blakahollow
pkgdesc="Google Fonts family: Blaka Hollow"
arch=('any')
url="https://fonts.google.com/specimen/Blaka+Hollow"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/blakahollow/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/blakahollow/BlakaHollow-Regular.ttf"
)
sha256sums=(
  "94b5d5a52420a96f2b4f427bc6f56133f6ddbdfaffa17fdd29049811fc9fd64c"
  "59cb30824e6023d454b4b44038cf44cdc9a4ad67f9795171c646c98ceb2bd542"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
