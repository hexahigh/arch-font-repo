pkgname=ttf-google-kalnia
pkgver=1.105
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/kalnia
pkgdesc="Google Fonts family: Kalnia"
arch=('any')
url="https://fonts.google.com/specimen/Kalnia"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/kalnia/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/kalnia/Kalnia%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "46eec4220309d801b70628d371aeff217e5151dfaad11606a71f2af5f1396f7a"
  "33685d0ec4abcca2736a51a10a6d4ee1aab2e608e6598c6926af9550b86731a4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
