pkgname=ttf-gluk-galberik
pkgver=0.50
pkgrel=1
pkgdesc="Galberik font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Galberik'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Galberik/Galberik.zip")
sha256sums=('81c8684e21da5c30cb3a3d090d341ec6cfa6f9fdb70289f088de713212bee0e7')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Galberik
License info from upstream page: OpenFontLicense
EOF
}
