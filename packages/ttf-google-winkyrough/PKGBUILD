pkgname=ttf-google-winkyrough
pkgver=1.206
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/winkyrough
pkgdesc="Google Fonts family: Winky Rough"
arch=('any')
url="https://fonts.google.com/specimen/Winky+Rough"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/winkyrough/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/winkyrough/WinkyRough-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/winkyrough/WinkyRough%5Bwght%5D.ttf"
)
sha256sums=(
  "8c9cdb626a2a846b36a2eaf28988da22ed5848e1f67903e99cb4cca16e2e2f14"
  "17941dc695d1c6d5a2eeffe28f9aed303262ddb398ff721637428ec56d760c23"
  "5f23615b697b7a440794fb11c85ab7735fe815f600ce15c981986936bba2e152"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
