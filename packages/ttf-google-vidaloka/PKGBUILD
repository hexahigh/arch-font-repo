pkgname=ttf-google-vidaloka
pkgver=1.011
pkgrel=1
_commit="d2e82d5379dcc92012a8e4655f5bbf9929bed84a"  # Latest commit touching ofl/vidaloka
pkgdesc="Google Fonts family: Vidaloka"
arch=('any')
url="https://fonts.google.com/specimen/Vidaloka"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/vidaloka/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/vidaloka/Vidaloka-Regular.ttf"
)
sha256sums=(
  "36931b77dd81fa96fffad91b6acb54931e600845eb81f91ecf1b4459012c621a"
  "5e90b4016da17f26a2f653bd9468bbb7e7b081f40c11ff5c24088420edc4dbe2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
