pkgname=ttf-google-yatraone
pkgver=1.002
pkgrel=1
_commit="99494aaa393730db3842b755bfa49a7d2428b143"  # Latest commit touching ofl/yatraone
pkgdesc="Google Fonts family: Yatra One"
arch=('any')
url="https://fonts.google.com/specimen/Yatra+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/yatraone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/yatraone/YatraOne-Regular.ttf"
)
sha256sums=(
  "71e5222c549d85a1403b6e709b4328b81d7b51ba021b8bd20df89550da80c087"
  "c47a94a4edf30f4eae0ca1c84777f4b70bc350221b6249de6b64fefdded2d3cd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
