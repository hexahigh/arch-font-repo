pkgname=ttf-google-notosansoriya
pkgver=2.007
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansoriya
pkgdesc="Google Fonts family: Noto Sans Oriya"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Oriya"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoriya/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoriya/NotoSansOriya[wdth,wght].ttf"
)
sha256sums=(
  "c90ff15ade263a49148e35af34e9c177c6d56881e81260b29f10123e9e227eca"
  "910342275d619081b896b4ed25fd9ad6ff320c25591b810de1fcc4beb153ba82"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
