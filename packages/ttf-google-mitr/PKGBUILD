pkgname=ttf-google-mitr
pkgver=1.003
pkgrel=1
_commit="17209f25d6df2b7ab06b4fbd8fe395dcb2fc116a"  # Latest commit touching ofl/mitr
pkgdesc="Google Fonts family: Mitr"
arch=('any')
url="https://fonts.google.com/specimen/Mitr"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mitr/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mitr/Mitr-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mitr/Mitr-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mitr/Mitr-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mitr/Mitr-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mitr/Mitr-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mitr/Mitr-SemiBold.ttf"
)
sha256sums=(
  "427ae4ac208b3cb1930bc2398141bed5880f0c057af4d2fc91b2f7ba8dcffb7d"
  "92349c05cd6a35549d0fb3e9b0d7d73059717e212cbda182ee28e5917150bc34"
  "dc3e6a03603bb0db3dc6833042e218a917d211d52d93bca426aa606f129d4488"
  "0ddb2f43bc071cd1546d1abdb0447c4a411e06450e69d97c838c2725fc8064a6"
  "847340933424d473bff6d011bc08543a2a2d2a670985a93e3431e3ac8926068f"
  "3763923ca8d860f9c06f483f663cd3d8d94e9ed8c2f35a7ce35bb6b13e1219fd"
  "257e8612923ed13838b2f0a0f9b25527aa83513c657df049a5ee608e6d4a059d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
