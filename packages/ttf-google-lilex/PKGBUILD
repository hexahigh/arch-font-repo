pkgname=ttf-google-lilex
pkgver=2.621
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/lilex
pkgdesc="Google Fonts family: Lilex"
arch=('any')
url="https://fonts.google.com/specimen/Lilex"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/lilex/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/lilex/Lilex-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/lilex/Lilex[wght].ttf"
)
sha256sums=(
  "cc3bd94cf51f40137e353fc9ca0859d54ec07e59c2092270b64a0723f4b34011"
  "84a80f6db4fbcdd03bde31a8561e3ba9c7f7a6673cce05d627bf5e6816abf57b"
  "ac99facd1db106a77d662a8285d97f1f241fb1f5316a41f8ceee8279b4750d82"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
