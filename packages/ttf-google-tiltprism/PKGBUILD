pkgname=ttf-google-tiltprism
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/tiltprism
pkgdesc="Google Fonts family: Tilt Prism"
arch=('any')
url="https://fonts.google.com/specimen/Tilt+Prism"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/tiltprism/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/tiltprism/TiltPrism[XROT,YROT].ttf"
)
sha256sums=(
  "97941703cd5fb1d5e86a062c9463ed12a613dbfbab9961c333699bdb2d277321"
  "28e96351753e177dc6e097f7f089c6942cdf26416e861f4ab9d6ee0bc57c7515"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
