pkgname=ttf-google-geostar
pkgver=1.002
pkgrel=1
_commit="d974dfc1b59e685383e9cf641146701c88b11716"  # Latest commit touching ofl/geostar
pkgdesc="Google Fonts family: Geostar"
arch=('any')
url="https://fonts.google.com/specimen/Geostar"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/geostar/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/geostar/Geostar-Regular.ttf"
)
sha256sums=(
  "013e33b6b2919fd0ffbdde6080a1c0f4521689fdce0f4876a59cf49ff8ae31c0"
  "891b92c124bbe4ac006c0b8b7402215486b7cb7951488178f415694a5898d12b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
