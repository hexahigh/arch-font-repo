pkgname=ttf-google-elmessiri
pkgver=2.020
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/elmessiri
pkgdesc="Google Fonts family: El Messiri"
arch=('any')
url="https://fonts.google.com/specimen/El+Messiri"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/elmessiri/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/elmessiri/ElMessiri%5Bwght%5D.ttf"
)
sha256sums=(
  "b69113722df50071b68ea377ad261919f08fd0dd6672f68b8868445586a30770"
  "5d58d5259d2accccba39cffe12e1226e88b6afc5150e3605eb2a9c2fe06ccab0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
