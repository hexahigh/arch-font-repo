pkgname=ttf-google-bangers
pkgver=2.100
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/bangers
pkgdesc="Google Fonts family: Bangers"
arch=('any')
url="https://fonts.google.com/specimen/Bangers"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bangers/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bangers/Bangers-Regular.ttf"
)
sha256sums=(
  "630dd5a307c0657b094d324e069b390edf90182fe5003639e06c02a0e5769af7"
  "4160a7311de9342674cce9160cde9fcbb30f48190397d86ff1b70b455af65824"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
