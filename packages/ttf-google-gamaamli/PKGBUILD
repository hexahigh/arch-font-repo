pkgname=ttf-google-gamaamli
pkgver=1.000
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/gamaamli
pkgdesc="Google Fonts family: Ga Maamli"
arch=('any')
url="https://fonts.google.com/specimen/Ga+Maamli"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gamaamli/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gamaamli/GaMaamli-Regular.ttf"
)
sha256sums=(
  "8778610a53692ed2fb14015f43af51edcd9ca09eed2a0071973cf3954a079f66"
  "68466b07730b44635898ee56c5bac8d89903b62df2d93ef16e7d4120a00a6638"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
