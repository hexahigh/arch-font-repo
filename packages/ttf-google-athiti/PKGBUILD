pkgname=ttf-google-athiti
pkgver=1.033
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/athiti
pkgdesc="Google Fonts family: Athiti"
arch=('any')
url="https://fonts.google.com/specimen/Athiti"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/athiti/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/athiti/Athiti-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/athiti/Athiti-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/athiti/Athiti-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/athiti/Athiti-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/athiti/Athiti-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/athiti/Athiti-SemiBold.ttf"
)
sha256sums=(
  "1d08c63944e639bbfe8a1b81e3c6a63836806c126b3573b9cda0db83fd27ffe9"
  "164aaaf1c046e834f418bc79ba5ffe636c79c2a26ec9146e1eaf9487cbeea833"
  "12737cd3ab743baa423ce14dde806672181c53aeca3fc596966da3a54c9db6e9"
  "f0a732e2336296b16c5d52cddd640902bac94a65b48d732e964f6f5a2a9627d6"
  "72d2657716b16233c8b093924d584044ab91a9ed997bc72dee152ca23c731bc9"
  "666f5474258cbffd537b494e2d6a441ee849778e2175a4e222d4d625c6efe0e5"
  "2e76cacba59a3e9d39cea52292d2e8a8ad9a6459336ab811bab0f141103544f3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
