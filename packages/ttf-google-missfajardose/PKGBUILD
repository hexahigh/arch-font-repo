pkgname=ttf-google-missfajardose
pkgver=1.000
pkgrel=1
_commit="ffc6a1c0d611d3c2cae621e27dce8c48f189a563"  # Latest commit touching ofl/missfajardose
pkgdesc="Google Fonts family: Miss Fajardose"
arch=('any')
url="https://fonts.google.com/specimen/Miss+Fajardose"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/missfajardose/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/missfajardose/MissFajardose-Regular.ttf"
)
sha256sums=(
  "d1bf0acea511ad1f4de53e942cffb8ab0e67c03c6203d6f390d71105d52c33f0"
  "f76e0f245e781a75ea9fa528706b417173f7741439369c07d1501276170ab709"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
