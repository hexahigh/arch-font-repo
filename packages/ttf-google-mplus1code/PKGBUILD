pkgname=ttf-google-mplus1code
pkgver=1.005
pkgrel=1
_commit="89c10dc9e57fbb8d954b06c0b6e1dda0c5c213b9"  # Latest commit touching ofl/mplus1code
pkgdesc="Google Fonts family: M PLUS 1 Code"
arch=('any')
url="https://fonts.google.com/specimen/M+PLUS+1+Code"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1code/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1code/MPLUS1Code%5Bwght%5D.ttf"
)
sha256sums=(
  "04971e3fcee60b247395150d93b3616f6a0b092572332c96187b472976553abc"
  "5a8b90c4d0e46c0dfd11eb951303ddc6ab5fba1f77a2ff1184133eed271f9723"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
