pkgname=ttf-google-yarndings12charted
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/yarndings12charted
pkgdesc="Google Fonts family: Yarndings 12 Charted"
arch=('any')
url="https://fonts.google.com/specimen/Yarndings+12+Charted"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/yarndings12charted/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/yarndings12charted/Yarndings12Charted-Regular.ttf"
)
sha256sums=(
  "111fd2463b6d65d75431bcdee7b54e0a0b88d5d7deca2ca562ba54f45f9128ba"
  "4f09a9d084aec3d88ce52d11367713cd91c48ae9a250405fcd0b9112b33bf201"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
