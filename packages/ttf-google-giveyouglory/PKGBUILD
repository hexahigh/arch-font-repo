pkgname=ttf-google-giveyouglory
pkgver=1.002
pkgrel=1
_commit="2f6e668ad6eff3710d80babef897e0780c3f8773"  # Latest commit touching ofl/giveyouglory
pkgdesc="Google Fonts family: Give You Glory"
arch=('any')
url="https://fonts.google.com/specimen/Give+You+Glory"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/giveyouglory/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/giveyouglory/GiveYouGlory.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "fb71f9a46a3234c2d98dbbe44e711f65654368031c57b927bf7679a46e278c80"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
