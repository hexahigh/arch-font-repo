pkgname=ttf-google-norican
pkgver=1.100
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/norican
pkgdesc="Google Fonts family: Norican"
arch=('any')
url="https://fonts.google.com/specimen/Norican"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/norican/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/norican/Norican-Regular.ttf"
)
sha256sums=(
  "b7ac0199d926980457302e0486f9561c61c0d2f84f3ba170fcd8e0f9d3956a4c"
  "71ee99002e70bb69f8f613bd29d646d6044aaf34612efcff689a11afa4291d04"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
