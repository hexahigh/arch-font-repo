pkgname=ttf-google-splinesans
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/splinesans
pkgdesc="Google Fonts family: Spline Sans"
arch=('any')
url="https://fonts.google.com/specimen/Spline+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/splinesans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/splinesans/SplineSans[wght].ttf"
)
sha256sums=(
  "45b2aa0796f435bd620d864b6b44ff08855dc575524f23ffb43161e69cb5dbfc"
  "65250939de0ab412d2b2349c9cb85304a5919fc3c5d4e74713a2d8a1f45f2947"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
