pkgname=ttf-google-notosanscoptic
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanscoptic
pkgdesc="Google Fonts family: Noto Sans Coptic"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Coptic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscoptic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscoptic/NotoSansCoptic-Regular.ttf"
)
sha256sums=(
  "322570ceef6e9935b2422470682e42481903eb444fc416455c32c2c3c888c78c"
  "51990af1bb0df7be8bfe98fda97769cecfa36eee15381e5504df400276abd735"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
