pkgname=ttf-google-mochiypopone
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mochiypopone
pkgdesc="Google Fonts family: Mochiy Pop One"
arch=('any')
url="https://fonts.google.com/specimen/Mochiy+Pop+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mochiypopone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mochiypopone/MochiyPopOne-Regular.ttf"
)
sha256sums=(
  "76be26178f13ef82866cf6a5c54272191bb583c203ad7035021c7681c9043558"
  "9e009430e1316c271a5f34759c6b65fc343c4e806f193042528887e7235a92c6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
