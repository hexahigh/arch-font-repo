pkgname=ttf-google-averiasanslibre
pkgver=1.002
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/averiasanslibre
pkgdesc="Google Fonts family: Averia Sans Libre"
arch=('any')
url="https://fonts.google.com/specimen/Averia+Sans+Libre"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/averiasanslibre/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/averiasanslibre/AveriaSansLibre-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averiasanslibre/AveriaSansLibre-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averiasanslibre/AveriaSansLibre-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averiasanslibre/AveriaSansLibre-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averiasanslibre/AveriaSansLibre-LightItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averiasanslibre/AveriaSansLibre-Regular.ttf"
)
sha256sums=(
  "46239ba6485d28553fd944da4ad32a00d9c403aa1c3e111676b0b96fe458d1d4"
  "c54cc938b365fa4442b9de4db603f26596e9ef3d3feba311cf986b6e13107863"
  "e0fa53165e0e7ccd3651073619762b66110dd0addc368245586c08c02ebc2d60"
  "8603d2963618dbb46eed3b46b1c7f70454af7b1d5607a4e6e9c6a00649c23e4f"
  "03725f74b84f520d8f27d29d542c31b2213c0e06caff563a43745950e88649c7"
  "37f7dfdf2e2ab82d73cb86779619a1dfe495823c82425f8982777fa4c12a8c9c"
  "834a9a8ef3a37da0165274d0345836b430e54ef15e6ebf070ae7c5805034efbc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
