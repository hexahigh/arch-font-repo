pkgname=ttf-google-maidenorange
pkgver=1.001
pkgrel=1
_commit="111668ecc2e516a9814c994b5cc0c2ef9ae4f4de"  # Latest commit touching apache/maidenorange
pkgdesc="Google Fonts family: Maiden Orange"
arch=('any')
url="https://fonts.google.com/specimen/Maiden+Orange"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/maidenorange/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/maidenorange/MaidenOrange-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "fd63e44269350a9761db9a88db9a301c82671123c7a9550fa4004b26b5d16200"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
