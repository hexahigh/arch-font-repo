pkgname=ttf-google-oleoscript
pkgver=1.002
pkgrel=1
_commit="fbd77f5632e1fab240a0a6b41f98d4744e60cdd6"  # Latest commit touching ofl/oleoscript
pkgdesc="Google Fonts family: Oleo Script"
arch=('any')
url="https://fonts.google.com/specimen/Oleo+Script"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/oleoscript/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/oleoscript/OleoScript-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/oleoscript/OleoScript-Regular.ttf"
)
sha256sums=(
  "8fbe530adcbe30c658393c3f2b5a4785d6765afcefdfe47f594730131f3a0abd"
  "7e4843c9d74233f00a2815954177e33758c1c42a08d218b11c131cf7d818f1d5"
  "1aa003ac938adf9bea644c406ce90eeb1913138aa1d7492242c0ca948c0f48ac"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
