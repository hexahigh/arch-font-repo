pkgname=ttf-google-ebgaramond
pkgver=1.002
pkgrel=1
_commit="c337133ee4c04681a7deef772aa83d439ddc775f"  # Latest commit touching ofl/ebgaramond
pkgdesc="Google Fonts family: EB Garamond"
arch=('any')
url="https://fonts.google.com/specimen/EB+Garamond"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ebgaramond/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ebgaramond/EBGaramond-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ebgaramond/EBGaramond%5Bwght%5D.ttf"
)
sha256sums=(
  "0985066662eb755ed3683ae5482a81a9195b49ce3f7e165cc2388b3dbece7dd7"
  "b76b365299331ddff5f8077648ef3b6fbb67f3bd15bebb955a42c6e57904aed0"
  "684fcc0db2239b43497341d596d68422ea60ef7522cf2e857071ad84e4ade2a4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
