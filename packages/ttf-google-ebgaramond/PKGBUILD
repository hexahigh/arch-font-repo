pkgname=ttf-google-ebgaramond
pkgver=1.001
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/ebgaramond
pkgdesc="Google Fonts family: EB Garamond"
arch=('any')
url="https://fonts.google.com/specimen/EB+Garamond"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ebgaramond/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ebgaramond/EBGaramond-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ebgaramond/EBGaramond[wght].ttf"
)
sha256sums=(
  "6f9e3a1c51f617e7b110862426204ec7a56d8c6d2f731373b5de6b8d069099b6"
  "3b681621f9c52ef3e013955305009c5d00f85a50c612897a3b4f18bbce490458"
  "b7f1dd91643e4f81f60e43fa9c4ba117663a001621913dcfd213706a4d83e6d9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
