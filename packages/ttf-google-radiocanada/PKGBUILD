pkgname=ttf-google-radiocanada
pkgver=2.104
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/radiocanada
pkgdesc="Google Fonts family: Radio Canada"
arch=('any')
url="https://fonts.google.com/specimen/Radio+Canada"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/radiocanada/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/radiocanada/RadioCanada-Italic%5Bwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/radiocanada/RadioCanada%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "86b4932ef0e19f8fd573ec941c3e121ae80771187ad1b854ae2b52525d452544"
  "473fa77b1d9b106828de36fd6371670829c8b5770f83d6b905ec3c052478a1a3"
  "54918d2c5fadb4436e8fd304f97fa0c7bc7a5d504e9a37773fb4df0f33d42056"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
