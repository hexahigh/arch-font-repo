pkgname=ttf-google-faustina
pkgver=1.200
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/faustina
pkgdesc="Google Fonts family: Faustina"
arch=('any')
url="https://fonts.google.com/specimen/Faustina"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/faustina/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/faustina/Faustina-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/faustina/Faustina[wght].ttf"
)
sha256sums=(
  "2d8f6a7be96a15fd2deaa8e6b5320cec6c253216b5a8f7e1becccfc51147b877"
  "215b9bf63da0c9584b5a0aa8e2270da6a2b62c1281f5c39089613c3aaeffa2be"
  "2ce2606f0ee1d493873c24818a391e02606ee76ac924b3d985cbb820c0a53ea5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
