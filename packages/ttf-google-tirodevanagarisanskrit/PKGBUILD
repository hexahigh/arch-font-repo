pkgname=ttf-google-tirodevanagarisanskrit
pkgver=1.52
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/tirodevanagarisanskrit
pkgdesc="Google Fonts family: Tiro Devanagari Sanskrit"
arch=('any')
url="https://fonts.google.com/specimen/Tiro+Devanagari+Sanskrit"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/tirodevanagarisanskrit/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/tirodevanagarisanskrit/TiroDevanagariSanskrit-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/tirodevanagarisanskrit/TiroDevanagariSanskrit-Regular.ttf"
)
sha256sums=(
  "2ed6051706542c5d6d96480318152b17900bb6d4dbadb11d7d5d6464d8b3e0dd"
  "9641914032154ea68a7caed100320cf547d63891a1e3962033ba91dc9c33ac2b"
  "75ae873e5e3f9c30fb962a3d283b9f5e7bc5bca57822a2aa926753b297b150ca"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
