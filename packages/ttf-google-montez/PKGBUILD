pkgname=ttf-google-montez
pkgver=1.001
pkgrel=1
_commit="10467458584c9ed8b93b3b4e9101ebf3d8e5f593"  # Latest commit touching apache/montez
pkgdesc="Google Fonts family: Montez"
arch=('any')
url="https://fonts.google.com/specimen/Montez"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/montez/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/montez/Montez-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "f58fc790f20cf612393737bb90c4ac418eea72147e988182f4eb7ee57f4639f3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
