pkgname=ttf-google-rocksalt
pkgver=1.001
pkgrel=1
_commit="b91c01c6e3eb21891c27c613b483b3afd68c5410"  # Latest commit touching apache/rocksalt
pkgdesc="Google Fonts family: Rock Salt"
arch=('any')
url="https://fonts.google.com/specimen/Rock+Salt"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/rocksalt/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/rocksalt/RockSalt-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "c5421d1ced1949488f29d11b75b7ef967abe2d870f816246bf18fdc0f3e29c96"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
