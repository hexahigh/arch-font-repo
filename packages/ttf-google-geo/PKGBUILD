pkgname=ttf-google-geo
pkgver=001.2
pkgrel=1
_commit="1d1ab61eaf128da7189b91bcacf3c087116adcea"  # Latest commit touching ofl/geo
pkgdesc="Google Fonts family: Geo"
arch=('any')
url="https://fonts.google.com/specimen/Geo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/geo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/geo/Geo-Oblique.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/geo/Geo-Regular.ttf"
)
sha256sums=(
  "cd059851dc2abcd2865ae318e8b949736f958794210acb90316530fd100fc904"
  "4f0083782a238a2c03fb8864119b1df5c0c8388a208a0f03d7a7c11313e679f3"
  "38669ed77c0ffe1859f45143c63614c0f1953074331536cb35d3caca944be605"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
