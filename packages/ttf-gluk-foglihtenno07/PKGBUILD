pkgname=ttf-gluk-foglihtenno07
pkgver=0.871
pkgrel=1
pkgdesc="FoglihtenNo07 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=FoglihtenNo07'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/FoglihtenNo07/FoglihtenNo07_0871.zip")
sha256sums=('bfc7d38a064fdb2e0ad5acdd5fab9f5552d047a2be8d148e001afe77667e2ae4')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=FoglihtenNo07
License info from upstream page: OpenFontLicense
EOF
}
