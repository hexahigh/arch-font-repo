pkgname=ttf-google-chokokutai
pkgver=1.000
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/chokokutai
pkgdesc="Google Fonts family: Chokokutai"
arch=('any')
url="https://fonts.google.com/specimen/Chokokutai"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/chokokutai/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/chokokutai/Chokokutai-Regular.ttf"
)
sha256sums=(
  "55270f3e221dc526d84c2833e512cc0f399bcd2b4b1746f63d532345b23fae56"
  "c622b971d1bdb2d8cd64f978746e6d52d361417ae4222c275cb57549e34e097e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
