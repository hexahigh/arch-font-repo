pkgname=ttf-google-fugazone
pkgver=1.002
pkgrel=1
_commit="fc2680a0f214a82dcc85ba9039575c8a30ab8467"  # Latest commit touching ofl/fugazone
pkgdesc="Google Fonts family: Fugaz One"
arch=('any')
url="https://fonts.google.com/specimen/Fugaz+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/fugazone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/fugazone/FugazOne-Regular.ttf"
)
sha256sums=(
  "5951473ab31533bfe1452bbcece47f237a5546c7e7d45ff1aec0289619623294"
  "14fd5becce8b0ae987e44b3f9fa9e3e6c87463e9585ac15db6c8271462068a62"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
