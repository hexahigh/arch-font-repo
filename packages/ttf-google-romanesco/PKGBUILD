pkgname=ttf-google-romanesco
pkgver=1.000
pkgrel=1
_commit="7effd096aee8db9d11c4ab54c0e0a27ef4845c4e"  # Latest commit touching ofl/romanesco
pkgdesc="Google Fonts family: Romanesco"
arch=('any')
url="https://fonts.google.com/specimen/Romanesco"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/romanesco/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/romanesco/Romanesco-Regular.ttf"
)
sha256sums=(
  "e75230ee246a04912366cd8d759d081200d80fb0756766c96dd52f73e8b40bed"
  "2af822e2e972a6552572667f73fee23adb4f146db97f89edfe6ad722d0c16076"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
