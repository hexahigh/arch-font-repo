pkgname=ttf-google-bungeetint
pkgver=2.001
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bungeetint
pkgdesc="Google Fonts family: Bungee Tint"
arch=('any')
url="https://fonts.google.com/specimen/Bungee+Tint"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bungeetint/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bungeetint/BungeeTint-Regular.ttf"
)
sha256sums=(
  "ff43f39d2143afa2ef0a7009629d25f62de23f0614ecdaea6dd07f6c58c5d2b1"
  "ebe2699c1507981225cfa75c601a2f66aea813e919b34ada735c676fb4b32726"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
