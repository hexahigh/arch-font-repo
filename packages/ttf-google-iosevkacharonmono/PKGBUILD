  "https://github.com/google/fonts/raw/$_commit/ofl/iosevkacharonmono/IosevkaCharonMono-LightItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/iosevkacharonmono/IosevkaCharonMono-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/iosevkacharonmono/IosevkaCharonMono-MediumItalic.ttf"
