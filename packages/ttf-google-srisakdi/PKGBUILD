pkgname=ttf-google-srisakdi
pkgver=1.000
pkgrel=1
_commit="c4faaef994356be94b074669600dc8c09efe4da3"  # Latest commit touching ofl/srisakdi
pkgdesc="Google Fonts family: Srisakdi"
arch=('any')
url="https://fonts.google.com/specimen/Srisakdi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/srisakdi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/srisakdi/Srisakdi-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/srisakdi/Srisakdi-Regular.ttf"
)
sha256sums=(
  "4398885e6b303830d81eea03444aae6fb08a44f41b6acd193c88a2f8cd17606e"
  "c017270f68bac7c3b282c9d80e6665f56ad4f5d670db590a2851dcb9c0a75f57"
  "073d1694bda5cf42082574a4b7d57df298d7f2cfc9ee997f8f5ab9b214cf72c9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
