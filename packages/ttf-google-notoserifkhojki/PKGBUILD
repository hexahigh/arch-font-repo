pkgname=ttf-google-notoserifkhojki
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifkhojki
pkgdesc="Google Fonts family: Noto Serif Khojki"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Khojki"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifkhojki/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifkhojki/NotoSerifKhojki[wght].ttf"
)
sha256sums=(
  "82ead5cfe70167960007329171dcffe99886373b3159619e596e84f08890234c"
  "d3d89a3fbf6ed2bd0761481332c2a6ab06db4f0500d3775accd94d31829697a0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
