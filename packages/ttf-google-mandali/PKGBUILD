pkgname=ttf-google-mandali
pkgver=1.0.5
pkgrel=1
_commit="4e5f06dbb274a27ebe71ed54ea706b3ee40eabd9"  # Latest commit touching ofl/mandali
pkgdesc="Google Fonts family: Mandali"
arch=('any')
url="https://fonts.google.com/specimen/Mandali"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mandali/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mandali/Mandali-Regular.ttf"
)
sha256sums=(
  "1b8eef90c567309fef17962cc969dd9ed1de69176517238e744018bb983e7c1c"
  "8ba4663d114aff639e4974b65795353c193272026308608d95770aaaa6afd806"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
