pkgname=ttf-gluk-znikomitno25
pkgver=0.56
pkgrel=1
pkgdesc="ZnikomitNo25 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=ZnikomitNo25'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/ZnikomitNo25/ZnikomitNo25-056.zip")
sha256sums=('04a04b0cb684582ea6e6b64a44fc18f0340ebe48034d343b713b0c8ed22b514d')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=ZnikomitNo25
License info from upstream page: OpenFontLicense
EOF
}
