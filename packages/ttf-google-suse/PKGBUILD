pkgname=ttf-google-suse
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/suse
pkgdesc="Google Fonts family: SUSE"
arch=('any')
url="https://fonts.google.com/specimen/SUSE"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/suse/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/suse/SUSE-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/suse/SUSE%5Bwght%5D.ttf"
)
sha256sums=(
  "d5d12664886d0311d55bf6e9dd0c711c1d0eb26a131d99c04bf34d9f96529f64"
  "05c15e422b8d4bf0a940e5d971cdfe3ea84d0f253ac114fd7ed4797f55ff520f"
  "16bda691d6c69df476d8c4edd8cf2a342576d7236793548fc876e31e8ea24fd8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
