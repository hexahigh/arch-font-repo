pkgname=ttf-google-ovo
pkgver=1.001
pkgrel=1
_commit="c42f4721360a3e7336a65ef038bad5a9579f0f0f"  # Latest commit touching ofl/ovo
pkgdesc="Google Fonts family: Ovo"
arch=('any')
url="https://fonts.google.com/specimen/Ovo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ovo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ovo/Ovo-Regular.ttf"
)
sha256sums=(
  "008445a4d53fbd71bff9cf733bdfd841a1b15fb58ef3473f7bab4c456e3b2930"
  "8d4f113ada748f44d005371bee5692e58950a84e6068b74f54710e280a29f389"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
