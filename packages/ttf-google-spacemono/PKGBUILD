pkgname=ttf-google-spacemono
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/spacemono
pkgdesc="Google Fonts family: Space Mono"
arch=('any')
url="https://fonts.google.com/specimen/Space+Mono"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/spacemono/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/spacemono/SpaceMono-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/spacemono/SpaceMono-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/spacemono/SpaceMono-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/spacemono/SpaceMono-Regular.ttf"
)
sha256sums=(
  "8e4ee42b2553e1e01504e61cb0d46d148cd8c9e5eacaa3622a7df2d4f2955b9f"
  "405e73d41afb7e5906efce206a326af5c956f38e255f35421c260e861e599c59"
  "cdcc95eddee312879a9728494e595f591cb159f3f276d79bc58673dec7e57138"
  "eca264c8690a91fe837d19a6badf2d88961610c4c8aafcb196526192a9f258c5"
  "95837e182baeeada83368f7748db28357f0a1b75c6b84ff7065b5edf933c8e18"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
