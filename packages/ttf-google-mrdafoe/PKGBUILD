pkgname=ttf-google-mrdafoe
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mrdafoe
pkgdesc="Google Fonts family: Mr Dafoe"
arch=('any')
url="https://fonts.google.com/specimen/Mr+Dafoe"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mrdafoe/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mrdafoe/MrDafoe-Regular.ttf"
)
sha256sums=(
  "0da6a3e5b24a9fa04085c20a2a1d3101eeb1e0bff56a2291f407187e1b2adcf2"
  "a42a3c66a709927f358243fdfcbc437bd8eb188e2ee6a680c52f5be12c670fd2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
