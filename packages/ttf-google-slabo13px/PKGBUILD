pkgname=ttf-google-slabo13px
pkgver=1.02
pkgrel=1
_commit="13cc1d90bcbb733213b3c23e8d40ee8cd604d37b"  # Latest commit touching ofl/slabo13px
pkgdesc="Google Fonts family: Slabo 13px"
arch=('any')
url="https://fonts.google.com/specimen/Slabo+13px"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/slabo13px/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/slabo13px/Slabo13px-Regular.ttf"
)
sha256sums=(
  "76a55594c9a18b7d94b8119de838237eb834bae4e8c646d6d363aee587b7b427"
  "7b86edc3c9605f9e0d997658735b75ae1d5e11606a9109b8cc99521eb2b3f406"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
