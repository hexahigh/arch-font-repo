pkgname=ttf-google-archivonarrow
pkgver=3.002
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/archivonarrow
pkgdesc="Google Fonts family: Archivo Narrow"
arch=('any')
url="https://fonts.google.com/specimen/Archivo+Narrow"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/archivonarrow/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/archivonarrow/ArchivoNarrow-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/archivonarrow/ArchivoNarrow%5Bwght%5D.ttf"
)
sha256sums=(
  "b2087ef3fb91248e346600d19021249152a9688efea72905aa1996bb16a4c8de"
  "147c09214be086bf1c70311ffb66f4f5a252e48f828f1d49e35ae56951016cc6"
  "adbe027f625c8393ae0f6e174e32e233dda485bc3eda5153ce428275394ef97f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
