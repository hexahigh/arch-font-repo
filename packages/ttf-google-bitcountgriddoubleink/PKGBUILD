pkgname=ttf-google-bitcountgriddoubleink
pkgver=1.001
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bitcountgriddoubleink
pkgdesc="Google Fonts family: Bitcount Grid Double Ink"
arch=('any')
url="https://fonts.google.com/specimen/Bitcount+Grid+Double+Ink"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bitcountgriddoubleink/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bitcountgriddoubleink/BitcountGridDoubleInk%5BCRSV%2CELSH%2CELXP%2CSZP1%2CSZP2%2CXPN1%2CXPN2%2CYPN1%2CYPN2%2Cslnt%2Cwght%5D.ttf"
)
sha256sums=(
  "061dfb7681d7fff942e04f5217c40e05d2fe5a3cea6001222039fea4b0432254"
  "6da42b0c3bef339d827afcb4f8bf3aa90b780b18cfe752e468771757d5a42c4c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
