pkgname=ttf-google-notosansogham
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansogham
pkgdesc="Google Fonts family: Noto Sans Ogham"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Ogham"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansogham/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansogham/NotoSansOgham-Regular.ttf"
)
sha256sums=(
  "d5e3e9b305ff13448c11cb348dce7f180eb42c961a53325c1339fdeeaec4e239"
  "6a70572d381f3a54fdaa3b373b865f4d97377c65434493b294b1dfacc7c4f58c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
