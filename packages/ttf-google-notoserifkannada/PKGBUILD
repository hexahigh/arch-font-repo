pkgname=ttf-google-notoserifkannada
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifkannada
pkgdesc="Google Fonts family: Noto Serif Kannada"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Kannada"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifkannada/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifkannada/NotoSerifKannada%5Bwght%5D.ttf"
)
sha256sums=(
  "9d49a4e56df9b36403b139f48bf07fd87cc5e716cb3203c54b04b674adb16238"
  "3d97c98dd59251a85fcc6e95edf9be02b60147e92486927390247f1cd4d5eb37"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
