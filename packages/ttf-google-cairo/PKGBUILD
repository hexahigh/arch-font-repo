pkgname=ttf-google-cairo
pkgver=3.130
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/cairo
pkgdesc="Google Fonts family: Cairo"
arch=('any')
url="https://fonts.google.com/specimen/Cairo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cairo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cairo/Cairo%5Bslnt%2Cwght%5D.ttf"
)
sha256sums=(
  "a4554e1799d42e1405924b61eb0e0722ae1623b1f1f07f995348f96c496362a9"
  "667c987182391c91f4e57a2f455b1794fb5e3ee6ca4ef3383e86bb690fa9c964"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
