pkgname=ttf-google-spinnaker
pkgver=1.001
pkgrel=1
_commit="58d95612a50a286dca1b13287c7d3212de2daa82"  # Latest commit touching ofl/spinnaker
pkgdesc="Google Fonts family: Spinnaker"
arch=('any')
url="https://fonts.google.com/specimen/Spinnaker"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/spinnaker/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/spinnaker/Spinnaker-Regular.ttf"
)
sha256sums=(
  "f938d4076b66a13cf984ce88d92a07ff9802e8ae5e1f4a28cdc43fad122ae611"
  "f89852fb1cbf415eac1893d98978d77b934475d53d46838fd146924a4d2e13fc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
