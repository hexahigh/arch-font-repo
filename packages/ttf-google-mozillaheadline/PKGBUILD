pkgname=ttf-google-mozillaheadline
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mozillaheadline
pkgdesc="Google Fonts family: Mozilla Headline"
arch=('any')
url="https://fonts.google.com/specimen/Mozilla+Headline"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mozillaheadline/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mozillaheadline/MozillaHeadline%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "d0f4ab49be920e6c7b99a1b51d7f35aa85a38afdd4a22db9fd4b4dab2390d178"
  "7d04f994cbffedacf9281f7d141c2d50bc7e3c02321bd8a12f7b323d813c7bdc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
