pkgver=0.072
pkgrel=1
_commit="f2480dad6f8e7b1f42c023d3542e55eb8c3a2822"  # Latest commit touching ofl/sairacondensed
pkgdesc="Google Fonts family: Saira Condensed"
arch=('any')
url="https://fonts.google.com/specimen/Saira+Condensed"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sairacondensed/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sairacondensed/SairaCondensed-Black.ttf"
