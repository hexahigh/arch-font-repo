  "https://github.com/google/fonts/raw/$_commit/ofl/sairacondensed/SairaCondensed-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sairacondensed/SairaCondensed-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sairacondensed/SairaCondensed-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sairacondensed/SairaCondensed-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sairacondensed/SairaCondensed-Thin.ttf"
)
