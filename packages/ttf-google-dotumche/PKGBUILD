pkgname=ttf-google-dotumche
pkgver=2.21
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/dotumche
pkgdesc="Google Fonts family: DotumChe"
arch=('any')
url="https://fonts.google.com/specimen/DotumChe"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/dotumche/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/dotumche/DotumChe-Regular.ttf"
)
sha256sums=(
  "59fc225e9c23417ad83070289cd77814937c72fe7c65e72aaff13e5114957988"
  "c2c030ca896d46ff28dae17663e9fe22ab2fc6e6518c96d75e15ca8fb441bd2f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
