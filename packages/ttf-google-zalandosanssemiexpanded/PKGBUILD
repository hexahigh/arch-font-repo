pkgname=ttf-google-zalandosanssemiexpanded
pkgver=1.800
pkgrel=1
_commit="bc23e2cdcf4a49418f51f01fee7f8601437f0bdc"  # Latest commit touching ofl/zalandosanssemiexpanded
pkgdesc="Google Fonts family: Zalando Sans SemiExpanded"
arch=('any')
url="https://fonts.google.com/specimen/Zalando+Sans+SemiExpanded"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosanssemiexpanded/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosanssemiexpanded/ZalandoSansSemiExpanded-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosanssemiexpanded/ZalandoSansSemiExpanded%5Bwght%5D.ttf"
)
sha256sums=(
  "411a22de2734b25584e4764f7212b004f241181ac04944a3bcee0e0371afe547"
  "b24ebdd0e0f1a3fa959fc38d78b108249b1ac57bd1125ef3c18acecd90f3120d"
  "d4ef6e1d652da0590b7d0cceb5b4d5a1a063b4927be99f52dcb7a679eb3ae92b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
