pkgname=ttf-google-mukta
pkgver=2.538
pkgrel=1
_commit="4ed247183585550f5ee6d09665680c282227df41"  # Latest commit touching ofl/mukta
pkgdesc="Google Fonts family: Mukta"
arch=('any')
url="https://fonts.google.com/specimen/Mukta"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mukta/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mukta/Mukta-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mukta/Mukta-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mukta/Mukta-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mukta/Mukta-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mukta/Mukta-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mukta/Mukta-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mukta/Mukta-SemiBold.ttf"
)
sha256sums=(
  "2ee5e8e47cd7d08f60bb9555f72b25912c9e81b13f5bc9a0551ddf943da6ca98"
  "7d22891cd57507b04af95a67ffaf59b7073b3595a27d1cfbbcefb418de820a12"
  "328eeebffe06fac60d60b46fe60c3995a908d2347e9c285f1eef1a0c9d73e004"
  "ff3260e6fd667797b0beb80430b0da318ccdac73c0f90fe828c2dd5a093265a1"
  "161f2f22d33a1c75d9fb37d74ea99e8dbbe119cd5c102c83146fb032a552e8f2"
  "4db18bd8f19582607e8a6af0c4bf158b4b3378b426e42ad39d444d216c70074c"
  "2958e4af564507df2a856164df6f9978dacb03f999a4f34a0c269dc8a4de9688"
  "f437fb098f8f29acb8628617cb2682f0780ef22fa8b0443de1f66090c36e510a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
