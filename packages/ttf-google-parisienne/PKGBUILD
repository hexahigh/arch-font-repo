pkgname=ttf-google-parisienne
pkgver=1.000
pkgrel=1
_commit="f8991dec47f9c2f15a74a1ab131bdf5f1b2fc095"  # Latest commit touching ofl/parisienne
pkgdesc="Google Fonts family: Parisienne"
arch=('any')
url="https://fonts.google.com/specimen/Parisienne"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/parisienne/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/parisienne/Parisienne-Regular.ttf"
)
sha256sums=(
  "1dd84b611f4bed7f9ff9089e76a96337b187e6f283a4ab33bcb987f844f2c4db"
  "bc9ee17f022e20bc700797e5f557d14bfa43af0c98d9e6c9c5c1ca4ec7aacd57"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
