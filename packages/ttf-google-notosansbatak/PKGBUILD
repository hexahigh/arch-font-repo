pkgname=ttf-google-notosansbatak
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansbatak
pkgdesc="Google Fonts family: Noto Sans Batak"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Batak"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbatak/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbatak/NotoSansBatak-Regular.ttf"
)
sha256sums=(
  "ff0723191d946fd4c7e53effb67b3b5b25b1c3f3aa85f5244230fa2580a8fc1b"
  "87e5caee797e50fae28c5db0a9321ea19080950ebb65231a456e9c7c0041a67f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
