pkgname=ttf-google-amstelvaralpha
pkgver=0.000
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/amstelvaralpha
pkgdesc="Google Fonts family: Amstelvaralpha"
arch=('any')
url="https://fonts.google.com/specimen/Amstelvaralpha"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/amstelvaralpha/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/amstelvaralpha/AmstelvarAlpha-VF.ttf"
)
sha256sums=(
  "06c79c896894160a5810d869a822fa7d02a0e2ccffd97920b8cf3b880380f6e5"
  "8064db0a8d839ae41296252291acb8e4deffab64dddfb55485b0180420568626"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
