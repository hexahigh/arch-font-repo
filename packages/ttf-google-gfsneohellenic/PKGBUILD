pkgname=ttf-google-gfsneohellenic
pkgver=1.0
pkgrel=1
_commit="73a9aa7c505eb902435376ca9a9c4ca9c2b05bd7"  # Latest commit touching ofl/gfsneohellenic
pkgdesc="Google Fonts family: GFS Neohellenic"
arch=('any')
url="https://fonts.google.com/specimen/GFS+Neohellenic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gfsneohellenic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gfsneohellenic/GFSNeohellenic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gfsneohellenic/GFSNeohellenicBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gfsneohellenic/GFSNeohellenicBoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gfsneohellenic/GFSNeohellenicItalic.ttf"
)
sha256sums=(
  "bfc205682f5454b42a732ec857b665293ab8bc6f0ee901a0967219ba7ffdb190"
  "14d54dd7f36fdd7140d3f6357c99a8ead988a808b298471e02ba2c0992aa110d"
  "b1a3900f5f3327ab79d18c762fca17e46c0db37a32fbf34f7dca41458bd46f53"
  "b486c325aadd1c7dc4f5a87c41ae9c8823ea7285de9d7ad8f8fa6e836d41cad1"
  "39214ba27aec72823881bdc967b6b8929079609749db1911eda0f7072e461688"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
