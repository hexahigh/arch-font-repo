pkgname=ttf-google-stalinistone
pkgver=3.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/stalinistone
pkgdesc="Google Fonts family: Stalinist One"
arch=('any')
url="https://fonts.google.com/specimen/Stalinist+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/stalinistone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/stalinistone/StalinistOne-Regular.ttf"
)
sha256sums=(
  "194e25172d0144f29aff4b6fb2931ff0be0139448a5cd867db37863c9179330a"
  "73cc48eefa01543b09fd3df9bab6af2a302e52e292b8625f4b62c868bc152eeb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
