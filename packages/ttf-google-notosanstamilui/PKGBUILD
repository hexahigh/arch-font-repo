pkgname=ttf-google-notosanstamilui
pkgver=2.001
pkgrel=1
_commit="54584294ef89979740aa9687fdc3c04d11c4b539"  # Latest commit touching ofl/notosanstamilui
pkgdesc="Google Fonts family: Noto Sans Tamil UI"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Tamil+UI"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstamilui/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstamilui/NotoSansTamilUI%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "66dabbaafd95cf14827b69b5ada6af1bdcde237b505e36ac215797f0dc9bc281"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
