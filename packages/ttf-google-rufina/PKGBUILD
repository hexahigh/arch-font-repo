pkgname=ttf-google-rufina
pkgver=1.001
pkgrel=1
_commit="df42574db2ebe8c245d4c5ff01cd258d6190285b"  # Latest commit touching ofl/rufina
pkgdesc="Google Fonts family: Rufina"
arch=('any')
url="https://fonts.google.com/specimen/Rufina"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rufina/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rufina/Rufina-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/rufina/Rufina-Regular.ttf"
)
sha256sums=(
  "ce1108854c91696a8549bb21459f1dc74e8a1ec11664d712c3868c40042f1a8a"
  "6677451f47d8fd528b8607335ad3bae52db34f775559fc3db99dc7281f5805e0"
  "0b26e1388e827afa7c40e3ec268c85010dda0c759be0a169025509b59b1a4b1c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
