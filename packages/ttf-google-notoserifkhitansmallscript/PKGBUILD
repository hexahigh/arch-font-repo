pkgname=ttf-google-notoserifkhitansmallscript
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifkhitansmallscript
pkgdesc="Google Fonts family: Noto Serif Khitan Small Script"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Khitan+Small+Script"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifkhitansmallscript/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifkhitansmallscript/NotoSerifKhitanSmallScript-Regular.ttf"
)
sha256sums=(
  "58068590e3e02b923b3c8b7e94d3668aeeac58e9d7ecc05f3e5243c2ae385e55"
  "3e164843a3f04b9f89b533a8cb87141b0ee72661b035a4229cb6f58934d44eba"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
