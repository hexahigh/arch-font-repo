pkgname=ttf-google-drsugiyama
pkgver=1.000
pkgrel=1
_commit="0536a2cc916c1535610e3446fc5e2e758fff4fc9"  # Latest commit touching ofl/drsugiyama
pkgdesc="Google Fonts family: Dr Sugiyama"
arch=('any')
url="https://fonts.google.com/specimen/Dr+Sugiyama"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/drsugiyama/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/drsugiyama/DrSugiyama-Regular.ttf"
)
sha256sums=(
  "3621f156cc7a26e0a9cb413332e0bb35a0e76b36dbfe0b1c885b565a7bf3051e"
  "8436c1eae3a06126a6e0aa85b1dffb1b507d39eab7b6512a9bb1adc5d514d9b9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
