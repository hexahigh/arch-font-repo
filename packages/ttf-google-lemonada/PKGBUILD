pkgname=ttf-google-lemonada
pkgver=4.005
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/lemonada
pkgdesc="Google Fonts family: Lemonada"
arch=('any')
url="https://fonts.google.com/specimen/Lemonada"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/lemonada/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/lemonada/Lemonada%5Bwght%5D.ttf"
)
sha256sums=(
  "d8a8801a55cbc8eeaab7dc9396c4491d60cc7e4ecb2501c6f8282754d743fc2a"
  "84134e9e1da7d593839073157980a4d38296d2be10b61469a8f3169204959ad9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
