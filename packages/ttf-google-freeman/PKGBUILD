pkgname=ttf-google-freeman
pkgver=1.000
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/freeman
pkgdesc="Google Fonts family: Freeman"
arch=('any')
url="https://fonts.google.com/specimen/Freeman"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/freeman/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/freeman/Freeman-Regular.ttf"
)
sha256sums=(
  "51421d8463941d678ebd7d28b93950c028352d36403187fa023e83dc0680b551"
  "48fac93ede204981c621a1fb039bdfcbbdf7e646aa7a7f823d4191bcebe16f49"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
