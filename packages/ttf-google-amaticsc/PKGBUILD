pkgname=ttf-google-amaticsc
pkgver=2.505
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/amaticsc
pkgdesc="Google Fonts family: Amatic SC"
arch=('any')
url="https://fonts.google.com/specimen/Amatic+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/amaticsc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/amaticsc/AmaticSC-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/amaticsc/AmaticSC-Regular.ttf"
)
sha256sums=(
  "301f77908df2b00141b4dcea50cc1a586c3afcee78843bd811088e8263623f9d"
  "d367beadee66efbb657d24d3d8f30f3b60633e9d5c8ded7385541cf775cabb4d"
  "513a76f96d39a5366bd27c258674aaea35ee51c42b8f3060387f74649ee8c8aa"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
