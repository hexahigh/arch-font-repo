pkgname=ttf-google-notosansbuginese
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansbuginese
pkgdesc="Google Fonts family: Noto Sans Buginese"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Buginese"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbuginese/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbuginese/NotoSansBuginese-Regular.ttf"
)
sha256sums=(
  "1b63982dfebd74eab553a4aa303bc18811d9f136f82e20c37df7262ce3125bca"
  "af1ed02af9eff48e872c3fcf922ba72053b776c2f0d1a0d4cb36e57d5e3508b5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
