pkgname=ttf-google-oldstandardtt
pkgver=3.000
pkgrel=1
_commit="0edc5b3328428f52c6df57b9df32b2a867ecaad2"  # Latest commit touching ofl/oldstandardtt
pkgdesc="Google Fonts family: Old Standard TT"
arch=('any')
url="https://fonts.google.com/specimen/Old+Standard+TT"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/oldstandardtt/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/oldstandardtt/OldStandard-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/oldstandardtt/OldStandard-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/oldstandardtt/OldStandard-Regular.ttf"
)
sha256sums=(
  "4faa2d9e2ce0a4b5b37e62ee6fafe474a539b31578f7214ed97cc3503aeb8ebd"
  "7d831e9d799ad23ee98e889381a9db2a283b2dac7f228dd5c06071decb9c54db"
  "4b9522f4711317fc06e2413a58b4662c249cb707df193d682b9d640e365ef564"
  "42717a1280b523a506ca2b0285cca380e77fe214b1f6e3d75a8b925005f19eac"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
