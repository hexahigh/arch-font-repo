pkgname=ttf-google-khmer
pkgver=2.00
pkgrel=1
_commit="8ff38478c21d79318f529d0d3157e422d3f626a9"  # Latest commit touching ofl/khmer
pkgdesc="Google Fonts family: Khmer"
arch=('any')
url="https://fonts.google.com/specimen/Khmer"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/khmer/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/khmer/Khmer.ttf"
)
sha256sums=(
  "6827fa45930d5847fca5b3d3898b3d87a229fba772a5b6c5bc33bf73ec83478d"
  "cc88eae47fe7875f6a0ad2135e01e5910dacebed03445c4f8d1951f9cf69e3d1"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
