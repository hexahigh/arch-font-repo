pkgname=ttf-google-bigshouldersstencil
pkgver=2.001
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/bigshouldersstencil
pkgdesc="Google Fonts family: Big Shoulders Stencil"
arch=('any')
url="https://fonts.google.com/specimen/Big+Shoulders+Stencil"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersstencil/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersstencil/BigShouldersStencil[opsz,wght].ttf"
)
sha256sums=(
  "fbc746aabf0eb1847dfd92e2efc4596d79fa897d60b8e64062a22f585508fb3f"
  "758ec880296a8bdaf736a31fc57e90fa16673d8c357efc3c36bdb6582d625f0a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
