pkgname=ttf-google-schoolbell
pkgver=1.001
pkgrel=1
_commit="0b623f43ed4b306e7c473c8b8daad06992ade9e8"  # Latest commit touching apache/schoolbell
pkgdesc="Google Fonts family: Schoolbell"
arch=('any')
url="https://fonts.google.com/specimen/Schoolbell"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/schoolbell/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/schoolbell/Schoolbell-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "00ff6655a5eb1eb70d32f2b7351d1bcf3f45f3f9ca40fd5c0d25da79f7f82a50"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
