pkgname=ttf-google-kiteone
pkgver=1.002
pkgrel=1
_commit="130fcfb0ff422fec96b335616b2ca99f91914792"  # Latest commit touching ofl/kiteone
pkgdesc="Google Fonts family: Kite One"
arch=('any')
url="https://fonts.google.com/specimen/Kite+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/kiteone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/kiteone/KiteOne-Regular.ttf"
)
sha256sums=(
  "ea54eb4bd4d5a57ec47417d02855ba011af5d917303461617fe01a5688e0525d"
  "f482673f99d08cf01d617e871cc49f529ae479c321e1ec7f009419275a2f7b61"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
