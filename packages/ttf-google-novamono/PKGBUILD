pkgname=ttf-google-novamono
pkgver=1.2
pkgrel=1
_commit="ec5151d3aeafafd7ad0eecc0df9e73aaad2af2a3"  # Latest commit touching ofl/novamono
pkgdesc="Google Fonts family: Nova Mono"
arch=('any')
url="https://fonts.google.com/specimen/Nova+Mono"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/novamono/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/novamono/NovaMono.ttf"
)
sha256sums=(
  "197c3f48cff4df3d768230e0bbdbc4305d8b8b9041ea6fb5e00872af66adc5ae"
  "648eadb6648c0801b186d3dcef60ee6aa84a791b1e09c726935c0712508b4807"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
