pkgname=ttf-google-cantarell
pkgver=1.004
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/cantarell
pkgdesc="Google Fonts family: Cantarell"
arch=('any')
url="https://fonts.google.com/specimen/Cantarell"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/cantarell/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/cantarell/Cantarell-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/cantarell/Cantarell-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/cantarell/Cantarell-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/cantarell/Cantarell-Regular.ttf"
)
sha256sums=(
  "3d916878ddf8e33ecddd57b8cadfb4c3cf84760cf9c1d66ed3e0654c20403d6e"
  "1b15d4acd20df636755bafa1e026e73fb277740aa27442198795fcf0d1cb9818"
  "913df4975de5e304a2395c7e1b9c994dad4bc93f1e80b94ec8662113d87d3e3b"
  "113797007a0baa9eaba2688de40b51f1d907f5c4f2add61cfd25a5e626153613"
  "840a255779258a2b24b5e3d1f32a821ed641fdd5ef1e47c4dc180064db9ccfa1"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
