pkgname=ttf-google-playwritenzbasic
pkgver=1.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwritenzbasic
pkgdesc="Google Fonts family: Playwrite NZ Basic"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+NZ+Basic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritenzbasic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritenzbasic/PlaywriteNZBasic[wght].ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "e2c28359c82efe11bab003b8e657a8ef0bd7b7ffe95690da50a8fd5217c64a20"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
