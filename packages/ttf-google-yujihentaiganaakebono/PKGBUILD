pkgname=ttf-google-yujihentaiganaakebono
pkgver=3.002
pkgrel=1
_commit="f6a4e8a8247cd8382551b8c2926fae6b650df6f0"  # Latest commit touching ofl/yujihentaiganaakebono
pkgdesc="Google Fonts family: Yuji Hentaigana Akebono"
arch=('any')
url="https://fonts.google.com/specimen/Yuji+Hentaigana+Akebono"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/yujihentaiganaakebono/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/yujihentaiganaakebono/YujiHentaiganaAkebono-Regular.ttf"
)
sha256sums=(
  "ef7c85c72ae94381c8bc4832ae4e6fbabdeafa2bb8a31313cd75dce95a690256"
  "8e387eeb5c24cd2945d8804caab8f97985b694cec8d2b228da63cceb16c7a8f3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
