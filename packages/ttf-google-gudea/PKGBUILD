pkgname=ttf-google-gudea
pkgver=1.003
pkgrel=1
_commit="6f23d06ca111a3ed09ca0137ee2aa514d3716847"  # Latest commit touching ofl/gudea
pkgdesc="Google Fonts family: Gudea"
arch=('any')
url="https://fonts.google.com/specimen/Gudea"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gudea/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gudea/Gudea-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gudea/Gudea-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gudea/Gudea-Regular.ttf"
)
sha256sums=(
  "315a576cbc7ab61c9e347b5725893bc8498fdcb8fc10831793c6864bc2cefba8"
  "2b1b56763dd590f782b65b07978fbe6f9a83ba5ecfdaf698c0e942ca06181059"
  "d4e7abc76e5bf3686436938840927b3522fd704c1f920514b31b67993409e274"
  "a4b5410090a821ea17021627312babdf3d8db0271217fd8c4d9f629ef0a2d90b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
