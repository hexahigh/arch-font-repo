pkgname=ttf-google-notoserifnyiakengpuachuehmong
pkgver=1.000
pkgrel=1
_commit="54584294ef89979740aa9687fdc3c04d11c4b539"  # Latest commit touching ofl/notoserifnyiakengpuachuehmong
pkgdesc="Google Fonts family: Noto Serif Nyiakeng Puachue Hmong"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Nyiakeng+Puachue+Hmong"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifnyiakengpuachuehmong/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifnyiakengpuachuehmong/NotoSerifNyiakengPuachueHmong%5Bwght%5D.ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "802b838de1cae59401c5140620479ee6dc4eaa28d877d4fcc5b79d92e8b43555"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
