pkgname=ttf-gluk-foglihtenno04
pkgver=0.70
pkgrel=1
pkgdesc="FoglihtenNo04 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=FoglihtenNo04'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/FoglihtenNo04/FoglihtenNo04-070.zip")
sha256sums=('63f288555bc5a92e044f28bb8b4adb91f3d8b0ae5fce4dd6283396c3aebd7d2b')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=FoglihtenNo04
License info from upstream page: OpenFontLicense
EOF
}
