pkgname=ttf-google-notosanstagbanwa
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanstagbanwa
pkgdesc="Google Fonts family: Noto Sans Tagbanwa"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Tagbanwa"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstagbanwa/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstagbanwa/NotoSansTagbanwa-Regular.ttf"
)
sha256sums=(
  "3c2f7990d23f5f5150ea8c8eab653a197ca191934cccbf09514afdae76b559b1"
  "9f9288024e3eddfd3ce77088c4806e0515d47aa093b1a04bc7bc24bdfd5d998a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
