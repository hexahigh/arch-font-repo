pkgname=ttf-google-stacksansnotch
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/stacksansnotch
pkgdesc="Google Fonts family: Stack Sans Notch"
arch=('any')
url="https://fonts.google.com/specimen/Stack+Sans+Notch"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/stacksansnotch/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/stacksansnotch/StackSansNotch%5Bwght%5D.ttf"
)
sha256sums=(
  "ebffb381c127e2c8b2b4d7e9e2aa515bb44ba2c62bf1db2f75ce5ea25e7005bb"
  "95ffd7f11127cce2f7c16017b0538498850183c58467b57d15a31e9613be3a40"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
