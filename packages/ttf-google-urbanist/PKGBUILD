pkgname=ttf-google-urbanist
pkgver=1.303
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/urbanist
pkgdesc="Google Fonts family: Urbanist"
arch=('any')
url="https://fonts.google.com/specimen/Urbanist"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/urbanist/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/urbanist/Urbanist-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/urbanist/Urbanist[wght].ttf"
)
sha256sums=(
  "ee1221b1c2d08920e5f9ca764eb228dafa5c8090df9cf665373c2287b9cb8f49"
  "05ac7a65decda23806d1678d44b8ef23dd656d6793555499dd79ee24c3e777ed"
  "748362d51eb276840e9f0023cd2d98299bf709a95fb3a5ae4ffcb624c638ebb9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
