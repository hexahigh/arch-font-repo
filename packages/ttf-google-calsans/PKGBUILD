pkgname=ttf-google-calsans
pkgver=1.000
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/calsans
pkgdesc="Google Fonts family: Cal Sans"
arch=('any')
url="https://fonts.google.com/specimen/Cal+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/calsans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/calsans/CalSans-Regular.ttf"
)
sha256sums=(
  "c6bd569e2bb98d55fcdaeb53918c023741772ea882d470844195f858a41c5551"
  "040f5d1335848146e769ca40ce9664ca8b7639eecdd7316f468b7db20d1c9c01"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
