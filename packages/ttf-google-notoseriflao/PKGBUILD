pkgname=ttf-google-notoseriflao
pkgver=2.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoseriflao
pkgdesc="Google Fonts family: Noto Serif Lao"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Lao"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriflao/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriflao/NotoSerifLao%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "a42993999944845fb5af693ea678a372a053db1f0981d55e911dcfa9d330f279"
  "c35bb3fbbdbd88c0d8ce5ee13e4854cb51471d9b809108570876b48c8f970df6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
