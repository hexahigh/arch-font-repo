pkgname=ttf-google-novaslim
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/novaslim
pkgdesc="Google Fonts family: Nova Slim"
arch=('any')
url="https://fonts.google.com/specimen/Nova+Slim"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/novaslim/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/novaslim/NovaSlim.ttf"
)
sha256sums=(
  "42e7b456fee0d0dc86927579b3d2626d42bb0f4cc9778f3a92ca8ada4e46348e"
  "78cf188017f211f64ea14fd1c946cc15dcfdec867f4759a50aff0b4350e38eed"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
