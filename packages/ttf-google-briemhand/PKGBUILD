pkgname=ttf-google-briemhand
pkgver=1.004
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/briemhand
pkgdesc="Google Fonts family: Briem Hand"
arch=('any')
url="https://fonts.google.com/specimen/Briem+Hand"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/briemhand/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/briemhand/BriemHand[wght].ttf"
)
sha256sums=(
  "ebd116b7b49a952a803623ceda86b549253f094f35934923dcbf9ba178086d67"
  "baa74c890e29a80a003ee4b50171daae4f448e5952491c9c2682ef6b5dffb02e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
