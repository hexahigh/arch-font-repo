pkgname=ttf-google-balthazar
pkgver=1.000
pkgrel=1
_commit="4f715b8d514494198ac324d00e7ea2443ab52485"  # Latest commit touching ofl/balthazar
pkgdesc="Google Fonts family: Balthazar"
arch=('any')
url="https://fonts.google.com/specimen/Balthazar"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/balthazar/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/balthazar/Balthazar-Regular.ttf"
)
sha256sums=(
  "876db27db250a9b9c03fc2ef30a5efe1f37c2ed2686d368c3779583bdf746912"
  "b495856b693458a99a4fcfe420944b6034afe823eb159e8437b4e8929d5aceaa"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
