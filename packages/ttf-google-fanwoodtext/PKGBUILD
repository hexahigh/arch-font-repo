pkgname=ttf-google-fanwoodtext
pkgver=1.101
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/fanwoodtext
pkgdesc="Google Fonts family: Fanwood Text"
arch=('any')
url="https://fonts.google.com/specimen/Fanwood+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/fanwoodtext/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/fanwoodtext/FanwoodText-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/fanwoodtext/FanwoodText-Regular.ttf"
)
sha256sums=(
  "9ca8b9e5db7184105da255bb110023cf1cce6caa56186341bb7b09ba97b20ba5"
  "23f51e2fda243a8759d5c32ff8a94da23dc697e8c9a014d4718aa0ab7ed3c808"
  "98aa9cbf5c5ece368501d188b1565ae3e7f6c9970ee3823769b8e67219dc33c2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
