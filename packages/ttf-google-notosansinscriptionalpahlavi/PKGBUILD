pkgname=ttf-google-notosansinscriptionalpahlavi
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansinscriptionalpahlavi
pkgdesc="Google Fonts family: Noto Sans Inscriptional Pahlavi"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Inscriptional+Pahlavi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansinscriptionalpahlavi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansinscriptionalpahlavi/NotoSansInscriptionalPahlavi-Regular.ttf"
)
sha256sums=(
  "0e246b748c637c88e8e0c34d5c1d27fe46bf477738653e46055df5c015c24ded"
  "96aa13745c70634bc902662aaa2a665818d277b04d3318992346c54954237cd6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
