pkgname=ttf-google-eczar
pkgver=2.000
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/eczar
pkgdesc="Google Fonts family: Eczar"
arch=('any')
url="https://fonts.google.com/specimen/Eczar"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/eczar/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/eczar/Eczar[wght].ttf"
)
sha256sums=(
  "003e3a0675b0b5d38cb6a188039d33a8d747a84effec32e7f8aa6e25cf6d3e2d"
  "b52af3a3b457f9b2278612b73c97eaf28270ffc91c99e4c90471cc15bb8748c6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
