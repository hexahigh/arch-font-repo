pkgname=ttf-google-averialibre
pkgver=1.002
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/averialibre
pkgdesc="Google Fonts family: Averia Libre"
arch=('any')
url="https://fonts.google.com/specimen/Averia+Libre"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/averialibre/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/averialibre/AveriaLibre-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averialibre/AveriaLibre-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averialibre/AveriaLibre-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averialibre/AveriaLibre-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averialibre/AveriaLibre-LightItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/averialibre/AveriaLibre-Regular.ttf"
)
sha256sums=(
  "46239ba6485d28553fd944da4ad32a00d9c403aa1c3e111676b0b96fe458d1d4"
  "374f67a2b8b8c7e45a543ec6558e03437e8c6a4450cc724a5d70cae89aba679d"
  "9a13370078d6be2c07778d2b03eee2e172aefc640c45327316a9ebf5c50d41a9"
  "5e5b4d33f0911fd1a2d23d2096533933f131dd258f8c3196e1695e64256a7202"
  "b74d2b2dadfe7bf27abf1f25bb1b324504e52d8f6452ebb34a5672fbce12ff05"
  "34871b14abcea6cb9dcee65ab635be65d08b0f825cd88d70a44ed5217bb9a524"
  "3dda695e06012f89b39eaccd77fbbcf22133a17b00ce5ddf3e4e9a996546b865"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
