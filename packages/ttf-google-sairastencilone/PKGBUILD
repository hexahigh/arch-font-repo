pkgname=ttf-google-sairastencilone
pkgver=1.004
pkgrel=1
_commit="d9fe4ab5599f2d07066c288ece78f552019e799e"  # Latest commit touching ofl/sairastencilone
pkgdesc="Google Fonts family: Saira Stencil One"
arch=('any')
url="https://fonts.google.com/specimen/Saira+Stencil+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sairastencilone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sairastencilone/SairaStencilOne-Regular.ttf"
)
sha256sums=(
  "fc7c16a0d286a351a7de245a0bd661275e9d393de8955c7fa37ef3c8b85b7e3e"
  "781496fdaf8e04cf6741b31025f6b4ba84f66021b097a8e0d85cbea2180cf223"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
