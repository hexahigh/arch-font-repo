pkgname=ttf-google-diphylleia
pkgver=1.000
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/diphylleia
pkgdesc="Google Fonts family: Diphylleia"
arch=('any')
url="https://fonts.google.com/specimen/Diphylleia"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/diphylleia/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/diphylleia/Diphylleia-Regular.ttf"
)
sha256sums=(
  "9279f4143833810493f74b4520c8b8fce2526d9df2da9564ffe897e065e1d461"
  "a0f505e19758bbe69da3e1cdd89fac74e69e851aa82195a61c861bcee7a53293"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
