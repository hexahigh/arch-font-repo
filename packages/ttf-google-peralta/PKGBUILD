pkgname=ttf-google-peralta
pkgver=1.000
pkgrel=1
_commit="5ba9c69c9623191a96ac6939a8932fa70ca408be"  # Latest commit touching ofl/peralta
pkgdesc="Google Fonts family: Peralta"
arch=('any')
url="https://fonts.google.com/specimen/Peralta"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/peralta/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/peralta/Peralta-Regular.ttf"
)
sha256sums=(
  "e8dd8f53b2fa502ace0636debbe7e357c4888d8d02b8b41d6a9a22d3058a63dc"
  "2bbd48b64ff49ca19148bbc3d6d8595f0262d8cf39809f443528754295c56c2b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
