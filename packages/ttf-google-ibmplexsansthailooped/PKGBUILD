  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthailooped/IBMPlexSansThaiLooped-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthailooped/IBMPlexSansThaiLooped-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthailooped/IBMPlexSansThaiLooped-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthailooped/IBMPlexSansThaiLooped-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansthailooped/IBMPlexSansThaiLooped-Thin.ttf"
)
sha256sums=(
