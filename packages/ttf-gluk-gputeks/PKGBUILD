pkgname=ttf-gluk-gputeks
pkgver=0.90
pkgrel=1
pkgdesc="Gputeks font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Gputeks'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/gputeks/Gputeks-0.9.zip")
sha256sums=('d8ac1f959a002ccfd05a2efa06984aabd1e217ebe833a6f2f413cb6b6cfcf0d3')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Gputeks
License info from upstream page: OpenFontLicense
EOF
}
