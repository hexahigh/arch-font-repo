pkgname=ttf-google-islandmoments
pkgver=1.010
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/islandmoments
pkgdesc="Google Fonts family: Island Moments"
arch=('any')
url="https://fonts.google.com/specimen/Island+Moments"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/islandmoments/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/islandmoments/IslandMoments-Regular.ttf"
)
sha256sums=(
  "e8697c6fe444e393a33ff5b9f929483db7a782b404f82453589782500298a22c"
  "688e4c5368b51b0d1122c4fb4c2c8f89c685f66bec489bfe07cb3287772c4b71"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
