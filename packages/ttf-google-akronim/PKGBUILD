pkgname=ttf-google-akronim
pkgver=1.002
pkgrel=1
_commit="585d3e2e90e8e7a4e463956ea010aeceea9e8193"  # Latest commit touching ofl/akronim
pkgdesc="Google Fonts family: Akronim"
arch=('any')
url="https://fonts.google.com/specimen/Akronim"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/akronim/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/akronim/Akronim-Regular.ttf"
)
sha256sums=(
  "f15a9a3a9a665c2d17655b8fedad86d9a8f30081d46bb91236beb1bc7294a589"
  "b5528ba2b9d60b90cbbe06e587655762dc518616d2613cbdf616751beaf7e2f8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
