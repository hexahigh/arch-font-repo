pkgname=ttf-google-whisper
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/whisper
pkgdesc="Google Fonts family: Whisper"
arch=('any')
url="https://fonts.google.com/specimen/Whisper"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/whisper/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/whisper/Whisper-Regular.ttf"
)
sha256sums=(
  "5a5681c41a0eb58eebe8ce4bad1bc8a088335a362c5d4fe02ca572dcadaae98f"
  "f1f415a0de888897ab638fe6a0547406ecc469901d26afd06af619ddb4c623ec"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
