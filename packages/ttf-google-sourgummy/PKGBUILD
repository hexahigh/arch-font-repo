pkgname=ttf-google-sourgummy
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sourgummy
pkgdesc="Google Fonts family: Sour Gummy"
arch=('any')
url="https://fonts.google.com/specimen/Sour+Gummy"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sourgummy/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sourgummy/SourGummy-Italic%5Bwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sourgummy/SourGummy%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "1eb024b31134b9e11ebdb2cd50697dd948d74a5a3eb7eedcfc4e71a8912a12ca"
  "04bad20f657e0938b4cafd5bb7e7a8801a3ab10506d53770e9d32a8a5cafbb82"
  "a9a710e4a90795f006b83fcf2ff3e036fc851d32c3c65762228df3c825675fd6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
