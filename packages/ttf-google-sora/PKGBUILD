pkgname=ttf-google-sora
pkgver=2.000
pkgrel=1
_commit="e4aca37908e6f3781f968785e4579a4b9a8434e8"  # Latest commit touching ofl/sora
pkgdesc="Google Fonts family: Sora"
arch=('any')
url="https://fonts.google.com/specimen/Sora"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sora/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sora/Sora%5Bwght%5D.ttf"
)
sha256sums=(
  "ba0b9729c9428ba79a0459ab8ec575791b51509dbec213e383d0316d37fec299"
  "84ff7096ae3ec6c8be47d906d1a0ba4de7f2ce78c615275c77301964a316e16c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
