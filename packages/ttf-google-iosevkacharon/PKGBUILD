  "https://github.com/google/fonts/raw/$_commit/ofl/iosevkacharon/IosevkaCharon-LightItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/iosevkacharon/IosevkaCharon-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/iosevkacharon/IosevkaCharon-MediumItalic.ttf"
