pkgname=ttf-google-gothica1
pkgver=2.50
pkgrel=1
_commit="765ac1ee9cca7d8d128b99c5bfd79d9a09c6fed8"  # Latest commit touching ofl/gothica1
pkgdesc="Google Fonts family: Gothic A1"
arch=('any')
url="https://fonts.google.com/specimen/Gothic+A1"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
