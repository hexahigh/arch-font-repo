  "https://github.com/google/fonts/raw/$_commit/ofl/gothica1/GothicA1-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gothica1/GothicA1-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gothica1/GothicA1-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gothica1/GothicA1-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gothica1/GothicA1-Thin.ttf"
)
