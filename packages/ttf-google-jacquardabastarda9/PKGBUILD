pkgname=ttf-google-jacquardabastarda9
pkgver=1.001
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/jacquardabastarda9
pkgdesc="Google Fonts family: Jacquarda Bastarda 9"
arch=('any')
url="https://fonts.google.com/specimen/Jacquarda+Bastarda+9"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/jacquardabastarda9/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/jacquardabastarda9/JacquardaBastarda9-Regular.ttf"
)
sha256sums=(
  "de769fdfdef9f647a840e14f8f3a1d60eaeb05cf646388cf4178bf824a7e4630"
  "7d8e5c30bd58598913fc5fd297bc875d1fab1c05fc407c2dfc406a0be9c5a22c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
