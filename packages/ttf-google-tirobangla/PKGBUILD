pkgname=ttf-google-tirobangla
pkgver=1.52
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/tirobangla
pkgdesc="Google Fonts family: Tiro Bangla"
arch=('any')
url="https://fonts.google.com/specimen/Tiro+Bangla"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/tirobangla/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/tirobangla/TiroBangla-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/tirobangla/TiroBangla-Regular.ttf"
)
sha256sums=(
  "2ed6051706542c5d6d96480318152b17900bb6d4dbadb11d7d5d6464d8b3e0dd"
  "deb8330a56697cfabef8ff393c6d36af60531229b138bf9a3ffe834330cb03e1"
  "a763523dc3f90a71962cb8d9400b8f0a86b40b2cb01676f165101a2967127ae4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
