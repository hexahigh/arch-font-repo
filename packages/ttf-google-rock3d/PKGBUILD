pkgname=ttf-google-rock3d
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rock3d
pkgdesc="Google Fonts family: Rock 3D"
arch=('any')
url="https://fonts.google.com/specimen/Rock+3D"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rock3d/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rock3d/Rock3D-Regular.ttf"
)
sha256sums=(
  "91595b148d8e476851147257a1234aa4a1dba722424fcdbdfca8965450fb48ad"
  "c95e67174335f12678fc309e321ad4e4099e9411b5a7a2edfbb5011116123f16"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
