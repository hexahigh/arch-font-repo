pkgname=ttf-google-caladea
pkgver=1.001
pkgrel=1
_commit="f6adb847ba23235450a30f0b66ef60db7cd6c60f"  # Latest commit touching ofl/caladea
pkgdesc="Google Fonts family: Caladea"
arch=('any')
url="https://fonts.google.com/specimen/Caladea"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/caladea/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/caladea/Caladea-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/caladea/Caladea-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/caladea/Caladea-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/caladea/Caladea-Regular.ttf"
)
sha256sums=(
  "ccdab61d371d8c8683a128a92cd7d498dbdb1d37689f7cb21f1bf6b16658d213"
  "ae3cb2dcbc925809dd29d2a44e9802211cab66be541bacbfc9c08c74b27c3742"
  "ccabaa7b7e2fdf253d2b1a5fa699dd8a3df8d835a9eb285ad82631a677eb76c0"
  "4359a8e24f748b6447b1ff6d7a174febe70961d29f8bb8634b56dacd740a3deb"
  "f1e899278b7b4491aba5b6a8253c4b04c050cc59b21865be5c37559a775153cd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
