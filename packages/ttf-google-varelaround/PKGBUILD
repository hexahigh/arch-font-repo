pkgname=ttf-google-varelaround
pkgver=3.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/varelaround
pkgdesc="Google Fonts family: Varela Round"
arch=('any')
url="https://fonts.google.com/specimen/Varela+Round"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/varelaround/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/varelaround/VarelaRound-Regular.ttf"
)
sha256sums=(
  "45446732635812510428bf1bad902a8b133f3c7348ad8593ecca90895595b278"
  "e1e47eb66dbc2ddc106661338e712d9176c9e83c669a82fde155324823d03aa2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
