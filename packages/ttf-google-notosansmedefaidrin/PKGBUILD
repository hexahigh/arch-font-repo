pkgname=ttf-google-notosansmedefaidrin
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansmedefaidrin
pkgdesc="Google Fonts family: Noto Sans Medefaidrin"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Medefaidrin"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmedefaidrin/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmedefaidrin/NotoSansMedefaidrin[wght].ttf"
)
sha256sums=(
  "47755a5e817c401cdca376815aae527195d333688277cce00a542b83ed532fa7"
  "538e31337f09ceaf290e374c2e8a649211ba56523482c2f6674e2868b5555546"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
