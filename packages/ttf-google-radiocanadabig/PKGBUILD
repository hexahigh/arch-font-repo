pkgname=ttf-google-radiocanadabig
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/radiocanadabig
pkgdesc="Google Fonts family: Radio Canada Big"
arch=('any')
url="https://fonts.google.com/specimen/Radio+Canada+Big"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/radiocanadabig/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/radiocanadabig/RadioCanadaBig-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/radiocanadabig/RadioCanadaBig%5Bwght%5D.ttf"
)
sha256sums=(
  "5253ab3498481bca4a73dda0c489848aa91770139ba0316eec3648a938e3c3a6"
  "0bb4d0d21d3e312415c9703df39099eb06e1129af970bb4daa2454c0edcb882d"
  "9d7fc9bd74b5d27e48bba194ed2993f054ebc9672463dc5f14bf1907932341d8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
