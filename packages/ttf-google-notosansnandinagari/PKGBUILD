pkgname=ttf-google-notosansnandinagari
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansnandinagari
pkgdesc="Google Fonts family: Noto Sans Nandinagari"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Nandinagari"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnandinagari/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnandinagari/NotoSansNandinagari-Regular.ttf"
)
sha256sums=(
  "1b03662d65f124e6333ccf45d389154e42028c8eee158b28ccba7ce344723b80"
  "ed326d58e570027ecff41cb3f0286a389f52118bf1313273e4ce2faa3d5d5f51"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
