pkgname=ttf-google-mclaren
pkgver=1.000
pkgrel=1
_commit="d92a4f3214862c9026ce734e85587dd68d88a5c2"  # Latest commit touching ofl/mclaren
pkgdesc="Google Fonts family: McLaren"
arch=('any')
url="https://fonts.google.com/specimen/McLaren"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mclaren/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mclaren/McLaren-Regular.ttf"
)
sha256sums=(
  "846ce83956a732edd57b74d9ba988d58abc8c8e6d0926859559318ce6aed139d"
  "3164e0dbdaa761e9a6bc1dff3532a3b3f631b6f2137c09847b2a7514e4bdc4ef"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
