pkgname=ttf-google-gajrajone
pkgver=1.000
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/gajrajone
pkgdesc="Google Fonts family: Gajraj One"
arch=('any')
url="https://fonts.google.com/specimen/Gajraj+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gajrajone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gajrajone/GajrajOne-Regular.ttf"
)
sha256sums=(
  "4e9a7cb5e08ca48e87b31184036b705690828000e1b5e8777f9ec01dce84aba6"
  "eb924f0e1cb9f29f129a76645dadcc36d0f3a831185ac530a6b5af607ae06231"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
