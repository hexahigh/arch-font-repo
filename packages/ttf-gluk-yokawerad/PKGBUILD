pkgname=ttf-gluk-yokawerad
pkgver=0.79
pkgrel=1
pkgdesc="Yokawerad font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Yokawerad'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Yokawerad/Yokawerad079.zip")
sha256sums=('fff4873b1b81087b06e3587356cd1ba6dd572e87dec969c387f7c36c5f4be41b')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Yokawerad
License info from upstream page: OpenFontLicense
EOF
}
