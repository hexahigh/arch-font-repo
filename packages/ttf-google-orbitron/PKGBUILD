pkgname=ttf-google-orbitron
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/orbitron
pkgdesc="Google Fonts family: Orbitron"
arch=('any')
url="https://fonts.google.com/specimen/Orbitron"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/orbitron/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/orbitron/Orbitron[wght].ttf"
)
sha256sums=(
  "ab609b0e110d622435ff337cdf233288556e011bbf9bd0550be98846c0630819"
  "f42db2dd16e642258e35782916eceb1dcdbea06fb958d77ad71dc5963587e8fd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
