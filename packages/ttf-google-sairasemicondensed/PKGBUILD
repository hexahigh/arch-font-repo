  "https://github.com/google/fonts/raw/$_commit/ofl/sairasemicondensed/SairaSemiCondensed-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sairasemicondensed/SairaSemiCondensed-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/sairasemicondensed/SairaSemiCondensed-SemiBold.ttf"
