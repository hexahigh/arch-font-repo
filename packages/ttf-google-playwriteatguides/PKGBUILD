pkgname=ttf-google-playwriteatguides
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwriteatguides
pkgdesc="Google Fonts family: Playwrite AT Guides"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+AT+Guides"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwriteatguides/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwriteatguides/PlaywriteATGuides-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwriteatguides/PlaywriteATGuides-Regular.ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "a9f075e96d4c33b614c5454a7b6b3e6f4ca68cfed0f3674713d3d0369f7dd058"
  "7708b88b250f4cb7a5a6395c97ffb46daf80034e2954c497b7c1a34ac6401ff6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
