pkgname=ttf-gluk-namskout
pkgver=0.32
pkgrel=1
pkgdesc="Namskout font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Namskout'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Namskout/Namskout_032.zip")
sha256sums=('ec35e688f98dac30bbecdc1c1e58ebbc4be34b4982b819cfbee5bea008d5c5e5')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Namskout
License info from upstream page: OpenFontLicense
EOF
}
