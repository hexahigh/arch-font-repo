pkgname=ttf-google-markazitextvfbeta
pkgver=1.000
pkgrel=1
_commit="4e5f06dbb274a27ebe71ed54ea706b3ee40eabd9"  # Latest commit touching ofl/markazitextvfbeta
pkgdesc="Google Fonts family: Markazitextvfbeta"
arch=('any')
url="https://fonts.google.com/specimen/Markazitextvfbeta"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/markazitextvfbeta/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/markazitextvfbeta/MarkaziText-VF.ttf"
)
sha256sums=(
  "51be9e2a0d1876b769a236d7a096a307c4e76242edeefe27ef351d412d30511c"
  "967e420776e4da0b9c0098eae46aaf3230b054f8eb4d1e8afcae8c651a3c406f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
