pkgname=ttf-google-notosanslepcha
pkgver=2.006
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanslepcha
pkgdesc="Google Fonts family: Noto Sans Lepcha"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Lepcha"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslepcha/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslepcha/NotoSansLepcha-Regular.ttf"
)
sha256sums=(
  "d6a4fe388105d6738b6f56eae2b43368a58e6191d5d62d9e9440b38b4d32547f"
  "9624931ae8f9a8a2a45233e5486fac1a80f333a0b3a25f84d0e2484363914f84"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
