pkgname=ttf-gluk-foglihtenno06
pkgver=0.76
pkgrel=1
pkgdesc="FoglihtenNo06 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=FoglihtenNo06'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/FoglihtenNo06/FoglihtenNo06_076.zip")
sha256sums=('e78232c4bd869a7efeebfcaf0d16d6b966fda1dc0728b6fcb4f04b9aa2b07423')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=FoglihtenNo06
License info from upstream page: OpenFontLicense
EOF
}
