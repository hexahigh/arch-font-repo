pkgname=ttf-google-gloock
pkgver=1.000
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/gloock
pkgdesc="Google Fonts family: Gloock"
arch=('any')
url="https://fonts.google.com/specimen/Gloock"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gloock/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gloock/Gloock-Regular.ttf"
)
sha256sums=(
  "321e28d45a430e017d9d1d6a47ef1fd261aad354723b014cf1933a765036c311"
  "c3a67e0212f7da01764796ae721cb9bab3e122d142354f97cf9c63fb763e6d77"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
