pkgname=ttf-google-limelight
pkgver=1.002
pkgrel=1
_commit="d841b5e71c64b527564a5cfeda7966ee523cc152"  # Latest commit touching ofl/limelight
pkgdesc="Google Fonts family: Limelight"
arch=('any')
url="https://fonts.google.com/specimen/Limelight"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/limelight/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/limelight/Limelight-Regular.ttf"
)
sha256sums=(
  "6b53fb03a50914cc382f4d025ee595c17c43f24ae870f840bc51969d3e316c7e"
  "f5bf8a9159adfc5b9c756c85d812a4fd1299b8916fefdf39ad4b24ade6d8d0cf"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
