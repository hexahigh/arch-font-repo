pkgname=ttf-google-notosanssyriacwestern
pkgver=3.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssyriacwestern
pkgdesc="Google Fonts family: Noto Sans Syriac Western"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Syriac+Western"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssyriacwestern/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssyriacwestern/NotoSansSyriacWestern[wght].ttf"
)
sha256sums=(
  "8636ef5e1d3912baff80863bdee75d056a3c148896ad0689c00aa72d11d83172"
  "29d375b81b36ab042c543f94b31a9ca4982ee1af02e352a6285fa6a0ce25c5b8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
