pkgname=ttf-google-calligraffitti
pkgver=1.002
pkgrel=1
_commit="23d083ea347fd3f0bbb061c1dfbe7777b6c93d6b"  # Latest commit touching apache/calligraffitti
pkgdesc="Google Fonts family: Calligraffitti"
arch=('any')
url="https://fonts.google.com/specimen/Calligraffitti"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/calligraffitti/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/calligraffitti/Calligraffitti-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "d6c0464e8c53dd8fefca7ee3af1aa2c20c6cf6a40e4537d2cd4353bff3a168d0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
