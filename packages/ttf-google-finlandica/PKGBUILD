pkgname=ttf-google-finlandica
pkgver=1.064
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/finlandica
pkgdesc="Google Fonts family: Finlandica"
arch=('any')
url="https://fonts.google.com/specimen/Finlandica"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/finlandica/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/finlandica/Finlandica-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/finlandica/Finlandica%5Bwght%5D.ttf"
)
sha256sums=(
  "0a55f40011bdfbdd4a07ef363fdc054d92ca3a5f0fc66381aac82344bd9cec2c"
  "70b7bddb5b5d01aeb8461e5a4c0d022efbc892ad96f68eb7d163cb3440360725"
  "8192c7f916ad929890b799bd4fe0974200be62e024c267c7b234632caca6658e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
