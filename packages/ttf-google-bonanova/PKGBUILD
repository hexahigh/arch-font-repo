pkgname=ttf-google-bonanova
pkgver=4.001
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bonanova
pkgdesc="Google Fonts family: Bona Nova"
arch=('any')
url="https://fonts.google.com/specimen/Bona+Nova"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bonanova/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bonanova/BonaNova-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bonanova/BonaNova-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bonanova/BonaNova-Regular.ttf"
)
sha256sums=(
  "38f7dca74a98bbcc13858c9f56e9c7d86e12b4242f2a5ccbecf6e9277c9fd363"
  "c59ccb3ba8f0151236b1b427b58bee0c90607c82ef747cc6e19d5e20138385dd"
  "0d61c160a521b072d1af19e9683754f3f5761bbce35f73fdf091ecdf495bc6c2"
  "d72f7715b6b66096e0cc2971e4954f8be33bdced1f143f9c5739a03cdb60bede"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
