pkgname=ttf-google-scada
pkgver=4.000
pkgrel=1
_commit="378672967bf54af2ff1eec93fcf3ad6e3a22c414"  # Latest commit touching ofl/scada
pkgdesc="Google Fonts family: Scada"
arch=('any')
url="https://fonts.google.com/specimen/Scada"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/scada/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/scada/Scada-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/scada/Scada-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/scada/Scada-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/scada/Scada-Regular.ttf"
)
sha256sums=(
  "0a852a06f0256a6684662663ccb1d8e08d131abd1f70cf8d972a344cf31aa381"
  "3a0085400cfc229bc4329e77dd5a11eb79e7fc881f5c285f813b251133ddd095"
  "c509976fc82880d6729bf6a4db19786f2eaf86dfe4ccf36060afb3d871e6f547"
  "3f479dbfe80ed74d3ff880076468f9818edd28ff9909e5f22ce698224a085c1f"
  "4ae8f108b8ce016017a2fe40ff65ec613eb6a4149ce3b9a9fe60cea117b55036"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
