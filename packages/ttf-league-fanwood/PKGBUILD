pkgname=ttf-league-fanwood
pkgver=20240219
pkgrel=1
pkgdesc="The League of Moveable Type family: fanwood"
arch=('any')
url='https://github.com/theleagueof/fanwood'
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=("https://github.com/theleagueof/fanwood/archive/cbaaed9704e7d37d3dcdbdf0b472e9efd0e39432.tar.gz")
sha256sums=("f2cb82ff4891c87f4a6ffafa70168be32ff79a193f42c4448902630f8138340f")

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped OpenType/TrueType font binaries from the repository archive.
  find "${srcdir}" -type f \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  license_file="$(find "${srcdir}" -type f \( -iname 'OFL*' -o -iname 'LICENSE*' \) | head -n 1)"
  if [[ -n "${license_file}" ]]; then
    install -Dm644 "${license_file}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  fi
}
