pkgname=ttf-google-notoserifdogra
pkgver=1.007
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifdogra
pkgdesc="Google Fonts family: Noto Serif Dogra"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Dogra"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifdogra/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifdogra/NotoSerifDogra-Regular.ttf"
)
sha256sums=(
  "5e67c5a885cfcfd6ce8c2807e440c07091e3ea5432b2557b13611e3ce5b0691b"
  "82c4680f67a8437f6e237adbc5da559751bb3fcd251e9b82c6d7bd9879896024"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
