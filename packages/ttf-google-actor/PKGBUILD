pkgname=ttf-google-actor
pkgver=1.001
pkgrel=1
_commit="d72de0f2297b05318463f4855da59ce433f9aaa7"  # Latest commit touching ofl/actor
pkgdesc="Google Fonts family: Actor"
arch=('any')
url="https://fonts.google.com/specimen/Actor"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/actor/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/actor/Actor-Regular.ttf"
)
sha256sums=(
  "c1bcd16ffc9d095822fd6b7fa1a24c7918b24815ed05711421f804293d2efa62"
  "a7cf62975a5ecaa8a3be2e2913ffb4a335831315478b93bec722ad982308ea38"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
