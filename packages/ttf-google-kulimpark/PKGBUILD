  "https://github.com/google/fonts/raw/$_commit/ofl/kulimpark/KulimPark-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/kulimpark/KulimPark-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/kulimpark/KulimPark-SemiBoldItalic.ttf"
