pkgname=ttf-google-eduqldbeginner
pkgver=1.003
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/eduqldbeginner
pkgdesc="Google Fonts family: Edu QLD Beginner"
arch=('any')
url="https://fonts.google.com/specimen/Edu+QLD+Beginner"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/eduqldbeginner/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/eduqldbeginner/EduQLDBeginner%5Bwght%5D.ttf"
)
sha256sums=(
  "9c50bb9d2dbfd864553688da113bf817a294f3721b7a35ac6569c63bb939a998"
  "de937b07983c86f690a114d012c5d38cc607cb11cd75aa2cbfa638d5ae109c39"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
