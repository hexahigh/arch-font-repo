pkgname=ttf-google-molle
pkgver=1.002
pkgrel=1
_commit="b270f3a60d9565e4a7b0a07fc07890a783297890"  # Latest commit touching ofl/molle
pkgdesc="Google Fonts family: Molle"
arch=('any')
url="https://fonts.google.com/specimen/Molle"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/molle/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/molle/Molle-Regular.ttf"
)
sha256sums=(
  "af9b97696048d509e3d70f8108b7c4381084f95c8fedd97acaa76b0b287668be"
  "5693a09a77e5afd28380d269e2cf03ca78c4fd92a8bacd248910221cbfe2ef58"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
