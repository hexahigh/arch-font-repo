pkgname=ttf-google-sassyfrass
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sassyfrass
pkgdesc="Google Fonts family: Sassy Frass"
arch=('any')
url="https://fonts.google.com/specimen/Sassy+Frass"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sassyfrass/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sassyfrass/SassyFrass-Regular.ttf"
)
sha256sums=(
  "4c28e5c8e904020d010057646481259101cc0d10a6a8e204d8d796f083ecb4c7"
  "91fc6e0f43a277ddb590faf8a97fd3016f4f1251a9dea2deaf658b1812c42899"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
