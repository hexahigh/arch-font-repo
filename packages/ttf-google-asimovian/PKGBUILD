pkgname=ttf-google-asimovian
pkgver=3.000
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/asimovian
pkgdesc="Google Fonts family: Asimovian"
arch=('any')
url="https://fonts.google.com/specimen/Asimovian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/asimovian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/asimovian/Asimovian-Regular.ttf"
)
sha256sums=(
  "26e2c22734ef964801002595098bc0473a04b14112f9a003acb4959c3dd2046b"
  "0ca907ed08a2d43785fabdda6be798771cce01df266e6c42a8dd28b7c36ea5df"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
