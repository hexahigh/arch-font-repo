pkgname=ttf-google-alumnisanscollegiateone
pkgver=1.100
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/alumnisanscollegiateone
pkgdesc="Google Fonts family: Alumni Sans Collegiate One"
arch=('any')
url="https://fonts.google.com/specimen/Alumni+Sans+Collegiate+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanscollegiateone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanscollegiateone/AlumniSansCollegiateOne-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanscollegiateone/AlumniSansCollegiateOne-Regular.ttf"
)
sha256sums=(
  "2b0ed87071361caf613d6362b46d7289037f1001af3b11ab747905692f87025e"
  "aa1ec3cafa94926b00e61da029c48271e6845400167c10f8b659b938da9d54ee"
  "9bd48b280391794c7a5aea97476b25051b4705c7963e4b63b2c84876db31b59b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
