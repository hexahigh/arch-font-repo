pkgname=ttf-google-notocoloremojicompattest
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notocoloremojicompattest
pkgdesc="Google Fonts family: Noto Color Emoji Compat Test"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Color+Emoji+Compat+Test"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notocoloremojicompattest/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notocoloremojicompattest/NotoColorEmojiCompatTest-Regular.ttf"
)
sha256sums=(
  "531b0954400dc0026fd55302be06c665c895d2795819d1d18a642652afee1a7a"
  "6e549759a4476fb250b0f787fd84689f8edeef15eebc8779d5ce5159534db6cb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
