pkgname=ttf-google-swankyandmoomoo
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/swankyandmoomoo
pkgdesc="Google Fonts family: Swanky and Moo Moo"
arch=('any')
url="https://fonts.google.com/specimen/Swanky+and+Moo+Moo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/swankyandmoomoo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/swankyandmoomoo/SwankyandMooMoo.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "a745effa8961790717966f7c69d96756a7abe2d334a08be333a656b7c54b627f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
