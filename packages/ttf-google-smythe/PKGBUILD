pkgname=ttf-google-smythe
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/smythe
pkgdesc="Google Fonts family: Smythe"
arch=('any')
url="https://fonts.google.com/specimen/Smythe"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/smythe/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/smythe/Smythe-Regular.ttf"
)
sha256sums=(
  "d849309d514833fe3d7a610e10f6cd5d99b4f9552bfa304969acbf89c66e4422"
  "51207abbe4ef2d576b3033e95fc5bd30282c0db766807e1b8ae3f19d2540e11c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
