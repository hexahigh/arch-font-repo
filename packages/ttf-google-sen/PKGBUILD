pkgname=ttf-google-sen
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sen
pkgdesc="Google Fonts family: Sen"
arch=('any')
url="https://fonts.google.com/specimen/Sen"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sen/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sen/Sen[wght].ttf"
)
sha256sums=(
  "1d37e58d4bc1383c5141211bbd5bf123d80aa1d26d5b09dfcbac2bfc2fffb826"
  "5a2d5777100be28024b4f28505d678c006bc52e9d9fa78f554a1252b5f254c77"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
