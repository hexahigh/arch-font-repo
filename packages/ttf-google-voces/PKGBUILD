pkgname=ttf-google-voces
pkgver=1.100
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/voces
pkgdesc="Google Fonts family: Voces"
arch=('any')
url="https://fonts.google.com/specimen/Voces"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/voces/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/voces/Voces-Regular.ttf"
)
sha256sums=(
  "fd17f80dc48ff767d91d0dd9f821eebfd8b73ee82f55537a9052b6b0107622c8"
  "828b9e89bf8f207aa3b4bb929b2d4f19ef56e927adb55e5a22192564e891a2c8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
