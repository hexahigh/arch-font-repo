pkgname=ttf-google-dosis
pkgver=3.002
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/dosis
pkgdesc="Google Fonts family: Dosis"
arch=('any')
url="https://fonts.google.com/specimen/Dosis"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/dosis/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/dosis/Dosis%5Bwght%5D.ttf"
)
sha256sums=(
  "6dfa3951f0c829518b284608fcc1acb196cba1536b1ae1713a49deccde1ccc53"
  "b2238eef0b3464904fed097ef274c704bc63d21407369b7d7a5be7b0821a0e82"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
