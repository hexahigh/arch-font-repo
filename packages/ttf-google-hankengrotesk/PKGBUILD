pkgname=ttf-google-hankengrotesk
pkgver=3.013
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/hankengrotesk
pkgdesc="Google Fonts family: Hanken Grotesk"
arch=('any')
url="https://fonts.google.com/specimen/Hanken+Grotesk"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hankengrotesk/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hankengrotesk/HankenGrotesk-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/hankengrotesk/HankenGrotesk[wght].ttf"
)
sha256sums=(
  "e02ccb89a86839b22feff7872ff5cc355cc0f58318d29eee20e2cf83a612f16d"
  "ae5731726ff75301a3cb63f2e98d1babc77d55ab09fb8e229ca75f5bd46fbe32"
  "813b3f8fa0965405669a89b38e51bbefd95eef6b8e20d1cb2d8c10cce062662f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
