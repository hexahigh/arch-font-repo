pkgname=ttf-google-rasa
pkgver=2.004
pkgrel=1
_commit="a475fc8d6ca08bfb14336a7c8ea81b41f81e6a04"  # Latest commit touching ofl/rasa
pkgdesc="Google Fonts family: Rasa"
arch=('any')
url="https://fonts.google.com/specimen/Rasa"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rasa/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rasa/Rasa-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/rasa/Rasa[wght].ttf"
)
sha256sums=(
  "27d2d3c15cded787be66c6f51c4b24bea99863f4f162961b5088e4521c2e2bd5"
  "ecea773edd1e87c3310a0fb811ec6102aea71da235f93bc2ce2506e81b3c21a7"
  "10d2f75aaf7b3f232c948c34584c49caf0cdd17a4c93eb7a5aeb3438efd42e19"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
