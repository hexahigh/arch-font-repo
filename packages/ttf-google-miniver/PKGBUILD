pkgname=ttf-google-miniver
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/miniver
pkgdesc="Google Fonts family: Miniver"
arch=('any')
url="https://fonts.google.com/specimen/Miniver"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/miniver/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/miniver/Miniver-Regular.ttf"
)
sha256sums=(
  "56c4ff36faaaf336bc5fee659ff6fab2413d67499cc22acc29079b3892d8931b"
  "0637ff653a9113189d196434f2055388638083dde397964b83aa2c1800d5b5b7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
