pkgname=ttf-google-corben
pkgver=1.101
pkgrel=1
_commit="848e1a926ba00990a9621b9629c84405639db40c"  # Latest commit touching ofl/corben
pkgdesc="Google Fonts family: Corben"
arch=('any')
url="https://fonts.google.com/specimen/Corben"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/corben/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/corben/Corben-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/corben/Corben-Regular.ttf"
)
sha256sums=(
  "aad1e82802172d4c1d22dd015a5b8b4275e5665a49c1df54ed64716fca7ae194"
  "1fb5959682b89680467ab628e2f1e6359c6062acbb7edcea14ffcca1124db0f1"
  "dd2c2697a8f936a43b5f0a2bae1bc82cdaf40f8a5fc1d15c1ecd562b3ea16044"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
