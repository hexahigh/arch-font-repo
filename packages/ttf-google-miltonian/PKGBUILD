pkgname=ttf-google-miltonian
pkgver=1.008
pkgrel=1
_commit="2ee77f8a4d2c906cee5a0e8d03bb7df233a060b4"  # Latest commit touching ofl/miltonian
pkgdesc="Google Fonts family: Miltonian"
arch=('any')
url="https://fonts.google.com/specimen/Miltonian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/miltonian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/miltonian/Miltonian-Regular.ttf"
)
sha256sums=(
  "aa5d677391db4e54ad324b6888792e533c5d800de7ab713302a2fc8bff2f4f6e"
  "bd4ada3764e6774964efe097463533b2759755e390f68e3d16974264f8dd2d98"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
