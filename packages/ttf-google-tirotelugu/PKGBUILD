pkgname=ttf-google-tirotelugu
pkgver=1.53
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/tirotelugu
pkgdesc="Google Fonts family: Tiro Telugu"
arch=('any')
url="https://fonts.google.com/specimen/Tiro+Telugu"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/tirotelugu/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/tirotelugu/TiroTelugu-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/tirotelugu/TiroTelugu-Regular.ttf"
)
sha256sums=(
  "2ed6051706542c5d6d96480318152b17900bb6d4dbadb11d7d5d6464d8b3e0dd"
  "8f15489b577de6f135113df186ca09440adeba233999ad345cf16f7fc1bd766b"
  "aefd72a31b1a9d726047d3dc34568f0aacc3a5048971f73d3228d4d2a6087240"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
