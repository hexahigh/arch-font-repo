pkgname=ttf-google-hubotsans
pkgver=2.000
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/hubotsans
pkgdesc="Google Fonts family: Hubot Sans"
arch=('any')
url="https://fonts.google.com/specimen/Hubot+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hubotsans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hubotsans/HubotSans-Italic%5Bwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/hubotsans/HubotSans%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "9593ae8ccefcbd9f3dea9e4da74b421ea04da7f597e8e64250f6419fc6032139"
  "785b129a5b9c8f04b4e8883dd26235ef7ae58d862068726a3e254092c28bc829"
  "229c7682f64b499668d2f47ac803bbde0b5a63225326c8659ea436748ab29965"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
