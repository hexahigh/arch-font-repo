pkgname=ttf-google-judson
pkgver=20110429
pkgrel=1
_commit="6ee14a75a282b5f435bfe7f15638d1693702100f"  # Latest commit touching ofl/judson
pkgdesc="Google Fonts family: Judson"
arch=('any')
url="https://fonts.google.com/specimen/Judson"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/judson/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/judson/Judson-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/judson/Judson-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/judson/Judson-Regular.ttf"
)
sha256sums=(
  "36e2f1debc9778bac79fac1a0cb5a5ef51c102f00b58ef7d8a05324144b68166"
  "07e77390c353d7e4e69862b91e0a79f6774b19d1602b5f4a504ed15ef6f1023c"
  "2bddaed218ead284599fcdcc2889dfb59e804f89db48779e05c0ee87216fdd8f"
  "73790bf79197e5bbf24178df3841ff27fb2fca05dd1f17fc1046e4bbe16caf95"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
