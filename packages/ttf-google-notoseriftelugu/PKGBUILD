pkgname=ttf-google-notoseriftelugu
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoseriftelugu
pkgdesc="Google Fonts family: Noto Serif Telugu"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Telugu"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriftelugu/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoseriftelugu/NotoSerifTelugu%5Bwght%5D.ttf"
)
sha256sums=(
  "481c72a8f1b4f645a7e6b10326be41b2da2c15cb470ff48a07fab773eed00102"
  "32210d8d514d9aad43bf927fbd47c7e3066ee6a20c0258678f2ee45915012a26"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
