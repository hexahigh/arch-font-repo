pkgname=ttf-google-hubballi
pkgver=1.000
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/hubballi
pkgdesc="Google Fonts family: Hubballi"
arch=('any')
url="https://fonts.google.com/specimen/Hubballi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hubballi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hubballi/Hubballi-Regular.ttf"
)
sha256sums=(
  "0f3199eac4dcfc512e37593730841da3da6a937ac633c3f0f61d13355d3744d3"
  "e51ad77d40b5adccd6c6ca537863ef4e364bd374c56593e007fbf5402a9a1cdd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
