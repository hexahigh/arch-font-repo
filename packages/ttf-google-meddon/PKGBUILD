pkgname=ttf-google-meddon
pkgver=1.000
pkgrel=1
_commit="30c61ef30bf7b89629cf20a2f9b52f76f367c400"  # Latest commit touching ofl/meddon
pkgdesc="Google Fonts family: Meddon"
arch=('any')
url="https://fonts.google.com/specimen/Meddon"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/meddon/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/meddon/Meddon.ttf"
)
sha256sums=(
  "eb1992aec1cf892ec94ffc116d79b62c7cb03dc108141b94a57a4195d210b514"
  "c983e998ff7e01242544659c971bf4055bfb43a9fc5a0dd83ca7dafd105f94da"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
