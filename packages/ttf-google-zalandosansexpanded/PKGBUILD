pkgname=ttf-google-zalandosansexpanded
pkgver=1.800
pkgrel=1
_commit="7be71b9a2a85b75a02227fb6a7395cf7fb57a9db"  # Latest commit touching ofl/zalandosansexpanded
pkgdesc="Google Fonts family: Zalando Sans Expanded"
arch=('any')
url="https://fonts.google.com/specimen/Zalando+Sans+Expanded"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosansexpanded/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosansexpanded/ZalandoSansExpanded-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosansexpanded/ZalandoSansExpanded%5Bwght%5D.ttf"
)
sha256sums=(
  "411a22de2734b25584e4764f7212b004f241181ac04944a3bcee0e0371afe547"
  "289cd38cd7880f4af8e2714a6190f6511ebde887354eb9ad5f5e45c1c892c6de"
  "e3f331b7125dfdcd202f2135c8b48a3766ba5c4fafaa6fedad1bf37b01d6fb3b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
