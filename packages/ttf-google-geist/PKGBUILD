pkgname=ttf-google-geist
pkgver=1.800
pkgrel=1
_commit="87a44ad3d4535f7b3a5a715a08e8944f144afd06"  # Latest commit touching ofl/geist
pkgdesc="Google Fonts family: Geist"
arch=('any')
url="https://fonts.google.com/specimen/Geist"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/geist/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/geist/Geist-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/geist/Geist%5Bwght%5D.ttf"
)
sha256sums=(
  "1781d2806a07d91c4edf4740b88449fab7d0eadad53f7c351b94cd4d4eb8c00f"
  "a464348abe41a6392f18d04c0ac2ad3c26619357ff5fdd76aff3059116f45e62"
  "73894e0448cae90a92b6c2f8732b7bb9acb7b94c418bff559dad4a18e1de9659"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
