pkgname=ttf-google-roboto
pkgver=3.015
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/roboto
pkgdesc="Google Fonts family: Roboto"
arch=('any')
url="https://fonts.google.com/specimen/Roboto"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/roboto/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/roboto/Roboto-Italic%5Bwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/roboto/Roboto%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "061402327a96aadb0bfb694a960ed289ecd38d383e396243831ab81feb109c41"
  "9725a847af6b460ffca162ae66d20dad48b01876137947180b42d7dcd7887182"
  "d7598e12c5dbef095ff8272cfc55da0250bd07fbdecbac8a530b9b277872a134"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
