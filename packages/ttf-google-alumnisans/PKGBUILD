pkgname=ttf-google-alumnisans
pkgver=1.018
pkgrel=1
_commit="db061989d54a1a232e07d38aabf7c094f2ba29d2"  # Latest commit touching ofl/alumnisans
pkgdesc="Google Fonts family: Alumni Sans"
arch=('any')
url="https://fonts.google.com/specimen/Alumni+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisans/AlumniSans-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisans/AlumniSans[wght].ttf"
)
sha256sums=(
  "08e1c6fa00b198f9cf90fd8c7f540ce400892063234d5a3b38dcae9f659c977f"
  "2ad29364c0841c2057eee44b3d13deb2af74d3f13e14bc519a8dfd4142c1ad54"
  "9255d5201c7aba5bf1bde1e8521f0fee691f0588b83f40db228a5f9bbaacfbc4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
