pkgname=ttf-google-zalandosans
pkgver=1.800
pkgrel=1
_commit="84e6b03dc0ace8f84973eac176e1430eeec1aea4"  # Latest commit touching ofl/zalandosans
pkgdesc="Google Fonts family: Zalando Sans"
arch=('any')
url="https://fonts.google.com/specimen/Zalando+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosans/ZalandoSans-Italic%5Bwdth%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/zalandosans/ZalandoSans%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "411a22de2734b25584e4764f7212b004f241181ac04944a3bcee0e0371afe547"
  "70dcf38b38ee3f179211f4a43f99a4cf4e976e16336676d83ae83a8e79078336"
  "9ef9c85d9b108f588858e045aee46ebbc8e324002d1891c2f662d40a2704dcd8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
