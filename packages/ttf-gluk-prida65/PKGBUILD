pkgname=ttf-gluk-prida65
pkgver=0.64
pkgrel=1
pkgdesc="Prida65 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Prida65'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Prida65/Prida65.zip")
sha256sums=('f8693c4a2c6766a2a279948f78d2a9b5ecbdfba987d6ae3e13d924c4efaf51df')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Prida65
License info from upstream page: OpenFontLicense
EOF
}
