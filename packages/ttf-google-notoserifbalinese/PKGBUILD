pkgname=ttf-google-notoserifbalinese
pkgver=2.007
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifbalinese
pkgdesc="Google Fonts family: Noto Serif Balinese"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Balinese"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifbalinese/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifbalinese/NotoSerifBalinese-Regular.ttf"
)
sha256sums=(
  "ecabb888bd0f68305f514ad22d780951da537fba72370ccb36f6209cdb14325f"
  "781c98b8d5ff17e9647442f2d2e931c2033df17b3ce63cb376fc9b6c8ede05d4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
