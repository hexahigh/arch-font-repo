pkgname=ttf-google-notosansoldturkic
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansoldturkic
pkgdesc="Google Fonts family: Noto Sans Old Turkic"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Old+Turkic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoldturkic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoldturkic/NotoSansOldTurkic-Regular.ttf"
)
sha256sums=(
  "74bb75fa973b17a9cf559445529c1a9fa56b3afe55dcc19608469ac79a03f25f"
  "b8e3f206a9fdaea960a988bb1ed3275391eb534d127859611dca87f2204da4a7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
