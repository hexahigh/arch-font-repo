pkgname=ttf-google-sendflowers
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sendflowers
pkgdesc="Google Fonts family: Send Flowers"
arch=('any')
url="https://fonts.google.com/specimen/Send+Flowers"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sendflowers/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sendflowers/SendFlowers-Regular.ttf"
)
sha256sums=(
  "a07b444918d700ed5d2e5ca153d3e55035874c24f8ed7a30ee9be026b03a719a"
  "4c667e639f9c8a37c3d46663be0885245c3b0fbc283138cfa5d83135f3386c91"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
