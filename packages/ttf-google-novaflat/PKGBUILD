pkgname=ttf-google-novaflat
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/novaflat
pkgdesc="Google Fonts family: Nova Flat"
arch=('any')
url="https://fonts.google.com/specimen/Nova+Flat"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/novaflat/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/novaflat/NovaFlat.ttf"
)
sha256sums=(
  "d2f87f90d108a947f98c030d9d8e4bf27e761ce83f222453b9a7230c5fb309e1"
  "de302932cdca6d274f7f791b9805d6e0f84ec44ae6ed630f1b1e8c616fc04c42"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
