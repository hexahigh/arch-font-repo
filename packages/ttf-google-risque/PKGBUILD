pkgname=ttf-google-risque
pkgver=1.000
pkgrel=1
_commit="70a05e2bb43a57ce59ce89abba8e7d28c29192ef"  # Latest commit touching ofl/risque
pkgdesc="Google Fonts family: Risque"
arch=('any')
url="https://fonts.google.com/specimen/Risque"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/risque/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/risque/Risque-Regular.ttf"
)
sha256sums=(
  "33e3a83e377c6a41149044bd919f50d9a971d801052d4e0c0a98cb417b42ae38"
  "84b3d76741a27e63c66af80c24dee25ed58172751d0fcb3a5f4bd582676bfabd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
