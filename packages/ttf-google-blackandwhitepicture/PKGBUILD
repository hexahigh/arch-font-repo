pkgname=ttf-google-blackandwhitepicture
pkgver=1.64
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/blackandwhitepicture
pkgdesc="Google Fonts family: Black And White Picture"
arch=('any')
url="https://fonts.google.com/specimen/Black+And+White+Picture"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/blackandwhitepicture/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/blackandwhitepicture/BlackAndWhitePicture-Regular.ttf"
)
sha256sums=(
  "a9b3e7e1cf5735dc49d802b88b1858a2a50307ba2a877ddf3f0b27d8b1d0abc5"
  "4d72cd6de1f210b446c86f06b4e13d7641cbcfb1b375c6927341388aa8e08056"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
