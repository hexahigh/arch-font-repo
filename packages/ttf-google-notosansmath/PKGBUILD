pkgname=ttf-google-notosansmath
pkgver=3.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansmath
pkgdesc="Google Fonts family: Noto Sans Math"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Math"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmath/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmath/NotoSansMath-Regular.ttf"
)
sha256sums=(
  "403a95275b469061b7d4371c328e0ada3bc7d63328abe2e88aad5cd243b2fe21"
  "3f495fe933c06786e4d5f6d86b8ee70b6753a68ee3b9d87528726de0f6e2c47d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
