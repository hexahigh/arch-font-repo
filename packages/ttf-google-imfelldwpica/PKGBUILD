pkgname=ttf-google-imfelldwpica
pkgver=3.00
pkgrel=1
_commit="f023d9d161d4456ab39bb2eff4acd970e02dbe36"  # Latest commit touching ofl/imfelldwpica
pkgdesc="Google Fonts family: IM Fell DW Pica"
arch=('any')
url="https://fonts.google.com/specimen/IM+Fell+DW+Pica"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/imfelldwpica/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/imfelldwpica/IMFePIit28P.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/imfelldwpica/IMFePIrm28P.ttf"
)
sha256sums=(
  "2a3ca501fc4d5efcad9798531e3e06962b1e20c60e464f6cbd6c17630112c773"
  "e09a00654b5dd266aee743c0c43d129c8404a2d5e0ebf27e5a0e472bd1900b8d"
  "f65e54016dfab4222ba552cfb82260b14a7df6527cce66430f5f66022addb052"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
