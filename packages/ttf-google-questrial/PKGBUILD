pkgname=ttf-google-questrial
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/questrial
pkgdesc="Google Fonts family: Questrial"
arch=('any')
url="https://fonts.google.com/specimen/Questrial"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/questrial/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/questrial/Questrial-Regular.ttf"
)
sha256sums=(
  "c9bcf9bea97a216657d25325f418f0fe7fd0bc847b3dbb3f1b5a05b207370608"
  "0ee7f2debabb13773fd38468b31820e11fca202a8f98c4d80b6ffcb796899b6f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
