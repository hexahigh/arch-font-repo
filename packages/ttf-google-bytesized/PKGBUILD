pkgname=ttf-google-bytesized
pkgver=1.000
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bytesized
pkgdesc="Google Fonts family: Bytesized"
arch=('any')
url="https://fonts.google.com/specimen/Bytesized"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bytesized/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bytesized/Bytesized-Regular.ttf"
)
sha256sums=(
  "5f1150f1ed33740aa5549f68f4bbbfd5d61b9bab8a5502d03349a08714765e46"
  "867b090a29cf5b45378692d3163439bb51875a3ddf4e37dcabf62030d04f1d51"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
