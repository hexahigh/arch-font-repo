pkgname=ttf-google-librecaslontext
pkgver=2.000
pkgrel=1
_commit="ea37b132420c876be7220094ea6374be0efb23e3"  # Latest commit touching ofl/librecaslontext
pkgdesc="Google Fonts family: Libre Caslon Text"
arch=('any')
url="https://fonts.google.com/specimen/Libre+Caslon+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/librecaslontext/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/librecaslontext/LibreCaslonText-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/librecaslontext/LibreCaslonText%5Bwght%5D.ttf"
)
sha256sums=(
  "a294245c822c5aa9fd9a9f3189418e99415428be5fecadf797793d5d8f6a3ad3"
  "60ca1a3aade61c8c381800ca85b9b2f0fb341d89ebe065e12cd6ec2ee2e53e54"
  "c11809dbfd5445886293d89b32bfc2584075c80e77750cf1c284113e36b8b3f4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
