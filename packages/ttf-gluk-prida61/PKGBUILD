pkgname=ttf-gluk-prida61
pkgver=0.53
pkgrel=1
pkgdesc="Prida61 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Prida61'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Prida61/Prida61.zip")
sha256sums=('9bb6dd6e157f507b3746f8f00abc7bb698b1153d12a41266012444d93cff3bfc')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Prida61
License info from upstream page: OpenFontLicense
EOF
}
