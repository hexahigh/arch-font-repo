pkgname=ttf-google-notosanskhudawadi
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanskhudawadi
pkgdesc="Google Fonts family: Noto Sans Khudawadi"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Khudawadi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanskhudawadi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanskhudawadi/NotoSansKhudawadi-Regular.ttf"
)
sha256sums=(
  "fc41afc2ff35b773da629641500b5b99d8243f121571c10b54cceabe516330b3"
  "1650e84136b1e9a4e3b4e8f2e96b3542be7587716c58b4c0da6814ed1d87a721"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
