pkgname=ttf-google-jsmathcmmi10
pkgver=001.001
pkgrel=1
_commit="5bb43f7897883c3560af56a52e880af14f81e7dd"  # Latest commit touching apache/jsmathcmmi10
pkgdesc="Google Fonts family: jsMath cmmi10"
arch=('any')
url="https://fonts.google.com/specimen/jsMath+cmmi10"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/aclonica/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/jsmathcmmi10/jsMath-cmmi10.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "f8f569e095af15da561908026353a73fe7d176f276d86bf7f6fee094bae5bc87"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
