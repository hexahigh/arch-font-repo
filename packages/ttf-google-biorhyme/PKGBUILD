pkgname=ttf-google-biorhyme
pkgver=1.600
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/biorhyme
pkgdesc="Google Fonts family: BioRhyme"
arch=('any')
url="https://fonts.google.com/specimen/BioRhyme"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/biorhyme/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/biorhyme/BioRhyme%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "b14f883330579c3373e41c7c0acdfde91b2e812edfe1e6c5af91bd32a5fa7d13"
  "3ef9bcf73838d59683b4144ddd4687bc9023340ee8e2bec33bc7b3cead65c9f7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
