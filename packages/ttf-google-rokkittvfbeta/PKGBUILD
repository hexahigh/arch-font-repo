pkgname=ttf-google-rokkittvfbeta
pkgver=3.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rokkittvfbeta
pkgdesc="Google Fonts family: Rokkittvfbeta"
arch=('any')
url="https://fonts.google.com/specimen/Rokkittvfbeta"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rokkittvfbeta/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rokkittvfbeta/RokkittVFBeta.ttf"
)
sha256sums=(
  "9898e006de203a8898f09384239ff634c6e4c86a99663cc2725e4351cb10c4a1"
  "21955b8fb5cd8ffe0179bf2aebf35d913e957c914fe168b2625429edfbe32737"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
