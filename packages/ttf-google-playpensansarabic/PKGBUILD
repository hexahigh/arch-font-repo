pkgname=ttf-google-playpensansarabic
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playpensansarabic
pkgdesc="Google Fonts family: Playpen Sans Arabic"
arch=('any')
url="https://fonts.google.com/specimen/Playpen+Sans+Arabic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playpensansarabic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playpensansarabic/PlaypenSansArabic%5Bwght%5D.ttf"
)
sha256sums=(
  "59440310cc2c539b53c835306f74ac8c01f1ece58bf4c65e556fca275b80a730"
  "31122f11b6aa8a36a283f95797663a575afffbe2d52b69e496f3a2440942a226"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
