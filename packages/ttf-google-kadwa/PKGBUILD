pkgname=ttf-google-kadwa
pkgver=1.001
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/kadwa
pkgdesc="Google Fonts family: Kadwa"
arch=('any')
url="https://fonts.google.com/specimen/Kadwa"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/kadwa/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/kadwa/Kadwa-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/kadwa/Kadwa-Regular.ttf"
)
sha256sums=(
  "b01cec9e5e2035b70a6aeb61c673d1f6d5c91539845be07733bd9880fddeb9f0"
  "4dca4a79280ecc1911deb83cc0441dbd53d65af10a42b07157c7a9f2de1e25cc"
  "2d726feadfadcf1e1eb31d443556b830da66badbb0629e984419d8ddab7e6e9d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
