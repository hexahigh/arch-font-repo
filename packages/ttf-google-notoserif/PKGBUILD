pkgname=ttf-google-notoserif
pkgver=2.015
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserif
pkgdesc="Google Fonts family: Noto Serif"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserif/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserif/NotoSerif-Italic[wdth,wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserif/NotoSerif[wdth,wght].ttf"
)
sha256sums=(
  "cee9892f9f0cc8fe882c9e9537ee6a89621d86ee7ceaf70b02e2b2b1c25c061a"
  "e87acbc6c0efd0d9a20d6a8cbbda2b266c14be3a3a6f5af8ec9d7b2460570ad1"
  "4d8e6761424656867019081a1a01336f3cb086982682698714054fc33f782713"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
