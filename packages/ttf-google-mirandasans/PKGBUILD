pkgname=ttf-google-mirandasans
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mirandasans
pkgdesc="Google Fonts family: Miranda Sans"
arch=('any')
url="https://fonts.google.com/specimen/Miranda+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mirandasans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mirandasans/MirandaSans-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mirandasans/MirandaSans[wght].ttf"
)
sha256sums=(
  "0d0ac9b2ed19a9f999ff3c7a2ac9f7c88b21c00c6a4c34654f4fdf8c0cabbf2b"
  "b03311e4c47f0ead62a3f294ee71a052e6407aac996021e7dd172a29e83ef0c0"
  "378e5e03484506cab7118e053505b12f531aa9d070960fe17af0c17b6ea48ca8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
