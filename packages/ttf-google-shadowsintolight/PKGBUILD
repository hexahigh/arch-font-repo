pkgname=ttf-google-shadowsintolight
pkgver=001.000
pkgrel=1
_commit="f3bdc48faa537b2ff3304fcdd73d4f505a6ff352"  # Latest commit touching ofl/shadowsintolight
pkgdesc="Google Fonts family: Shadows Into Light"
arch=('any')
url="https://fonts.google.com/specimen/Shadows+Into+Light"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/shadowsintolight/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/shadowsintolight/ShadowsIntoLight.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "1347863151acdc00fa281daaba1a3543dbce5870b55f9cf7479a15bb84007681"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
