pkgname=ttf-google-caprasimo
pkgver=1.001
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/caprasimo
pkgdesc="Google Fonts family: Caprasimo"
arch=('any')
url="https://fonts.google.com/specimen/Caprasimo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/caprasimo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/caprasimo/Caprasimo-Regular.ttf"
)
sha256sums=(
  "755d165efdbad1ad4a7840aa1f2484b0111627993e162bdcfb25fb2c277db955"
  "786ab84ee787d40df55be78cb4361e485a1c6687195cbcccf3538cb5e46ced90"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
