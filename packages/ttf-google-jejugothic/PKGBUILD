pkgname=ttf-google-jejugothic
pkgver=1.000
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/jejugothic
pkgdesc="Google Fonts family: Jejugothic"
arch=('any')
url="https://fonts.google.com/specimen/Jejugothic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/jejugothic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/jejugothic/JejuGothic-Regular.ttf"
)
sha256sums=(
  "6939af7114f0a33c7e6142d4c1320d1bbde11aebe6d8f3c48fc5fb3e0f676a7b"
  "88993f158a110b9053c14b09b6f7c8440c603f6fe92ff382fb3db83af11dce87"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
