pkgname=ttf-google-imbue
pkgver=1.102
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/imbue
pkgdesc="Google Fonts family: Imbue"
arch=('any')
url="https://fonts.google.com/specimen/Imbue"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/imbue/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/imbue/Imbue%5Bopsz%2Cwght%5D.ttf"
)
sha256sums=(
  "6bedaf6a91cc0f23c61b1be288107e7aab97913447575c6f59f395e4e04b4588"
  "bf45ff1dc01974acedf4f11bcbfa7365053d97f4d598ddafe189d238ac80a534"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
