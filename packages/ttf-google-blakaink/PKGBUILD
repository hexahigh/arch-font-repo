pkgname=ttf-google-blakaink
pkgver=1.003
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/blakaink
pkgdesc="Google Fonts family: Blaka Ink"
arch=('any')
url="https://fonts.google.com/specimen/Blaka+Ink"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/blakaink/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/blakaink/BlakaInk-Regular.ttf"
)
sha256sums=(
  "94b5d5a52420a96f2b4f427bc6f56133f6ddbdfaffa17fdd29049811fc9fd64c"
  "d745f0be7cf43f4e8998834ef730b3cab22a82db19d6a1737008b7b4a87112ea"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
