pkgname=ttf-google-bitcountsingleink
pkgver=1.002
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bitcountsingleink
pkgdesc="Google Fonts family: Bitcount Single Ink"
arch=('any')
url="https://fonts.google.com/specimen/Bitcount+Single+Ink"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bitcountsingleink/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bitcountsingleink/BitcountSingleInk%5BCRSV%2CELSH%2CELXP%2CSZP1%2CSZP2%2CXPN1%2CXPN2%2CYPN1%2CYPN2%2Cslnt%2Cwght%5D.ttf"
)
sha256sums=(
  "c214f3227a93a64c5b73d7e6a1a922c90803fcfb7312404fa2890c63f56fadf8"
  "3dc8184914b365b1b5d19533b416afa591cbe25fcd5cc7c5ecb33fe51d1ac4bb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
