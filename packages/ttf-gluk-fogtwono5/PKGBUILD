pkgname=ttf-gluk-fogtwono5
pkgver=0.88
pkgrel=1
pkgdesc="FogtwoNo5 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=FogtwoNo5'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/FogtwoNo5/FogtwoNo5_088.zip")
sha256sums=('90cbb76e921e884cb42fcaef923cdd6eb0f7e7da423e9d2d605ebf3a384be41e')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=FogtwoNo5
License info from upstream page: OpenFontLicense
EOF
}
