pkgname=ttf-google-ibmplexsansjp
pkgver=1.001
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/ibmplexsansjp
pkgdesc="Google Fonts family: IBM Plex Sans JP"
arch=('any')
url="https://fonts.google.com/specimen/IBM+Plex+Sans+JP"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansjp/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansjp/IBMPlexSansJP-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansjp/IBMPlexSansJP-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansjp/IBMPlexSansJP-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansjp/IBMPlexSansJP-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansjp/IBMPlexSansJP-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansjp/IBMPlexSansJP-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ibmplexsansjp/IBMPlexSansJP-Thin.ttf"
)
sha256sums=(
  "7e6b2818edbd8f6a01ae80641cc8f16a51080d08fb4e532be3a0b6f74adb07da"
  "bd8a98b9b55c9ea3f0fa1ed094c15981788cc9a41b0357f4453014fd1d44da19"
  "83b3a8d967295c162938946d6a9395d539c95fd53e161e0e4b01e5d7f39a2ea6"
  "f6390231b0ce848866d5599765897d4b882d6b29dc0484dd4d1a5435b05761ba"
  "1d09f5e25b19e54b2c55da70de58f9962512c3e07ed7c3e1c9bad77ace5c22e6"
  "372f8bba95f386856ae435dc0e69f08db1cac29bed513d99171a0ae2d307ba2a"
  "5985c29d2d5d444072915cf5874dc80e0a3f5fadbf14a9e3013a03a8fe6d7ff5"
  "773042bf5e8f428d46fcf81b9255c6a451f20cbd39983f308e96808a2e15e134"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
