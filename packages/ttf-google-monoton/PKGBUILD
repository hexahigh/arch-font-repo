pkgname=ttf-google-monoton
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/monoton
pkgdesc="Google Fonts family: Monoton"
arch=('any')
url="https://fonts.google.com/specimen/Monoton"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/monoton/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/monoton/Monoton-Regular.ttf"
)
sha256sums=(
  "585c6d2da8bcd8ffa651e0016f2e992a6891b625143a46a1dacf00699a817d9a"
  "951c4cea65ffede784a7c9672feec5d329a7e1e12216c42d53ecf36c90d04dea"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
