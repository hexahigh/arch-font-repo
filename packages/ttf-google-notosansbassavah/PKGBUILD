pkgname=ttf-google-notosansbassavah
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansbassavah
pkgdesc="Google Fonts family: Noto Sans Bassa Vah"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Bassa+Vah"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbassavah/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansbassavah/NotoSansBassaVah[wght].ttf"
)
sha256sums=(
  "287edd17552fbfffb8b695582889adad29672599d654cf53d820aace29208256"
  "b6c065b905d4ca228580027164f2102fae76215724c43a36e8ebf3c7ee81b8fb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
