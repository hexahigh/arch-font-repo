pkgname=ttf-google-fingerpaint
pkgver=1.002
pkgrel=1
_commit="409c56391856c9b37cd071aa05c0c4e6498c0fa2"  # Latest commit touching ofl/fingerpaint
pkgdesc="Google Fonts family: Finger Paint"
arch=('any')
url="https://fonts.google.com/specimen/Finger+Paint"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/fingerpaint/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/fingerpaint/FingerPaint-Regular.ttf"
)
sha256sums=(
  "d336c098ea798bf14de111cd90dff7d6bc340852405246511345d0f8564fe76e"
  "fce000ae028b09ca53949172a838282c678796e1542d259e6da373e257377fc8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
