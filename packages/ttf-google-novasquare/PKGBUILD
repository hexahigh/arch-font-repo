pkgname=ttf-google-novasquare
pkgver=2.000
pkgrel=1
_commit="a16dee833a4aebd3b74167c9b9674b2a2fb52610"  # Latest commit touching ofl/novasquare
pkgdesc="Google Fonts family: Nova Square"
arch=('any')
url="https://fonts.google.com/specimen/Nova+Square"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/novasquare/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/novasquare/NovaSquare.ttf"
)
sha256sums=(
  "c0bcb72e68dd416db0bb9fcec7a7fa62321b0147cde00d8c8f82748e33aefd34"
  "bf7d8725e2fed1984cadbcb4e54d67cd898f042e11c14e9c30074b14dab6963f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
