pkgname=ttf-google-vastshadow
pkgver=1.002
pkgrel=1
_commit="598c28004b036f1be1c43a3a4c622d21a47f5789"  # Latest commit touching ofl/vastshadow
pkgdesc="Google Fonts family: Vast Shadow"
arch=('any')
url="https://fonts.google.com/specimen/Vast+Shadow"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/vastshadow/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/vastshadow/VastShadow-Regular.ttf"
)
sha256sums=(
  "f1d1a3536fa4b9c71d04fe4c8d8bbfc0cc5c457d6883f45086b04d0bc07ed12d"
  "98bdf7f93c2330697078ece27e48dea7d97b253a547d699bf7afc4bdfa641a93"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
