pkgname=ttf-google-pinyonscript
pkgver=1.008
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/pinyonscript
pkgdesc="Google Fonts family: Pinyon Script"
arch=('any')
url="https://fonts.google.com/specimen/Pinyon+Script"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pinyonscript/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pinyonscript/PinyonScript-Regular.ttf"
)
sha256sums=(
  "61d07cb0eaa943943648df2b11d0c2210e772053c192871e13f680b53fe0b77e"
  "4aab130a6ed27f8b8117738c84a5602edf9300cdcc0651a9a65bf96f451ac29a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
