pkgname=ttf-google-lindenhill
pkgver=1.202
pkgrel=1
_commit="e7afee42fc1ca468ad9531fbc1794aacdedf4131"  # Latest commit touching ofl/lindenhill
pkgdesc="Google Fonts family: Linden Hill"
arch=('any')
url="https://fonts.google.com/specimen/Linden+Hill"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/lindenhill/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/lindenhill/LindenHill-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/lindenhill/LindenHill-Regular.ttf"
)
sha256sums=(
  "9ca8b9e5db7184105da255bb110023cf1cce6caa56186341bb7b09ba97b20ba5"
  "6071ebcba53242167cfe38dfd0ae108125055405fb1b4ecd0468e287a9e7c743"
  "eed3fde6c495dd558b88aa0d3486516dd4d9956a497c335db7beaa9c29d0508a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
