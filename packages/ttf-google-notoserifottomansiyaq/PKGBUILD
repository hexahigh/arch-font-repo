pkgname=ttf-google-notoserifottomansiyaq
pkgver=1.006
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifottomansiyaq
pkgdesc="Google Fonts family: Noto Serif Ottoman Siyaq"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Ottoman+Siyaq"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifottomansiyaq/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifottomansiyaq/NotoSerifOttomanSiyaq-Regular.ttf"
)
sha256sums=(
  "7f6a7ae1130aa5931a54f4a2bcfa63596178353391aaeae143a29d5f7101deaf"
  "c709105016fb6db957cfcf8ce504c115fe504b6a9055427ff227b73a24d7dd6c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
