pkgname=ttf-google-bbhbartle
pkgver=1.000
pkgrel=1
_commit="ec997b1d4517cec107dd4809e5f48e75529f77fe"  # Latest commit touching ofl/bbhbartle
pkgdesc="Google Fonts family: BBH Bartle"
arch=('any')
url="https://fonts.google.com/specimen/BBH+Bartle"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bbhbartle/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bbhbartle/BBHBartle-Regular.ttf"
)
sha256sums=(
  "f9e9e63de5a83078dd630aff864065ca9fa8706d416e9e66bbe4574dcddfed2b"
  "f0de1a96b31ed2ce012172dd28d4a5a7c3d4c7fdee84f32f311608ec4eca3431"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
