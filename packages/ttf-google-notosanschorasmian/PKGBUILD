pkgname=ttf-google-notosanschorasmian
pkgver=1.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanschorasmian
pkgdesc="Google Fonts family: Noto Sans Chorasmian"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Chorasmian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanschorasmian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanschorasmian/NotoSansChorasmian-Regular.ttf"
)
sha256sums=(
  "9154669974b25a4694c515f835bcc6a354291df78a57fa167ac8b3946a8c2ce0"
  "30496cc8f77c1ef3f97f3c61791a579c4aa97983e8678ffc81a341151af5756b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
