pkgname=ttf-google-platypi
pkgver=1.200
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/platypi
pkgdesc="Google Fonts family: Platypi"
arch=('any')
url="https://fonts.google.com/specimen/Platypi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/platypi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/platypi/Platypi-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/platypi/Platypi%5Bwght%5D.ttf"
)
sha256sums=(
  "ade68a34526aa802593c39d1ea9056337810d02663700c5a6bfebfab6b835e17"
  "716b546cb067982720d2db8327da4921ca32c07206d036b59def8cff6a00f537"
  "c4a2f2525bd0deaed25ccca4e0be42d5dcbf2a4739e2cc32fe3e7603333b7d53"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
