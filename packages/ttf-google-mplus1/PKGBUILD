pkgname=ttf-google-mplus1
pkgver=1.001
pkgrel=1
_commit="eecdc665f102cd8b0a3cabeaac08815b77eab1a7"  # Latest commit touching ofl/mplus1
pkgdesc="Google Fonts family: M PLUS 1"
arch=('any')
url="https://fonts.google.com/specimen/M+PLUS+1"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1/MPLUS1%5Bwght%5D.ttf"
)
sha256sums=(
  "04971e3fcee60b247395150d93b3616f6a0b092572332c96187b472976553abc"
  "20785932102b0e9809422b2f31cc6b55183d0285c7af63d5373101208267bdc6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
