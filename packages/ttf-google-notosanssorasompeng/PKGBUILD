pkgname=ttf-google-notosanssorasompeng
pkgver=2.101
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssorasompeng
pkgdesc="Google Fonts family: Noto Sans Sora Sompeng"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Sora+Sompeng"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssorasompeng/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssorasompeng/NotoSansSoraSompeng[wght].ttf"
)
sha256sums=(
  "a95dc9b1eab6e384e5f14d125074cddac6108c30a829190cfedc973d571a59cf"
  "1fe66f4904e960705b68c60f7e92ae579ef80bab30f29b894d44eed1edc306e0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
