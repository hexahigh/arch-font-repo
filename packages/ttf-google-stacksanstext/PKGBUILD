pkgname=ttf-google-stacksanstext
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/stacksanstext
pkgdesc="Google Fonts family: Stack Sans Text"
arch=('any')
url="https://fonts.google.com/specimen/Stack+Sans+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/stacksanstext/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/stacksanstext/StackSansText[wght].ttf"
)
sha256sums=(
  "ebffb381c127e2c8b2b4d7e9e2aa515bb44ba2c62bf1db2f75ce5ea25e7005bb"
  "6a9be24c1371f9344d5b1f243a08928e6324a6426e9f3b3716a7936ae4751256"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
