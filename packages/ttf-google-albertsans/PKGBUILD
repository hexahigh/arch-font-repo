pkgname=ttf-google-albertsans
pkgver=1.025
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/albertsans
pkgdesc="Google Fonts family: Albert Sans"
arch=('any')
url="https://fonts.google.com/specimen/Albert+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/albertsans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/albertsans/AlbertSans-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/albertsans/AlbertSans%5Bwght%5D.ttf"
)
sha256sums=(
  "5c856c086e8743b84932aae46ced424729a703932b601e9eb8aaeac15a617ec6"
  "16eb3291f7389045e90a00abb66a3d2bca1d03387b7ebbbc2b0cd9a094f86226"
  "8fe5d4cf5822d7096d4d17ad781c90f97c745ac13a22be619db74966fba45fda"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
