pkgname=ttf-google-arsenal
pkgver=2.000
pkgrel=1
_commit="d382f7d7a6821a4747a4ab3f4980ca1256eee7eb"  # Latest commit touching ofl/arsenal
pkgdesc="Google Fonts family: Arsenal"
arch=('any')
url="https://fonts.google.com/specimen/Arsenal"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/arsenal/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/arsenal/Arsenal-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/arsenal/Arsenal-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/arsenal/Arsenal-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/arsenal/Arsenal-Regular.ttf"
)
sha256sums=(
  "a94cfd8d1f5c33f9a7506def359b907f3313f7008bb57fc893985963cd342f8f"
  "eeaf97f8df9d5bb69c8db23f7d2ace61b6e4eeefd99c1a226f0577a0b3a23fe4"
  "276c72baa7fc670e03c2951fb10be5d75c3e0c852111a10a84c8e0c739fed90c"
  "3e38a69ce81ed89b8a1fe20cb1eecbad762aad58c122ea8438bdb8be40ed550c"
  "544784eccc5405570c8d91419739a12c2a9ee7cfc947715cee51fa060701b4c2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
