pkgname=ttf-google-snowburstone
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/snowburstone
pkgdesc="Google Fonts family: Snowburst One"
arch=('any')
url="https://fonts.google.com/specimen/Snowburst+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/snowburstone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/snowburstone/SnowburstOne-Regular.ttf"
)
sha256sums=(
  "cd354a6084383c50398fae709ebe3a5dd98b947c486c1fe9de5f89caf81f980c"
  "ede8110b5922b718c9b80717a4c5dcc2b4a862767d8319877983773c900bb00f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
