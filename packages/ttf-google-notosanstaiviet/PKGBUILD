pkgname=ttf-google-notosanstaiviet
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanstaiviet
pkgdesc="Google Fonts family: Noto Sans Tai Viet"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Tai+Viet"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstaiviet/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanstaiviet/NotoSansTaiViet-Regular.ttf"
)
sha256sums=(
  "12353b96af2837abbe42f486d99c487836d8d9778b058c37d920ca2ec0cc83a3"
  "ba2a5346d6a9c041663fc835cf090efcbb9feb81a620245e7a64ecf6caafc59d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
