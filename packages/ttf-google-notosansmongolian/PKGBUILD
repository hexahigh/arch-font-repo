pkgname=ttf-google-notosansmongolian
pkgver=3.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansmongolian
pkgdesc="Google Fonts family: Noto Sans Mongolian"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Mongolian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmongolian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmongolian/NotoSansMongolian-Regular.ttf"
)
sha256sums=(
  "b0158b3c0b16c20e22ea662850503a7980111c5c704501e942cc1a7ed12dc011"
  "805a55e10492c547ccadc1ad04faabdef61a74a5c02ecce69748378d66ef032d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
