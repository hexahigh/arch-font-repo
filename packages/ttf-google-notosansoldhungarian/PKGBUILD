pkgname=ttf-google-notosansoldhungarian
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansoldhungarian
pkgdesc="Google Fonts family: Noto Sans Old Hungarian"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Old+Hungarian"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoldhungarian/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoldhungarian/NotoSansOldHungarian-Regular.ttf"
)
sha256sums=(
  "8b78300a14978656a55fac2ee73466ece7d6e9e9d8a4ba770f81ed92f3ec8af4"
  "c23b363986fabc168af489c5d4eaf3c10fbb110599ffe6ca3b2eac777aa73079"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
