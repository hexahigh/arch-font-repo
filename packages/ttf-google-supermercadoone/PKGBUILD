pkgname=ttf-google-supermercadoone
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/supermercadoone
pkgdesc="Google Fonts family: Supermercado One"
arch=('any')
url="https://fonts.google.com/specimen/Supermercado+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/supermercadoone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/supermercadoone/SupermercadoOne-Regular.ttf"
)
sha256sums=(
  "88dcde7d08e509a3eec64886292a36cbd58ed9bb52f37f91f55656fb9d21ddb8"
  "73e1f6c46e4f94949df8394a5dc207a5ae4c75b94d19b012c7b8eaa67dca3750"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
