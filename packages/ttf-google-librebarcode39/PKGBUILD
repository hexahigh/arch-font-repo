pkgname=ttf-google-librebarcode39
pkgver=1.005
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/librebarcode39
pkgdesc="Google Fonts family: Libre Barcode 39"
arch=('any')
url="https://fonts.google.com/specimen/Libre+Barcode+39"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/librebarcode39/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/librebarcode39/LibreBarcode39-Regular.ttf"
)
sha256sums=(
  "a4b7ccd1bda3269afba7d6d9293a7161e699d2f4f1f280dd8a8535c569388de9"
  "0c8907f28765e6f021f3a910d193e4e02f518065fbdcbbc777c1958728bcc6a5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
