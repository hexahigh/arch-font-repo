pkgname=ttf-google-emblemaone
pkgver=1.003
pkgrel=1
_commit="6e37096bf3a8b41b586bc9a6843bbec0d4401912"  # Latest commit touching ofl/emblemaone
pkgdesc="Google Fonts family: Emblema One"
arch=('any')
url="https://fonts.google.com/specimen/Emblema+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/emblemaone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/emblemaone/EmblemaOne-Regular.ttf"
)
sha256sums=(
  "8f94e5901c371537043e0c762c827ce33963e7bd186fbea0abafc035ef7120a7"
  "068ab584fb9868c299776adb871cf693b21123ccfb6ed5fab98ff861d1d42bee"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
