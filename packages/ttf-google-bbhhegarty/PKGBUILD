pkgname=ttf-google-bbhhegarty
pkgver=1.000
pkgrel=1
_commit="0cdca60cfbdaf5944a586d517c283f6077b34e4b"  # Latest commit touching ofl/bbhhegarty
pkgdesc="Google Fonts family: BBH Hegarty"
arch=('any')
url="https://fonts.google.com/specimen/BBH+Hegarty"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bbhhegarty/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bbhhegarty/BBHHegarty-Regular.ttf"
)
sha256sums=(
  "f9e9e63de5a83078dd630aff864065ca9fa8706d416e9e66bbe4574dcddfed2b"
  "34ce60212aa1d835bf44fd61c9fc24092c9e34c1182dd91f2cbf41f69999af21"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
