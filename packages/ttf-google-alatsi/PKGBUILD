pkgname=ttf-google-alatsi
pkgver=1.008
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/alatsi
pkgdesc="Google Fonts family: Alatsi"
arch=('any')
url="https://fonts.google.com/specimen/Alatsi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alatsi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alatsi/Alatsi-Regular.ttf"
)
sha256sums=(
  "2c3849ff305df315fe85b7b328fc2a926da7be9c54340285a0e9fe2e1df89187"
  "16b62400d74df555a35e145d0d8835e4f06e6d5c4707a8d0faf76d4e99910292"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
