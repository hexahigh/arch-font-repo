pkgname=ttf-google-bitter
pkgver=3.021
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bitter
pkgdesc="Google Fonts family: Bitter"
arch=('any')
url="https://fonts.google.com/specimen/Bitter"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bitter/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bitter/Bitter-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bitter/Bitter[wght].ttf"
)
sha256sums=(
  "152a1e283e23b42c4940da4c72f2f5bebaa17969cb77c76d7af05903846006f1"
  "5e6e0af503171c9d7b4be7a22c16f474d7a638cf83a80051d825bcc58d664bc3"
  "ef2b9a711fb02f1e5823b34da1b7450e0fc76793b7d733a8b41006e24916d4a7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
