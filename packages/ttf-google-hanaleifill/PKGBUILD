pkgname=ttf-google-hanaleifill
pkgver=1.000
pkgrel=1
_commit="387645393c2d057a4837857c08bda3590a9bce41"  # Latest commit touching ofl/hanaleifill
pkgdesc="Google Fonts family: Hanalei Fill"
arch=('any')
url="https://fonts.google.com/specimen/Hanalei+Fill"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hanaleifill/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hanaleifill/HanaleiFill-Regular.ttf"
)
sha256sums=(
  "1f581506286e960436548dba0701aab278f7e67f2adc6bdae2958923867d1e64"
  "1916f208a0e8c2d1b9535e26f8f77e45b641e98f9bf16e809cdd478367b641db"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
