pkgname=ttf-google-pridi
pkgver=1.003
pkgrel=1
_commit="ec1ec88c683bee895eb79a6d9ea030baeaf522b0"  # Latest commit touching ofl/pridi
pkgdesc="Google Fonts family: Pridi"
arch=('any')
url="https://fonts.google.com/specimen/Pridi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pridi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pridi/Pridi-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/pridi/Pridi-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/pridi/Pridi-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/pridi/Pridi-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/pridi/Pridi-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/pridi/Pridi-SemiBold.ttf"
)
sha256sums=(
  "1d08c63944e639bbfe8a1b81e3c6a63836806c126b3573b9cda0db83fd27ffe9"
  "7ed16f946290c59f336c1cb031a80a5fd4ae60e6c261bffa9e06c92df6865ff4"
  "12f2ed9cd258b585083be1a6faa490c6e41917d95a4fbe045fdb43819eed8a9c"
  "3f328cfdface42003202df36d275b0d3498c7484dd384add3fbb066c5829dab0"
  "d38ca6dd91f8ede51cb793dc05c56c2381a4933a8849ddc09281ecb50943294b"
  "cc5a2ea9660d78fc64c909c29582ab8bd7195128f81bed825d7cee985369a4da"
  "afb99e891ab2ada5072940193766bffb53a836f7e75cd8ec85213a61edde4ce4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
