pkgname=ttf-google-blackopsone
pkgver=1.004
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/blackopsone
pkgdesc="Google Fonts family: Black Ops One"
arch=('any')
url="https://fonts.google.com/specimen/Black+Ops+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/blackopsone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/blackopsone/BlackOpsOne-Regular.ttf"
)
sha256sums=(
  "f67ca4a200424868ee8fcd5464d7b35ac1cbf7723f6bfdbd19a8524689fab9a8"
  "282a825b5f294377387e3969f765408157dbea8da0f5d0aae68c6bc704b145b3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
