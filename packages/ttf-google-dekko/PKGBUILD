pkgname=ttf-google-dekko
pkgver=1.001
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/dekko
pkgdesc="Google Fonts family: Dekko"
arch=('any')
url="https://fonts.google.com/specimen/Dekko"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/dekko/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/dekko/Dekko-Regular.ttf"
)
sha256sums=(
  "f139d6f43d2a63a8fb3ded48b8ec747d9d59a7fbb13d077d9b96ac88580bc1ad"
  "e6b151a5bdc521833ceb9a4f8010195515259e9416abfe055cfd16adb2e1af42"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
