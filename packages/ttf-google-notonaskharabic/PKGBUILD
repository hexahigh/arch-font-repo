pkgname=ttf-google-notonaskharabic
pkgver=2.021
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notonaskharabic
pkgdesc="Google Fonts family: Noto Naskh Arabic"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Naskh+Arabic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notonaskharabic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notonaskharabic/NotoNaskhArabic%5Bwght%5D.ttf"
)
sha256sums=(
  "a7a5a25eb188bf1cd96982030d53e23c33485c69b1044a562254226857ee13af"
  "67b5a525a661b607971fbd3f96a81b89d3a768e74534fca84f18ac97e6fab72f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
