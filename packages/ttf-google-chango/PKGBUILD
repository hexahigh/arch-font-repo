pkgname=ttf-google-chango
pkgver=1.001
pkgrel=1
_commit="1957a34023c8b26321e3abbead1be1a60ba8b605"  # Latest commit touching ofl/chango
pkgdesc="Google Fonts family: Chango"
arch=('any')
url="https://fonts.google.com/specimen/Chango"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/chango/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/chango/Chango-Regular.ttf"
)
sha256sums=(
  "e98ce988fba1c138f4e7c0c5120809706ab1b24a3c29638ca83ab2ff082e08db"
  "3e566f4b881f24198fe1b6525aae970f9200078136e3416abc7ba0272d2f80d9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
