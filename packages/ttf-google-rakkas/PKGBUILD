pkgname=ttf-google-rakkas
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rakkas
pkgdesc="Google Fonts family: Rakkas"
arch=('any')
url="https://fonts.google.com/specimen/Rakkas"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rakkas/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rakkas/Rakkas-Regular.ttf"
)
sha256sums=(
  "5c36e7ec460b285185ea23847aa1f508708d9ce15d5c055279defd022972f836"
  "54278882e4774c14d50c3b555f127d0fe586366d5b787316ebbcbd8108829e60"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
