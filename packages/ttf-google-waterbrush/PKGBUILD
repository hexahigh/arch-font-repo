pkgname=ttf-google-waterbrush
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/waterbrush
pkgdesc="Google Fonts family: Water Brush"
arch=('any')
url="https://fonts.google.com/specimen/Water+Brush"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/waterbrush/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/waterbrush/WaterBrush-Regular.ttf"
)
sha256sums=(
  "eaa2e23b59eb264d9f982126f5d6cb7594b00a6a5e3684d916ecbf0c31004610"
  "2cbdccbca5d4be005fe4edd8895b91618a7f96639eaeeb4987ad83e81afc71a7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
