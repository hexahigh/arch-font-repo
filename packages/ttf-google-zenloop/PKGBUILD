pkgname=ttf-google-zenloop
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/zenloop
pkgdesc="Google Fonts family: Zen Loop"
arch=('any')
url="https://fonts.google.com/specimen/Zen+Loop"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/zenloop/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/zenloop/ZenLoop-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/zenloop/ZenLoop-Regular.ttf"
)
sha256sums=(
  "5f08909b75e1705f0e0d73b64654f5f1a649f523cad91f58c6777098fc46bf40"
  "7ae5141733792d8596d9be4b9ab865ccbfda30bcade02c935b5a918875bc46d8"
  "06c4de349ee28ef965f9a5361ef2c28841628adcc3e86490b9811584acb2378b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
