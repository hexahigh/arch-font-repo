pkgname=ttf-google-playwritedegrund
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwritedegrund
pkgdesc="Google Fonts family: Playwrite DE Grund"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+DE+Grund"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritedegrund/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritedegrund/PlaywriteDEGrund%5Bwght%5D.ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "47cc063ac4253f46e7e63eec0909004526db4eb863dce601e8632e4a37a72c86"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
