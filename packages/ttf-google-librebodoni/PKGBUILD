pkgname=ttf-google-librebodoni
pkgver=2.005
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/librebodoni
pkgdesc="Google Fonts family: Libre Bodoni"
arch=('any')
url="https://fonts.google.com/specimen/Libre+Bodoni"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/librebodoni/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/librebodoni/LibreBodoni-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/librebodoni/LibreBodoni[wght].ttf"
)
sha256sums=(
  "7ce3bf8e8087bf7495a3e1ed2044e83439db990c778d61b128fd09b7876d0420"
  "6a9b0c88764dcf6c094653e3c28da045fcebca48734254afdcbfec46b9ab4fcd"
  "0d543665bd869819ffd7d46608804e245497ba835960832d44be89e561b0c717"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
