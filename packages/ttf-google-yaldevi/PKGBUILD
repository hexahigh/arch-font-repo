pkgname=ttf-google-yaldevi
pkgver=1.100
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/yaldevi
pkgdesc="Google Fonts family: Yaldevi"
arch=('any')
url="https://fonts.google.com/specimen/Yaldevi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/yaldevi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/yaldevi/Yaldevi%5Bwght%5D.ttf"
)
sha256sums=(
  "9d8a27215d55e25527a33cc90f0dfd32e382454cf3b5d8f815f303c9030b42d1"
  "21d5516cd9a8831964b57503f5b7a119aafa9603bdddd0183e91a0ac8c8dc2e4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
