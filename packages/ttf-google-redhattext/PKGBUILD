pkgname=ttf-google-redhattext
pkgver=1.030
pkgrel=1
_commit="f9ee7c8910dddefaa884468d0b064c4969e8a2c5"  # Latest commit touching ofl/redhattext
pkgdesc="Google Fonts family: Red Hat Text"
arch=('any')
url="https://fonts.google.com/specimen/Red+Hat+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/redhattext/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/redhattext/RedHatText-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/redhattext/RedHatText%5Bwght%5D.ttf"
)
sha256sums=(
  "435fbfb7e66988b2a06686a4cb966faec733f35d8fe100a1601573c27f3e0bb8"
  "e7c263cf563dbd9fea7567839e22f3e34ed21234bd0a9b057402f921d1b1fa7e"
  "52343c51f688537b72967b78a7883ac29d96d698e0f0707bb11bac1987e0855d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
