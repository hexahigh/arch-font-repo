pkgname=ttf-google-hind
pkgver=2.001
pkgrel=1
_commit="50f308770df035044a72572ac632a2bd5f1f0be4"  # Latest commit touching ofl/hind
pkgdesc="Google Fonts family: Hind"
arch=('any')
url="https://fonts.google.com/specimen/Hind"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hind/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hind/Hind-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/hind/Hind-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/hind/Hind-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/hind/Hind-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/hind/Hind-SemiBold.ttf"
)
sha256sums=(
  "f62ef357d3a1c3d27edd35a6e1ba350e8a8d13499797964eeadefbf0b3b15d1f"
  "330c54396bc27628c32e69b88654e41065722182c6f33b936a2a46d72c9d6774"
  "c31b8b6073b14f89187586fb1fa38710d8adae3429ef41e1a398dacbfe839e51"
  "70f9c1158390d0c93a8bc24b35b4be4b2439653372bbce7381a32c686fb91a98"
  "01de158022f53077b52303e46de3b0ab5fb245222a7ffe25a2a57fdd9e969162"
  "1742a1b0aba97b49da1d3ee3af568fa997c59a3cfe73829f7bec293f416d25dd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
