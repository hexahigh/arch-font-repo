pkgname=ttf-google-afacad
pkgver=1.000
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/afacad
pkgdesc="Google Fonts family: Afacad"
arch=('any')
url="https://fonts.google.com/specimen/Afacad"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/afacad/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/afacad/Afacad-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/afacad/Afacad[wght].ttf"
)
sha256sums=(
  "a65e37f173d58cab5d4f8eb6373f4e24ee79ad6c80235dbe845a117917af2d99"
  "1cf0a5853330267433c0a1603e239ff33e5963887ec2545c96a1516ca960a717"
  "89513fc375cafeecca81110f6a3ef5882d7ac2d871a365b6c93bbfa6039b8230"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
