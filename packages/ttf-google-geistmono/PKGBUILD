pkgname=ttf-google-geistmono
pkgver=1.700
pkgrel=1
_commit="474230b8692984fe26f91a6588165fabb88e1101"  # Latest commit touching ofl/geistmono
pkgdesc="Google Fonts family: Geist Mono"
arch=('any')
url="https://fonts.google.com/specimen/Geist+Mono"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/geistmono/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/geistmono/GeistMono-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/geistmono/GeistMono%5Bwght%5D.ttf"
)
sha256sums=(
  "1781d2806a07d91c4edf4740b88449fab7d0eadad53f7c351b94cd4d4eb8c00f"
  "632bed258f849dec44d33b3cd2b0c8399821d530c087ed95ac7131016f7f895f"
  "87c2aff9723544a9adaea19d92e42a33705c9723624801b6e0224c2206a6af0d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
