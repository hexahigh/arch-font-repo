pkgname=ttf-google-volkhov
pkgver=1.010
pkgrel=1
_commit="6f2b1051eba18c5629c3a517ba5b06f149a0ea83"  # Latest commit touching ofl/volkhov
pkgdesc="Google Fonts family: Volkhov"
arch=('any')
url="https://fonts.google.com/specimen/Volkhov"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/volkhov/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/volkhov/Volkhov-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/volkhov/Volkhov-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/volkhov/Volkhov-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/volkhov/Volkhov-Regular.ttf"
)
sha256sums=(
  "1c43e70c49ef7a9b35fcb3758fec8ec5969ff1274c4834b4466b9014f3b9f55f"
  "ad28a57498198a9336b673cea068582aa443dc72c98a3222552e8392225af646"
  "4863ee6fce826ad47bbf68531bbc0cd861a6c832e8a4905ea79de0aa6add05c2"
  "027360a4bfabcfcf49f95c9f9944b2147cd95c3a72dcb2a66eac7e7ef6e714f1"
  "f8f49e898a4e9df91ac2f3e0d34deb4912d4fe2424831b514de297c8046d58d9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
