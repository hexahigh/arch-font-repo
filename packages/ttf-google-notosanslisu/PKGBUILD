pkgname=ttf-google-notosanslisu
pkgver=2.102
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanslisu
pkgdesc="Google Fonts family: Noto Sans Lisu"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Lisu"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslisu/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslisu/NotoSansLisu%5Bwght%5D.ttf"
)
sha256sums=(
  "1f65bfdc26d6bd6e57249c60a86ea355761fb9150694e50206175d3fa8d3c166"
  "669592efd358c495000ae79201dbec736d877d04fabf4dfc4dfb887cd9eeac40"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
