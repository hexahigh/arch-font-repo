pkgname=ttf-google-tinos
pkgver=1.23
pkgrel=1
_commit="90d7886db9000c893b9559828bf028aaed5f9c10"  # Latest commit touching apache/tinos
pkgdesc="Google Fonts family: Tinos"
arch=('any')
url="https://fonts.google.com/specimen/Tinos"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/tinos/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/tinos/Tinos-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/apache/tinos/Tinos-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/apache/tinos/Tinos-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/apache/tinos/Tinos-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "6a0afe87068ba5ddeb6a9bb7b9d0dc41666966c044767df69de3efb7e33f5af8"
  "52c4d87a988eb1f1c25e1fcb97970d456a2fb252e0fa2116e2b4bb33e7824bda"
  "751c979043c9641dad389ab9c680c2c9ffb0a0c7352153f48b9ebd958e8963d8"
  "1061395ac6775f3cea27dc9ef3d7a3b9cc34c2b4a2d97aa649411294d5165990"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
