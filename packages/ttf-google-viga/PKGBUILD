pkgname=ttf-google-viga
pkgver=1.001
pkgrel=1
_commit="80251c57846d2bb603151eaa25f390252714d240"  # Latest commit touching ofl/viga
pkgdesc="Google Fonts family: Viga"
arch=('any')
url="https://fonts.google.com/specimen/Viga"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/viga/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/viga/Viga-Regular.ttf"
)
sha256sums=(
  "b67eed9578defb59cc4ff4b58428fb816786e499e84cdeafca54723b055c169e"
  "730ad2a38691ce19ee5aa9dd9ec84ae8737b2084b06eef13435a4facad9b063c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
