pkgname=ttf-gluk-promocyja
pkgver=0.96
pkgrel=1
pkgdesc="Promocyja font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Promocyja'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/promocyja/Promocyja096.zip")
sha256sums=('3d768932f9d4b86ac2dac07b51c6a5fc28b33adb6f6835f8db97d1bd18244a1f')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Promocyja
License info from upstream page: Public Domain
EOF
}
