pkgname=ttf-google-notosansdeseret
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansdeseret
pkgdesc="Google Fonts family: Noto Sans Deseret"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Deseret"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansdeseret/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansdeseret/NotoSansDeseret-Regular.ttf"
)
sha256sums=(
  "cdfc75eeec8b7d71279b2412798808f2b7c5d70fe672ad624c3418b58ccd1c42"
  "aaab78856a00ca015e8f545200c82093b33192990651a0f62926a13cf0a7b080"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
