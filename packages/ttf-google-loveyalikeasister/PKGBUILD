pkgname=ttf-google-loveyalikeasister
pkgver=1.002
pkgrel=1
_commit="4e5f06dbb274a27ebe71ed54ea706b3ee40eabd9"  # Latest commit touching ofl/loveyalikeasister
pkgdesc="Google Fonts family: Love Ya Like A Sister"
arch=('any')
url="https://fonts.google.com/specimen/Love+Ya+Like+A+Sister"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/loveyalikeasister/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/loveyalikeasister/LoveYaLikeASister.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "4fbe2c1fa647de5a415acac7b2b6491542fe9767b6199719a3bd77a7cf35eb0d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
