pkgname=ttf-google-dmseriftext
pkgver=5.200
pkgrel=1
_commit="545a4e4aa717bf330ae21938acb232b96cbcc04a"  # Latest commit touching ofl/dmseriftext
pkgdesc="Google Fonts family: DM Serif Text"
arch=('any')
url="https://fonts.google.com/specimen/DM+Serif+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/dmseriftext/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/dmseriftext/DMSerifText-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/dmseriftext/DMSerifText-Regular.ttf"
)
sha256sums=(
  "a3e5cdd67d4571dd0a24fcc968de0efde7ae97ef752daf0906e4767619dd7231"
  "d016b81df5cd7462188a0ba11dc343ce2897dffa39fb1fcff0fef0bb7684364e"
  "94b5fa7bac0f406cb3149512037f37ea21b55cecd732c3fd3a076260441399cd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
