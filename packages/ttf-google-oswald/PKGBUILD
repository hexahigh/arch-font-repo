pkgname=ttf-google-oswald
pkgver=4.103
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/oswald
pkgdesc="Google Fonts family: Oswald"
arch=('any')
url="https://fonts.google.com/specimen/Oswald"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/oswald/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/oswald/Oswald%5Bwght%5D.ttf"
)
sha256sums=(
  "0fd731a904b729a4e02eaf5e8ebd06783edd9abe400e8882760160230675b652"
  "5b38c246e255a12f5712d640d56bcced0472466fc68983d2d0410ec0457c2817"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
