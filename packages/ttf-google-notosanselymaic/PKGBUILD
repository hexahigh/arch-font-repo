pkgname=ttf-google-notosanselymaic
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanselymaic
pkgdesc="Google Fonts family: Noto Sans Elymaic"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Elymaic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanselymaic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanselymaic/NotoSansElymaic-Regular.ttf"
)
sha256sums=(
  "bdfb572fad1e0d80331b02e52d9f2184a4e5b2b3991427eff95c1d816fbd2a77"
  "4a4772cbb8a278019152bafd58fef3892fae055d0b137f3fb1f61663960e156b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
