pkgname=ttf-google-mogra
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mogra
pkgdesc="Google Fonts family: Mogra"
arch=('any')
url="https://fonts.google.com/specimen/Mogra"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mogra/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mogra/Mogra-Regular.ttf"
)
sha256sums=(
  "889287344475d39b48b6c354fd025ea6f4b726e9b2785b70b5e335f754116984"
  "1d7133f5926cf5e7042b587b838bc5c5bcfe6c86b19157afd544c71a630159d8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
