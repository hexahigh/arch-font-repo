pkgname=ttf-google-notosanssharada
pkgver=2.006
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssharada
pkgdesc="Google Fonts family: Noto Sans Sharada"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Sharada"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssharada/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssharada/NotoSansSharada-Regular.ttf"
)
sha256sums=(
  "110e682353242abfe1529151fda818b381cb722b4d5a46388c13f55225e21b1b"
  "2ccfb8e72773d318c03b8414ad82686c97ee65a9825fdb1a388e376c4df13372"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
