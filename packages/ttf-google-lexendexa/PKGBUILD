pkgname=ttf-google-lexendexa
pkgver=1.007
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/lexendexa
pkgdesc="Google Fonts family: Lexend Exa"
arch=('any')
url="https://fonts.google.com/specimen/Lexend+Exa"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/lexendexa/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/lexendexa/LexendExa%5Bwght%5D.ttf"
)
sha256sums=(
  "5da8505887d0fa7fe963445fd58852707fda34adfeb65af25c99d152bab285bd"
  "d03a5ef7cf352a5508c6a64dc7b7b9e50bb7afddba1a90d792a801a6f421a63c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
