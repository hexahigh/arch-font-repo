pkgname=ttf-google-meerainimai
pkgver=2.0.0
pkgrel=1
_commit="d92a4f3214862c9026ce734e85587dd68d88a5c2"  # Latest commit touching ofl/meerainimai
pkgdesc="Google Fonts family: Meera Inimai"
arch=('any')
url="https://fonts.google.com/specimen/Meera+Inimai"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/meerainimai/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/meerainimai/MeeraInimai-Regular.ttf"
)
sha256sums=(
  "d530c14e9cc263c567b47742ef20df2a41374f00732ba4f290f52adad428b1a2"
  "3dffa9501ac790b5e1c3ebecdba4f2c90a617a7d3131fad129893929bc56708e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
