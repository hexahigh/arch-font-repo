pkgname=ttf-google-notosanscuneiform
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanscuneiform
pkgdesc="Google Fonts family: Noto Sans Cuneiform"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Cuneiform"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscuneiform/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanscuneiform/NotoSansCuneiform-Regular.ttf"
)
sha256sums=(
  "83e16aed35737ea80911a82938ad4bfe762fde24928010c2c80d21ece07bec14"
  "b4e0a892514fcb1beb081c8b652fb36689f77105491d1796c2c3f5a59b4524d2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
