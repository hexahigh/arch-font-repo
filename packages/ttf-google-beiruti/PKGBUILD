pkgname=ttf-google-beiruti
pkgver=1.41
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/beiruti
pkgdesc="Google Fonts family: Beiruti"
arch=('any')
url="https://fonts.google.com/specimen/Beiruti"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/beiruti/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/beiruti/Beiruti%5Bwght%5D.ttf"
)
sha256sums=(
  "3f45003d401898d732000102b547b92508fc804a6f613fe11bcae755f27d534f"
  "c31f26b93e90ac916757de63c060370c5382457f85d50f64f930b96e5477f222"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
