pkgname=ttf-google-ruluko
pkgver=1.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/ruluko
pkgdesc="Google Fonts family: Ruluko"
arch=('any')
url="https://fonts.google.com/specimen/Ruluko"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ruluko/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ruluko/Ruluko-Regular.ttf"
)
sha256sums=(
  "e604b133509815768e6ec4738bb04844ce9a23e80099d2b61e5d75ef46acbeb0"
  "c426db1373755d3ba00456dece5cf5ad1c8023978f60cbfe7b7e256ab1c89c3f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
