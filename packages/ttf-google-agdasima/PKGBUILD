pkgname=ttf-google-agdasima
pkgver=2.002
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/agdasima
pkgdesc="Google Fonts family: Agdasima"
arch=('any')
url="https://fonts.google.com/specimen/Agdasima"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/agdasima/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/agdasima/Agdasima-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/agdasima/Agdasima-Regular.ttf"
)
sha256sums=(
  "5a5df9eeb233115038bb9bbe00d37897195864802cb889fe755697ba7736d518"
  "d75fd96cf62e06d172484ad158614546437a2a988b16feed8b751f9838447ec5"
  "512b6ec7aa802bb92cf3b816644ca11facf630b087d6e3ab3cd4b8d4eae77896"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
