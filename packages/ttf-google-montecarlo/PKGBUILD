pkgname=ttf-google-montecarlo
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/montecarlo
pkgdesc="Google Fonts family: MonteCarlo"
arch=('any')
url="https://fonts.google.com/specimen/MonteCarlo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/montecarlo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/montecarlo/MonteCarlo-Regular.ttf"
)
sha256sums=(
  "1431e4458b02d3fba371726627ce93269fc26440cebacdf0c4965ea4a3cb5cb3"
  "11d397212722b5ddd1e3190c3812139035e7acffb01da8ceaec96eaf985e12b5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
