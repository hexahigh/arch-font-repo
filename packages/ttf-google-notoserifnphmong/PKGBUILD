pkgname=ttf-google-notoserifnphmong
pkgver=1.001
pkgrel=1
_commit="54584294ef89979740aa9687fdc3c04d11c4b539"  # Latest commit touching ofl/notoserifnphmong
pkgdesc="Google Fonts family: Noto Serif NP Hmong"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+NP+Hmong"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifnphmong/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifnphmong/NotoSerifNPHmong%5Bwght%5D.ttf"
)
sha256sums=(
  "e13fc63364c2d60d1933e3a20c74a265d949f1e2321155db2b0df103f78d539e"
  "6917f29fdcb76668b8ad4c85038d54815b5899c49242c82b76c3b3dcc2bb216f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
