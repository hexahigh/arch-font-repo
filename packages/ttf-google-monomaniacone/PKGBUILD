pkgname=ttf-google-monomaniacone
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/monomaniacone
pkgdesc="Google Fonts family: Monomaniac One"
arch=('any')
url="https://fonts.google.com/specimen/Monomaniac+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/monomaniacone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/monomaniacone/MonomaniacOne-Regular.ttf"
)
sha256sums=(
  "0e7bc933f607a0fe98e2635cef0df76dc9b6a0198a7a7ad035e8a2b8d329e137"
  "4045d2b419268efce1b1ef33004603c74c045804137693f1fb98c79576f31c6f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
