pkgname=ttf-google-notosansmayannumerals
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansmayannumerals
pkgdesc="Google Fonts family: Noto Sans Mayan Numerals"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Mayan+Numerals"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmayannumerals/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansmayannumerals/NotoSansMayanNumerals-Regular.ttf"
)
sha256sums=(
  "4ea975c31fc83692252a4c19382bbd539e7a06afa2eaacdad4ef433132cf64bc"
  "b073279ae1eabfbe8bd4232f5f83fdaeb439267f5580a7849ed9c4a04cf35d34"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
