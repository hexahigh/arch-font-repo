pkgname=ttf-google-konkhmersleokchher
pkgver=1.000
pkgrel=1
_commit="130fcfb0ff422fec96b335616b2ca99f91914792"  # Latest commit touching ofl/konkhmersleokchher
pkgdesc="Google Fonts family: Konkhmer Sleokchher"
arch=('any')
url="https://fonts.google.com/specimen/Konkhmer+Sleokchher"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/konkhmersleokchher/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/konkhmersleokchher/KonkhmerSleokchher-Regular.ttf"
)
sha256sums=(
  "d4577dd4b58d06011490a6715de2e17d6808d65fb68f4f3b95a68e9c7c929469"
  "16cf848e5670b1565cff77a1827347a56ee085e0b556f1f6e66de8d3ba0ef0df"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
