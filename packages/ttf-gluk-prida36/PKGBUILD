pkgname=ttf-gluk-prida36
pkgver=0.57
pkgrel=1
pkgdesc="Prida36 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Prida36'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Prida36/Prida36_057.zip")
sha256sums=('ca151341df30872c3e2bb9afa998627fb7f725df0a719655dcc0993cbd79e46b')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Prida36
License info from upstream page: OpenFontLicense
EOF
}
