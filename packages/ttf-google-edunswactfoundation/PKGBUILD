pkgname=ttf-google-edunswactfoundation
pkgver=1.003
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/edunswactfoundation
pkgdesc="Google Fonts family: Edu NSW ACT Foundation"
arch=('any')
url="https://fonts.google.com/specimen/Edu+NSW+ACT+Foundation"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/edunswactfoundation/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/edunswactfoundation/EduNSWACTFoundation[wght].ttf"
)
sha256sums=(
  "9c50bb9d2dbfd864553688da113bf817a294f3721b7a35ac6569c63bb939a998"
  "5a4b22cc39c04d97472bbe705b9700e864492b853b4941645da60202b796146a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
