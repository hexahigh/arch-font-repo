pkgname=ttf-google-mingzat
pkgver=1.200
pkgrel=1
_commit="7c5b40ffa43fcf1958de9579e59d8fb065b96fb2"  # Latest commit touching ofl/mingzat
pkgdesc="Google Fonts family: Mingzat"
arch=('any')
url="https://fonts.google.com/specimen/Mingzat"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mingzat/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mingzat/Mingzat-Regular.ttf"
)
sha256sums=(
  "d94b22562ace7dc3f4e3a934a15c587569eeb30eb5c09e8910b48aee2854c2ba"
  "c1507a565a1d263c6473a2b36944d5244bfa5b6e6f6af023a3dc8c7234fedd05"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
