pkgname=ttf-google-inika
pkgver=1.001
pkgrel=1
_commit="f4910312af934b5530011ca2155efdfdaa0f9ea6"  # Latest commit touching ofl/inika
pkgdesc="Google Fonts family: Inika"
arch=('any')
url="https://fonts.google.com/specimen/Inika"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/inika/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/inika/Inika-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/inika/Inika-Regular.ttf"
)
sha256sums=(
  "3169e7e0e87168908218f11d660a52c0b81b5952fd73918a596e70721d68d3e5"
  "57c5b398a0d72c85283a4640337091bc974aae9ef03b1bd159523b747c1197f3"
  "3fe94a6697ababc3b8b580e005d2718a2ce0fe2afea08b164ee5259d9ea8db25"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
