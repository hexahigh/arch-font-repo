pkgname=ttf-google-notosansadlam
pkgver=3.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansadlam
pkgdesc="Google Fonts family: Noto Sans Adlam"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Adlam"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansadlam/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansadlam/NotoSansAdlam%5Bwght%5D.ttf"
)
sha256sums=(
  "0e86b3990089b054d8e6a29520589ac7ff3926738e2868e20d1b7f137d337d14"
  "fda98eedbbad51d6c80319065bb193a1b3c9410a8309f09063082b768a54159f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
