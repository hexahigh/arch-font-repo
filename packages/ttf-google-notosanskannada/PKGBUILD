pkgname=ttf-google-notosanskannada
pkgver=2.006
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanskannada
pkgdesc="Google Fonts family: Noto Sans Kannada"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Kannada"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanskannada/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanskannada/NotoSansKannada%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "9d49a4e56df9b36403b139f48bf07fd87cc5e716cb3203c54b04b674adb16238"
  "cca4f3b3a8cb12fb261f1b43baf5d2f7f59d90fe123d41f0065ed3a183997ec9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
