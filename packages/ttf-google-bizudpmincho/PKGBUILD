pkgname=ttf-google-bizudpmincho
pkgver=1.06
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bizudpmincho
pkgdesc="Google Fonts family: BIZ UDPMincho"
arch=('any')
url="https://fonts.google.com/specimen/BIZ+UDPMincho"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudpmincho/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudpmincho/BIZUDPMincho-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bizudpmincho/BIZUDPMincho-Regular.ttf"
)
sha256sums=(
  "ef0ed524b3bd012f37015e986809eed6f67905456ebfc1ebd7fcc2765282ee01"
  "99618e39b881597efc03d58706bd194757c968c1bf7a7017a893efead6b1b260"
  "dbcea04578ac1e9d3484525e870ce491bd04361768f4d2ba4b827d96e20f891d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
