pkgname=ttf-google-sigmar
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sigmar
pkgdesc="Google Fonts family: Sigmar"
arch=('any')
url="https://fonts.google.com/specimen/Sigmar"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sigmar/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sigmar/Sigmar-Regular.ttf"
)
sha256sums=(
  "75ff072c71b85d17c237e06104b5ff6648095cd62229a321b3bb5750f18df49d"
  "0597d733ed4722af36157f1e72d2415e123a9052655d67410c9ab8a0b223f54d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
