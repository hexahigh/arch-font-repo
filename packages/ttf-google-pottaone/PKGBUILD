pkgname=ttf-google-pottaone
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/pottaone
pkgdesc="Google Fonts family: Potta One"
arch=('any')
url="https://fonts.google.com/specimen/Potta+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pottaone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pottaone/PottaOne-Regular.ttf"
)
sha256sums=(
  "fe55933bcfad354914050fe0e7c879bd666a623f1e363a651198ac40c271cd26"
  "bde843868b56e429e1c863da2efa76df533162b226d990efcb96d533b0ca2a93"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
