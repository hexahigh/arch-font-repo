pkgname=ttf-google-nototraditionalnushu
pkgver=2.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/nototraditionalnushu
pkgdesc="Google Fonts family: Noto Traditional Nushu"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Traditional+Nushu"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/nototraditionalnushu/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/nototraditionalnushu/NotoTraditionalNushu%5Bwght%5D.ttf"
)
sha256sums=(
  "1cabb5c007be074c36e1a390b591265c31fa910d20d73af57e13093928f8cac0"
  "5944d18bbd4cb3422e249177afe2e4a645b58e4265b079809b47a8210ca315e7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
