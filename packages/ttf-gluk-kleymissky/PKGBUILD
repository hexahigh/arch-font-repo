pkgname=ttf-gluk-kleymissky
pkgver=0.283
pkgrel=1
pkgdesc="Kleymissky font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Kleymissky'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Kleymissky/Kleymissky_0283.zip")
sha256sums=('4d0b0f3553a7ef26a47f85d5875aa3cee293d49ead1a749b7e898150400cde02')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Kleymissky
License info from upstream page: OpenFontLicense
EOF
}
