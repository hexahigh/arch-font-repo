pkgname=ttf-google-sueellenfrancisco
pkgver=1.002
pkgrel=1
_commit="2483fb9fd9d6046927de4d80b3434d95e84e5712"  # Latest commit touching ofl/sueellenfrancisco
pkgdesc="Google Fonts family: Sue Ellen Francisco"
arch=('any')
url="https://fonts.google.com/specimen/Sue+Ellen+Francisco"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sueellenfrancisco/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sueellenfrancisco/SueEllenFrancisco-Regular.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "d6d72e046e8e92f659eacfb7457cf7e1f2142c112c3d8c43c0b5a3904a5c8621"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
