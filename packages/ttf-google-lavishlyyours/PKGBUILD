pkgname=ttf-google-lavishlyyours
pkgver=1.010
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/lavishlyyours
pkgdesc="Google Fonts family: Lavishly Yours"
arch=('any')
url="https://fonts.google.com/specimen/Lavishly+Yours"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/lavishlyyours/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/lavishlyyours/LavishlyYours-Regular.ttf"
)
sha256sums=(
  "f679d25307d193d34ed36afedde50715c97f155a3c720d90d39e7e5d468e0092"
  "4a07a5002a4f852952818eebdcf008e48ea7d537541cc8ff7eb842088842313e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
