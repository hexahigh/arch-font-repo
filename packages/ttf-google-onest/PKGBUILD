pkgname=ttf-google-onest
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/onest
pkgdesc="Google Fonts family: Onest"
arch=('any')
url="https://fonts.google.com/specimen/Onest"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/onest/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/onest/Onest[wght].ttf"
)
sha256sums=(
  "071195d8806e226faeee60259c28ca67b458227af5195a73f5cfcab06e3003bc"
  "3faa4b905661849b2332e394b42f91b5bf5575e553c516caa81811e868a4d589"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
