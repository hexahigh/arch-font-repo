  "https://github.com/google/fonts/raw/$_commit/ofl/muktamahee/MuktaMahee-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktamahee/MuktaMahee-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktamahee/MuktaMahee-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktamahee/MuktaMahee-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktamahee/MuktaMahee-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktamahee/MuktaMahee-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktamahee/MuktaMahee-SemiBold.ttf"
)
sha256sums=(
  "46751a31966477e3f038d1e5ff1146a33234a3a523a0e6a21be3221cba082a34"
  "f3d58ebd5f28d3913bcbfc2eb1b512f8b19d7b3e82eeb63adeac4c35414c29bc"
  "a818bc5d365109c983088dcda549f75d0633477a105520a0cc4ea411b96c816c"
  "6780020b758bff126aa7670f7b44a6e86f399d19256a4a6831308e5764f4eeb8"
  "c82c1dac3686050e0d9254fcb0a71a0b2a011c23bb85ebd185facd415b4cac60"
