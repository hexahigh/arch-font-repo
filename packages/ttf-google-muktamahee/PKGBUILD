pkgname=ttf-google-muktamahee
pkgver=2.538
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/muktamahee
pkgdesc="Google Fonts family: Mukta Mahee"
arch=('any')
url="https://fonts.google.com/specimen/Mukta+Mahee"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
