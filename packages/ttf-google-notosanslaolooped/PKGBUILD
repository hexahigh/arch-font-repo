pkgname=ttf-google-notosanslaolooped
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanslaolooped
pkgdesc="Google Fonts family: Noto Sans Lao Looped"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Lao+Looped"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslaolooped/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanslaolooped/NotoSansLaoLooped[wdth,wght].ttf"
)
sha256sums=(
  "a42993999944845fb5af693ea678a372a053db1f0981d55e911dcfa9d330f279"
  "5bffa09e287f48df6a02915ed4738c0b5b79a0c14e86954970fcf3167af6a8b0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
