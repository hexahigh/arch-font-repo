pkgname=ttf-google-notosansarabicui
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansarabicui
pkgdesc="Google Fonts family: Noto Sans Arabic UI"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Arabic+UI"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansarabicui/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansarabicui/NotoSansArabicUI%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "2d47090f7a3de2fd01ba8aff9a775263b3ab70a46cd2a6bfe3d1c3e1dd89ffe5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
