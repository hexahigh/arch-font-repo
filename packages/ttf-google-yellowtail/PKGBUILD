pkgname=ttf-google-yellowtail
pkgver=001.002
pkgrel=1
_commit="e77fdf0f4f6757f773feeea5603898e7d875dceb"  # Latest commit touching apache/yellowtail
pkgdesc="Google Fonts family: Yellowtail"
arch=('any')
url="https://fonts.google.com/specimen/Yellowtail"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/yellowtail/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/yellowtail/Yellowtail-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "3e06841b13000975f3cc38aa84e326e601a4378a4c52d50b5e9fee3598c5d236"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
