pkgname=ttf-google-notosansavestan
pkgver=2.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansavestan
pkgdesc="Google Fonts family: Noto Sans Avestan"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Avestan"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansavestan/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansavestan/NotoSansAvestan-Regular.ttf"
)
sha256sums=(
  "3554a83d7ac9f12aefb36a548e6c88fe1a71711d5c57f86001305c78a5c03152"
  "fe2ed44b8b3949cddced6c748bb67e161727b133d1e7a67c20385b314d2a4158"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
