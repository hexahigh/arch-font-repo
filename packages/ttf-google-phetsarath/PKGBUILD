pkgname=ttf-google-phetsarath
pkgver=1.01
pkgrel=1
_commit="fe89588cf742d9691bee4b4c32de177ee622c949"  # Latest commit touching ofl/phetsarath
pkgdesc="Google Fonts family: Phetsarath"
arch=('any')
url="https://fonts.google.com/specimen/Phetsarath"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/phetsarath/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/phetsarath/Phetsarath-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/phetsarath/Phetsarath-Regular.ttf"
)
sha256sums=(
  "6e6efa9b0556d100cfe60690cff5d9be7144df77adabfd2c278dbfee451351ea"
  "3b8cced65a9b4a49da487c4abb6c36c9dafb2c11e3c75a16b7da32a28bc2ecab"
  "0d0328c2036319a06ae4e0093d1ea32b6d849069f624cf6dd67e1f6ebc4635a8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
