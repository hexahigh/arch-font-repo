pkgname=ttf-google-zillaslabhighlight
pkgver=1.1
pkgrel=1
_commit="19e8bc8b91eb482e8b24a8141abf95be5237728b"  # Latest commit touching ofl/zillaslabhighlight
pkgdesc="Google Fonts family: Zilla Slab Highlight"
arch=('any')
url="https://fonts.google.com/specimen/Zilla+Slab+Highlight"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/zillaslabhighlight/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/zillaslabhighlight/ZillaSlabHighlight-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/zillaslabhighlight/ZillaSlabHighlight-Regular.ttf"
)
sha256sums=(
  "3cbf579238e4eacd90ad67883d971aa346ce8990d658635f78f98d608a6830a2"
  "e6653c7e0299c1cae5e7fe21157267ade56dd301b36cda073c407299b82548f4"
  "2c9248dba34693c039b6e20cb34faa9ed385fe676ec8c7f364effbce37e35bc7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
