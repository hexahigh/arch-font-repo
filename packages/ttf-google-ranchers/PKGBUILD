pkgname=ttf-google-ranchers
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/ranchers
pkgdesc="Google Fonts family: Ranchers"
arch=('any')
url="https://fonts.google.com/specimen/Ranchers"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ranchers/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ranchers/Ranchers-Regular.ttf"
)
sha256sums=(
  "0fc8e6675568c02aac6b41dd3cccaf2264fc5969601effe68e09b26635879b2c"
  "19568aba8965664d1bc6f5a48c24d269c97501eed87af26b912f42b6e6f22adc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
