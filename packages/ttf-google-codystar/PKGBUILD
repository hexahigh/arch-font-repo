pkgname=ttf-google-codystar
pkgver=1.000
pkgrel=1
_commit="3dd78844021e948ceb633d1dcee3f7885561b5d9"  # Latest commit touching ofl/codystar
pkgdesc="Google Fonts family: Codystar"
arch=('any')
url="https://fonts.google.com/specimen/Codystar"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/codystar/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/codystar/Codystar-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/codystar/Codystar-Regular.ttf"
)
sha256sums=(
  "35dca6122235851d236bd861124f4a893d409eba021cd8c6a292a19df0f4640d"
  "fa1fcf4f00f3c35b82219320a2322f561bc9e7f5ae6ded498a28958f5c07a3c0"
  "99f059a3e31afdaf3fea53d39bc62b15df38a5d882104ae1d1a5ca2df547c10a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
