pkgname=ttf-google-astasans
pkgver=1.000
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/astasans
pkgdesc="Google Fonts family: Asta Sans"
arch=('any')
url="https://fonts.google.com/specimen/Asta+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/astasans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/astasans/AstaSans[wght].ttf"
)
sha256sums=(
  "2448ea782a6364d571a4848c34db8a042311f44c78cf00265888db19ea10d5a4"
  "f68410bf7d04deb992097758640145c72ddcf234070794237fc4994e18991c33"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
