  "https://github.com/google/fonts/raw/$_commit/ofl/encodesanscondensed/EncodeSansCondensed-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/encodesanscondensed/EncodeSansCondensed-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/encodesanscondensed/EncodeSansCondensed-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/encodesanscondensed/EncodeSansCondensed-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/encodesanscondensed/EncodeSansCondensed-Thin.ttf"
)
