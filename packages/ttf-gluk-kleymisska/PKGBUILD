pkgname=ttf-gluk-kleymisska
pkgver=0.30
pkgrel=1
pkgdesc="Kleymisska font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Kleymisska'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Kleymisska/Kleymisska_030.zip")
sha256sums=('607995d7ad69739d58cda96f5559273010e6de139311d9d18923658725928993')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Kleymisska
License info from upstream page: OpenFontLicense
EOF
}
