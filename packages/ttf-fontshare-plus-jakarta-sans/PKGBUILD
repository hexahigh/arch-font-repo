pkgname=ttf-fontshare-plus-jakarta-sans
pkgver=2.006
pkgrel=1
_slug="plus-jakarta-sans"
pkgdesc="Fontshare family: Plus Jakarta Sans"
arch=('any')
url="https://www.fontshare.com/fonts/plus-jakarta-sans/"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://api.fontshare.com/v2/fonts/download/plus-jakarta-sans")
sha256sums=('beeff130a26a1802656ba08674e9f282ee1117db858ec63909e529a067cb3edb')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install every shipped TTF/OTF/TTC font from the Fontshare bundle.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  license_file="$(find "${srcdir}" -type f \( -iname 'OFL.txt' -o -iname 'FFL.txt' -o -iname 'LICENSE*' \) | head -n 1)"
  if [[ -n "${license_file}" ]]; then
    install -Dm644 "${license_file}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  fi
}
