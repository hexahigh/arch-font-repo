pkgname=ttf-google-notosansnko_todelist
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansnko_todelist
pkgdesc="Google Fonts family: Noto Sans N Ko"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+N+Ko"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnko_todelist/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnko_todelist/NotoSansNKo-Regular.ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "389f4082894bf1833dc5f140a282496114366b410779fbb16b3486f4660e9313"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
