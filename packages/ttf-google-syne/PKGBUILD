pkgname=ttf-google-syne
pkgver=2.200
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/syne
pkgdesc="Google Fonts family: Syne"
arch=('any')
url="https://fonts.google.com/specimen/Syne"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/syne/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/syne/Syne%5Bwght%5D.ttf"
)
sha256sums=(
  "cc43cdce6f91c57989af8459341c276655e34224e954fa69c2ad700831a742d8"
  "ce5ac77142a65cab2248a1a2ebb740b1d4d9c20b52488877d3ff664d1356104a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
