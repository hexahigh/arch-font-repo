pkgname=ttf-google-youngserif
pkgver=3.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/youngserif
pkgdesc="Google Fonts family: Young Serif"
arch=('any')
url="https://fonts.google.com/specimen/Young+Serif"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/youngserif/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/youngserif/YoungSerif-Regular.ttf"
)
sha256sums=(
  "737d8d343b674c6894f373de71a044b6782c130f2aebf180933d63ddf7a3dc19"
  "42bb2602364b28569fdce5eeb6ab3d81cf8090ba81b211f1229ed69f33155523"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
