pkgname=ttf-google-triodion
pkgver=1.202
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/triodion
pkgdesc="Google Fonts family: Triodion"
arch=('any')
url="https://fonts.google.com/specimen/Triodion"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/triodion/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/triodion/Triodion-Regular.ttf"
)
sha256sums=(
  "17c317eeeb7a3eddea14c8b8d595ac6d9fcc39951dfc06cf56fd8e532be087c8"
  "fc93ae1a214a8dbb0746ee5afa705042b4d65430327c648eeafe15ff5f53bfe3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
