pkgname=ttf-google-notosanshanifirohingya
pkgver=2.102
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanshanifirohingya
pkgdesc="Google Fonts family: Noto Sans Hanifi Rohingya"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Hanifi+Rohingya"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanshanifirohingya/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanshanifirohingya/NotoSansHanifiRohingya[wght].ttf"
)
sha256sums=(
  "addc4a900f32e670a401766f144d6a1fc1bc7dffed87350e310ef1d68ba404f8"
  "8ae85e850664b2d319c3b359bbf59b285e0e472afcaf96e34f37810e4b441d1b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
