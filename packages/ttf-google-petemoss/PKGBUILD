pkgname=ttf-google-petemoss
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/petemoss
pkgdesc="Google Fonts family: Petemoss"
arch=('any')
url="https://fonts.google.com/specimen/Petemoss"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/petemoss/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/petemoss/Petemoss-Regular.ttf"
)
sha256sums=(
  "e8ed3488dac3452e67746a5ebac23bf5cf72a614b606a1f80a81ade4e0e6b03f"
  "c15315bba38c1b4fdcc6aadda5bb7aecb9d341121bbc0ea2e23f05bf6fb614c4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
