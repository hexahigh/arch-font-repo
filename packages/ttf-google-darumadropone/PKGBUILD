pkgname=ttf-google-darumadropone
pkgver=1.000
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/darumadropone
pkgdesc="Google Fonts family: Darumadrop One"
arch=('any')
url="https://fonts.google.com/specimen/Darumadrop+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/darumadropone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/darumadropone/DarumadropOne-Regular.ttf"
)
sha256sums=(
  "bd898c86fb555f060ee9e5d318d631bbdcd196b98ae8019e0077421f46da132f"
  "beef6d9031918823176ea0f9f729cb811a5f250598d7c8c684b3dee333810689"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
