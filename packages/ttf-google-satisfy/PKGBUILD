pkgname=ttf-google-satisfy
pkgver=1.001
pkgrel=1
_commit="1bf1ba256af8ffbc25714b1152698916e05fe541"  # Latest commit touching apache/satisfy
pkgdesc="Google Fonts family: Satisfy"
arch=('any')
url="https://fonts.google.com/specimen/Satisfy"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/satisfy/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/satisfy/Satisfy-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "55bb141a0a23a32278d5fa7fd2e853824faa173b94774660ebeddb106be07c80"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
