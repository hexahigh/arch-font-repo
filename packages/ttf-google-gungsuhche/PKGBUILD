pkgname=ttf-google-gungsuhche
pkgver=2.21
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/gungsuhche
pkgdesc="Google Fonts family: GungsuhChe"
arch=('any')
url="https://fonts.google.com/specimen/GungsuhChe"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gungsuhche/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gungsuhche/GungsuhChe-Regular.ttf"
)
sha256sums=(
  "cc115f501827fffddcbf1ef86e5248ee55e40f0c3fb9725173b248ccc2d5df51"
  "ad7744ead7cb467fa12ffc565d1ba864a1a2f972c1bea1e3208062c369982c64"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
