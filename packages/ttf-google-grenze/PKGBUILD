pkgname=ttf-google-grenze
pkgver=1.003
pkgrel=1
_commit="b9edf4389a90f688d5912804e0692788d283e59e"  # Latest commit touching ofl/grenze
pkgdesc="Google Fonts family: Grenze"
arch=('any')
url="https://fonts.google.com/specimen/Grenze"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/grenze/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/grenze/Grenze-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/grenze/Grenze%5Bwght%5D.ttf"
)
sha256sums=(
  "55a21d1fcebfa5e02100db3ae4dcff2658e9ba63e0b64149203bf6a9d645db86"
  "60e9821fff9603945d835a73257a743a8c6754fd3fda1e4329af50ea7e46f9c2"
  "04afa4836bcd41e1ff9867a0dc27d628d31ddec618ec67715c526ebc3cae92f4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
