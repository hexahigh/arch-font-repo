pkgname=ttf-google-chirongoroundtc
pkgver=1.002
pkgrel=1
_commit="8cece0442e7352ede7bf368e209b8e5f57a33e3f"  # Latest commit touching ofl/chirongoroundtc
pkgdesc="Google Fonts family: Chiron GoRound TC"
arch=('any')
url="https://fonts.google.com/specimen/Chiron+GoRound+TC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/chirongoroundtc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/chirongoroundtc/ChironGoRoundTC%5Bwght%5D.ttf"
)
sha256sums=(
  "7b9cc84fe1935d1418de4af57b4106038fb836b3a162e1b86507c7fc8543a759"
  "47cd5ff5153799d4c0d05bcc64da849e13b8eb842e46728a66bf2d52c480231f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
