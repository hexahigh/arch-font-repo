pkgname=ttf-google-delicioushandrawn
pkgver=1.002
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/delicioushandrawn
pkgdesc="Google Fonts family: Delicious Handrawn"
arch=('any')
url="https://fonts.google.com/specimen/Delicious+Handrawn"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/delicioushandrawn/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/delicioushandrawn/DeliciousHandrawn-Regular.ttf"
)
sha256sums=(
  "3fa395232efa6d42e5af84de2503875c895b24a9299bb84aa54633c74bf8a0d2"
  "5b78da9362d2018cab40ba93565f7a0134723f6a5ee4e3432726d45473a51277"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
