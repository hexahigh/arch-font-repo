pkgname=ttf-google-sankofadisplay
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sankofadisplay
pkgdesc="Google Fonts family: Sankofa Display"
arch=('any')
url="https://fonts.google.com/specimen/Sankofa+Display"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sankofadisplay/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sankofadisplay/SankofaDisplay-Regular.ttf"
)
sha256sums=(
  "8e115d039913e90bb4bcbed53601594db2e5556536ba1bcc4aec4f6026dfbf5f"
  "747b51b50660960d481505bf10354d68df79e6aea97fcac3faa8252dfb757429"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
