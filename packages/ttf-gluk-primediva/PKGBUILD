pkgname=ttf-gluk-primediva
pkgver=0.64
pkgrel=1
pkgdesc="Primediva font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Primediva'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Primediva/Primediva_064.zip")
sha256sums=('ed7a02273de1b2b7e97ed8d9bf9e67a9c6d1dad600879383cfb51d706049521a')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Primediva
License info from upstream page: OpenFontLicense
EOF
}
