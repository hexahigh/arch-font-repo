pkgname=ttf-google-notoserifkhmer
pkgver=2.004
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifkhmer
pkgdesc="Google Fonts family: Noto Serif Khmer"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Khmer"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifkhmer/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifkhmer/NotoSerifKhmer[wdth,wght].ttf"
)
sha256sums=(
  "be0407f060aea48787ff9e75d8d3aedef70aef113b3ce9aca26fdaacd10b1870"
  "50ad032042491e98b440e41490d26b716d8d43886eebfafa9735f6284c1980e2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
