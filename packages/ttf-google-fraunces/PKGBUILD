pkgname=ttf-google-fraunces
pkgver=1.000
pkgrel=1
_commit="4024282d9b0cffcdb8e3024560862746178d741f"  # Latest commit touching ofl/fraunces
pkgdesc="Google Fonts family: Fraunces"
arch=('any')
url="https://fonts.google.com/specimen/Fraunces"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/fraunces/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/fraunces/Fraunces-Italic%5BSOFT%2CWONK%2Copsz%2Cwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/fraunces/Fraunces%5BSOFT%2CWONK%2Copsz%2Cwght%5D.ttf"
)
sha256sums=(
  "bdf4c22802eaf804f998195871c6b8938aac2ac14b2d78a8bd66a6f1eced833b"
  "b24448c43702fac4ee856781d461a0dfba8d8e594b6e8e190234b75fed2c0e01"
  "177ff6c0f14e5550a3c624247cd1189611d4eb65d000b14944c63d967958abbb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
