pkgname=ttf-google-alumnisanspinstripe
pkgver=1.010
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/alumnisanspinstripe
pkgdesc="Google Fonts family: Alumni Sans Pinstripe"
arch=('any')
url="https://fonts.google.com/specimen/Alumni+Sans+Pinstripe"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanspinstripe/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanspinstripe/AlumniSansPinstripe-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanspinstripe/AlumniSansPinstripe-Regular.ttf"
)
sha256sums=(
  "855c8e5b459dfa20361af32b393bab0c18f67f888ee7bd69d54318cbefcaa7fe"
  "5639e0d5bfec3719f127139d232c60c42aa3ae661b580e405e6a9b06002ab6be"
  "c00bc8d641f2ddc444bbb9a07125f4eb1e6eda0384a896196ad0c7be0a9cfeea"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
