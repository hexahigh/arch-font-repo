pkgname=ttf-google-heebo
pkgver=3.100
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/heebo
pkgdesc="Google Fonts family: Heebo"
arch=('any')
url="https://fonts.google.com/specimen/Heebo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/heebo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/heebo/Heebo%5Bwght%5D.ttf"
)
sha256sums=(
  "866747cbccae229433e946b90fcfc457b81c33ac89e593855770851354f9e6c3"
  "18f930b583fa8fe6b40b2f8263b7ac6afbac07adc91a12467874e7467d3ace30"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
