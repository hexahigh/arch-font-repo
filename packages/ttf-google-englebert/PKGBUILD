pkgname=ttf-google-englebert
pkgver=1.010
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/englebert
pkgdesc="Google Fonts family: Englebert"
arch=('any')
url="https://fonts.google.com/specimen/Englebert"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/englebert/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/englebert/Englebert-Regular.ttf"
)
sha256sums=(
  "56fd4c8ff2b01a60bbab0c919817cd58503029efd5d39261aeb8934f831ec4ee"
  "97be7df4f050113b713077b9cb4a51e7f62c155ba22c7adf7ee65e0d7b0f7577"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
