pkgname=ttf-google-adamina
pkgver=1.013
pkgrel=1
_commit="7beedcffa59af71485370f3407ab220e22f33504"  # Latest commit touching ofl/adamina
pkgdesc="Google Fonts family: Adamina"
arch=('any')
url="https://fonts.google.com/specimen/Adamina"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/adamina/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/adamina/Adamina-Regular.ttf"
)
sha256sums=(
  "16a8be6ac4b009ba1dd1e17cea48762f4915609ea5dca1303f716cf63998739d"
  "e7108cfee0a718d5885fc8d0f03555fa6e0c4b6309e4b15ea991aadd824c34b7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
