pkgname=ttf-google-bigshouldersstenciltextsc
pkgver=2.001
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/bigshouldersstenciltextsc
pkgdesc="Google Fonts family: Big Shoulders Stencil Text SC"
arch=('any')
url="https://fonts.google.com/specimen/Big+Shoulders+Stencil+Text+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersstenciltextsc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersstenciltextsc/BigShouldersStencilTextSC[wght].ttf"
)
sha256sums=(
  "fbc746aabf0eb1847dfd92e2efc4596d79fa897d60b8e64062a22f585508fb3f"
  "970efc1f8eb45174ae6fa7e14aa33449af764dc8f925d296e3b9aa1878b87e74"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
