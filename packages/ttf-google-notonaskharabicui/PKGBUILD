pkgname=ttf-google-notonaskharabicui
pkgver=2.015
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notonaskharabicui
pkgdesc="Google Fonts family: Noto Naskh Arabic UI"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Naskh+Arabic+UI"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notonaskharabicui/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notonaskharabicui/NotoNaskhArabicUI%5Bwght%5D.ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "6bcf69fb867a773084baf29736b6410ff7a0fd67c821271fe6eb87ed2292b1cd"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
