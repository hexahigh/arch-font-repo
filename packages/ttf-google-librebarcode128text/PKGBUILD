pkgname=ttf-google-librebarcode128text
pkgver=1.005
pkgrel=1
_commit="90f782e99e568864870fda8f98c269bb1fb40a8a"  # Latest commit touching ofl/librebarcode128text
pkgdesc="Google Fonts family: Libre Barcode 128 Text"
arch=('any')
url="https://fonts.google.com/specimen/Libre+Barcode+128+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/librebarcode128text/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/librebarcode128text/LibreBarcode128Text-Regular.ttf"
)
sha256sums=(
  "a4b7ccd1bda3269afba7d6d9293a7161e699d2f4f1f280dd8a8535c569388de9"
  "0e8a268749e77c8bf1644a19cdd65e83af6486bcadc06225e486cdf569d58f58"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
