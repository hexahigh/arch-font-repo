pkgname=ttf-google-stintultracondensed
pkgver=1.000
pkgrel=1
_commit="8da48a893890ac4fc454cc0ebcd3f169749e12f1"  # Latest commit touching ofl/stintultracondensed
pkgdesc="Google Fonts family: Stint Ultra Condensed"
arch=('any')
url="https://fonts.google.com/specimen/Stint+Ultra+Condensed"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/stintultracondensed/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/stintultracondensed/StintUltraCondensed-Regular.ttf"
)
sha256sums=(
  "fc1e501d419d84a8f1a800adae092045002d7141241f498237611dbb8ea763d7"
  "1c32b77a50e960f9e88e29e1c65a0a15ffe277681ace0dbf207fafa7be23591e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
