pkgname=ttf-google-pontanosans
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/pontanosans
pkgdesc="Google Fonts family: Pontano Sans"
arch=('any')
url="https://fonts.google.com/specimen/Pontano+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pontanosans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pontanosans/PontanoSans%5Bwght%5D.ttf"
)
sha256sums=(
  "a247e9c11f1d488e94c40190b162ac871064dc639c0eae4ebc28013c89b599ec"
  "cafd98966b473326a8d6344abb34ec543267f47fb76ca7532855db5a08a0a002"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
