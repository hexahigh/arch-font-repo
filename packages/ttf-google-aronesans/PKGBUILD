pkgname=ttf-google-aronesans
pkgver=1.001
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/aronesans
pkgdesc="Google Fonts family: AR One Sans"
arch=('any')
url="https://fonts.google.com/specimen/AR+One+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/aronesans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/aronesans/AROneSans%5BARRR%2Cwght%5D.ttf"
)
sha256sums=(
  "c1bec22a6baf0cc6365b3f049694559f171a92ffa6eef2ddb26b0950ff6a4693"
  "235b1352c58fb6d9763d74711d7c2e1d726d805fc04cad8fde2f56a469566b5f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
