pkgname=ttf-google-notosanssundanese
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssundanese
pkgdesc="Google Fonts family: Noto Sans Sundanese"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Sundanese"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssundanese/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssundanese/NotoSansSundanese%5Bwght%5D.ttf"
)
sha256sums=(
  "2d42ae3d7f3522cfd45fcd4daffa698a1d7b5c13b2512593d0f993633fa428fa"
  "28282be9cce5a96e6b5baa3cc48044187f65d610879ff29b1dc5fe5ea465df6a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
