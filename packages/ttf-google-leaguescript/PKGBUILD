pkgname=ttf-google-leaguescript
pkgver=1.001
pkgrel=1
_commit="d2fe750bb2c1140c2371fb30de1279b0e178d824"  # Latest commit touching ofl/leaguescript
pkgdesc="Google Fonts family: League Script"
arch=('any')
url="https://fonts.google.com/specimen/League+Script"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/leaguescript/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/leaguescript/LeagueScript-Regular.ttf"
)
sha256sums=(
  "81d0973236b5b5709a80a217a330db36eabedf57bf4031de46b4660b69901234"
  "42c3a493028aec3a2266e540a1264f7b5e26eefd17219dda9b165b928986308a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
