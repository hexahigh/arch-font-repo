pkgname=ttf-google-anekbangla
pkgver=1.003
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/anekbangla
pkgdesc="Google Fonts family: Anek Bangla"
arch=('any')
url="https://fonts.google.com/specimen/Anek+Bangla"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/anekbangla/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/anekbangla/AnekBangla%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "de62be758bba267e653a5f457dfebb4680957e2c343eb3e7de15aff4746bed05"
  "8b4ec2eaf7400ea9903718a4addf3135475292e6e0b04db7735d0f999289d919"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
