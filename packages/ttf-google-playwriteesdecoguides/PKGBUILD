pkgname=ttf-google-playwriteesdecoguides
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwriteesdecoguides
pkgdesc="Google Fonts family: Playwrite ES Deco Guides"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+ES+Deco+Guides"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwriteesdecoguides/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwriteesdecoguides/PlaywriteESDecoGuides-Regular.ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "2ca6b8ee59c3b5568d4c5e526963684550ca980f9b37b948176d56d550630bf2"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
