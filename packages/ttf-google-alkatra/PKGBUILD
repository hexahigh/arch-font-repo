pkgname=ttf-google-alkatra
pkgver=1.100
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/alkatra
pkgdesc="Google Fonts family: Alkatra"
arch=('any')
url="https://fonts.google.com/specimen/Alkatra"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alkatra/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alkatra/Alkatra[wght].ttf"
)
sha256sums=(
  "5985658cc7672eb25b95427a485ce922402908c90d9feaca2a88930cd98e54d9"
  "af6d39e8085eda5db66b19100571709bd41c41938400f2c365dadde86dd28466"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
