pkgname=ttf-google-mousememoirs
pkgver=1.000
pkgrel=1
_commit="ecf4cbccd7cd8575b91767cb87d9d04120e6766b"  # Latest commit touching ofl/mousememoirs
pkgdesc="Google Fonts family: Mouse Memoirs"
arch=('any')
url="https://fonts.google.com/specimen/Mouse+Memoirs"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mousememoirs/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mousememoirs/MouseMemoirs-Regular.ttf"
)
sha256sums=(
  "81d6c3788a6b641cb9f543389d9d5c0cd3bf94fbb5639be19c102b9274c34291"
  "1bb7f4baccb46375c5692327af8313fdc242b9e6a584d43c637357a3de998834"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
