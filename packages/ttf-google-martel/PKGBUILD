pkgname=ttf-google-martel
pkgver=1.001
pkgrel=1
_commit="65f72f0ad55a7c8f5b1b71bb57addae8b3c06254"  # Latest commit touching ofl/martel
pkgdesc="Google Fonts family: Martel"
arch=('any')
url="https://fonts.google.com/specimen/Martel"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/martel/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/martel/Martel-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/martel/Martel-DemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/martel/Martel-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/martel/Martel-Heavy.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/martel/Martel-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/martel/Martel-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/martel/Martel-UltraLight.ttf"
)
sha256sums=(
  "f177d98c67b84250ec87a03ca6ad161e84cab15b435e960039b971797a065f4a"
  "072b7259061a99128e50056b081024975dfc6e4c0b265ab99f75bf66bd50c338"
  "6be979323225cd9d1a3964403b2771816e007610ee68d8d4bf08a75f2e7e08bf"
  "5bc47c0d423242f1dc9f7e33246cf264c72fb0672ebc76d4774494fe71ccf9a4"
  "6122fc615d2ea31a44380737c679d6193a2de5a263f6bd6b329679b4f640609e"
  "589537240a3d2c06793c5e7d5f85fc60a4ceba9b95e35206f3a7b5d90f6f6938"
  "b733e56144115d5da6a6415d2971ab97b7262948d172e27309ad00ce9096b876"
  "775fa07561b055b31297ad2f05bf5f45eddc1645318ed2c419724a41b09cf010"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
