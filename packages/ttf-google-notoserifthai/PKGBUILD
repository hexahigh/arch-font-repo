pkgname=ttf-google-notoserifthai
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notoserifthai
pkgdesc="Google Fonts family: Noto Serif Thai"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Serif+Thai"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifthai/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifthai/NotoSerifThai%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "2e98fd23a52d253db8612cd5942c8f2ff4111b21d2367050fdca91d8ccc374a0"
  "34a7ad11647c845303aabdde639059806c56b84719e5d2ceb28eb038711bdf53"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
