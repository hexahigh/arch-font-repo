pkgname=ttf-google-newtegomin
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/newtegomin
pkgdesc="Google Fonts family: New Tegomin"
arch=('any')
url="https://fonts.google.com/specimen/New+Tegomin"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/newtegomin/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/newtegomin/NewTegomin-Regular.ttf"
)
sha256sums=(
  "448df04b698cb1101857b61c7d1b4187beb59d3a0fb5edbd834d308758cda95e"
  "bcae8775f0f9b88e12e40434918c56817e96e3a291e2a6595a34fb38fe3e58fb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
