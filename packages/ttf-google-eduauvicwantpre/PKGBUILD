pkgname=ttf-google-eduauvicwantpre
pkgver=1.001
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/eduauvicwantpre
pkgdesc="Google Fonts family: Edu AU VIC WA NT Pre"
arch=('any')
url="https://fonts.google.com/specimen/Edu+AU+VIC+WA+NT+Pre"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/eduauvicwantpre/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/eduauvicwantpre/EduAUVICWANTPre[wght].ttf"
)
sha256sums=(
  "11a98fa66908aa244c7608443d945dd50e2821d879bb25b5897ffc8f94712688"
  "973adafba66b6df689ba134e53715ae1cb97b74a6b8f9c1bc58394052a415f52"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
