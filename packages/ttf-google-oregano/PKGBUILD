pkgname=ttf-google-oregano
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/oregano
pkgdesc="Google Fonts family: Oregano"
arch=('any')
url="https://fonts.google.com/specimen/Oregano"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/oregano/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/oregano/Oregano-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/oregano/Oregano-Regular.ttf"
)
sha256sums=(
  "96b7bc175186cd0153a9682a1c9bb1da7103ab13a83abef8026bc64582ca616f"
  "5e4df67997869d4e68dba1a38463a70c8679d29cb7ac678779631db9382f5538"
  "0c2eaed981aeefa8445c4a937794fd1ec7dd5a5b40ff60307a59775cc239b187"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
