pkgname=ttf-google-flowcircular
pkgver=1.101
pkgrel=1
_commit="03dac7d00bdcc3ade9a1f77b855ae076b94d59f7"  # Latest commit touching ofl/flowcircular
pkgdesc="Google Fonts family: Flow Circular"
arch=('any')
url="https://fonts.google.com/specimen/Flow+Circular"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/flowcircular/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/flowcircular/FlowCircular-Regular.ttf"
)
sha256sums=(
  "54665278a85e00842c5a261c2bc51c4735082f0164edcd95da27ed11e253e604"
  "ea87d5b1d0be7c5a3cf63054ad3e1d5ed54cca7491f9237a1226cb72f6340e78"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
