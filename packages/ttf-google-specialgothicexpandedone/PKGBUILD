pkgname=ttf-google-specialgothicexpandedone
pkgver=1.010
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/specialgothicexpandedone
pkgdesc="Google Fonts family: Special Gothic Expanded One"
arch=('any')
url="https://fonts.google.com/specimen/Special+Gothic+Expanded+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/specialgothicexpandedone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/specialgothicexpandedone/SpecialGothicExpandedOne-Regular.ttf"
)
sha256sums=(
  "0bac2fe19bcf60beddb3c9301da3c7889e6d5b996af22462853ff391b933f978"
  "b6c347c00c607f9ca562e6054cadf87fb3ea20dbe2cc482bad3086fa4de48027"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
