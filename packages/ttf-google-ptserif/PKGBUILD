pkgname=ttf-google-ptserif
pkgver=1.000
pkgrel=1
_commit="80327115aa6e63ea8947558e5fb676f5287878ba"  # Latest commit touching ofl/ptserif
pkgdesc="Google Fonts family: PT Serif"
arch=('any')
url="https://fonts.google.com/specimen/PT+Serif"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ptserif/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ptserif/PT_Serif-Web-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ptserif/PT_Serif-Web-BoldItalic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ptserif/PT_Serif-Web-Italic.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ptserif/PT_Serif-Web-Regular.ttf"
)
sha256sums=(
  "ddf311c28ddf5a5ad9747649837346b67bed9d356789c3072bb27dbce49e514d"
  "038ba7336bd7ea14f12ad155bed51a4345cac5153275d521dec3ba04021c526e"
  "f003788ba08981eb0988b3557a6f224a53dab49c20e283e8b74d5af3c466f8be"
  "f57e95ff9dc85691a3b2e193f2028db36f6663939a46c0fc4f286d618b80b7ce"
  "a4951fade06ff8f09b7673aa81ffb65a8cd409e24d3289a6dc670bc4dda2557a"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
