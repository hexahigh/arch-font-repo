pkgname=ttf-gluk-ketosag
pkgver=0.24
pkgrel=1
pkgdesc="Ketosag font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=Ketosag'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/Ketosag/Ketosag_024.zip")
sha256sums=('e439ef631552da0eb367d6bebe442517a7187dc60a8ae1c65713ada6f60c3ab9')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=Ketosag
License info from upstream page: OpenFontLicense
EOF
}
