pkgname=ttf-google-metamorphous
pkgver=1.001
pkgrel=1
_commit="74e1adf703ea5943921dd7e6b5df4758019da10a"  # Latest commit touching ofl/metamorphous
pkgdesc="Google Fonts family: Metamorphous"
arch=('any')
url="https://fonts.google.com/specimen/Metamorphous"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/metamorphous/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/metamorphous/Metamorphous-Regular.ttf"
)
sha256sums=(
  "4fece81b541808b40293b0cd3f5b1990274e1100e1c20455dc2987cd96639d3f"
  "55939a5664e06807e87fa4af64f52039ead12f002dda8317393fdce2f7ff57fe"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
