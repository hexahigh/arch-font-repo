pkgname=ttf-google-blinker
pkgver=1.016
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/blinker
pkgdesc="Google Fonts family: Blinker"
arch=('any')
url="https://fonts.google.com/specimen/Blinker"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
