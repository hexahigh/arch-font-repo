  "https://github.com/google/fonts/raw/$_commit/ofl/blinker/Blinker-Black.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/blinker/Blinker-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/blinker/Blinker-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/blinker/Blinker-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/blinker/Blinker-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/blinker/Blinker-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/blinker/Blinker-SemiBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/blinker/Blinker-Thin.ttf"
)
sha256sums=(
  "3ae0ef4107cdb72d21f4076575487e7b1c76fdc2d62d451ef223633a3196cb20"
  "9404723f3a1a2c600c2b1ca8ba3bdaa1fcc348cdcaa94301181f97e368cfff49"
  "da7c3e42b502b5445263d492b5adcdff01e656d87beddf8cc5bae5657898664a"
  "2aadb3bf884c0f60c1fccf861ccc4c31ae4ff42c87b23444cd979246d6863129"
  "99070de9779f72df4e836b8dff77aba1db6102c41f093d200c5d77f336b16174"
