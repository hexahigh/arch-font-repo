pkgname=ttf-google-jaro
pkgver=1.000
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/jaro
pkgdesc="Google Fonts family: Jaro"
arch=('any')
url="https://fonts.google.com/specimen/Jaro"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/jaro/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/jaro/Jaro%5Bopsz%5D.ttf"
)
sha256sums=(
  "0072c96dc8ffe3207285f28cc622ecbd6938372e476bc232a2d03bd404250869"
  "38d50e38a6fb082069984b363eb0a9280fc6a5e7f8a69fce2afce52bb6bc9670"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
