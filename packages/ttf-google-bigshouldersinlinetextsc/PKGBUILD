pkgname=ttf-google-bigshouldersinlinetextsc
pkgver=2.002
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/bigshouldersinlinetextsc
pkgdesc="Google Fonts family: Big Shoulders Inline Text SC"
arch=('any')
url="https://fonts.google.com/specimen/Big+Shoulders+Inline+Text+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersinlinetextsc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersinlinetextsc/BigShouldersInlineTextSC[wght].ttf"
)
sha256sums=(
  "fbc746aabf0eb1847dfd92e2efc4596d79fa897d60b8e64062a22f585508fb3f"
  "28ccd62c3931f32c31bb6d34f5338f369a556b92cbb2ba6ec45d748c562c08ed"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
