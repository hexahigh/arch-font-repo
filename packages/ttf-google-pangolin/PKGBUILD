pkgname=ttf-google-pangolin
pkgver=1.101
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/pangolin
pkgdesc="Google Fonts family: Pangolin"
arch=('any')
url="https://fonts.google.com/specimen/Pangolin"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/pangolin/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/pangolin/Pangolin-Regular.ttf"
)
sha256sums=(
  "b4fc1d55ce610f255c5712f8169543f9610536d002deb99bbc99bfbba9f8a560"
  "cf4f0a46704c7859d4943320fce6c6d06cc7dc450ef971c3676ef36f9f482299"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
