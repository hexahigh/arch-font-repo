pkgname=ttf-google-notosanschakma
pkgver=2.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanschakma
pkgdesc="Google Fonts family: Noto Sans Chakma"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Chakma"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanschakma/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanschakma/NotoSansChakma-Regular.ttf"
)
sha256sums=(
  "4f95be0c30353cefed3d98051bb6762754893267ddbe123783cf92e8aa6f787f"
  "0e560c61cfe0f378377741770d38b5f802457455dd78aaf4b89614082659fba5"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
