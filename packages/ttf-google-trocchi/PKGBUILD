pkgname=ttf-google-trocchi
pkgver=1.101
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/trocchi
pkgdesc="Google Fonts family: Trocchi"
arch=('any')
url="https://fonts.google.com/specimen/Trocchi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/trocchi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/trocchi/Trocchi-Regular.ttf"
)
sha256sums=(
  "b5b48b6baf1a46fbe309af924841891869f4aeddda039943b20c623028b6c726"
  "d2d81d30d99aaa2c234e1d7bb67ee2e9f27f108f8d2ebef1c89e0db623734b91"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
