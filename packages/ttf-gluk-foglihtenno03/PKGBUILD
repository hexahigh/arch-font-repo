pkgname=ttf-gluk-foglihtenno03
pkgver=0.59
pkgrel=1
pkgdesc="FoglihtenNo03 font by Gluk"
arch=('any')
url='https://www.glukfonts.pl/font.php?font=FoglihtenNo03'
license=('custom')
depends=('fontconfig')
provides=('ttf-font')
source=("${pkgname}-${pkgver}.zip::https://www.glukfonts.pl/fontdl/f231212/font/foglihtenNo03/FoglihtenNo03-059.zip")
sha256sums=('d826328903a711b67a8ecd33bcdd1b64db6c5e12dbcd34be3f24dde2053cf262')

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  # Install all shipped font binaries for this family.
  find "${srcdir}" -type f \
    \( -name '*.ttf' -o -name '*.otf' -o -name '*.ttc' \) \
    ! -path '*/__MACOSX/*' ! -name '._*' -print0 | while IFS= read -r -d '' font; do
    install -m644 "${font}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done

  install -dm755 "${pkgdir}/usr/share/licenses/${pkgname}"
  cat > "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
Source: https://www.glukfonts.pl/font.php?font=FoglihtenNo03
License info from upstream page: OpenFontLicense
EOF
}
