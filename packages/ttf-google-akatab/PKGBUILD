pkgname=ttf-google-akatab
pkgver=4.000
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/akatab
pkgdesc="Google Fonts family: Akatab"
arch=('any')
url="https://fonts.google.com/specimen/Akatab"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/akatab/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/akatab/Akatab-Black.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/akatab/Akatab-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/akatab/Akatab-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/akatab/Akatab-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/akatab/Akatab-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/akatab/Akatab-SemiBold.ttf"
)
sha256sums=(
  "31040e54582c8910e962a73e34a65fb108cadf0aca6d0a0f91378ef7cea93ffa"
  "31ddec2b9ed113d6003368ca61efe3707df5e93804f337aca6d5d24a1f2700e1"
  "d7bf342248fa07fcc0e3aeb186f1f9286e10c8465ee427dd74776c3ba1a10fab"
  "d56e1275568d4a88d66ce20fb7987d3adb90cafac1976a941b756719e753e58f"
  "e0ce76da55ce20a8ae5159efcca7cfe9ab01749d8338d6a8c47b7415c166aa52"
  "7efecab54eb02e1b47087ec1ebbe6ac32b4308ac02e18f71c1f7567ec4d69fb4"
  "e5a581ce73fa4ead0fc5129c330033f042ab3fcc08475ea38cdeb03efa3bc0c8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
