pkgname=ttf-google-shipporiantique
pkgver=2.001
pkgrel=1
_commit="41ec566b323f1f856c4123e3da61ca08dcaac004"  # Latest commit touching ofl/shipporiantique
pkgdesc="Google Fonts family: Shippori Antique"
arch=('any')
url="https://fonts.google.com/specimen/Shippori+Antique"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/shipporiantique/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/shipporiantique/ShipporiAntique-Regular.ttf"
)
sha256sums=(
  "9ad629515fb62dfc2a831187b260bb53b4fcae1494dd4cb94c2b30da2466da51"
  "b88fd5138c77c1359406051786d45c88ab34e2040c6dfa385f00a4e17edaab52"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
