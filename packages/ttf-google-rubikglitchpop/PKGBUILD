pkgname=ttf-google-rubikglitchpop
pkgver=2.201
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rubikglitchpop
pkgdesc="Google Fonts family: Rubik Glitch Pop"
arch=('any')
url="https://fonts.google.com/specimen/Rubik+Glitch+Pop"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rubikglitchpop/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rubikglitchpop/RubikGlitchPop-Regular.ttf"
)
sha256sums=(
  "f9e2d4498ea80d38bac7b8841d68af68c132fa67e1552e7c05717e6987de1d74"
  "20545e9c47a8d5f1a23305c598c54b2c29f252079db2965e593184e765d5880f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
