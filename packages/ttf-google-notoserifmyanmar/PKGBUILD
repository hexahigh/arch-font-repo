  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifmyanmar/NotoSerifMyanmar-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifmyanmar/NotoSerifMyanmar-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/notoserifmyanmar/NotoSerifMyanmar-SemiBold.ttf"
