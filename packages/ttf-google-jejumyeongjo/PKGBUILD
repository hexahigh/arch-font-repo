pkgname=ttf-google-jejumyeongjo
pkgver=1.000
pkgrel=1
_commit="6e4b84c976cadb3c49a40fd9a1c203e4f7fcf2da"  # Latest commit touching ofl/jejumyeongjo
pkgdesc="Google Fonts family: Jejumyeongjo"
arch=('any')
url="https://fonts.google.com/specimen/Jejumyeongjo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/jejumyeongjo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/jejumyeongjo/JejuMyeongjo-Regular.ttf"
)
sha256sums=(
  "6939af7114f0a33c7e6142d4c1320d1bbde11aebe6d8f3c48fc5fb3e0f676a7b"
  "41dfe08357bf3b57068e07a5ba3ed8d318e2b197324c1e147cb57d43e1028bf7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
