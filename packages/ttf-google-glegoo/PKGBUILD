pkgname=ttf-google-glegoo
pkgver=2.0.1
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/glegoo
pkgdesc="Google Fonts family: Glegoo"
arch=('any')
url="https://fonts.google.com/specimen/Glegoo"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/glegoo/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/glegoo/Glegoo-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/glegoo/Glegoo-Regular.ttf"
)
sha256sums=(
  "638774cdf8233b5ddaf9ebee1821e9de1d5d59c335d8ee3ba0b47fb17833b502"
  "8ad5922db134fe9bf9f2691fc5554293c06884cf89823f452fc76db6b3de7fef"
  "237ca320ef867416c46c6fdfa6edc2ac5f49a121396ad0279a2e0f8ed7aaa3b1"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
