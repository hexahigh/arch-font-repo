pkgname=ttf-google-notosansoldpermic
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansoldpermic
pkgdesc="Google Fonts family: Noto Sans Old Permic"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Old+Permic"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoldpermic/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansoldpermic/NotoSansOldPermic-Regular.ttf"
)
sha256sums=(
  "368ec41388919a8214a906db7ab1491a8b3588b81938d2c33225e607c8b5c564"
  "a0a446342fbb13aee85bdfd77b27362ca9b5a4fd8f8fa4318ee33e41dc581bf6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
