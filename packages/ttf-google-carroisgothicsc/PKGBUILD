pkgname=ttf-google-carroisgothicsc
pkgver=1.002
pkgrel=1
_commit="55414cfd8c30feb70ff5ec2404f5591e61e379ca"  # Latest commit touching ofl/carroisgothicsc
pkgdesc="Google Fonts family: Carrois Gothic SC"
arch=('any')
url="https://fonts.google.com/specimen/Carrois+Gothic+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/carroisgothicsc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/carroisgothicsc/CarroisGothicSC-Regular.ttf"
)
sha256sums=(
  "afc1b710d644c1262e1765d2401abcf93a545a4cb051955e2243fbabb8164e25"
  "3dfc5fe797ab3e04327287d9dbae313847623670417e850d39e24662071f1c98"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
