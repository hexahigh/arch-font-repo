pkgname=ttf-google-freehand
pkgver=8.002
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/freehand
pkgdesc="Google Fonts family: Freehand"
arch=('any')
url="https://fonts.google.com/specimen/Freehand"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/freehand/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/freehand/Freehand-Regular.ttf"
)
sha256sums=(
  "eb42d30e111024646a167f47f3e85c5c2df21ceb36a3a279a6f19e2584b00ec8"
  "3f2f1155d862304cf29cc4252aa5df4d47468d127c3c12cbf16894b0dda6c833"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
