pkgname=ttf-google-raviprakash
pkgver=1.0.4
pkgrel=1
_commit="903e42a82f1b0825940c9ff8591b122fc367e735"  # Latest commit touching ofl/raviprakash
pkgdesc="Google Fonts family: Ravi Prakash"
arch=('any')
url="https://fonts.google.com/specimen/Ravi+Prakash"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/raviprakash/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/raviprakash/RaviPrakash-Regular.ttf"
)
sha256sums=(
  "ae629d13b06d9afc5cf3c07d585f3192b89b7decaffc5c4dfcfa7ce11a2a2b11"
  "f539bdb2673b3e1b69a279da763d178a6e4b4cafe5a12c85be0f5e03b547fcb6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
