pkgname=ttf-google-inclusivesans
pkgver=2.004
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/inclusivesans
pkgdesc="Google Fonts family: Inclusive Sans"
arch=('any')
url="https://fonts.google.com/specimen/Inclusive+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/inclusivesans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/inclusivesans/InclusiveSans-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/inclusivesans/InclusiveSans[wght].ttf"
)
sha256sums=(
  "0690e0819628a20c5ee68388a7bae621e5c3e53be57276169decd00111d8f2cf"
  "1b94e7bc731a3d91e358bff9f9253ccef36012e214c0ba64661741fa44494b2e"
  "52ae5fdb8eda45633f1e9817ebdb07d8075c89081d51204f16f78394608a5c4e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
