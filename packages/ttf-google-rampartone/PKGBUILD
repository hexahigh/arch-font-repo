pkgname=ttf-google-rampartone
pkgver=1.100
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/rampartone
pkgdesc="Google Fonts family: Rampart One"
arch=('any')
url="https://fonts.google.com/specimen/Rampart+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/rampartone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/rampartone/RampartOne-Regular.ttf"
)
sha256sums=(
  "1286896706738557c1fb98f0f66006d4ca675e475d681ca85976fd0da9daa353"
  "a4c60ee835175fa147eb483fac0dd8ff9007c37884ef77af86b0a868fa554d49"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
