pkgname=ttf-google-grandifloraone
pkgver=1.000
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/grandifloraone
pkgdesc="Google Fonts family: Grandiflora One"
arch=('any')
url="https://fonts.google.com/specimen/Grandiflora+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/grandifloraone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/grandifloraone/GrandifloraOne-Regular.ttf"
)
sha256sums=(
  "4d0bb797c98a0840faec0952153a4030442f263fcf08b906e38837ea8f401808"
  "592da2454a6626ee68558e220df28808b95f7dd140cd1ceb8a0d72b777f157ad"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
