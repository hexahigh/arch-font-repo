pkgname=ttf-google-reemkufi
pkgver=2.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/reemkufi
pkgdesc="Google Fonts family: Reem Kufi"
arch=('any')
url="https://fonts.google.com/specimen/Reem+Kufi"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/reemkufi/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/reemkufi/ReemKufi[wght].ttf"
)
sha256sums=(
  "3e1dea8822e6e4008fe0ebd2f65f88579683cfee198c0089407fa197535dbe65"
  "33ead1986cd48c138c4d906c9e5a6341877268461f97623409a2014de1cd4aa4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
