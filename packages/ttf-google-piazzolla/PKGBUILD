pkgname=ttf-google-piazzolla
pkgver=2.005
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/piazzolla
pkgdesc="Google Fonts family: Piazzolla"
arch=('any')
url="https://fonts.google.com/specimen/Piazzolla"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/piazzolla/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/piazzolla/Piazzolla-Italic[opsz,wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/piazzolla/Piazzolla[opsz,wght].ttf"
)
sha256sums=(
  "eb54463ef24368895c812c9117e677a59bd2379f80da85515e19b473f310e4ed"
  "ffeb38d0c9b332f6ef685352bfbae5e65775ccdc2ae142f49ac8ed2d7d215268"
  "b6b6451daba93a4b71f88ca8e37a66c3fd2b4e57ec54a407cddf6ae65b62c7b7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
