pkgname=ttf-google-craftygirls
pkgver=1.001
pkgrel=1
_commit="0537729f8f95546e040d0ff9dce96528eabec6f1"  # Latest commit touching apache/craftygirls
pkgdesc="Google Fonts family: Crafty Girls"
arch=('any')
url="https://fonts.google.com/specimen/Crafty+Girls"
license=('Apache')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/apache/craftygirls/LICENSE.txt"
  "https://github.com/google/fonts/raw/$_commit/apache/craftygirls/CraftyGirls-Regular.ttf"
)
sha256sums=(
  "cfc7749b96f63bd31c3c42b5c471bf756814053e847c10f3eb003417bc523d30"
  "5f92fed441fc72e75fd520ee63b4785c9b657404c53e1f269c95a6016298ef45"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
