pkgname=ttf-google-alumnisanssc
pkgver=1.018
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/alumnisanssc
pkgdesc="Google Fonts family: Alumni Sans SC"
arch=('any')
url="https://fonts.google.com/specimen/Alumni+Sans+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanssc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanssc/AlumniSansSC-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/alumnisanssc/AlumniSansSC%5Bwght%5D.ttf"
)
sha256sums=(
  "08e1c6fa00b198f9cf90fd8c7f540ce400892063234d5a3b38dcae9f659c977f"
  "62b490f2ee301d2dda0554f4bfc68ac8ab905d89762716702391a49174554a26"
  "41a67970fd2a6f6a806578451d7e9902b45008043de2d60bf47e005ec0dab922"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
