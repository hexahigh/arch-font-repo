pkgname=ttf-google-hurricane
pkgver=1.010
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/hurricane
pkgdesc="Google Fonts family: Hurricane"
arch=('any')
url="https://fonts.google.com/specimen/Hurricane"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hurricane/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hurricane/Hurricane-Regular.ttf"
)
sha256sums=(
  "064358800fe0bce38e0f0c75f748649b702b221dba298bd9de2e6b4026df45b8"
  "5ea86b562ca5c2b1893c233367cde1aee0d677bb6d30af9c3f699c270880da13"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
