pkgname=ttf-google-blaka
pkgver=1.003
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/blaka
pkgdesc="Google Fonts family: Blaka"
arch=('any')
url="https://fonts.google.com/specimen/Blaka"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/blaka/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/blaka/Blaka-Regular.ttf"
)
sha256sums=(
  "94b5d5a52420a96f2b4f427bc6f56133f6ddbdfaffa17fdd29049811fc9fd64c"
  "5cd0ff67dcfbc371c6450afffe10f6e7027ffada0c31f436beb8865e57b781a3"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
