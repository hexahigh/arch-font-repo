pkgname=ttf-google-bodonimoda
pkgver=2.005
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bodonimoda
pkgdesc="Google Fonts family: Bodoni Moda"
arch=('any')
url="https://fonts.google.com/specimen/Bodoni+Moda"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bodonimoda/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bodonimoda/BodoniModa-Italic[opsz,wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bodonimoda/BodoniModa[opsz,wght].ttf"
)
sha256sums=(
  "931dfe2e0cd3c9443295f5c1d754b8a8403bf060df50c1d5900267ade83d0046"
  "dfff1619f8f6871c6372f8855b67211f9a73b4e93d45aca868cd8f46a48622de"
  "550f5e34ee0a828d7941b1fe9bc58b34e5260d3f33a61532e6d0a0114e79a5cf"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
