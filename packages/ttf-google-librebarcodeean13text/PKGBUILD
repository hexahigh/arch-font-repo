pkgname=ttf-google-librebarcodeean13text
pkgver=1.008
pkgrel=1
_commit="e2332cf862ac3145c0ee5f24f04f4c1819b2410b"  # Latest commit touching ofl/librebarcodeean13text
pkgdesc="Google Fonts family: Libre Barcode EAN13 Text"
arch=('any')
url="https://fonts.google.com/specimen/Libre+Barcode+EAN13+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/librebarcodeean13text/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/librebarcodeean13text/LibreBarcodeEAN13Text-Regular.ttf"
)
sha256sums=(
  "a4b7ccd1bda3269afba7d6d9293a7161e699d2f4f1f280dd8a8535c569388de9"
  "4a7c7c830a98e9dc6896b80e9f6e7bc6ec0a0fab942bc4a4cbe9a29f5bcd3c02"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
