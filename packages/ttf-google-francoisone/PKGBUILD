pkgname=ttf-google-francoisone
pkgver=2.000
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/francoisone
pkgdesc="Google Fonts family: Francois One"
arch=('any')
url="https://fonts.google.com/specimen/Francois+One"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/francoisone/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/francoisone/FrancoisOne-Regular.ttf"
)
sha256sums=(
  "09685e225ba9b697b2ccd2d4098cac5ecbed0679960605258a271af60749887b"
  "700fb5e4a5b6edb14dde2dcd481e5a9cac14281579cf42500170bae7cddd3609"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
