pkgname=ttf-google-kiwimaru
pkgver=1.100
pkgrel=1
_commit="130fcfb0ff422fec96b335616b2ca99f91914792"  # Latest commit touching ofl/kiwimaru
pkgdesc="Google Fonts family: Kiwi Maru"
arch=('any')
url="https://fonts.google.com/specimen/Kiwi+Maru"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/kiwimaru/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/kiwimaru/KiwiMaru-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/kiwimaru/KiwiMaru-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/kiwimaru/KiwiMaru-Regular.ttf"
)
sha256sums=(
  "07ceae7a6e3294cbbd0fdf6e35226550566a1cce9fd226d0f8a57f3d34c664fe"
  "30f856bc944911b025bfbf640bf6b9ffe18a9c7b06b20d4ef26fe5cc9b3819f8"
  "b2659f300a7d48c3f29eb273ffc5e1b26cc416ac8c37ff6bb2f3e43c2f4d235a"
  "b0c3103b2639f690c1fcb44e060058383174bfd2eb72e6635bc9869b374dee87"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
