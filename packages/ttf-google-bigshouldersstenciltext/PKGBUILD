pkgname=ttf-google-bigshouldersstenciltext
pkgver=2.001
pkgrel=1
_commit="5353cb65947b200cb987f5fd8e526c053dc13e8d"  # Latest commit touching ofl/bigshouldersstenciltext
pkgdesc="Google Fonts family: Big Shoulders Stencil Text"
arch=('any')
url="https://fonts.google.com/specimen/Big+Shoulders+Stencil+Text"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersstenciltext/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersstenciltext/BigShouldersStencilText[wght].ttf"
)
sha256sums=(
  "338f9c050f19daeda1d597243faf79f3a3d437c338af58cb7047617d0ce08771"
  "583e3423e62bb853b4970d7b10d44384d179d86e3e96a0bc54103cfbfb96a122"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
