pkgname=ttf-google-hostgrotesk
pkgver=1.003
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/hostgrotesk
pkgdesc="Google Fonts family: Host Grotesk"
arch=('any')
url="https://fonts.google.com/specimen/Host+Grotesk"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/hostgrotesk/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/hostgrotesk/HostGrotesk-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/hostgrotesk/HostGrotesk[wght].ttf"
)
sha256sums=(
  "f04ad0873907546e160c7a79b1e42bd3cd380c7e5ee4c1b3c11f43faca1675e7"
  "8e16d5b25106332b4330ab02f59bfeb7bb40ba0c060c3053f4c08d4ca8ae4d22"
  "74c77b8e850d58dd3d8b22e39111a73bef3450de9fb57018ef99119f2d484f5d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
