pkgname=ttf-google-salsa
pkgver=1.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/salsa
pkgdesc="Google Fonts family: Salsa"
arch=('any')
url="https://fonts.google.com/specimen/Salsa"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/salsa/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/salsa/Salsa-Regular.ttf"
)
sha256sums=(
  "31c59bcdd538c113ef5c048f56827439facb12b7e5cfd158b04c83727edc453b"
  "3e69c0731a5104d4f25477aa2cdf9d7e9c54b201c60e99c37380ebd05097930c"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
