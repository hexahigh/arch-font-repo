pkgname=ttf-google-notosansvai
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansvai
pkgdesc="Google Fonts family: Noto Sans Vai"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Vai"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansvai/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansvai/NotoSansVai-Regular.ttf"
)
sha256sums=(
  "765206100bc8ad011be3a0976323394c28f335c69c49de152c3bd8bd27cdb803"
  "1ee63dafc2d2a71c42d7bb06259ae1728d8fd155bc752254a1cc5a7002e13a8d"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
