pkgname=ttf-google-luxuriousscript
pkgver=1.010
pkgrel=1
_commit="4e5f06dbb274a27ebe71ed54ea706b3ee40eabd9"  # Latest commit touching ofl/luxuriousscript
pkgdesc="Google Fonts family: Luxurious Script"
arch=('any')
url="https://fonts.google.com/specimen/Luxurious+Script"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/luxuriousscript/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/luxuriousscript/LuxuriousScript-Regular.ttf"
)
sha256sums=(
  "0d53601eaba9a6f5dbf7ee43e26edbb37ea5fb7f3f170052ca5dc8d51704a5ea"
  "db1a118a34eb835f7960a09d8be472b65971d7798772842dc3cd37a8641491e9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
