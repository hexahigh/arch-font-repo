pkgname=ttf-google-epundasans
pkgver=2.205
pkgrel=1
_commit="1796e34455b893092713d206e7f23e3e07699f00"  # Latest commit touching ofl/epundasans
pkgdesc="Google Fonts family: Epunda Sans"
arch=('any')
url="https://fonts.google.com/specimen/Epunda+Sans"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/epundasans/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/epundasans/EpundaSans-Italic[wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/epundasans/EpundaSans[wght].ttf"
)
sha256sums=(
  "0d48efd167a02346048688bffdc10b4f9d824e2bffbf0ffeca3a217c48d4411b"
  "1bd18e77526ee85d61c6faabc64c9db37455b7709947a38d0fbd25133ae695a8"
  "5b66232f4da371c82f22c5c4fd50ef99d46c1511e9a23a757e085e3060c2b0c0"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
