pkgname=ttf-google-georama
pkgver=1.001
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/georama
pkgdesc="Google Fonts family: Georama"
arch=('any')
url="https://fonts.google.com/specimen/Georama"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/georama/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/georama/Georama-Italic[wdth,wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/georama/Georama[wdth,wght].ttf"
)
sha256sums=(
  "e913854957b9c1aca0c81b29fca565827185ddee0f5a039319e0e45e1b7b3079"
  "321be0ed8688ed27a2ffd3e85efb9e3c7d9229842b7d9ba90999bf36e672fb00"
  "0a62419702ab557e0610a5a073a56f246d13a7db094ef97945a0aa56faf14ab1"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
