pkgname=ttf-google-annieuseyourtelescope
pkgver=1.003
pkgrel=1
_commit="5e92bdbd6711e5e7cc4d468f03439f4c1a852a4f"  # Latest commit touching ofl/annieuseyourtelescope
pkgdesc="Google Fonts family: Annie Use Your Telescope"
arch=('any')
url="https://fonts.google.com/specimen/Annie+Use+Your+Telescope"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/annieuseyourtelescope/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/annieuseyourtelescope/AnnieUseYourTelescope-Regular.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "221b54062adb0df36d4b8f0d2f98aef4f827fc34b974cae2ce232a5e233149b9"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
