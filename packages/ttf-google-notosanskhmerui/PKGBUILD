pkgname=ttf-google-notosanskhmerui
pkgver=2.001
pkgrel=1
_commit="54584294ef89979740aa9687fdc3c04d11c4b539"  # Latest commit touching ofl/notosanskhmerui
pkgdesc="Google Fonts family: Noto Sans Khmer UI"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Khmer+UI"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanskhmerui/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanskhmerui/NotoSansKhmerUI%5Bwdth%2Cwght%5D.ttf"
)
sha256sums=(
  "5e0da210fb04058a8c0087985d2d456b931c2579811a49655721d3cf0c36b6d6"
  "1467a1828bfbfe6598127482e7c3d3d7c82bed213d4d54e3066dce5d980db77b"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
