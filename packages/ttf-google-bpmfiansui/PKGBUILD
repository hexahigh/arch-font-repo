pkgname=ttf-google-bpmfiansui
pkgver=1.610
pkgrel=1
_commit="a93a721ef91faf1f6f7860786a83224e0e59017d"  # Latest commit touching ofl/bpmfiansui
pkgdesc="Google Fonts family: Bpmf Iansui"
arch=('any')
url="https://fonts.google.com/specimen/Bpmf+Iansui"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bpmfiansui/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bpmfiansui/BpmfIansui-Regular.ttf"
)
sha256sums=(
  "7f4e87a64cb3f3421650b2f0f12fbf23e97f06f93d1d395cae6a8d3205db1c26"
  "72716054f083b8c8953b45ab4c28dcf7a771e3be2eb58a848a459418058f1cb7"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
