pkgname=ttf-google-ingriddarling
pkgver=1.010
pkgrel=1
_commit="0b58fb370093f9a9f4ff785d94405710b79de67c"  # Latest commit touching ofl/ingriddarling
pkgdesc="Google Fonts family: Ingrid Darling"
arch=('any')
url="https://fonts.google.com/specimen/Ingrid+Darling"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ingriddarling/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ingriddarling/IngridDarling-Regular.ttf"
)
sha256sums=(
  "8cf345e9566428f6171371bbd5bcc7f8ebe443712b9349267dc59391b7d4aeb1"
  "f08b43438d6dc7742a9c0434e7199e01272a2c1b2b135c9a886f6517c9e5ae4f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
