pkgname=ttf-google-mplus1p
pkgver=1.062
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mplus1p
pkgdesc="Google Fonts family: M PLUS 1p"
arch=('any')
url="https://fonts.google.com/specimen/M+PLUS+1p"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1p/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1p/MPLUS1p-Black.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1p/MPLUS1p-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1p/MPLUS1p-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1p/MPLUS1p-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1p/MPLUS1p-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1p/MPLUS1p-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/mplus1p/MPLUS1p-Thin.ttf"
)
sha256sums=(
  "da15da6b1496d4de18f97e2ad1b722ef8a1c121149c2c93b2cf7eac6ac27b35c"
  "815821a62ce085e453af318ca004768e336329d5a7d6f7bed272e97e7862d43e"
  "76eb077b0a31ca33ca40238e47da5a17e2786741607cec09678d7d2e5ab1afc1"
  "d17f745712668b0dcd95e42b3634a90a76195228d4abf88a0be8e98ddbc441b2"
  "e39fa39f8556c3fdf47e01f68915d8d17936107f33fbead6b1b40fcf605c118c"
  "28b2f52a40ae988064810b71d67e127df75a16e08d7df4e192d1006e4075394f"
  "2f294ad496432b1608f070d310e3aa2adcf1de4af429f4901df97ec4bd361ed1"
  "aa093fe44beb740d2730e0437bdd0bfeb57b526d30e8b2410e29ec6503434dd6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
