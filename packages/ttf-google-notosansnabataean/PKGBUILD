pkgname=ttf-google-notosansnabataean
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosansnabataean
pkgdesc="Google Fonts family: Noto Sans Nabataean"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Nabataean"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnabataean/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosansnabataean/NotoSansNabataean-Regular.ttf"
)
sha256sums=(
  "d1d3fa924183e4c4f14d17fd5bdd2b1ab3e433c898bb2cb6074b5cf331c22485"
  "b21dc4564143ce3647bfb5c410b8b2f0affb257756693b9578a1328fdf9d82e8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
