pkgname=ttf-google-mynerve
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/mynerve
pkgdesc="Google Fonts family: Mynerve"
arch=('any')
url="https://fonts.google.com/specimen/Mynerve"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mynerve/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mynerve/Mynerve-Regular.ttf"
)
sha256sums=(
  "b4f46a426751128d9415c0b36a3a652dd21a116039e5926ac1890762a223713d"
  "1844706b0020e74f1cc38810266f8c45741bd0d9b7beeb05a584caee11dbc63e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
