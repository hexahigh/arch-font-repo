pkgname=ttf-google-bigshouldersstencildisplaysc
pkgver=2.001
pkgrel=1
_commit="c13390277dfb1fcc7415d84ef7ef9cfc1e52f8c1"  # Latest commit touching ofl/bigshouldersstencildisplaysc
pkgdesc="Google Fonts family: Big Shoulders Stencil Display SC"
arch=('any')
url="https://fonts.google.com/specimen/Big+Shoulders+Stencil+Display+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersstencildisplaysc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bigshouldersstencildisplaysc/BigShouldersStencilDisplaySC[wght].ttf"
)
sha256sums=(
  "fbc746aabf0eb1847dfd92e2efc4596d79fa897d60b8e64062a22f585508fb3f"
  "42e26acf67c9fcda467a38b63f5a7cd022b55aa96bdc4af249ab8058dd1cc3fc"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
