pkgname=ttf-google-playwritecz
pkgver=1.003
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/playwritecz
pkgdesc="Google Fonts family: Playwrite CZ"
arch=('any')
url="https://fonts.google.com/specimen/Playwrite+CZ"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritecz/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/playwritecz/PlaywriteCZ[wght].ttf"
)
sha256sums=(
  "0370f5946020846b0ca65e44950d11411ea3bd3c4c0d755916470f9f96cd8cb8"
  "39e8aedac9ab5a9d9e5003359f0a6631fced9d4531d15db0dd5d9efdadd0fcae"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
