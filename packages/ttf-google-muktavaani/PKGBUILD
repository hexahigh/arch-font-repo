pkgname=ttf-google-muktavaani
pkgver=2.538
pkgrel=1
_commit="d9359deb5a726c6e67417f55c052687d522c98c9"  # Latest commit touching ofl/muktavaani
pkgdesc="Google Fonts family: Mukta Vaani"
arch=('any')
url="https://fonts.google.com/specimen/Mukta+Vaani"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/muktavaani/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktavaani/MuktaVaani-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktavaani/MuktaVaani-ExtraBold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktavaani/MuktaVaani-ExtraLight.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktavaani/MuktaVaani-Light.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktavaani/MuktaVaani-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktavaani/MuktaVaani-Regular.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/muktavaani/MuktaVaani-SemiBold.ttf"
)
sha256sums=(
  "d24ff874133ecd133e55d7c4070d2edab14d3933477c2bccb3a0d8d1cc9c33bf"
  "e11f330d219010c13b85e3bc568366ba32544f1c4ae7f9c4976792ed2918ac51"
  "427f6ca0b008914d4e0ca277fab7fd63d3c439863661f08e39f4fccc7e1a488d"
  "6107a72e51ccf4a747a264d21de81069a614005fca8f87273fbcb0f64d6d4413"
  "a3585b04045ca3fdf642b147e032fb02b61d8a5372b7216b8c17d6eedb612017"
