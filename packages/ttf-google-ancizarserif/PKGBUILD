pkgname=ttf-google-ancizarserif
pkgver=8.100
pkgrel=1
_commit="fffdadf0f0c9cc1ec8b407063424a8bfbee05611"  # Latest commit touching ofl/ancizarserif
pkgdesc="Google Fonts family: Ancizar Serif"
arch=('any')
url="https://fonts.google.com/specimen/Ancizar+Serif"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ancizarserif/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ancizarserif/AncizarSerif-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/ancizarserif/AncizarSerif%5Bwght%5D.ttf"
)
sha256sums=(
  "b15d6b75ec5ada62baf3737ffcab2ca72d1126c3067b07001802f9c8df829caa"
  "b30f075790e14795508a42dda7b8f6269509e15a13a4c653b3665662bdfbf45c"
  "fcc35d7fe2780846344d7187515d483bb69f3d9bcc49c4833a219e4d9109db98"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
