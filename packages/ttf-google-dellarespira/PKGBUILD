pkgname=ttf-google-dellarespira
pkgver=0.201
pkgrel=1
_commit="58f37ee58d050a4c9d30878b385151434f7ecb95"  # Latest commit touching ofl/dellarespira
pkgdesc="Google Fonts family: Della Respira"
arch=('any')
url="https://fonts.google.com/specimen/Della+Respira"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/dellarespira/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/dellarespira/DellaRespira-Regular.ttf"
)
sha256sums=(
  "19e186a088a50835b38b59409a76b8df2d0252ce114a99e79e306231bbe253b7"
  "81518be5b7baf69db5b8e4cff1a447ac2f6bf7a6029ca4963a67e1fb1b0b9218"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
