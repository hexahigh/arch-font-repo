pkgname=ttf-google-anekodia
pkgver=1.003
pkgrel=1
_commit="95f4904fc8bcf26d3420fe315560c96417c6dec7"  # Latest commit touching ofl/anekodia
pkgdesc="Google Fonts family: Anek Odia"
arch=('any')
url="https://fonts.google.com/specimen/Anek+Odia"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/anekodia/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/anekodia/AnekOdia[wdth,wght].ttf"
)
sha256sums=(
  "de62be758bba267e653a5f457dfebb4680957e2c343eb3e7de15aff4746bed05"
  "673bb6e51b71af1de1f11f9a547a3a58c50a6fa32d480958e1ef0f06980ca45f"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
