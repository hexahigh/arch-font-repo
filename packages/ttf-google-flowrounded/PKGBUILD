pkgname=ttf-google-flowrounded
pkgver=1.101
pkgrel=1
_commit="ff1f93bbe72e2d965842557db5dc94a10077bb89"  # Latest commit touching ofl/flowrounded
pkgdesc="Google Fonts family: Flow Rounded"
arch=('any')
url="https://fonts.google.com/specimen/Flow+Rounded"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/flowrounded/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/flowrounded/FlowRounded-Regular.ttf"
)
sha256sums=(
  "54665278a85e00842c5a261c2bc51c4735082f0164edcd95da27ed11e253e604"
  "dd3319188800beba4f303532f254880f77c513dfb8ee54e44cd7fa2fdeb25123"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
