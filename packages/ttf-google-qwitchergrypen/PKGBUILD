pkgname=ttf-google-qwitchergrypen
pkgver=1.100
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/qwitchergrypen
pkgdesc="Google Fonts family: Qwitcher Grypen"
arch=('any')
url="https://fonts.google.com/specimen/Qwitcher+Grypen"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/qwitchergrypen/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/qwitchergrypen/QwitcherGrypen-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/qwitchergrypen/QwitcherGrypen-Regular.ttf"
)
sha256sums=(
  "893e23589ddf2536380e3ad01f2780c726919566440915971d58faef5247161f"
  "a48354aa42dca6dfaf16700b453d03c73ef34e6168b05c100edd7b957eb3add7"
  "54f877a938c45e55f44344a6fe143f83f60cedbc653dc2e318617a9df97e964e"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
