pkgname=ttf-google-genos
pkgver=1.010
pkgrel=1
_commit="a60a77e14f28abd4ef243a1b5dfc48df0cec5205"  # Latest commit touching ofl/genos
pkgdesc="Google Fonts family: Genos"
arch=('any')
url="https://fonts.google.com/specimen/Genos"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/genos/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/genos/Genos-Italic%5Bwght%5D.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/genos/Genos%5Bwght%5D.ttf"
)
sha256sums=(
  "c29a3fd5e7962b626fcbcf6713d47ae4656fded06335b607d14f03a4a25cb82b"
  "88591d5374bc8ec1d7e4e1151f0289bd00a71903a52a380379491afd730a773e"
  "88a32589d9d8615ab728977d647f5e5010dbf789050d4cf25d6607b14d49a1f1"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
