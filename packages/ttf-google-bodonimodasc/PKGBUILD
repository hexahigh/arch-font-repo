pkgname=ttf-google-bodonimodasc
pkgver=2.005
pkgrel=1
_commit="6ce172f74aa355ea43eb964fa4a91570a4d3064d"  # Latest commit touching ofl/bodonimodasc
pkgdesc="Google Fonts family: Bodoni Moda SC"
arch=('any')
url="https://fonts.google.com/specimen/Bodoni+Moda+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/bodonimodasc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/bodonimodasc/BodoniModaSC-Italic[opsz,wght].ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/bodonimodasc/BodoniModaSC[opsz,wght].ttf"
)
sha256sums=(
  "86279342767d5f3e6b07b49dd591f196dcb0ec9ec8b9ea339c09221e61863d46"
  "303868aeaf81bf6c71ca63ac32669da9c9de7f73343e34a18893d3b5e58e672e"
  "fff815c5b6fb7da048acd9ca59a1b6a5751cf454cb701cd8185a2a0bf06d63ef"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
