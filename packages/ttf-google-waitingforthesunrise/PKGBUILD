pkgname=ttf-google-waitingforthesunrise
pkgver=1.001
pkgrel=1
_commit="a3f54021b4d9b5d97fea68221755d0f75a96ea75"  # Latest commit touching ofl/waitingforthesunrise
pkgdesc="Google Fonts family: Waiting for the Sunrise"
arch=('any')
url="https://fonts.google.com/specimen/Waiting+for+the+Sunrise"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/waitingforthesunrise/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/waitingforthesunrise/WaitingfortheSunrise.ttf"
)
sha256sums=(
  "0e441ae9f18ad0c294cc5b6ae3974c2db1614cab220598578b1b58c4cc334485"
  "ac74e70390f5b1be6927c1e079bd6143821a362550b264c5eb7edde34f0899f4"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
