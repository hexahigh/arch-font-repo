pkgname=ttf-google-diplomatasc
pkgver=1.002
pkgrel=1
_commit="7380f7cebbf2250460c23fd301b51bcbab162edf"  # Latest commit touching ofl/diplomatasc
pkgdesc="Google Fonts family: Diplomata SC"
arch=('any')
url="https://fonts.google.com/specimen/Diplomata+SC"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/diplomatasc/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/diplomatasc/DiplomataSC-Regular.ttf"
)
sha256sums=(
  "f4e8602be4b69bc44e3ce17d026622722b992a07b1aab0db23da48b0155b289e"
  "6c91b299f45463424e26daf5fbbd5f298ad7b2e89f25bee506dd34a6d5297054"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
