pkgname=ttf-google-mrssheppards
pkgver=1.000
pkgrel=1
_commit="40c368969853e6e70e67a3ede013955dcc858011"  # Latest commit touching ofl/mrssheppards
pkgdesc="Google Fonts family: Mrs Sheppards"
arch=('any')
url="https://fonts.google.com/specimen/Mrs+Sheppards"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/mrssheppards/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/mrssheppards/MrsSheppards-Regular.ttf"
)
sha256sums=(
  "967d75b89eef1f8a0ba1f5ee7dfb13427621f9116c6e7878ca04da8c9aa8641b"
  "0fa5f282a2ad512d3d5d276fc6d4796fe4fda0fc0612d8687113d5423c8c33d8"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
