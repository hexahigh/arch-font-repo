pkgname=ttf-google-gupter
pkgver=1.000
pkgrel=1
_commit="c1eda9233c33ad7775b27efd794f931095cf6133"  # Latest commit touching ofl/gupter
pkgdesc="Google Fonts family: Gupter"
arch=('any')
url="https://fonts.google.com/specimen/Gupter"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/gupter/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/gupter/Gupter-Bold.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gupter/Gupter-Medium.ttf"
  "https://github.com/google/fonts/raw/$_commit/ofl/gupter/Gupter-Regular.ttf"
)
sha256sums=(
  "d11742efedc994c84a152639a76098e3de6c097d77c06e3c4155b8ac00ae9328"
  "8fab8a84e5a47c4c5a5a4449ca62e3a6492fbddadd778de9d9fb2d3b1b36989c"
  "6ca9e0c2fa74cbd2b75a0e69b116218570ac74d80c1e92ebcc59bb6bdc8bb032"
  "cad87b6c06ac63e24f2b9741c0cbe4bcf5945826696f4baca61933c959052cf6"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
