pkgname=ttf-google-ribeye
pkgver=1.000
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/ribeye
pkgdesc="Google Fonts family: Ribeye"
arch=('any')
url="https://fonts.google.com/specimen/Ribeye"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/ribeye/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/ribeye/Ribeye-Regular.ttf"
)
sha256sums=(
  "9acc45e5ba18b5b38868fad1f51c03df4f5d7a43061d46314843de45c4444233"
  "c384b009dba7b9c973402427716ccf2a57dc5e44b30cfda45fc0ecc5cf238bcb"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
