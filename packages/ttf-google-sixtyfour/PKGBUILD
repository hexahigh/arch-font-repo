pkgname=ttf-google-sixtyfour
pkgver=2.001
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/sixtyfour
pkgdesc="Google Fonts family: Sixtyfour"
arch=('any')
url="https://fonts.google.com/specimen/Sixtyfour"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/sixtyfour/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/sixtyfour/Sixtyfour[BLED,SCAN].ttf"
)
sha256sums=(
  "a5ef1337c7efa6a7dfb4f23ada5dc9319653b60acb34601ed734608608fee39d"
  "3d5a3bb3257a491124347bac83ca7f0c8c77a9961270f353b498f3153e751c68"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
