pkgname=ttf-google-notosanssaurashtra
pkgver=2.002
pkgrel=1
_commit="8b0a1d0f5983c89bc2b93f1b5fb55f9e252744b5"  # Latest commit touching ofl/notosanssaurashtra
pkgdesc="Google Fonts family: Noto Sans Saurashtra"
arch=('any')
url="https://fonts.google.com/specimen/Noto+Sans+Saurashtra"
license=('OFL')
depends=('fontconfig')
provides=('ttf-font')
source=(
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssaurashtra/OFL.txt"
  "https://github.com/google/fonts/raw/$_commit/ofl/notosanssaurashtra/NotoSansSaurashtra-Regular.ttf"
)
sha256sums=(
  "aef66e1a5ca98031d65b2284c24de0e66158703fe84a0bf339ac600c8e355c1a"
  "d2df88b4e293636d04c363b13dc5c6f88fca0e9a3b6fece52f12c11d77e9e566"
)

package() {
  install -dm755 "${pkgdir}/usr/share/fonts/TTF/${pkgname}"

  shopt -s nullglob
  for pattern in *.ttf *.otf *.ttc *.woff2; do
    files=("${srcdir}"/${pattern})
    (( ${#files[@]} )) || continue
    install -m644 "${files[@]}" "${pkgdir}/usr/share/fonts/TTF/${pkgname}/"
  done
  shopt -u nullglob

  install -Dm644 "${srcdir}/OFL.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
